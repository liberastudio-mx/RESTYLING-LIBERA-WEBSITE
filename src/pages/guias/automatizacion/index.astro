---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Guías de Automatización" description="Guías prácticas sobre automatización de procesos: qué automatizar primero, qué herramientas usar y cuándo no automatizar.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--ai); font-family: var(--font-mono);">Guías</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Automatización</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Guías prácticas para automatizar tu empresa sin perder el control. Qué automatizar primero, qué herramientas usar y cuándo la automatización no es la respuesta.</p>
      <a href="/guias" style="color: var(--text-secondary); font-size: 0.875rem;">← Volver a Guías</a>
    </div>
  </section>
</Layout>
