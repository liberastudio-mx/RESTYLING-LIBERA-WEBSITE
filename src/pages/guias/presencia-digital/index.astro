---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Guías de Presencia Digital" description="Guías sobre cómo construir y optimizar tu presencia digital: qué debe tener una web, SEO local, Google Maps y más.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--presencia); font-family: var(--font-mono);">Guías</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Presencia Digital</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Guías para construir y optimizar tu presencia online. Qué debe tener un sitio web, cómo aparecer en Google Maps, SEO local y cómo saber si tu web está funcionando.</p>
      <a href="/guias/presencia-digital/como-saber-si-tu-web-convierte" style="color: var(--orange); font-size: 0.875rem; font-weight: 500; display: block; margin-bottom: 1rem;">Cómo saber si tu presencia digital está funcionando →</a>
      <a href="/guias" style="color: var(--text-secondary); font-size: 0.875rem;">← Volver a Guías</a>
    </div>
  </section>
</Layout>
