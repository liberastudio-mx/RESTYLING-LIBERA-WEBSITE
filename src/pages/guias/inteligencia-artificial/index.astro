---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Guías de Inteligencia Artificial" description="Guías sobre IA aplicada a empresas reales: agentes, asistentes internos, automatización documental y más.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--ai); font-family: var(--font-mono);">Guías</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Inteligencia Artificial</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Guías sobre IA aplicada a empresas reales. Sin hype. Agentes de IA, asistentes internos, automatización documental y cómo integrar inteligencia artificial en tu operación.</p>
      <a href="/guias/inteligencia-artificial/agentes-ia-empresa" style="color: var(--orange); font-size: 0.875rem; font-weight: 500; display: block; margin-bottom: 1rem;">Qué puede hacer un agente de IA en una empresa real →</a>
      <a href="/guias" style="color: var(--text-secondary); font-size: 0.875rem;">← Volver a Guías</a>
    </div>
  </section>
</Layout>
