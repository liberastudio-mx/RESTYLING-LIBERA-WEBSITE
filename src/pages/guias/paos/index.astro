---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Guías PAOS" description="Guías sobre el sistema operativo digital PAOS: qué es, cómo construirlo y cómo ordenar la operación de tu empresa.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--operacion); font-family: var(--font-mono);">Guías</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">PAOS</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Todo lo que necesitas saber sobre el sistema operativo digital de tu empresa: qué es un PAOS, cómo construirlo y por qué es la base de una operación escalable.</p>
      <a href="/guias/paos/que-es-un-paos" style="color: var(--orange); font-size: 0.875rem; font-weight: 500; display: block; margin-bottom: 1rem;">Qué es un PAOS y por qué tu empresa necesita uno →</a>
      <a href="/guias" style="color: var(--text-secondary); font-size: 0.875rem;">← Volver a Guías</a>
    </div>
  </section>
</Layout>
