---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Guías" description="Conocimiento abierto de LIBERA Studio sobre PAOS, automatización, IA y presencia digital. Para decidir mejor antes de invertir.">
  <section style="background: var(--surface);" class="pt-40 pb-20">
    <div class="container-libera">
      <div class="max-w-2xl mb-16" data-reveal>
        <span class="eyebrow block mb-4" style="color: var(--text-secondary); font-family: var(--font-mono);">Guías</span>
        <h1 class="font-display mb-6" style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; letter-spacing: -0.04em; color: var(--text-primary); line-height: 1.0;">
          Conocimiento abierto para decidir mejor.
        </h1>
        <p class="text-lg" style="color: var(--text-secondary);">
          Guías evergreen sobre PAOS, automatización, inteligencia artificial y presencia digital.
        </p>
      </div>
      <p class="text-base" style="color: var(--text-secondary);">Las guías estarán disponibles próximamente. <a href="/diagnostico" style="color: var(--orange);">Mientras tanto, solicita un diagnóstico →</a></p>
    </div>
  </section>
</Layout>
