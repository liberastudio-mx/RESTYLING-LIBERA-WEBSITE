---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Radio 9999" description="Infraestructura ligera para transmitir, organizar contenido y crear comunidad en torno a radio y audio.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--orange); font-family: var(--font-mono);">Producto digital</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Radio 9999</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Infraestructura ligera para transmitir, organizar contenido y crear comunidad en torno a radio y audio online.</p>
      <p class="eyebrow mb-8" style="color: var(--text-secondary); font-family: var(--font-mono);">Stack: Astro · Tailwind · Edge</p>
      <a href="/trabajo" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Trabajo</a>
    </div>
  </section>
</Layout>
