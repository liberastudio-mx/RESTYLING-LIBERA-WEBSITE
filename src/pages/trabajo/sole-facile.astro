---
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImg from '@/assets/images/logo sole facile per linkedin.png';

const stack = ['Webflow CMS', 'Google Analytics 4', 'Search Console', 'Airtable', 'Nuevo sitio en desarrollo'];
---

<Layout
  title="Sole Facile â€” Trabajo â€” LIBERA Studio"
  description="Gestión digital completa para Sole Facile SRL, Turín: sitio en Webflow, SEO, GA4, redes sociales y automatizaciones internas."
>

  <!-- HERO -->
  <section class="sf-project-hero" aria-labelledby="sf-title">
    <Image src={logoImg} alt="" class="sf-hero-bg" aria-hidden="true" widths={[400, 800]} sizes="100vw" />
    <div class="sf-hero-overlay" aria-hidden="true"></div>
    <div class="container-libera sf-hero-content">
      <a href="/trabajo" class="sf-back-link">&larr; Trabajo</a>
      <h1 id="sf-title">Sole Facile</h1>
      <p class="sf-hero-copy">
        Energía solar fotovoltaica a la medida para casas y empresas en Piamonte. LIBERA Studio gestiona lo digital: sitio, SEO, cookies y automatizaciones internas.
      </p>
      <div class="sf-stack-list" aria-label="Tecnologías del proyecto">
        {stack.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </section>


  <!-- 01 SITIO WEB -->
  <section style="background: var(--surface);" aria-label="Sitio web">
    <div class="container-libera py-16 lg:py-24">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <div>
          <h2
            class="display-lg mb-8"
            style="font-family: var(--font-display); color: var(--text-primary); line-height: 1.08;"
          >
            Webflow hoy. Sitio nuevo mañana. Más rápido, más ligero, sin dependencias.
          </h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text-secondary);">
            El sitio en línea <strong style="color: var(--text-primary);">solefacilesrl.com</strong> corre sobre Webflow CMS con 81 artículos publicados, páginas optimizadas y un blog activo. Funciona. Pero tiene los límites de cualquier plataforma rentada: cada función extra exige un plan más caro o una integración frágil.
          </p>
          <p class="text-lg leading-relaxed" style="color: var(--text-secondary);">
            Estamos construyendo un sitio nuevo desde cero. Más sólido en Core Web Vitals, con gestión interna de correos sobre Airtable sin depender de plataformas de terceros, y con un sistema de contenidos que el cliente puede administrar sin pasar por nosotros.
          </p>
        </div>

        <div class="grid gap-7">
          {[
            {
              label: 'Webflow CMS â€” sitio en línea',
              text: 'Gestión autónoma de contenidos. 81 artículos en el blog, páginas de servicios, productos y FAQ. Slugs, redirects y collections gestionados internamente.',
            },
            {
              label: 'Cookies internos',
              text: 'El banner de cookies está construido directamente dentro del sitio: sin CookieBot, sin OneTrust. Le evitamos al cliente una suscripción mensual a servicios externos que no aportan nada, y los datos de los usuarios se quedan dentro de su propia plataforma.',
            },
            {
              label: 'Nuevo sitio â€” en desarrollo',
              text: 'Código original, cero dependencias de plataformas CMS. Páginas más ligeras, carga más rápida y una estructura pensada para escalar sin costos crecientes.',
            },
            {
              label: 'Email marketing en Airtable',
              text: 'Sin Mailchimp, sin costo por contacto. La base de datos de leads ya vive en Airtable: construimos el flujo de correos directamente ahí, sin exportar datos.',
            },
            {
              label: 'SEO y performance',
              text: 'Canonical URL, Open Graph, breadcrumbs y JSON-LD en cada página. Fuentes optimizadas, ningún recurso bloqueante, Core Web Vitals como requisito del proyecto.',
            },
          ].map((item) => (
            <div class="border-t pt-6" style="border-color: var(--border);">
              <p class="text-xs font-semibold mb-2 uppercase tracking-wider" style="color: #f77f00; font-family: var(--font-mono);">
                {item.label}
              </p>
              <p class="text-base leading-relaxed" style="color: var(--text-secondary);">{item.text}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- 02 ANALYTICS Y COOKIES -->
  <section style="background: var(--ink);" aria-label="Analytics y cookies">
    <div class="container-libera py-16 lg:py-24">
      <h2
        class="display-lg mb-6 max-w-3xl"
        style="font-family: var(--font-display); color: #ffffff; line-height: 1.08;"
      >
        Todo medido. Sin servicios externos que se lleven los datos.
      </h2>
      <p class="text-lg mb-16 max-w-2xl leading-relaxed" style="color: rgba(255,255,255,0.55);">
        Google Analytics 4 y Search Console configurados a la medida. El banner de cookies se gestiona directamente dentro del sitio: sin CookieBot, sin OneTrust, sin scripts de terceros que ralenticen la página o recojan datos para alguien más.
      </p>
      <div class="grid md:grid-cols-3 gap-10">
        {[
          {
            title: 'Google Analytics 4',
            text: 'Configuración de GA4 desde cero: eventos personalizados para solicitudes de cotización y llamadas, conversiones registradas, audiencias segmentadas por zona geográfica (Turín y Piamonte).',
          },
          {
            title: 'Google Search Console',
            text: 'Propiedad verificada, redirects técnicos implementados, canonicals correctos, artículos duplicados resueltos. Monitoreo continuo de cobertura y rendimiento de consultas.',
          },
          {
            title: 'Cookies gestionadas internamente',
            text: 'Banner de consentimiento construido dentro del sitio. Cero dependencias externas: sin CookieBot, sin scripts de terceros. Los datos de los usuarios permanecen dentro de la plataforma del cliente.',
          },
        ].map((item) => (
          <div>
            <div class="w-8 h-0.5 mb-7" style="background: #f77f00;" aria-hidden="true"></div>
            <h3 class="text-lg font-semibold mb-4" style="color: #ffffff; font-family: var(--font-display);">
              {item.title}
            </h3>
            <p class="text-base leading-relaxed" style="color: rgba(255,255,255,0.5);">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- 03 AUTOMATIZACIONES -->
  <section style="background: #003049;" aria-label="Automatizaciones">
    <div class="container-libera py-16 lg:py-24">
      <p class="eyebrow mb-6" style="color: rgba(255,255,255,0.35); font-family: var(--font-mono);">04 &middot; Automatizaciones internas</p>
      <h2
        class="display-lg mb-6 max-w-3xl"
        style="font-family: var(--font-display); color: #ffffff; line-height: 1.08;"
      >
        Herramientas que ya usaban. Ahora conectadas entre sí.
      </h2>
      <p class="text-lg mb-16 max-w-2xl leading-relaxed" style="color: rgba(255,255,255,0.55);">
        Construimos un sistema que conecta las herramientas que Sole Facile ya usaba: formularios del sitio, base de datos de clientes, correo y WhatsApp. Cada nueva solicitud de cotización llega automáticamente al lugar correcto, sin copiar datos a mano.
      </p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px" style="background: rgba(255,255,255,0.08);">
        {[
          {
            num: '01',
            label: 'Formulario del sitio',
            text: 'Cada solicitud de cotización enviada desde el sitio entra automáticamente a la base de datos. Cero correos perdidos, cero captura manual.',
          },
          {
            num: '02',
            label: 'Base de datos de clientes',
            text: 'Airtable como hub central: historial de contactos, estado de cotizaciones y seguimiento. Filtros y vistas para gestionar el pipeline comercial.',
          },
          {
            num: '03',
            label: 'Correos automatizados',
            text: 'Confirmación automática al cliente apenas envía la solicitud. Notificación interna al equipo. Ningún cliente de correo que revisar manualmente.',
          },
          {
            num: '04',
            label: 'WhatsApp',
            text: 'Notificación por WhatsApp al equipo por cada nuevo lead entrante. El área comercial recibe los datos directamente en el teléfono, en tiempo real.',
          },
        ].map((item) => (
          <div class="p-8 lg:p-10" style="background: #003049;">
            <p class="text-xs mb-7" style="color: #f77f00; font-family: var(--font-mono); letter-spacing: 0.08em;">{item.num}</p>
            <h3 class="text-lg font-semibold mb-3" style="font-family: var(--font-display); color: #ffffff;">{item.label}</h3>
            <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.5);">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- CTA -->
  <section style="background: var(--surface); border-top: 1px solid var(--border);" aria-label="Volver">
    <div class="container-libera py-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <p class="text-xs mb-2" style="color: var(--text-secondary); font-family: var(--font-mono);">
          Sole Facile SRL &middot; Cliente &middot; Turín, Italia
        </p>
        <p class="text-base" style="color: var(--text-secondary);">
          Construimos algo así para tu empresa. El primer paso es el diagnóstico.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <a href="/trabajo" class="btn btn-ghost-dark">&larr; Ver todo el trabajo</a>
        <a href="/diagnostico" class="btn btn-primary">
          Solicitar diagnóstico
          <span class="btn-icon" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .sf-project-hero {
    position: relative;
    overflow: hidden;
    background: #003049;
    color: #fff;
  }

  .sf-hero-content {
    position: relative;
    z-index: 2;
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  .sf-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    opacity: 0.22;
    z-index: 0;
  }

  .sf-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, #003049 35%, rgba(0,48,73,0.55) 65%, rgba(0,48,73,0.15) 100%);
  }

  .sf-back-link {
    display: inline-flex;
    margin-bottom: 3.5rem;
    color: #f77f00;
    font: 0.8rem var(--font-mono);
    transition: opacity 0.2s;
  }

  .sf-back-link:hover { opacity: 0.75; }

  .sf-project-hero h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 1.0;
    color: #ffffff;
    margin-bottom: 2rem;
    white-space: nowrap;
  }

  .sf-hero-copy {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: rgba(255,255,255,0.6);
    max-width: 44ch;
    margin-bottom: 3rem;
  }

  .sf-stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sf-stack-list span {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: rgba(255,255,255,0.45);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
  }

  @media (max-width: 900px) {
    .sf-hero-logo-wrap { width: 65vw; }
  }

  @media (max-width: 560px) {
    .sf-hero-content { padding-top: 5.5rem; }
    .sf-project-hero h1 { white-space: normal; }
  }
</style>
