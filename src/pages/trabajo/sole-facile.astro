---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Sole Facile" description="Ecosistema digital para empresa de instalación solar en Italia. Web, contenido, automatizaciones y agente IA.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--operacion); font-family: var(--font-mono);">Cliente</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Sole Facile</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Ecosistema digital completo para empresa de instalación solar en Italia. Diseño web, estrategia de contenido, automatizaciones y agente de IA para atención al cliente.</p>
      <p class="eyebrow mb-8" style="color: var(--text-secondary); font-family: var(--font-mono);">Stack: WordPress · n8n · Claude API</p>
      <a href="/trabajo" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Trabajo</a>
    </div>
  </section>
</Layout>
