---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Cenote Scout" description="Plataforma para descubrir cenotes, rutas y experiencias en Yucatán. Sistema de datos, mapas y contenido editorial.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--presencia); font-family: var(--font-mono);">Producto digital</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Cenote Scout</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Plataforma para descubrir cenotes, rutas y experiencias en Yucatán. Sistema de datos geoespaciales, mapas interactivos y contenido editorial curado.</p>
      <p class="eyebrow mb-8" style="color: var(--text-secondary); font-family: var(--font-mono);">Stack: Astro · TypeScript · Supabase</p>
      <a href="/trabajo" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Trabajo</a>
    </div>
  </section>
</Layout>
