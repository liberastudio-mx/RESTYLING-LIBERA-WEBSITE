---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="PAOS Framework" description="Sistema operativo de conocimiento del estudio. Agentes, plantillas, workflows y base de datos estructurada.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--presencia); font-family: var(--font-mono);">Sistema interno</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">PAOS Framework</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">El sistema operativo de conocimiento del estudio. Base de conocimiento, agentes de IA, plantillas de proceso y workflows n8n integrados en una sola infraestructura.</p>
      <p class="eyebrow mb-8" style="color: var(--text-secondary); font-family: var(--font-mono);">Stack: Obsidian · n8n · Claude API</p>
      <a href="/trabajo" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Trabajo</a>
    </div>
  </section>
</Layout>
