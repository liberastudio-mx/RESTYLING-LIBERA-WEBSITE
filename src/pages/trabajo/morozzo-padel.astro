---
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImg from '@/assets/images/logo morozzo.png';

const stack = ['HTML', 'React CDN', 'Babel Standalone', 'OpenStreetMap', 'Playtomic', 'GitHub Pages'];

const projectLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'Morozzo Padel',
  description: 'Sitio web para ASD Morozzo Padel: presencia digital con mapa interactivo OSM, código original y coste de infraestructura cero.',
  url: 'https://www.liberastudio.tech/trabajo/morozzo-padel',
  inLanguage: 'es-MX',
  creator: { '@id': 'https://www.liberastudio.tech/#organization' },
  about: ['Diseño web', 'OpenStreetMap', 'GitHub Pages', 'GDPR'],
});
---

<Layout
  title="Morozzo Padel — Trabajo"
  description="Sitio web para ASD Morozzo Padel, Cuneo: mapa interactivo con OpenStreetMap, código original, GitHub Pages y GDPR compliant."
  jsonLdExtra={projectLd}
>
  <!-- Design: Brand | Vibe: Sport Utility | Layout: Editorial Split | Color: Committed -->
  <article class="morozzo-page">
    <section class="project-hero" aria-labelledby="morozzo-title">
      <div class="hero-mark" aria-hidden="true">
        <div class="padel-court">
          <span class="court-net"></span>
          <span class="court-circle"></span>
        </div>
      </div>
      <div class="hero-logo-wrap" aria-hidden="true">
        <Image src={logoImg} alt="" widths={[400, 800]} sizes="38vw" class="hero-logo" />
      </div>
      <div class="container-libera hero-content">
        <a href="/trabajo" class="back-link">&larr; Trabajo</a>
        <p class="eyebrow project-kicker">Cliente &middot; Morozzo, Cuneo &middot; Completado mayo 2026</p>
        <h1 id="morozzo-title">Morozzo<br />Padel</h1>
        <p class="hero-copy">
          Un club de padel en Piamonte que no tenía presencia digital. Una página que funciona, no pesa y no necesita mantenimiento mensual.
        </p>
        <div class="stack-list" aria-label="Tecnologías del proyecto">
          {stack.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="light-section" aria-labelledby="reto-title">
      <div class="container-libera split-layout">
        <div>
          <p class="section-index">01 · El punto de partida</p>
          <h2 id="reto-title">Un club activo sin ninguna página donde enviar a los interesados.</h2>
        </div>
        <div class="prose">
          <p>
            ASD Morozzo Padel lleva las canchas llenas por WhatsApp y boca a boca. Funciona. Pero cuando alguien busca el club en Google, no hay nada. Sin dirección, sin horarios, sin forma de contacto que no sea el número de alguien que conoce a alguien.
          </p>
          <p>
            El pedido era claro: una página que dé información real, cargue rápido en móvil y no cueste nada de mantenimiento cada mes. Sin CMS, sin hosting de pago, sin alguien que lo mantenga.
          </p>
          <blockquote>
            Sistemas que puedes mantener sin nosotros. Este es uno.
          </blockquote>
        </div>
      </div>
    </section>

    <section class="dark-section" aria-labelledby="sistema-title">
      <div class="container-libera">
        <p class="section-index muted">02 · Lo que construimos</p>
        <h2 id="sistema-title" class="section-heading">Una página que hace exactamente lo que necesita, sin nada que sobre.</h2>
        <div class="system-grid">
          {[
            {
              num: '01',
              title: 'Sitio sin dependencias',
              text: 'Un único index.html con React vía CDN y Babel Standalone. Sin build tool, sin npm, sin nada que actualizar. El código es editable directamente desde cualquier editor.',
            },
            {
              num: '02',
              title: 'Mapa OSM sin API key',
              text: 'Mapa con iframe de OpenStreetMap. Coordenadas verificadas del club (44.4263°N / 7.7261°E). Sin Google Maps, sin clave de API, sin coste por uso ni límite de cargas.',
            },
            {
              num: '03',
              title: 'Booking con Playtomic',
              text: 'Integración directa con Playtomic para reservar cancha. El flujo de conversión va desde la búsqueda en Google hasta la reserva confirmada sin salir del sitio.',
            },
            {
              num: '04',
              title: 'Deploy en GitHub Pages',
              text: 'Hosting gratuito con dominio personalizado. Video de fondo en el hero, galería de 8 fotos con drag-to-scroll, GDPR compliant con política de privacidad y cookies separadas.',
            },
          ].map((item) => (
            <div class="system-item">
              <span>{item.num}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="sand-section" aria-labelledby="principio-title">
      <div class="container-libera statement-layout">
        <p class="section-index">03 · Principio de diseño</p>
        <h2 id="principio-title">La tecnología desaparece. Jugar queda al frente.</h2>
        <p>
          La interfaz no compite con el club. Ordena la información, reduce dudas y libera al equipo de explicar una y otra vez lo básico. El resultado es un sitio que cualquier miembro puede entender y que no depende de nadie externo para seguir funcionando.
        </p>
      </div>
    </section>

    <section class="project-cta" aria-label="Siguiente paso">
      <div class="container-libera cta-layout">
        <div>
          <p class="cta-meta">Morozzo Padel &middot; Cliente &middot; Sitio web</p>
          <p>Tu negocio ya funciona. Imagínalo funcionando en orden.</p>
        </div>
        <div class="cta-actions">
          <a href="/trabajo" class="btn btn-ghost-light">&larr; Ver todo el trabajo</a>
          <a href="/diagnostico" class="btn btn-primary">
            Solicitar diagnóstico <span class="btn-icon" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </article>
</Layout>

<style>
  .morozzo-page { --project: #d62828; background: var(--surface); }
  .project-hero { position: relative; min-height: 100dvh; overflow: hidden; background: #003049; color: #fff; }
  .hero-content { position: relative; z-index: 2; padding-top: 11rem; padding-bottom: 5rem; }
  .hero-mark { position: absolute; inset: 0 0 0 auto; width: min(50vw, 44rem); display: grid; place-items: center; opacity: 0.14; }
  .padel-court { position: relative; width: min(80%, 30rem); aspect-ratio: 1.4; border: 2px solid var(--project); transform: rotate(-4deg); }
  .padel-court::before, .padel-court::after { content: ""; position: absolute; background: var(--project); }
  .padel-court::before { top: 50%; left: 0; width: 100%; height: 2px; }
  .padel-court::after { top: 0; left: 50%; width: 2px; height: 100%; }
  .court-net { position: absolute; z-index: 1; top: 0; left: 24%; width: 2px; height: 100%; background: var(--project); }
  .court-circle { position: absolute; z-index: 2; right: 13%; top: 18%; width: 3.5rem; aspect-ratio: 1; border: 2px solid var(--project); border-radius: 50%; background: #003049; }
  .hero-logo-wrap { position: absolute; right: 3vw; top: 50%; width: min(38vw, 34rem); transform: translateY(-50%); opacity: 0.07; z-index: 1; }
  .hero-logo { width: 100%; height: auto; filter: brightness(0) invert(1); }
  .back-link { display: inline-flex; margin-bottom: 3.5rem; color: rgb(255 255 255 / 0.48); font: 0.8rem var(--font-mono); transition: opacity 0.2s; }
  .back-link:hover { opacity: 0.65; }
  .project-kicker { color: var(--project); margin-bottom: 1.25rem; }
  h1 { max-width: 9ch; font: 700 clamp(4rem, 11vw, 9rem)/0.88 var(--font-display); letter-spacing: -0.045em; }
  .hero-copy { max-width: 42rem; margin-top: 2rem; color: rgb(255 255 255 / 0.68); font-size: clamp(1rem, 1.5vw, 1.25rem); line-height: 1.65; }
  .stack-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 3rem; }
  .stack-list span { padding: 0.45rem 0.8rem; border: 1px solid rgb(255 255 255 / 0.14); border-radius: 999px; color: rgb(255 255 255 / 0.58); font: 0.72rem var(--font-mono); }
  .light-section { padding: 7rem 0; }
  .split-layout { display: grid; grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.72fr); gap: clamp(3rem, 9vw, 9rem); }
  .section-index { margin-bottom: 1.5rem; color: #b75b00; font: 0.72rem var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; }
  h2 { max-width: 18ch; color: var(--text-primary); font: 700 clamp(2.2rem, 5vw, 4.5rem)/1 var(--font-display); letter-spacing: -0.04em; text-wrap: balance; }
  .prose { padding-top: 2.7rem; }
  .prose p { color: var(--text-secondary); font-size: 1.05rem; line-height: 1.75; }
  .prose p + p { margin-top: 1.5rem; }
  .prose blockquote { margin-top: 2rem; padding-left: 1.25rem; border-left: 2px solid var(--project); color: var(--text-primary); font-style: italic; line-height: 1.65; }
  .dark-section { padding: 7rem 0; background: #081f2c; color: #fff; }
  .muted { color: rgb(255 255 255 / 0.42); }
  .section-heading { color: #fff; max-width: 22ch; margin-bottom: 4rem; }
  .system-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid rgb(255 255 255 / 0.13); }
  .system-item { min-height: 18rem; padding: 2rem; border-right: 1px solid rgb(255 255 255 / 0.13); }
  .system-item:first-child { padding-left: 0; }
  .system-item:last-child { border-right: 0; }
  .system-item > span { color: var(--project); font: 0.72rem var(--font-mono); }
  .system-item h3 { margin-top: 4rem; color: #fff; font: 600 1.25rem var(--font-display); }
  .system-item p { margin-top: 1rem; color: rgb(255 255 255 / 0.55); line-height: 1.65; }
  .sand-section { padding: 7rem 0; background: #eae2b7; }
  .statement-layout { display: grid; grid-template-columns: 0.45fr 1.2fr 0.65fr; gap: clamp(2rem, 6vw, 6rem); align-items: start; }
  .statement-layout h2 { color: #003049; }
  .statement-layout > p:last-child { padding-top: 0.35rem; color: rgb(0 48 73 / 0.72); font-size: 1.05rem; line-height: 1.75; }
  .project-cta { padding: 4rem 0; border-top: 1px solid var(--border); }
  .cta-layout { display: flex; justify-content: space-between; align-items: center; gap: 2rem; }
  .cta-meta { margin-bottom: 0.5rem; color: var(--text-secondary); font: 0.72rem var(--font-mono); }
  .cta-layout > div > p:last-child { color: var(--text-secondary); }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  @media (max-width: 900px) {
    .hero-mark { width: 70vw; opacity: 0.06; }
    .hero-logo-wrap { width: 65vw; }
    .split-layout, .statement-layout { grid-template-columns: 1fr; gap: 2rem; }
    .prose { padding-top: 0; }
    .system-grid { grid-template-columns: 1fr 1fr; }
    .system-item:nth-child(2) { border-right: 0; }
    .system-item { border-bottom: 1px solid rgb(255 255 255 / 0.13); }
    .system-item:first-child { padding-left: 2rem; }
    .cta-layout { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 560px) {
    .hero-content { padding-top: 9rem; }
    .light-section, .sand-section, .dark-section { padding: 5rem 0; }
    .system-grid { grid-template-columns: 1fr; }
    .system-item { min-height: auto; border-right: 0; }
    .system-item h3 { margin-top: 2.5rem; }
  }
</style>
