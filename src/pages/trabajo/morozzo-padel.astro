---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Morozzo Padel" description="Presencia digital y sistema de reservas para club de pádel. Rediseño, SEO local y automatización de comunicación.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--productos); font-family: var(--font-mono);">Cliente</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Morozzo Padel</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Presencia digital completa para club de pádel. Rediseño web, SEO local y automatización de comunicación con socios y clientes por WhatsApp.</p>
      <p class="eyebrow mb-8" style="color: var(--text-secondary); font-family: var(--font-mono);">Stack: HTML/CSS · JS · WhatsApp API</p>
      <a href="/trabajo" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Trabajo</a>
    </div>
  </section>
</Layout>
