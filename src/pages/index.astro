      height: 100dvh;
    }

    .problem-right {
      height: 100dvh;
      min-height: 100dvh;
      padding-top: calc(var(--nav-height, 4rem) + 3rem);
      padding-bottom: 2rem;
    }

    .solutions-overlap {
      margin-top: -42rem;
