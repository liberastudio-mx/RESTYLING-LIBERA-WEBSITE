<script>
  // Soluciones accordion
  const solTriggers = [...document.querySelectorAll<HTMLButtonElement>('[data-sol-trigger]')];
  solTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const panel = trigger.nextElementSibling as HTMLElement | null;
      const isOpen = trigger.classList.contains('is-open');
      // Close all
      solTriggers.forEach((t) => {
        t.classList.remove('is-open');
        t.setAttribute('aria-expanded', 'false');
        (t.nextElementSibling as HTMLElement | null)?.classList.remove('is-open');
      });
      // Open if it was closed
      if (!isOpen) {
        trigger.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
        panel?.classList.add('is-open');
      }
    });
  });
</script>

<script>
  const isTouchScrollLayout = window.matchMedia('(max-width: 1023px), (hover: none), (pointer: coarse)').matches;

  const radarGallery = document.querySelector<HTMLElement>('[data-radar-gallery]');
  const radarDots = [...document.querySelectorAll<HTMLButtonElement>('[data-radar-dot]')];

  if (radarGallery) {
    const rail = radarGallery.querySelector<HTMLElement>('[data-radar-rail]');
    const slides = [...radarGallery.querySelectorAll<HTMLElement>('[data-radar-slide]')];
    let activeIndex = 0;

    if (rail && slides.length > 0) {
      const setActiveSlide = (index: number) => {
        activeIndex = Math.min(slides.length - 1, Math.max(0, index));
        radarDots.forEach((dot, dotIndex) => {
          const isActive = dotIndex === activeIndex;
          dot.classList.toggle('is-active', isActive);
          dot.setAttribute('aria-current', isActive ? 'true' : 'false');
        });
      };

      const goToSlide = (index: number) => {
        const target = slides[Math.min(slides.length - 1, Math.max(0, index))];
        if (!target) return;
        const railRect = rail.getBoundingClientRect();
        const targetRect = target.getBoundingClientRect();
        rail.scrollTo({
          left: rail.scrollLeft + targetRect.left - railRect.left,
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
        });
      };

      rail.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
        event.preventDefault();
        goToSlide(activeIndex + (event.key === 'ArrowRight' ? 1 : -1));
      });

      radarDots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const index = Number(dot.dataset.radarDot ?? '0');
          goToSlide(index);
        });
      });

      let dragging = false;
      let dragged = false;
      let dragStartX = 0;
      let dragStartScroll = 0;
      let pressedLink: HTMLAnchorElement | null = null;

      if (!isTouchScrollLayout) {
        rail.addEventListener('mousedown', (event) => {
          if (event.button !== 0) return;
          event.preventDefault();
          dragging = true;
          dragged = false;
          dragStartX = event.clientX;
          dragStartScroll = rail.scrollLeft;
          pressedLink = (event.target as Element).closest<HTMLAnchorElement>('a[href]');
          rail.classList.add('is-dragging');
        });

        window.addEventListener('mousemove', (event) => {
          if (!dragging) return;
          const distance = event.clientX - dragStartX;
          if (Math.abs(distance) > 6) dragged = true;
          rail.scrollLeft = dragStartScroll - distance;
        });

        const finishDrag = (event: MouseEvent) => {
          if (!dragging) return;
          dragging = false;
          rail.classList.remove('is-dragging');
          if (dragged) {
            const railLeft = rail.getBoundingClientRect().left;
            const nearestIndex = slides.reduce((nearest, slide, index) => {
              const currentDistance = Math.abs(slide.getBoundingClientRect().left - railLeft);
              const nearestDistance = Math.abs(slides[nearest].getBoundingClientRect().left - railLeft);
              return currentDistance < nearestDistance ? index : nearest;
            }, 0);
            window.requestAnimationFrame(() => goToSlide(nearestIndex));
          } else if (pressedLink) {
            if (event.ctrlKey || event.metaKey) {
              window.open(pressedLink.href, '_blank', 'noopener,noreferrer');
            } else {
              window.location.href = pressedLink.href;
            }
          }
          pressedLink = null;
        };

        window.addEventListener('mouseup', finishDrag);
        rail.addEventListener('dragstart', (event) => event.preventDefault());
      }
      rail.addEventListener('click', (event) => {
        if (!dragged) return;
        event.preventDefault();
        event.stopPropagation();
        dragged = false;
      }, true);

      const slideObserver = new IntersectionObserver(
        (entries) => {
          const mostVisible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (!mostVisible) return;
          const index = slides.indexOf(mostVisible.target as HTMLElement);
          if (index >= 0) setActiveSlide(index);
        },
        { root: rail, threshold: [0.55, 0.75, 0.95] }
      );

      slides.forEach((slide) => slideObserver.observe(slide));
      setActiveSlide(0);
    }
  }
</script>

<script>
  // Fit hero headline to exact container width with binary search on font-size
  function fitHeroHeadline() {
    const h1 = document.querySelector<HTMLElement>('[data-hero-headline]');
    if (!h1) return;
    const targetWidth = h1.clientWidth;
    const lines = [...h1.querySelectorAll<HTMLElement>('[data-hero-line]')];
    let lo = 10, hi = 90;
    while (hi - lo > 0.25) {
      const mid = (lo + hi) / 2;
      h1.style.fontSize = mid + 'px';
      const maxWidth = Math.max(...lines.map(l => l.scrollWidth));
      if (maxWidth <= targetWidth) lo = mid; else hi = mid;
    }
    h1.style.fontSize = lo + 'px';
  }
  fitHeroHeadline();
  window.addEventListener('resize', fitHeroHeadline);
</script>

<script>
  {
    const methodSection = document.querySelector('[data-method-clone-section]');
    const methodFrame = document.querySelector('.method-clone-sticky');
    const methodStage = document.querySelector('[data-method-clone-stage]');
    const methodSteps = [...document.querySelectorAll('[data-method-clone-step]')];
    const methodTitle = document.querySelector('[data-method-clone-title]');
    const methodTitleLines = [...document.querySelectorAll('[data-method-clone-title-line]')];
    const methodStepTitles = [...document.querySelectorAll('[data-method-clone-step-title]')];
    const reduceMethodMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouchScrollLayout = window.matchMedia('(max-width: 1023px), (hover: none), (pointer: coarse)').matches;

    let sectionTop = 0;
    let sectionHeight = 0;
    const cacheSectionRect = () => {
      if (!methodSection) return;
      sectionTop = methodSection.offsetTop;
      sectionHeight = methodSection.offsetHeight;
    };

    const fitMethodTitle = () => {
      if (!methodTitle) return;
      methodTitle.style.setProperty('--method-clone-title-fit', '1');
      let fit = 1;

      while (methodTitle.scrollWidth > methodTitle.clientWidth && fit > 0.52) {
        fit -= 0.02;
        methodTitle.style.setProperty('--method-clone-title-fit', fit.toFixed(2));
      }
    };

    const fitMethodStepTitles = () => {
      if (methodStepTitles.length === 0) return;

      document.documentElement.style.setProperty('--method-clone-step-title-fit', '1');
      let fit = 1;

      while (
        methodStepTitles.some((title) => title.scrollWidth > title.clientWidth) &&
        fit > 0.5
      ) {
        fit -= 0.02;
        document.documentElement.style.setProperty('--method-clone-step-title-fit', fit.toFixed(2));
      }
    };

    const updateMethodSteps = () => {
      if (!methodSection || methodSteps.length === 0 || reduceMethodMotion) return;

      const hideMethodSequence = () => {
        methodTitle?.style.setProperty('--method-clone-title-opacity', '0');

        methodTitleLines.forEach((line) => {
          line.style.setProperty('--method-clone-line-opacity', '0');
          line.style.setProperty('--method-clone-line-x', '0px');
          line.style.setProperty('--method-clone-line-y', '0px');
          line.style.setProperty('--method-clone-line-scale', '1');
          line.style.setProperty('--method-clone-line-accent', '0%');
        });

        methodSteps.forEach((step) => {
          step.style.setProperty('--method-clone-step-opacity', '0');
          step.style.setProperty('--method-clone-step-focus', '0%');
          step.style.setProperty('--method-clone-step-copy-opacity', '0');
          const stepTitle = step.querySelector('[data-method-clone-step-title]');
          stepTitle?.style.setProperty('--method-clone-step-title-x', '0px');
          stepTitle?.style.setProperty('--method-clone-step-title-y', '0px');
          stepTitle?.style.setProperty('--method-clone-step-title-scale', '1');
          step.setAttribute('aria-hidden', 'true');
        });
      };

      if (methodSection.getBoundingClientRect().top > 0) {
        hideMethodSequence();
        return;
      }

      const scrollable = Math.max(1, sectionHeight - window.innerHeight);
      const sectionProgress = (window.scrollY - sectionTop) / scrollable;
      const rawProgress = Math.min(1, Math.max(0, sectionProgress));
      const ease = (value) => value * value * (3 - 2 * value);
      const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
      const methodProgress = rawProgress;
      const titleSequenceEnd = 0.22;
      const stepSequenceStart = 0.3;
      const stepSequenceEnd = 0.88;
      const isMobileMethod = window.matchMedia('(max-width: 640px)').matches;
      const titleFadeStart = isMobileMethod ? 0.975 : 0.92;
      const titleFadeEnd = isMobileMethod ? 1 : 1;
      const lineWindow = titleSequenceEnd / Math.max(1, methodTitleLines.length);
      const stepsEnabled = methodProgress >= stepSequenceStart;
      const stepsProgress = clamp((methodProgress - stepSequenceStart) / (stepSequenceEnd - stepSequenceStart));
      const timeline = stepsProgress * methodSteps.length;
      const titleFade = 1 - ease(clamp((methodProgress - titleFadeStart) / (titleFadeEnd - titleFadeStart)));

      if (methodTitle) {
        methodTitle.style.setProperty('--method-clone-title-opacity', titleFade.toFixed(3));
      }

      const titleRect = methodTitle?.getBoundingClientRect();
      const navHeight = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--nav-height')) || 0;
      const frameRect = methodFrame?.getBoundingClientRect();
      const frameStyle = methodFrame ? getComputedStyle(methodFrame) : null;
      const framePaddingLeft = frameStyle ? parseFloat(frameStyle.paddingLeft) || 0 : 0;
      const framePaddingRight = frameStyle ? parseFloat(frameStyle.paddingRight) || 0 : 0;
      const heroLeft = frameRect ? frameRect.left + framePaddingLeft : Math.max(16, titleRect?.left ?? 0);
      const heroRight = frameRect ? frameRect.right - framePaddingRight : window.innerWidth - heroLeft;
      const heroSafeInset = clamp(window.innerWidth * 0.03, 18, 48);
      const heroInnerLeft = heroLeft + heroSafeInset;
      const heroInnerRight = heroRight - heroSafeInset;
      const heroAvailableWidth = Math.max(1, heroInnerRight - heroInnerLeft);
      const heroCenterX = heroInnerLeft + heroAvailableWidth / 2;
      const getLineTextWidth = (line) => Math.max(1, line.offsetWidth || line.scrollWidth);
      const heroReferenceLine = methodTitleLines[methodTitleLines.length - 1] ?? methodTitleLines[0];
      const heroReferenceWidth = heroReferenceLine ? getLineTextWidth(heroReferenceLine) : 1;
      const sharedHeroScale = heroAvailableWidth / heroReferenceWidth;

      methodTitleLines.forEach((line, index) => {
        const local = (methodProgress - index * lineWindow) / lineWindow;
        const lineWidth = getLineTextWidth(line);
        const lineHeight = Math.max(1, line.offsetHeight);
        const lineLeft = (titleRect?.left ?? 0) + line.offsetLeft;
        const lineTop = (titleRect?.top ?? 0) + line.offsetTop;
        const heroScale = sharedHeroScale;
        const heroX = heroCenterX - (lineWidth * heroScale) / 2 - lineLeft;
        const heroY = navHeight + (window.innerHeight - navHeight - lineHeight * heroScale) / 2 - lineTop;
        const finalY = -index * lineHeight * 0.34;
        let opacity = 0;
        let travel = 1;
        let scale = heroScale;
        let accent = 0;

        if (local >= 0 && local < 0.72) {
          opacity = 1;
          travel = 1;
          scale = heroScale;
        } else if (local >= 0.72 && local < 1) {
          const settle = ease((local - 0.72) / 0.28);
          opacity = 1;
          travel = 1 - settle;
          scale = heroScale + (0.66 - heroScale) * settle;
        } else if (local >= 1) {
          opacity = 1;
          travel = 0;
          scale = 0.66;
          accent = ease(clamp((local - 1) / 0.1));
        }

        line.style.setProperty('--method-clone-line-opacity', opacity.toFixed(3));
        line.style.setProperty('--method-clone-line-x', `${(heroX * travel).toFixed(1)}px`);
        line.style.setProperty('--method-clone-line-y', `${(heroY * travel + finalY * (1 - travel)).toFixed(1)}px`);
        line.style.setProperty('--method-clone-line-scale', scale.toFixed(3));
        line.style.setProperty('--method-clone-line-accent', `${Math.round(accent * 100)}%`);
      });

      const stageRect = methodStage?.getBoundingClientRect();
      const upperLineRects = methodTitleLines.map((line) => line.getBoundingClientRect());
      const settledStartTop = upperLineRects[0]?.top ?? navHeight;
      const settledStride = upperLineRects.length > 1
        ? upperLineRects[1].top - upperLineRects[0].top
        : upperLineRects[0]?.height ?? 48;
      const upperReferenceLine = methodTitleLines[0];
      const upperReferenceStyle = upperReferenceLine ? getComputedStyle(upperReferenceLine) : null;
      const upperReferenceFontSize = upperReferenceStyle
        ? parseFloat(upperReferenceStyle.fontSize) || 1
        : 1;
      const upperReferenceScale = upperReferenceLine
        ? parseFloat(upperReferenceLine.style.getPropertyValue('--method-clone-line-scale')) || 0.66
        : 0.66;
      const settledFontSize = upperReferenceFontSize * upperReferenceScale;

      methodSteps.forEach((step, index) => {
        const local = stepsEnabled ? timeline - index : -1;
        const stepTitle = methodStepTitles[index];
        const stepTitleFontSize = stepTitle
          ? parseFloat(getComputedStyle(stepTitle).fontSize) || 1
          : 1;
        const settledScale = settledFontSize / stepTitleFontSize;
        const naturalTitleTop = (stageRect?.top ?? 0) + (stepTitle?.offsetTop ?? 0);
        const settledY = settledStartTop + index * settledStride - naturalTitleTop;
        let opacity = 0;
        let titleY = 0;
        let titleScale = 1;
        let copyOpacity = 0;
        let focus = 0;

        if (local >= 0 && local < 0.72) {
          opacity = 1;
          titleY = 0;
          titleScale = 1;
          copyOpacity = 1;
          focus = 1;
        } else if (local >= 0.72 && local < 1) {
          const settle = ease((local - 0.72) / 0.28);
          opacity = 1;
          titleY = settledY * settle;
          titleScale = 1 + (settledScale - 1) * settle;
          copyOpacity = 1 - settle;
          focus = 1;
        } else if (local >= 1) {
          opacity = 1;
          titleY = settledY;
          titleScale = settledScale;
          copyOpacity = 0;
          focus = 1;
        }

        const fadedOpacity = opacity * titleFade;
        const fadedCopyOpacity = copyOpacity * titleFade;
        const active = fadedOpacity > 0.5;

        step.style.setProperty('--method-clone-step-opacity', fadedOpacity.toFixed(3));
        step.style.setProperty('--method-clone-step-focus', `${Math.round(focus * 100)}%`);
        step.style.setProperty('--method-clone-step-copy-opacity', fadedCopyOpacity.toFixed(3));
        stepTitle?.style.setProperty('--method-clone-step-title-x', '0px');
        stepTitle?.style.setProperty('--method-clone-step-title-y', `${titleY.toFixed(1)}px`);
        stepTitle?.style.setProperty('--method-clone-step-title-scale', titleScale.toFixed(3));
        step.setAttribute('aria-hidden', String(!active));
      });
    };

    let methodTicking = false;
    const requestMethodUpdate = () => {
      if (methodTicking) return;
      methodTicking = true;
      window.requestAnimationFrame(() => {
        updateMethodSteps();
        methodTicking = false;
      });
    };

    const onResize = () => {
      cacheSectionRect();
      fitMethodTitle();
      fitMethodStepTitles();
      requestMethodUpdate();
    };

    cacheSectionRect();
    fitMethodTitle();
    fitMethodStepTitles();
    updateMethodSteps();

    window.addEventListener('scroll', requestMethodUpdate, { passive: true });
    window.addEventListener('resize', onResize);

    if ('ResizeObserver' in window && methodTitle) {
      new ResizeObserver(onResize).observe(methodTitle);
    }

    // Scroll magnetism: snap to nearest title line or step when user pauses
    if (!reduceMethodMotion && !isTouchScrollLayout && methodSteps.length > 0) {
      const TITLE_END  = 0.22;
      const LINE_WIN   = TITLE_END / Math.max(1, methodTitleLines.length);
      const STEP_START = 0.3;
      const STEP_END   = 0.88;

      const scrollable = () => Math.max(1, sectionHeight - window.innerHeight);

      // Each title line peaks visually near local 0.36.
      const getTitleSnapY = (i) =>
        sectionTop + (i + 0.36) * LINE_WIN * scrollable();

      // Lower titles use the same visible hero window as the upper lines.
      const getStepSnapY = (i) => {
        const p = STEP_START + ((i + 0.36) / methodSteps.length) * (STEP_END - STEP_START);
        return sectionTop + p * scrollable();
      };

      // Find nearest Y from a list of candidates
      const nearestY = (candidates) =>
        candidates.reduce((best, y) =>
          Math.abs(window.scrollY - y) < Math.abs(window.scrollY - best) ? y : best,
          candidates[0]
        );

      let isSnapping = false;
      let snapTimer;

      const doSnap = () => {
        if (isSnapping) return;
        const sp = (window.scrollY - sectionTop) / scrollable();
        let targetY = null;

        if (sp >= LINE_WIN * 0.5 && sp < TITLE_END) {
          // Title zone: snap to nearest of the 3 lines
          // Lower bound (LINE_WIN*0.5) lets user exit the section freely at the top
          // Upper bound leaves a small free zone before the next title.
          targetY = nearestY(methodTitleLines.map((_, i) => getTitleSnapY(i)));
        } else if (sp >= STEP_START && sp <= STEP_END) {
          // Step zone: snap to nearest of the 6 steps
          const t = ((sp - STEP_START) / (STEP_END - STEP_START)) * methodSteps.length;
          const idx = Math.min(methodSteps.length - 1, Math.max(0, Math.round(t - 0.36)));
          targetY = getStepSnapY(idx);
        }

        if (targetY === null || Math.abs(window.scrollY - targetY) < 30) return;

        isSnapping = true;
        window.scrollTo({ top: targetY, behavior: 'smooth' });
        setTimeout(() => { isSnapping = false; }, 700);
      };

      window.addEventListener('wheel', () => {
        if (isSnapping) return;
        clearTimeout(snapTimer);
        snapTimer = setTimeout(doSnap, 300);
      }, { passive: true });
    }
  }

</script>

<script>
  // DotField: vanilla JS canvas background for hero
  (function initDotField() {
    const TWO_PI = Math.PI * 2;
    const P = {
      dotRadius:    1.5,
      dotSpacing:   14,
      cursorRadius: 750,
      bulgeStrength: 67,
      glowRadius:   160,
      gradientFrom: '#eae2b7',
      gradientTo:   '#fcbf49',
      glowColor:    '#ffffff',
    };

    const container = document.getElementById('hero-dot-field');
    if (!container) return;
    const staticTouchField = window.matchMedia('(max-width: 1023px), (hover: none), (pointer: coarse)').matches;

    // Canvas
    const canvas = document.createElement('canvas');
    canvas.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;';
    container.appendChild(canvas);
    const ctx = canvas.getContext('2d', { alpha: true })!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    // SVG glow overlay
    const glowId = 'dfg-' + Math.random().toString(36).slice(2, 7);
    const NS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(NS, 'svg');
    svg.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;overflow:visible;';
    const defs = document.createElementNS(NS, 'defs');
    const rg   = document.createElementNS(NS, 'radialGradient');
    rg.setAttribute('id', glowId);
    const s1 = document.createElementNS(NS, 'stop');
    s1.setAttribute('offset', '0%');
    s1.setAttribute('stop-color', P.glowColor);
    s1.setAttribute('stop-opacity', '0.18');
    const s2 = document.createElementNS(NS, 'stop');
    s2.setAttribute('offset', '100%');
    s2.setAttribute('stop-color', P.glowColor);
    s2.setAttribute('stop-opacity', '0');
    rg.appendChild(s1); rg.appendChild(s2); defs.appendChild(rg); svg.appendChild(defs);
    const glowCircle = document.createElementNS(NS, 'circle');
    glowCircle.setAttribute('cx', '-9999');
    glowCircle.setAttribute('cy', '-9999');
    glowCircle.setAttribute('r', String(P.glowRadius));
    glowCircle.setAttribute('fill', `url(#${glowId})`);
    glowCircle.style.opacity = '0';
    svg.appendChild(glowCircle);
    container.appendChild(svg);

    // State
    type Dot = { ax: number; ay: number; sx: number; sy: number };
    let dots: Dot[] = [];
    let W = 0, H = 0, offX = 0, offY = 0;
    let mx = -9999, my = -9999, pmx = -9999, pmy = -9999, mspeed = 0;
    let glowOpacity = 0, engagement = 0;
    let rafId = 0, resizeTimer = 0;

    function buildGrid(w: number, h: number) {
      const step = P.dotRadius * 2 + P.dotSpacing;
      const cols = Math.floor(w / step);
      const rows = Math.floor(h / step);
      const padX = (w - cols * step) / 2 + step / 2;
      const padY = (h - rows * step) / 2 + step / 2;
      dots = [];
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const ax = padX + c * step;
          const ay = padY + r * step;
          dots.push({ ax, ay, sx: ax, sy: ay });
        }
      }
    }

    function doResize() {
      const rect = container.getBoundingClientRect();
      W = rect.width; H = rect.height;
      canvas.width  = W * dpr; canvas.height = H * dpr;
      canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      offX = rect.left + window.scrollX;
      offY = rect.top  + window.scrollY;
      buildGrid(W, H);
    }

    function onResize() {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(doResize, 80);
    }

    function onMouseMove(e: MouseEvent) {
      mx = e.pageX - offX;
      my = e.pageY - offY;
    }

    const speedTimer = window.setInterval(() => {
      if (staticTouchField) return;
      const dx = pmx - mx, dy = pmy - my;
      const d = Math.sqrt(dx * dx + dy * dy);
      mspeed += (d - mspeed) * 0.4;
      if (mspeed < 0.001) mspeed = 0;
      pmx = mx; pmy = my;
    }, 20);

    function tick() {
      const cr = P.cursorRadius;
      const crSq = cr * cr;

      const targetEng = staticTouchField ? 0 : Math.min(mspeed / 5, 1);
      engagement += (targetEng - engagement) * 0.06;
      if (engagement < 0.001) engagement = 0;

      glowOpacity += (engagement - glowOpacity) * 0.08;
      glowCircle.setAttribute('cx', String(mx));
      glowCircle.setAttribute('cy', String(my));
      glowCircle.style.opacity = String(glowOpacity);

      ctx.clearRect(0, 0, W, H);

      const grad = ctx.createLinearGradient(0, 0, W, H);
      grad.addColorStop(0, P.gradientFrom);
      grad.addColorStop(1, P.gradientTo);
      ctx.fillStyle = grad;

      const eng = engagement;
      const r = P.dotRadius;

      ctx.beginPath();
      for (let i = 0; i < dots.length; i++) {
        const dot = dots[i];
        const dx = mx - dot.ax;
        const dy = my - dot.ay;
        const distSq = dx * dx + dy * dy;

        if (!staticTouchField && distSq < crSq && eng > 0.01) {
          const dist  = Math.sqrt(distSq);
          const t     = 1 - dist / cr;
          const push  = t * t * P.bulgeStrength * eng;
          const angle = Math.atan2(dy, dx);
          dot.sx += (dot.ax - Math.cos(angle) * push - dot.sx) * 0.15;
          dot.sy += (dot.ay - Math.sin(angle) * push - dot.sy) * 0.15;
        } else {
          dot.sx += (dot.ax - dot.sx) * 0.1;
          dot.sy += (dot.ay - dot.sy) * 0.1;
        }

        ctx.moveTo(dot.sx + r, dot.sy);
        ctx.arc(dot.sx, dot.sy, r, 0, TWO_PI);
      }
      ctx.fill();

      rafId = requestAnimationFrame(tick);
    }

    doResize();
    window.addEventListener('resize',    onResize,    { passive: true });
    if (!staticTouchField) {
      window.addEventListener('mousemove', onMouseMove, { passive: true });
    }
    rafId = requestAnimationFrame(tick);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
      clearInterval(speedTimer);
      window.removeEventListener('resize',    onResize);
      if (!staticTouchField) {
        window.removeEventListener('mousemove', onMouseMove);
      }
    }, { once: true });
  })();


</script>

<script>
  // Hero ink-reveal interactive mask
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const MC = [0, 24, 36];
    const BRUSH = 210;
    const EXPAND_MS = 300;
    const LIFETIME = 3500;
    const FADE_AT = 0.5;
    const R_START = 16;
    const R_VARY = 0.38;
    const STAMP_STEP = 10;   // smaller step = smoother trail
    const SEGMENTS = 36;
    const WOBBLE = [0.14, 0.08, 0.05];
    const GRAD_INNER = 0.18;
    const GRAD_STOPS = [1.0, 0.93, 0];
    const REVEAL_THRESHOLD = 0.85;
    const FULL_REVEAL_MS = 900;
    const TRACK_W = 120; // small offscreen canvas for accurate pixel coverage

    const canvas = /** @type {HTMLCanvasElement|null} */ (document.getElementById('hero-ink-canvas'));
    const section = document.getElementById('hero');
    if (!canvas || !section) return;

    const isTouch = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

    // On mobile, lock page scroll until the reveal is complete
    if (isTouch) {
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
    }

    function unlockScroll() {
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
    }

    /** @type {{ x: number; y: number; born: number; seed: number; rmax: number }[]} */
    let stamps = [];
    let running = false;
    let lastPos = /** @type {{ x: number; y: number } | null} */ (null);
    let dims = { w: 0, h: 0 };
    let fullyRevealed = false;
    let stampCount = 0;

    // Tiny offscreen canvas to measure actual pixel coverage
    const trackCanvas = document.createElement('canvas');
    let trackCtx = /** @type {CanvasRenderingContext2D|null} */ (null);
    let trackW = TRACK_W, trackH = TRACK_W;

    function initTrack() {
      trackW = TRACK_W;
      trackH = Math.max(1, Math.round(TRACK_W * dims.h / dims.w));
      trackCanvas.width = trackW;
      trackCanvas.height = trackH;
      trackCtx = trackCanvas.getContext('2d', { willReadFrequently: true });
      if (!trackCtx) return;
      trackCtx.fillStyle = 'black';
      trackCtx.fillRect(0, 0, trackW, trackH);
    }

    function carveTrack(x, y, r, seed) {
      if (!trackCtx) return;
      const sx = (x / dims.w) * trackW;
      const sy = (y / dims.h) * trackH;
      const sr = (r / dims.w) * trackW;
      trackCtx.globalCompositeOperation = 'destination-out';
      const g = trackCtx.createRadialGradient(sx, sy, sr * 0.1, sx, sy, sr);
      g.addColorStop(0, 'rgba(0,0,0,1)');
      g.addColorStop(1, 'rgba(0,0,0,0)');
      trackCtx.fillStyle = g;
      trackCtx.beginPath();
      for (let i = 0; i <= 12; i++) {
        const a = (i / 12) * Math.PI * 2;
        const wob = 0.78 + WOBBLE[0] * Math.sin(a * 3 + seed);
        const px = sx + Math.cos(a) * sr * wob;
        const py = sy + Math.sin(a) * sr * wob;
        i === 0 ? trackCtx.moveTo(px, py) : trackCtx.lineTo(px, py);
      }
      trackCtx.closePath();
      trackCtx.fill();
    }

    function checkCoverage() {
      if (!trackCtx) return 0;
      const data = trackCtx.getImageData(0, 0, trackW, trackH).data;
      let transparent = 0;
      for (let i = 3; i < data.length; i += 4) {
        if (data[i] < 64) transparent++;
      }
      return transparent / (trackW * trackH);
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = section.getBoundingClientRect();
      dims = { w: rect.width, h: rect.height };
      canvas.width = Math.round(dims.w * dpr);
      canvas.height = Math.round(dims.h * dpr);
      canvas.style.width = dims.w + 'px';
      canvas.style.height = dims.h + 'px';
      canvas.style.opacity = '1';
      fullyRevealed = false;
      stampCount = 0;
      initTrack();
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.globalCompositeOperation = 'source-over';
      ctx.fillStyle = `rgb(${MC[0]},${MC[1]},${MC[2]})`;
      ctx.fillRect(0, 0, dims.w, dims.h);
    }

    function triggerFullReveal() {
      fullyRevealed = true;
      stamps = [];
      running = false;
      if (isTouch) unlockScroll();
      const start = performance.now();
      (function fadeCanvas() {
        const t = Math.min(1, (performance.now() - start) / FULL_REVEAL_MS);
        const ease = 1 - Math.pow(1 - t, 3);
        canvas.style.opacity = String(1 - ease);
        if (t < 1) requestAnimationFrame(fadeCanvas);
      })();
    }

    function carveInk(ctx, x, y, r, seed, alpha) {
      const g = ctx.createRadialGradient(x, y, r * GRAD_INNER, x, y, r);
      g.addColorStop(0, `rgba(0,0,0,${GRAD_STOPS[0] * alpha})`);
      g.addColorStop(0.5, `rgba(0,0,0,${GRAD_STOPS[1] * alpha})`);
      g.addColorStop(1, `rgba(0,0,0,${GRAD_STOPS[2] * alpha})`);
      ctx.fillStyle = g;
      ctx.beginPath();
      for (let i = 0; i <= SEGMENTS; i++) {
        const a = (i / SEGMENTS) * Math.PI * 2;
        const wob =
          0.78 +
          WOBBLE[0] * Math.sin(a * 3 + seed) +
          WOBBLE[1] * Math.sin(a * 5 + seed * 2.1) +
          WOBBLE[2] * Math.sin(a * 7 + seed * 0.7);
        const px = x + Math.cos(a) * r * wob;
        const py = y + Math.sin(a) * r * wob;
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.closePath();
      ctx.fill();
    }

    function addStamp(x, y) {
      if (fullyRevealed) return;
      const rmax = BRUSH * (1 - R_VARY + Math.random() * R_VARY);
      const seed = Math.random() * Math.PI * 2;
      stamps.push({ x, y, born: performance.now(), seed, rmax });
      carveTrack(x, y, rmax, seed);
      // Check actual pixel coverage every 12 stamps (getImageData is costly)
      if (++stampCount % 12 === 0 && checkCoverage() >= REVEAL_THRESHOLD) {
        triggerFullReveal();
      }
    }

    function stampAlong(x, y) {
      if (!lastPos) {
        addStamp(x, y);
      } else {
        const dx = x - lastPos.x, dy = y - lastPos.y;
        const dist = Math.hypot(dx, dy);
        const steps = Math.max(1, Math.ceil(dist / STAMP_STEP));
        for (let i = 1; i <= steps; i++) {
          addStamp(lastPos.x + (dx * i) / steps, lastPos.y + (dy * i) / steps);
        }
      }
      lastPos = { x, y };
    }

    function loop() {
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      const now = performance.now();

      ctx.globalCompositeOperation = 'source-over';
      ctx.fillStyle = `rgb(${MC[0]},${MC[1]},${MC[2]})`;
      ctx.fillRect(0, 0, dims.w, dims.h);
      ctx.globalCompositeOperation = 'destination-out';

      for (let i = stamps.length - 1; i >= 0; i--) {
        const age = now - stamps[i].born;
        const t = age / LIFETIME;
        if (t >= 1) { stamps.splice(i, 1); continue; }
        const expandT = Math.min(1, age / EXPAND_MS);
        const ease = 1 - Math.pow(1 - expandT, 2.5);
        const r = R_START + (stamps[i].rmax - R_START) * ease;
        const alpha = t < FADE_AT ? 1.0 : 1.0 - (t - FADE_AT) / (1.0 - FADE_AT);
        carveInk(ctx, stamps[i].x, stamps[i].y, r, stamps[i].seed, alpha);
      }

      if (stamps.length) requestAnimationFrame(loop);
      else running = false;
    }

    function startLoop() {
      if (!running) { running = true; requestAnimationFrame(loop); }
    }

    function getCanvasPos(clientX, clientY) {
      const rect = canvas.getBoundingClientRect();
      return { x: clientX - rect.left, y: clientY - rect.top };
    }

    resize();
    window.addEventListener('resize', resize, { passive: true });

    section.style.cursor = 'crosshair';

    const hint = document.getElementById('hero-hint');
    let hintHidden = false;

    function hideHint() {
      if (hintHidden || !hint) return;
      hintHidden = true;
      hint.style.opacity = '0';
    }

    // Prevent mousedown from entering text-selection mode (breaks mousemove after 2nd click)
    section.addEventListener('mousedown', (e) => { e.preventDefault(); });

    // Use document-level mousemove so clicks never interrupt the effect
    function onDocMove(e) {
      const rect = canvas.getBoundingClientRect();
      if (
        e.clientX < rect.left || e.clientX > rect.right ||
        e.clientY < rect.top  || e.clientY > rect.bottom
      ) {
        lastPos = null;
        return;
      }
      const p = { x: e.clientX - rect.left, y: e.clientY - rect.top };
      stampAlong(p.x, p.y);
      startLoop();
      hideHint();
    }

    document.addEventListener('mousemove', onDocMove, { passive: true });

    section.addEventListener('touchstart', (e) => {
      if (!fullyRevealed) e.preventDefault();
      const t = e.touches[0];
      const p = getCanvasPos(t.clientX, t.clientY);
      lastPos = p; stampAlong(p.x, p.y); startLoop(); hideHint();
    }, { passive: false });
    section.addEventListener('touchmove', (e) => {
      if (!fullyRevealed) e.preventDefault(); // block page scroll until ink reveal is complete
      const t = e.touches[0];
      const p = getCanvasPos(t.clientX, t.clientY);
      stampAlong(p.x, p.y); startLoop();
    }, { passive: false });
    section.addEventListener('touchend', () => { lastPos = null; });

    document.addEventListener('astro:before-swap', () => {
      unlockScroll();
      window.removeEventListener('resize', resize);
      document.removeEventListener('mousemove', onDocMove);
    }, { once: true });
  })();
</script>
