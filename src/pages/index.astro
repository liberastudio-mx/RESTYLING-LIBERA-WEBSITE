  /* Desktop rhythm reset: only Metodo keeps scroll-driven choreography. */
  @media (min-width: 1024px) {
    .hero-pin-stage,
    .problem-pin-stage,
    .solutions-overlap,
    .work-pin-stage,
    .conocimiento-pin-stage {
