      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       7. CTA FINAL — Full-bleed dark, impatto massimo
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="cta"
    style="background: var(--ink);"
    class="py-48 lg:py-64 relative overflow-hidden"
    aria-label="Llamada a la acción"
  >
    <!-- Glow -->
    <div
      class="absolute inset-0 pointer-events-none"
