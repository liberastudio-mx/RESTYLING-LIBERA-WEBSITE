    }

    .method-step h3 {
      font-size: calc(clamp(3.4rem, 16vw, 8.75rem) * var(--method-step-title-fit, 1));
    }

    .method-step p {
      font-size: clamp(1.05rem, 3vw, 1.45rem);
      max-width: min(100%, 42rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .method-scroll {
      min-height: auto;
      padding-block: 7rem;
    }

    .method-sticky {
      position: relative;
      min-height: auto;
      padding-block: 0;
    }

    .method-layout {
      min-height: auto;
    }

    .method-title {
      --method-title-opacity: 1;
    }

    .method-title-line {
      --method-line-opacity: 1;
      --method-line-x: 0px;
      --method-line-y: 0px;
      --method-line-scale: 0.66;
      --method-line-accent: 100%;
    }

    .method-stage {
      min-height: auto;
      overflow: visible;
      display: grid;
      gap: 1px;
      background: var(--border-dark);
      border-top: 0;
    }

    .method-step {
      --method-step-focus: 100%;
      position: relative;
      opacity: 1;
      transform: none;
      background: var(--ink-mid);
    }
  }
</style>

<script>
  // Fit hero headline to exact container width — binary search on font-size
  function fitHeroHeadline() {
    const h1 = document.querySelector<HTMLElement>('[data-hero-headline]');
    if (!h1) return;
    const targetWidth = h1.clientWidth;
    const lines = [...h1.querySelectorAll<HTMLElement>('[data-hero-line]')];
    let lo = 10, hi = 90;
    while (hi - lo > 0.25) {
      const mid = (lo + hi) / 2;
      h1.style.fontSize = mid + 'px';
      const maxWidth = Math.max(...lines.map(l => l.scrollWidth));
      if (maxWidth <= targetWidth) lo = mid; else hi = mid;
    }
    h1.style.fontSize = lo + 'px';
  }
  fitHeroHeadline();
  window.addEventListener('resize', fitHeroHeadline);
</script>

<script>
  const solutionCards = [...document.querySelectorAll<HTMLElement>('[data-solution-card]')];
  const solutionImages = [...document.querySelectorAll<HTMLElement>('[data-solution-image]')];
  const solutionLabels = [...document.querySelectorAll<HTMLElement>('[data-solution-label]')];
  const solutionsSection = document.querySelector<HTMLElement>('[data-solutions-section]');

  const setActiveSolution = (id: string, intensity = 1) => {
    solutionCards.forEach((card) => {
      card.classList.toggle('is-active', card.dataset.solutionCard === id);
    });

    solutionImages.forEach((image) => {
      const isActive = image.dataset.solutionImage === id;
      image.classList.toggle('is-active', isActive);
      image.style.setProperty('--solution-image-opacity', isActive ? intensity.toFixed(3) : '0');
      image.style.setProperty('--solution-image-scale', isActive ? (0.985 + intensity * 0.015).toFixed(3) : '0.985');
    });

    solutionLabels.forEach((label) => {
      const isActive = label.dataset.solutionLabel === id;
      label.classList.toggle('is-active', isActive);
      label.style.setProperty('--solution-label-opacity', isActive ? intensity.toFixed(3) : '0');
    });
  };

  if (solutionsSection && solutionCards.length > 0) {
    const reduceSolutionsMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const ease = (value: number) => value * value * (3 - 2 * value);
    const clamp = (value: number, min = 0, max = 1) => Math.min(max, Math.max(min, value));
    let solutionTicking = false;

    const updateSolutions = () => {
      solutionTicking = false;

      if (window.innerWidth < 1024 || reduceSolutionsMotion) {
        solutionCards.forEach((card) => {
          card.classList.add('is-active');
          card.style.removeProperty('--solution-card-opacity');
        });
        setActiveSolution(solutionCards[0]?.dataset.solutionCard ?? '', 1);
        return;
      }

      const scrollable = Math.max(1, solutionsSection.offsetHeight - window.innerHeight);
      const rawProgress = clamp((window.scrollY - solutionsSection.offsetTop) / scrollable);
      const startPause = 0.08;
      const endPause = 0.06;
      const progress = clamp((rawProgress - startPause) / (1 - startPause - endPause));
      const maxIndex = Math.max(1, solutionCards.length - 1);
      const revealWindow = 0.07;
      let activeId = solutionCards[0]?.dataset.solutionCard ?? '';
      let activeIntensity = 0;
      let activeVisualOpacity = 0;

      solutionCards.forEach((card, index) => {
        const center = index / maxIndex;
        const distance = Math.abs(progress - center);
        const intensity = ease(clamp(1 - distance / revealWindow));
        const textOpacity = progress <= center
          ? (distance <= revealWindow ? 1 : 0)
          : ease(clamp(1 - (progress - center) / revealWindow));

        card.style.setProperty('--solution-card-opacity', textOpacity.toFixed(3));
        card.classList.toggle('is-active', textOpacity > 0.56);
        card.setAttribute('aria-hidden', textOpacity > 0.18 ? 'false' : 'true');

        if (intensity > activeIntensity) {
          activeIntensity = intensity;
          activeVisualOpacity = textOpacity;
          activeId = card.dataset.solutionCard ?? activeId;
        }
      });

      setActiveSolution(activeId, activeVisualOpacity);
    };

    const requestSolutionsUpdate = () => {
      if (solutionTicking) return;
      solutionTicking = true;
      window.requestAnimationFrame(updateSolutions);
    };

    updateSolutions();
    window.addEventListener('scroll', requestSolutionsUpdate, { passive: true });
    window.addEventListener('resize', requestSolutionsUpdate, { passive: true });
  }

  const methodSection = document.querySelector<HTMLElement>('[data-method-section]');
  const methodFrame = document.querySelector<HTMLElement>('.method-sticky');
  const methodSteps = [...document.querySelectorAll<HTMLElement>('[data-method-step]')];
  const methodTitle = document.querySelector<HTMLElement>('[data-method-title]');
  const methodTitleLines = [...document.querySelectorAll<HTMLElement>('[data-method-title-line]')];
  const methodStepTitles = [...document.querySelectorAll<HTMLElement>('[data-method-step-title]')];
  const reduceMethodMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Cache section geometry, updated on resize, not on every scroll frame
  let sectionTop = 0;
  let sectionHeight = 0;
  const cacheSectionRect = () => {
    if (!methodSection) return;
    sectionTop = methodSection.offsetTop;
    sectionHeight = methodSection.offsetHeight;
  };

  const fitMethodTitle = () => {
    if (!methodTitle) return;
    methodTitle.style.setProperty('--method-title-fit', '1');
    let fit = 1;

    while (methodTitle.scrollWidth > methodTitle.clientWidth && fit > 0.52) {
      fit -= 0.02;
      methodTitle.style.setProperty('--method-title-fit', fit.toFixed(2));
    }
  };

  const fitMethodStepTitles = () => {
    if (methodStepTitles.length === 0) return;

    document.documentElement.style.setProperty('--method-step-title-fit', '1');
    let fit = 1;

    while (
      methodStepTitles.some((title) => title.scrollWidth > title.clientWidth) &&
      fit > 0.5
    ) {
      fit -= 0.02;
      document.documentElement.style.setProperty('--method-step-title-fit', fit.toFixed(2));
    }
  };

  const updateMethodSteps = () => {
    if (!methodSection || methodSteps.length === 0 || reduceMethodMotion) return;

    const hideMethodSequence = () => {
      methodTitle?.style.setProperty('--method-title-opacity', '0');

      methodTitleLines.forEach((line) => {
        line.style.setProperty('--method-line-opacity', '0');
        line.style.setProperty('--method-line-x', '0px');
        line.style.setProperty('--method-line-y', '0px');
        line.style.setProperty('--method-line-scale', '1');
        line.style.setProperty('--method-line-accent', '0%');
      });

      methodSteps.forEach((step) => {
        step.style.setProperty('--method-step-opacity', '0');
        step.style.setProperty('--method-step-x', '0vw');
        step.style.setProperty('--method-step-y', '5.5rem');
        step.style.setProperty('--method-step-focus', '0%');
        step.setAttribute('aria-hidden', 'true');
      });
    };

    if (methodSection.getBoundingClientRect().top > 0) {
      hideMethodSequence();
      return;
    }

    const scrollable = Math.max(1, sectionHeight - window.innerHeight);
    const sectionProgress = (window.scrollY - sectionTop) / scrollable;
    const rawProgress = Math.min(1, Math.max(0, sectionProgress));
    const ease = (value: number) => value * value * (3 - 2 * value);
    const clamp = (value: number, min = 0, max = 1) => Math.min(max, Math.max(min, value));
    const entryDelay = 0;
    const methodProgress = clamp((rawProgress - entryDelay) / (1 - entryDelay));
    const titleSequenceEnd = 0.28;
    const stepSequenceStart = 0.36;
    const stepSequenceEnd = 0.92;
    const titleFadeStart = 0.925;
    const titleFadeEnd = 0.965;
    const lineWindow = titleSequenceEnd / Math.max(1, methodTitleLines.length);
    const stepsEnabled = methodProgress >= stepSequenceStart;
    const stepsProgress = clamp((methodProgress - stepSequenceStart) / (stepSequenceEnd - stepSequenceStart));
    const timeline = stepsProgress * methodSteps.length;
    const titleFade = 1 - ease(clamp((methodProgress - titleFadeStart) / (titleFadeEnd - titleFadeStart)));

    if (methodTitle) {
      if (sectionProgress < 0 || rawProgress < entryDelay) {
        hideMethodSequence();
        return;
      }

      methodTitle.style.setProperty('--method-title-opacity', titleFade.toFixed(3));
    }

    const titleRect = methodTitle?.getBoundingClientRect();
    const navHeight = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--nav-height')) || 0;
    const frameRect = methodFrame?.getBoundingClientRect();
    const frameStyle = methodFrame ? getComputedStyle(methodFrame) : null;
    const framePaddingLeft = frameStyle ? parseFloat(frameStyle.paddingLeft) || 0 : 0;
    const framePaddingRight = frameStyle ? parseFloat(frameStyle.paddingRight) || 0 : 0;
    const heroLeft = frameRect ? frameRect.left + framePaddingLeft : Math.max(16, titleRect?.left ?? 0);
    const heroRight = frameRect ? frameRect.right - framePaddingRight : window.innerWidth - heroLeft;
    const heroSafeInset = clamp(window.innerWidth * 0.03, 18, 48);
    const heroInnerLeft = heroLeft + heroSafeInset;
    const heroInnerRight = heroRight - heroSafeInset;
    const heroAvailableWidth = Math.max(1, heroInnerRight - heroInnerLeft);
    const heroCenterX = heroInnerLeft + heroAvailableWidth / 2;
    const getLineTextWidth = (line: HTMLElement) => {
      return Math.max(1, line.offsetWidth || line.scrollWidth);
    };
    const heroReferenceLine = methodTitleLines[methodTitleLines.length - 1] ?? methodTitleLines[0];
    const heroReferenceWidth = heroReferenceLine ? getLineTextWidth(heroReferenceLine) : 1;
    const sharedHeroScale = heroAvailableWidth / heroReferenceWidth;

    methodTitleLines.forEach((line, index) => {
      const local = (methodProgress - index * lineWindow) / lineWindow;
      const lineWidth = getLineTextWidth(line);
      const lineHeight = Math.max(1, line.offsetHeight);
      const lineLeft = line.offsetLeft;
      const lineTop = (titleRect?.top ?? 0) + line.offsetTop;
      const heroScale = sharedHeroScale;
      const heroX = heroCenterX - (lineWidth * heroScale) / 2 - lineLeft;
      const heroY = navHeight + (window.innerHeight - navHeight - lineHeight * heroScale) / 2 - lineTop;
      const finalY = -index * lineHeight * 0.34;
      let opacity = 0;
      let travel = 1;
      let scale = heroScale;
      let accent = 0;

      if (local >= 0 && local < 0.3) {
        opacity = 1;
        travel = 1;
        scale = heroScale;
        accent = 0;
      } else if (local >= 0.3 && local < 0.44) {
        opacity = 1;
        travel = 1;
        scale = heroScale;
        accent = 0;
      } else if (local >= 0.44 && local < 0.76) {
        opacity = 1;
        travel = 1;
        scale = heroScale;
        accent = 0;
      } else if (local >= 0.76 && local < 1) {
        const settle = ease((local - 0.76) / 0.24);
        opacity = 1;
        travel = 1 - settle;
        scale = heroScale + (0.66 - heroScale) * settle;
        accent = 0;
      } else if (local >= 1) {
        opacity = 1;
        travel = 0;
        scale = 0.66;
        accent = ease(clamp((local - 1) / 0.12));
      }

      line.style.setProperty('--method-line-opacity', opacity.toFixed(3));
      line.style.setProperty('--method-line-x', `${(heroX * travel).toFixed(1)}px`);
      line.style.setProperty('--method-line-y', `${(heroY * travel + finalY * (1 - travel)).toFixed(1)}px`);
      line.style.setProperty('--method-line-scale', scale.toFixed(3));
      line.style.setProperty('--method-line-accent', `${Math.round(accent * 100)}%`);
    });

    methodSteps.forEach((step, index) => {
      const local = stepsEnabled ? timeline - index : -1;
      let opacity = 0;
      let translateX = 0;
      let translateY = 5.5;
      let focus = 0;

      if (local >= 0 && local < 0.18) {
        const progress = ease(local / 0.18);
        opacity = progress;
        translateX = 0;
        translateY = 5.5 * (1 - progress);
        focus = progress;
      } else if (local >= 0.18 && local < 0.76) {
        opacity = 1;
        translateX = 0;
        translateY = 0;
        focus = 1;
      } else if (local >= 0.76 && local < 0.92) {
        const progress = ease((local - 0.76) / 0.16);
        opacity = 1 - progress;
        translateX = -46 * progress;
        translateY = 0;
        focus = 1;
      } else {
        opacity = 0;
        translateX = local < 0 ? 0 : -46;
        translateY = local < 0 ? 5.5 : 0;
        focus = local < 0 ? 0 : 1;
      }

      const active = opacity > 0.5;

      step.style.setProperty('--method-step-opacity', opacity.toFixed(3));
      step.style.setProperty('--method-step-x', `${translateX.toFixed(1)}vw`);
      step.style.setProperty('--method-step-y', `${translateY.toFixed(2)}rem`);
      step.style.setProperty('--method-step-focus', `${Math.round(focus * 100)}%`);
      step.setAttribute('aria-hidden', String(!active));
    });
  };

  let methodTicking = false;
  const requestMethodUpdate = () => {
    if (methodTicking) return;
    methodTicking = true;
    window.requestAnimationFrame(() => {
      updateMethodSteps();
      methodTicking = false;
    });
  };

  // On resize: refresh geometry cache + fit titles, then update steps
  const onResize = () => {
    cacheSectionRect();
    fitMethodTitle();
    fitMethodStepTitles();
    requestMethodUpdate();
  };

  cacheSectionRect();
  fitMethodTitle();
  fitMethodStepTitles();
  updateMethodSteps();

  window.addEventListener('scroll', requestMethodUpdate, { passive: true });
  window.addEventListener('resize', onResize);

  if ('ResizeObserver' in window && methodTitle) {
    new ResizeObserver(onResize).observe(methodTitle);
  }
</script>
