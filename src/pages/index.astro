---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="LIBERA Studio"
  description="Sitios web, automatizaciones, agentes de IA e integraciones que conectan tu presencia online con la operación real de tu negocio. Mérida, México."
>

  <!-- ═══════════════════════════════════════════════════════════════════
       1. HERO — Full-bleed dark, A como núcleo visual
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="hero"
    class="relative flex flex-col justify-end min-h-[100dvh] overflow-hidden"
    style="background: var(--ink);"
    aria-label="Hero"
  >
    <!-- Radial ambient glow — orange -->
    <div
      class="absolute pointer-events-none select-none"
      style="
        top: -10%; right: -5%;
        width: 70vw; height: 70vw;
        max-width: 800px; max-height: 800px;
        background: radial-gradient(ellipse at center, var(--orange-glow) 0%, transparent 65%);
        filter: blur(60px);
        will-change: transform;
      "
      aria-hidden="true"
    ></div>

    <!-- Subtle grid texture -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="
        background-image:
          linear-gradient(oklch(96% 0.005 60 / 0.03) 1px, transparent 1px),
          linear-gradient(90deg, oklch(96% 0.005 60 / 0.03) 1px, transparent 1px);
        background-size: 80px 80px;
      "
      aria-hidden="true"
    ></div>

    <!-- Giant A — system nucleus: layered strokes, nodes, connections -->
    <div
      class="hero-a absolute pointer-events-none select-none hidden sm:block"
      style="right: clamp(-3rem, 2vw, 5rem); top: 50%; width: min(46vw, 620px); aspect-ratio: 10 / 11;"
      aria-hidden="true"
    >
      <svg viewBox="0 0 400 440" fill="none" class="w-full h-full" aria-hidden="true">
        <defs>
          <linearGradient id="heroAGrad" x1="200" y1="80" x2="200" y2="440" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="oklch(70% 0.17 48)" />
            <stop offset="55%" stop-color="oklch(66% 0.16 48 / 0.5)" />
            <stop offset="100%" stop-color="oklch(66% 0.16 48 / 0.06)" />
          </linearGradient>
        </defs>

        <!-- depth echoes -->
        <path d="M16 444 L200 8 L384 444" stroke="oklch(96% 0.005 60 / 0.045)" stroke-width="1.5" />
        <path d="M52 444 L200 52 L348 444" stroke="oklch(96% 0.005 60 / 0.08)" stroke-width="1.5" />

        <!-- main A -->
        <path d="M88 444 L200 96 L312 444" stroke="url(#heroAGrad)" stroke-width="2" />
        <!-- crossbar -->
        <line x1="140" y1="330" x2="260" y2="330" stroke="oklch(96% 0.005 60 / 0.25)" stroke-width="1.5" />

        <!-- radiating system connections -->
        <line x1="200" y1="96" x2="330" y2="36" stroke="oklch(96% 0.005 60 / 0.12)" stroke-width="1" stroke-dasharray="2 7" />
        <line x1="200" y1="96" x2="86" y2="44" stroke="oklch(96% 0.005 60 / 0.09)" stroke-width="1" stroke-dasharray="2 7" />
        <line x1="260" y1="330" x2="368" y2="300" stroke="oklch(96% 0.005 60 / 0.09)" stroke-width="1" stroke-dasharray="2 7" />

        <!-- nodes -->
        <circle cx="200" cy="96" r="5" fill="var(--orange)" class="hero-a-node" />
        <circle cx="330" cy="36" r="2.5" fill="oklch(96% 0.005 60 / 0.4)" />
        <circle cx="86" cy="44" r="2" fill="oklch(96% 0.005 60 / 0.3)" />
        <circle cx="140" cy="330" r="3" fill="oklch(96% 0.005 60 / 0.45)" />
        <circle cx="260" cy="330" r="3" fill="oklch(96% 0.005 60 / 0.45)" />
        <circle cx="368" cy="300" r="2.5" fill="oklch(96% 0.005 60 / 0.35)" />
      </svg>
    </div>

    <!-- Content -->
    <div class="container-libera relative z-10 pb-20 pt-40">

      <!-- Eyebrow — 1 of max 3 on page -->
      <span class="eyebrow block mb-6" style="color: var(--orange); font-family: var(--font-mono);" data-reveal>
        Estudio de sistemas digitales — Mérida, MX
      </span>
      <!-- Headline -->
      <h1
        class="display-hero mb-8 max-w-5xl"
        style="color: var(--text-light);"
        data-reveal
      >
        Construimos los sistemas que
        <span style="color: var(--orange);">liberan</span> a tu negocio del caos.
      </h1>

      <!-- Subheadline -->
      <p
        class="mb-12 max-w-2xl text-lg leading-relaxed"
        style="color: var(--text-light); transition-delay: 110ms;"
        data-reveal
      >
        Sitios web, automatizaciones, agentes de IA e integraciones que conectan
        tu presencia online con la operación real de tu empresa. Diseñados para
        funcionar — y para que no dependas de nadie, ni siquiera de nosotros.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-start gap-4" style="transition-delay: 220ms;" data-reveal>
        <a href="/diagnostico" class="btn btn-primary text-base">
          Solicitar diagnóstico
          <span class="btn-icon" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M1 9L9 1M9 1H2M9 1v7"/>
            </svg>
          </span>
        </a>
        <a href="#metodo" class="btn btn-ghost-dark text-base">
          Cómo trabajamos
          <span aria-hidden="true">↓</span>
        </a>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div
      class="hidden md:flex absolute bottom-10 left-1/2 -translate-x-1/2 flex-col items-center gap-2"
      aria-hidden="true"
    >
      <div class="w-px h-12 overflow-hidden" style="background: oklch(26% 0.01 25);">
        <div
          class="w-full h-1/2"
          style="
            background: var(--orange);
            animation: scrollDrop 1.8s var(--ease-out-expo) infinite;
          "
        ></div>
      </div>
      <span class="eyebrow" style="color: oklch(38% 0.008 25); writing-mode: vertical-rl;">scroll</span>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       2. PROBLEMA — Full-bleed light, testo grande
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="problema"
    style="background: var(--surface);"
    class="py-32 lg:py-40"
    aria-label="El problema que resolvemos"
  >
    <div class="container-libera">
      <div class="max-w-4xl" data-reveal>
        <p class="section-label mb-10" style="color: var(--text-secondary);">
          <span style="color: var(--orange);">01</span> El problema
        </p>
        <h2 class="display-xl mb-10" style="color: var(--text-primary);">
          Tu negocio no necesita más herramientas.
          <span style="color: var(--text-secondary);"> Necesita un sistema.</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-8 mt-12">
          <div>
            <p class="text-lg leading-relaxed" style="color: var(--text-secondary);">
              Una web que no convierte. Mensajes de WhatsApp sin seguimiento. Clientes que preguntan y desaparecen.
              Información repartida entre Excel, notas y memoria. No es falta de tecnología —
              es falta de conexión entre las piezas.
            </p>
          </div>
          <div>
            <p class="text-lg leading-relaxed" style="color: var(--text-secondary);">
              Nosotros conectamos esas piezas para que tu negocio opere con claridad,
              y tú recuperes el tiempo que hoy se pierde en fricción.
            </p>
          </div>
        </div>
      </div>

      <!-- Pain point list -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px mt-16" style="background: var(--border);" data-reveal>
        {[
          'Te buscan en Google y no te encuentran — o no convences.',
          'Respondes tarde, a mano y sin registro de nada.',
          'Adoptaste herramientas que nadie en tu equipo usa.',
        ].map((text, i) => (
          <div class="flex items-start gap-5 p-8" style="background: var(--surface);">
            <span
              class="flex-shrink-0 text-xs font-mono mt-1"
              style="color: var(--orange); font-family: var(--font-mono); letter-spacing: 0.1em;"
              aria-hidden="true"
            >0{i + 1}</span>
            <p class="text-base leading-relaxed" style="color: var(--text-secondary);">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       3. SOLUCIONES — Full-bleed con 4 bloques colorati
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="soluciones"
    style="background: var(--surface-alt);"
    class="py-28 lg:py-36"
    aria-label="Nuestras soluciones"
  >
    <div class="container-libera">
      <div class="max-w-3xl mb-16" data-reveal>
        <p class="section-label mb-8" style="color: var(--text-secondary);">
          <span style="color: var(--orange);">02</span> Soluciones
        </p>
        <h2 class="display-lg" style="color: var(--text-primary);">
          Diseñamos la infraestructura digital que conecta presencia, operación e inteligencia.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          {
            id: 'presencia',
            label: 'Presencia Digital',
            promise: 'Para que te encuentren, te entiendan y te elijan.',
            description: 'Sitios web, landing pages, Google Business Profile, WhatsApp Business y SEO local. Tu primera impresión, trabajando 24/7.',
            href: '/soluciones/presencia-digital',
            accent: 'var(--presencia)',
            services: ['Sitios web premium', 'Landing pages', 'SEO local', 'Google Business'],
          },
          {
            id: 'operacion',
            label: 'Operación Inteligente',
            promise: 'Para operar con orden, no con memoria.',
            description: 'PAOS, CRM simple, dashboards internos y automatización de procesos. Cada mensaje, lead y tarea en su lugar.',
            href: '/soluciones/operacion-inteligente',
            accent: 'var(--operacion)',
            services: ['PAOS', 'CRM y leads', 'Dashboards', 'Integraciones'],
          },
          {
            id: 'ai',
            label: 'AI & Automation',
            promise: 'IA aplicada a procesos reales, no a demos.',
            description: 'Agentes de IA, asistentes internos, clasificación de mensajes y flujos con n8n. Automatizamos donde hay fricción, no donde hay moda.',
            href: '/soluciones/ai-automation',
            accent: 'var(--ai)',
            services: ['Agentes de IA', 'Asistentes internos', 'n8n & APIs', 'Automatización documental'],
          },
          {
            id: 'productos',
            label: 'Productos Digitales',
            promise: 'Herramientas que tu equipo realmente usa.',
            description: 'Web apps, MVPs, paneles administrativos y prototipos funcionales. Del problema al producto, sin años de desarrollo.',
            href: '/soluciones/productos-digitales',
            accent: 'var(--productos)',
            services: ['Web apps', 'MVPs', 'Apps internas', 'Prototipos'],
          },
        ].map((sol, i) => (
          <a
            href={sol.href}
            class="group relative flex flex-col justify-between p-8 lg:p-10 rounded-3xl overflow-hidden transition-all duration-300 hover:-translate-y-0.5"
            data-reveal
            style={`background: var(--surface); border: 1px solid var(--border); transition-delay: ${i * 90}ms;`}
          >
            <!-- Hover glow -->
            <div
              class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
              style={`background: radial-gradient(ellipse at top left, ${sol.accent}14 0%, transparent 60%);`}
              aria-hidden="true"
            ></div>
            <!-- Accent hairline — top, draws on hover -->
            <div
              class="absolute top-0 left-0 right-0 h-[2px] origin-left scale-x-0 group-hover:scale-x-100 pointer-events-none"
              style={`background: ${sol.accent}; transition: transform 0.45s var(--ease-premium);`}
              aria-hidden="true"
            ></div>
            <!-- Ghost index numeral -->
            <span
              class="absolute -top-3 right-6 font-display select-none pointer-events-none"
              style={`font-family: var(--font-display); font-size: 5.5rem; font-weight: 700; line-height: 1; color: ${sol.accent}; opacity: 0.09;`}
              aria-hidden="true"
            >0{i + 1}</span>

            <div class="relative">
              <!-- Color dot + label -->
              <div class="flex items-center gap-3 mb-6">
                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background: ${sol.accent};`} aria-hidden="true"></span>
                <span class="text-xs font-semibold tracking-widest uppercase" style={`color: ${sol.accent};`}>
                  {sol.label}
                </span>
              </div>

              <h3
                class="font-display text-2xl mb-4"
                style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.01em; line-height: 1.15; color: var(--text-primary);"
              >
                {sol.promise}
              </h3>

              <p class="text-base leading-relaxed mb-8" style="color: var(--text-secondary);">
                {sol.description}
              </p>

              <!-- Service tags -->
              <div class="flex flex-wrap gap-2">
                {sol.services.map((s) => (
                  <span
                    class="text-xs px-3 py-1 rounded-full"
                    style="background: var(--surface-alt); color: var(--text-secondary); border: 1px solid var(--border);"
                  >
                    {s}
                  </span>
                ))}
              </div>
            </div>

            <!-- Arrow -->
            <div class="relative mt-8 flex items-center gap-2" style={`color: ${sol.accent};`}>
              <span class="text-sm font-medium">Ver solución</span>
              <span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       4. MÉTODO — Editorial Split, sfondo scuro
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="metodo"
    data-method-section
    style="background: linear-gradient(to bottom, var(--ink-mid) 0, var(--ink-mid) calc(100% - 90dvh), transparent calc(100% - 90dvh), transparent 100%);"
    class="method-scroll"
    aria-label="Nuestro método"
  >
    <div class="container-libera method-sticky">
      <div class="method-layout">

        <!-- Left: sticky -->
        <div class="method-copy">
          <h2
            class="font-display method-title mb-8"
            data-method-title
            style="
              font-family: var(--font-display);
              font-weight: 700;
              letter-spacing: 0.015em;
            "
          >
            <span class="method-title-line" data-method-title-line><span>Primero </span><span class="method-title-action">ordenamos</span><span>.</span></span>
            <span class="method-title-line" data-method-title-line><span>Después </span><span class="method-title-action">diseñamos</span><span>.</span></span>
            <span class="method-title-line" data-method-title-line><span>Luego </span><span class="method-title-action">automatizamos</span><span>.</span></span>
          </h2>
        </div>

        <!-- Bottom: steps -->
        <div class="method-stage" data-method-stage>
          {[
            {
              title: 'Diagnóstico',
              description: 'Revisamos cómo te encuentran, cómo respondes y dónde se pierde valor. Sin compromiso y sin jerga.',
              accent: 'var(--presencia)',
            },
            {
              title: 'Arquitectura',
              description: 'Definimos qué construir, en qué orden y por qué. Lo que no aporta, no entra.',
              accent: 'var(--operacion)',
            },
            {
              title: 'Diseño',
              description: 'Claridad antes que decoración. Cada pantalla existe para explicar, convencer o convertir.',
              accent: 'var(--orange)',
            },
            {
              title: 'Desarrollo',
              description: 'Código original, stack moderno, sistemas probados. Nada de templates disfrazados.',
              accent: 'var(--ai)',
            },
            {
              title: 'Integración',
              description: 'Conectamos la solución con tu operación real: WhatsApp, CRM, formularios, analytics.',
              accent: 'var(--productos)',
            },
            {
              title: 'Evolución',
              description: 'Medimos, ajustamos y crecemos el sistema. Un sistema vivo no se entrega: se cultiva.',
              accent: 'var(--operacion)',
            },
          ].map((step) => (
            <div
              class="method-step"
              style={`--step-accent: ${step.accent};`}
              data-method-step
            >
              <h3
                class="font-display mb-4"
                style="font-family: var(--font-display);"
                data-method-step-title
              >
                {step.title}
              </h3>
              <p class="text-base leading-relaxed">
                {step.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       4.5 DIFERENCIADORES — Striscia marquee tra Metodo e Trabajo
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="diferenciadores"
    style="background: var(--ink); border-block: 1px solid var(--border-dark);"
    class="py-7 overflow-hidden"
    aria-label="Lo que nos diferencia"
  >
    <div class="diff-track" aria-hidden="false">
      {[0, 1].map((copy) => (
        <div class="diff-group" aria-hidden={copy === 1 ? 'true' : undefined}>
          {[
            'Código 100% original',
            'Sistemas que puedes mantener sin nosotros',
            'Respuesta en menos de 48h',
            'Construimos antes de prometer',
            'IA en producción, no en diapositivas',
          ].map((claim) => (
            <span class="diff-item">
              <span class="diff-dot" aria-hidden="true"></span>
              {claim}
            </span>
          ))}
        </div>
      ))}
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       5. TRABAJO — Eyebrow 2 di 3, card grid su sfondo chiaro
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="trabajo"
    style="background: var(--surface); background-image: radial-gradient(oklch(10% 0.01 25 / 0.045) 1px, transparent 1px); background-size: 22px 22px;"
    class="py-28"
    aria-label="Nuestro trabajo"
  >
    <div class="container-libera">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16" data-reveal>
        <div>
          <p class="section-label mb-8" style="color: var(--text-secondary);">
            <span style="color: var(--orange);">03</span> Trabajo
          </p>
          <h2 class="display-lg" style="color: var(--text-primary);">
            Construimos para clientes.<br/>
            <span style="color: var(--text-secondary);">También construimos para aprender.</span>
          </h2>
          <p class="text-base leading-relaxed mt-5 max-w-xl" style="color: var(--text-secondary);">
            Cada proyecto — propio o de cliente — es un sistema en producción.
            Esto es lo que construimos y lo que aprendimos construyéndolo.
          </p>
        </div>
        <a
          href="/trabajo"
          class="flex-shrink-0 inline-flex items-center gap-2 text-sm font-medium transition-colors duration-150 hover:opacity-70"
          style="color: var(--text-secondary);"
        >
          Ver todo el trabajo <span aria-hidden="true">→</span>
        </a>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-[1.18fr_0.82fr] gap-px"
        style="background: var(--border); border: 1px solid var(--border);"
      >
        {[
          {
            name: 'Cenote Scout',
            category: 'Producto digital',
            description: 'Plataforma para descubrir cenotes, rutas y experiencias en Yucatán. Sistema de datos, mapas y contenido editorial.',
            stack: ['Astro', 'TypeScript', 'Supabase'],
            status: 'En desarrollo',
            href: '/trabajo/cenote-scout',
            accent: 'var(--presencia)',
          },
          {
            name: 'LIBERA AI Automation',
            category: 'Sistema interno',
            description: 'Infraestructura de agentes y automatizaciones para operación del estudio. Publicación, análisis, CRM y flujos n8n.',
            stack: ['n8n', 'Claude API', 'Airtable'],
            status: 'En producción',
            href: '/trabajo/radar',
            accent: 'var(--ai)',
          },
          {
            name: 'Radio 9999',
            category: 'Producto digital',
            description: 'Infraestructura ligera para transmitir, organizar contenido y crear comunidad en torno a radio y audio.',
            stack: ['Astro', 'Tailwind', 'Edge'],
            status: 'Prototipo activo',
            href: '/trabajo/9999',
            accent: 'var(--orange)',
          },
          {
            name: 'Sole Facile',
            category: 'Cliente',
            description: 'Ecosistema digital para empresa de instalación solar en Italia. Web, contenido, automatizaciones y agente IA.',
            stack: ['WordPress', 'n8n', 'Claude API'],
            status: 'En producción',
            href: '/trabajo/sole-facile',
            accent: 'var(--operacion)',
          },
          {
            name: 'Morozzo Padel',
            category: 'Cliente',
            description: 'Presencia digital y sistema de reservas para club de pádel. Rediseño, SEO local y automatización de comunicación.',
            stack: ['HTML/CSS', 'JS', 'WhatsApp API'],
            status: 'Completado',
            href: '/trabajo/morozzo-padel',
            accent: 'var(--productos)',
          },
          {
            name: 'PAOS Framework',
            category: 'Sistema interno',
            description: 'Sistema operativo de conocimiento para el estudio. Agentes, plantillas, workflows y base de datos estructurada.',
            stack: ['Obsidian', 'n8n', 'Claude API'],
            status: 'En uso activo',
            href: '/trabajo/paos',
            accent: 'var(--presencia)',
          },
        ].map((project, i) => (
          <a
            href={project.href}
            class={`group flex flex-col justify-between transition-all duration-300 hover:-translate-y-0.5 ${i === 0 ? 'p-9 md:p-10 lg:row-span-2' : 'p-7'}`}
            style={`background: var(--surface); min-height: ${i === 0 ? '430px' : '230px'}; transition-delay: ${i * 65}ms;`}
            data-reveal
          >
            <div>
              <div class="flex items-start justify-between gap-4 mb-5">
                <div>
                  <span
                    class="block text-xs font-mono tracking-wider uppercase mb-2"
                    style={`color: ${project.accent}; font-family: var(--font-mono);`}
                  >
                    {project.category}
                  </span>
                  <h3
                    class={`font-display font-semibold ${i === 0 ? 'text-3xl md:text-4xl' : 'text-xl'}`}
                    style="font-family: var(--font-display); color: var(--text-primary);"
                  >
                    {project.name}
                  </h3>
                </div>
                <span
                  class="flex-shrink-0 text-xs px-3 py-1 rounded-full"
                  style="background: var(--surface-alt); color: var(--text-secondary); border: 1px solid var(--border); white-space: nowrap;"
                >
                  {project.status}
                </span>
              </div>

              <p class={`${i === 0 ? 'text-base max-w-xl' : 'text-sm'} leading-relaxed`} style="color: var(--text-secondary);">
                {project.description}
              </p>
            </div>

            <div>
              <div class="flex flex-wrap gap-2 mt-6 mb-4">
                {project.stack.map((tech) => (
                  <span
                    class="text-xs font-mono px-2.5 py-1 rounded-md"
