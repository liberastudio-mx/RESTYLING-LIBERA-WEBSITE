  /* ── Statement bridge ─────────────────────────────────────── */
  /* Contenedor scroll de 820dvh (720 método + 100 dwell).
     El método (z:1) se superpone vía margin-top negativo.
     Al terminar el método, las montañas quedan visibles 100dvh. */
  .statement-wrap {
    height: 720dvh; /* 620dvh método + 100dvh dwell */
    position: relative;
    z-index: 0;
  }

  /* Late mobile overrides — must follow the base rule above in source order */
  @media (max-width: 1023px) {
    .statement-wrap { height: calc(480svh + 100dvh); }
  }
  @media (max-width: 640px) {
    .statement-wrap { height: calc(440svh + 100dvh); }
  }
  @media (prefers-reduced-motion: reduce) {
    .statement-wrap  { height: auto; }
    .statement-dwell { height: 0; display: none; }
  }

  .statement-section {
    position: sticky;
    top: 0;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Espacio visible de montañas (100dvh) entre el fin del método y sol-section */
  .statement-dwell {
    height: 100dvh;
    position: relative;
    z-index: 0;
  }

  .statement-accent {
    color: var(--orange);
  }

  .statement-bg-img {
    position: absolute;
    inset: -3%;
    width: 106%;
    height: 106%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
    filter: blur(5px);
    transform: scale(1.03);
  }

  .statement-overlay {
    position: absolute;
    inset: 0;
    background: oklch(6% 0.02 235 / 0.55);
  }

  .statement-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem clamp(1.5rem, 8vw, 8rem);
    max-width: 100%;
  }

  .statement-heading {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4.5vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: oklch(97% 0.006 70);
    max-width: 18ch;
    margin: 0 auto;
  }

  /* ── Soluciones Acordeon ──────────────────────────────────── */
  .sol-section {
    padding-top: 6rem;
    padding-bottom: 6rem;
    background: var(--surface);
    position: relative;
    z-index: 1;
  }

  .sol-intro {
    max-width: 44rem;
    margin-bottom: 3rem;
  }

  .sol-eyebrow {
    display: inline-block;
