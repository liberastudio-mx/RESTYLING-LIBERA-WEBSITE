---
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import DiagnosticForm from '@/components/DiagnosticForm.astro';

import problemasImg    from '@/assets/images/LS - problemas.png';
import solOperacionImg from '@/assets/images/LS - 2 - operacion inteligente.png';
import solPresenciaImg from '@/assets/images/LS - 2 - presencia digital.png';
import solAiImg        from '@/assets/images/LS - 2 - Ai e automation.png';
import solProductosImg from '@/assets/images/LS - 2 - Productos digitales.png';
import logoCenotesImg  from '@/assets/images/logo cenotes.png';
import logoPaosImg     from '@/assets/images/Logo paos.png';
import logoSoleFacileImg from '@/assets/images/logo sole facile per linkedin.png';
import logoMorozzoImg  from '@/assets/images/logo morozzo.png';
import radarBgImg      from '@/assets/images/LS - Background radar.png';
import radar1Img       from '@/assets/images/LS - radar 1.png';
import radar2Img       from '@/assets/images/LS - radar 2.png';
import radar3Img       from '@/assets/images/LS - radar 3.png';
import radarOpenaiIpoImg from '@/assets/images/LS - radar openai ipo.png';
import radarGeminiMigrationImg from '@/assets/images/LS - radar gemini migration.png';
import heroMountainsImg from '@/assets/images/hero-libera-mountains.png';
import heroLogoImg from '@/assets/images/LIBERA-Logo-white.png';

const solucionesHome = [
  {
    id: 'operacion',
    label: 'Operación Interna',
    promise: 'Para operar con orden, no con memoria.',
    description: 'Second Brain/PAOS, CRM simple, dashboards internos y automatización de procesos. Cada mensaje, lead y tarea en su lugar.',
    href: '/soluciones/operacion-interna/paos',
    accent: '#003049',
    image: solOperacionImg,
    services: [
      { label: 'Second Brain/PAOS', href: '/soluciones/operacion-interna/paos' },
      { label: 'Automatización', href: '/soluciones/operacion-interna/automatizacion' },
      { label: 'CRM y seguimiento', href: '/soluciones/operacion-interna/crm-seguimiento' },
      { label: 'Dashboards', href: '/soluciones/operacion-interna/dashboards' },
      { label: 'Integraciones', href: '/soluciones/operacion-interna/integraciones' },
    ],
  },
  {
    id: 'presencia',
    label: 'Presencia Digital',
    promise: 'Para que te encuentren, te entiendan y te elijan.',
    description: 'Sitios web, landing pages, Google Business Profile, WhatsApp Business y redes sociales. Tu primera impresión, trabajando 24/7.',
    href: '/soluciones/presencia-digital/sitios-web-premium',
    accent: '#d62828',
    image: solPresenciaImg,
    services: [
      { label: 'Sitios web premium', href: '/soluciones/presencia-digital/sitios-web-premium' },
      { label: 'Landing pages', href: '/soluciones/presencia-digital/landing-pages' },
      { label: 'Google Business Profile', href: '/soluciones/presencia-digital/google-business-profile' },
      { label: 'WhatsApp Business', href: '/soluciones/presencia-digital/whatsapp-business' },
      { label: 'Redes sociales', href: '/soluciones/presencia-digital/redes-sociales' },
    ],
  },
  {
    id: 'ai',
    label: 'IA y automatización',
    promise: 'IA aplicada a procesos reales, no a demos.',
    description: 'Agentes de IA, asistentes internos, clasificación de mensajes y flujos con n8n. Automatizamos donde hay fricción.',
    href: '/soluciones/ai-automation/agentes-ia',
    accent: '#f77f00',
    image: solAiImg,
    services: [
      { label: 'Agentes de IA', href: '/soluciones/ai-automation/agentes-ia' },
      { label: 'Asistentes internos', href: '/soluciones/ai-automation/asistentes-internos' },
      { label: 'Flujos con n8n', href: '/soluciones/ai-automation/flujos-n8n' },
      { label: 'Clasificación de mensajes', href: '/soluciones/ai-automation/clasificacion-mensajes' },
      { label: 'Automatización documental', href: '/soluciones/ai-automation/automatizacion-documental' },
    ],
  },
  {
    id: 'productos',
    label: 'Productos Digitales',
    promise: 'Herramientas que tu equipo realmente usa.',
    description: 'Web apps, MVPs, paneles administrativos y prototipos funcionales. Del problema al producto, sin años de desarrollo.',
    href: '/soluciones/productos-digitales/web-apps',
    accent: '#fcbf49',
    image: solProductosImg,
    services: [
      { label: 'Web apps', href: '/soluciones/productos-digitales/web-apps' },
      { label: 'MVPs', href: '/soluciones/productos-digitales/mvps' },
      { label: 'Apps internas', href: '/soluciones/productos-digitales/apps-internas' },
      { label: 'Paneles admin', href: '/soluciones/productos-digitales/paneles-admin' },
      { label: 'Prototipos', href: '/soluciones/productos-digitales/prototipos' },
    ],
  },
];
---

<Layout
  title="LIBERA Studio — Estudio de sistemas digitales"
  description="Sitios web, automatizaciones, agentes de IA e integraciones que conectan tu presencia online con la operación real de tu negocio. Mérida, México."
>

  <!-- 1. HERO -->
  <div class="hero-pin-stage">
  <section
    id="hero"
    data-header-theme="dark"
    class="hero-panel relative flex flex-col justify-center min-h-[100dvh] overflow-hidden"
    style="background: #001824; user-select: none; -webkit-user-select: none;"
    aria-label="Hero"
  >
    <!-- Mountain background image -->
    <Image
      src={heroMountainsImg}
      alt=""
      aria-hidden="true"
      widths={[800, 1440, 1920]}
      sizes="100vw"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      style="z-index: 0;"
    />

    <!-- Hero content — sits between mountain (z-0) and canvas mask (z-2) -->
    <div
      class="hero-content-reveal absolute inset-0 flex flex-col items-center justify-center text-center px-6"
      style="z-index: 1;"
    >
      <Image
        src={heroLogoImg}
        alt="LIBERA Studio"
        width={858}
        height={160}
        class="hero-logo mb-8"
        loading="eager"
        style="width: clamp(20rem, 52vw, 64rem); height: auto;"
      />
      <p
        class="mb-10 leading-relaxed"
        style="color: rgba(255,255,255,0.88); font-size: clamp(1.05rem, 1.8vw, 1.5rem); max-width: 36rem;"
      >
        Menos tareas repetitivas. M&aacute;s negocio funcionando.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="#diagnostico" class="btn btn-primary">
          Cu&eacute;ntame tu proyecto
          <span class="btn-icon" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <!-- Ink-reveal canvas mask — sits on top of content and mountain (z-2) -->
    <canvas
      id="hero-ink-canvas"
      aria-hidden="true"
      style="position: absolute; inset: 0; width: 100%; height: 100%; z-index: 2; pointer-events: none;"
    ></canvas>

    <!-- Hint: fades out on first interaction -->
    <div id="hero-hint" aria-hidden="true" style="position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 0.6rem; pointer-events: none; transition: opacity 0.6s ease; white-space: nowrap;">
      <div class="hero-hint-ring"></div>
      <span class="hero-hint-mouse hero-hint-label">Mueve el cursor</span>
      <span class="hero-hint-touch hero-hint-label">Toca para liberar</span>
    </div>

  </section>
  </div>


  <!-- 2. PROBLEMA -->
  <div class="problem-pin-stage">
  <section
    id="problema"
    data-header-theme="light"
    style="background: #ffffff;"
    class="problem-overlap"
    aria-label="El problema que resolvemos"
  >
    <!-- Left: text + stats -->
    <div class="problem-left" data-reveal>
      <div class="problem-content">
        <h2 class="problem-title mb-6" style="color: var(--text-primary);">
          Tecnología que se integra a <em style="color: var(--orange); font-style: italic;">tu forma de trabajar.</em>
        </h2>
        <p class="problem-body mb-4" style="color: var(--text-secondary);">
          Una buena web, un WhatsApp bien configurado y procesos claros pueden cambiar la manera en que un negocio atiende, vende y crece.
        </p>
        <p class="problem-body" style="color: var(--text-secondary);">
          LIBERA diseña sistemas digitales simples, conectados y útiles: pensados para que tu equipo los use de verdad.
        </p>
      </div>

      <div class="problem-mobile-visual">
        <Image
          src={problemasImg}
          alt="Sistemas digitales integrados"
          widths={[400, 720]}
          sizes="100vw"
          loading="lazy"
        />
      </div>

      <div class="problem-stats">
        {[
          {
            value: '31%',
            text: 'de reducción en costos de TI atribuidos a automatización inteligente.',
            source: 'IBM Institute for Business Value',
          },
          {
            value: '0.5–3.4 pts',
            text: 'de crecimiento anual de productividad podrían venir de IA generativa y automatización.',
            source: 'McKinsey',
          },
          {
            value: '2.6x',
            text: 'más citas reportó Farmacias del Ahorro usando WhatsApp Flows.',
            source: 'WhatsApp Business',
          },
          {
            value: '51%',
            text: 'más interacciones reportó Banco Ciudad usando WhatsApp Business Platform.',
            source: 'WhatsApp Business',
          },
        ].map((stat) => (
          <div class="problem-stat">
            <p class="problem-stat-value font-display" style="font-family: var(--font-display);">{stat.value}</p>
            <p class="problem-stat-text">{stat.text}</p>
            <p class="problem-stat-source">Fuente: {stat.source}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: image full height -->
    <div class="problem-right">
      <Image
        src={problemasImg}
        alt="Sistemas digitales integrados"
        widths={[720, 1080]}
        sizes="50vw"
        loading="lazy"
        class="problem-img"
      />
    </div>
  </section>
  </div>

  <!-- STATEMENT — montañas fijas; el método (z:1) actúa como cortina blanca encima -->
  <div class="statement-wrap">
    <section class="statement-section" aria-label="Diseñamos los sistemas que conectan presencia, operación e inteligencia.">
      <Image
        src={heroMountainsImg}
        alt=""
        widths={[800, 1400, 2000]}
        sizes="100vw"
        class="statement-bg-img"
        loading="lazy"
      />
      <div class="statement-overlay" aria-hidden="true"></div>
      <div class="statement-content">
        <p class="statement-heading">
          Diseñamos los sistemas que conectan <span class="statement-accent">presencia</span>, <span class="statement-accent">operación</span> e <span class="statement-accent">inteligencia</span>.
        </p>
      </div>
    </section>
  </div>

  <!-- 3. METODO -->
  <section
    id="metodo"
    data-header-theme="light"
    data-method-clone-section
    class="method-clone-scroll"
    aria-label="Nuestro método"
  >
    <div class="container-libera method-clone-sticky">
      <div class="method-clone-layout">
        <div class="method-clone-copy">
          <h2
            class="font-display method-clone-title mb-8"
            data-method-clone-title
            style="
              font-family: var(--font-display);
              font-weight: 700;
              letter-spacing: 0.015em;
            "
          >
            <span class="method-clone-title-line" data-method-clone-title-line><span>Primero </span><span class="method-clone-title-action">ordenamos</span><span>.</span></span>
            <span class="method-clone-title-line" data-method-clone-title-line><span>Después </span><span class="method-clone-title-action">diseñamos</span><span>.</span></span>
            <span class="method-clone-title-line" data-method-clone-title-line><span>Luego </span><span class="method-clone-title-action">automatizamos</span><span>.</span></span>
          </h2>
        </div>

        <div class="method-clone-stage" data-method-clone-stage>
          {[
            {
              title: 'Diagnóstico',
              description: 'Revisamos cómo te encuentran, cómo respondes y dónde se pierde valor. Sin compromiso y sin jerga.',
              accent: 'var(--presencia)',
            },
            {
              title: 'Arquitectura',
              description: 'Definimos qué construir, en qué orden y por qué. Lo que no aporta, no entra.',
              accent: 'var(--operacion)',
            },
            {
              title: 'Diseño',
              description: 'Claridad antes que decoración. Cada pantalla existe para explicar, convencer o convertir.',
              accent: 'var(--orange)',
            },
            {
              title: 'Desarrollo',
              description: 'Código original, stack moderno, sistemas probados. Nada de templates disfrazados.',
              accent: 'var(--ai)',
            },
            {
              title: 'Integración',
              description: 'Conectamos la solución con tu operación real: WhatsApp, CRM, formularios, analytics.',
              accent: 'var(--productos)',
            },
            {
              title: 'Evolución',
              description: 'Medimos, ajustamos y crecemos el sistema. Un sistema vivo no se entrega: se cultiva.',
              accent: 'var(--operacion)',
            },
          ].map((step) => (
            <div
              class="method-clone-step"
              style={`--step-accent: ${step.accent};`}
              data-method-clone-step
            >
              <h3
                class="font-display mb-4"
                style="font-family: var(--font-display);"
                data-method-clone-step-title
              >
                {step.title}
              </h3>
              <p class="text-base leading-relaxed">
                {step.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Dwell 100dvh: espacio visible de montañas después que termina el método -->
  <div class="statement-dwell" aria-hidden="true"></div>

  <!-- 4. SOLUCIONES -->
  <section
    id="soluciones"
    data-header-theme="light"
    class="sol-section"
    aria-label="Nuestras soluciones"
  >
    <div class="container-libera">

      <div class="sol-accordion" role="list" aria-label="Soluciones">
        {solucionesHome.map((sol, i) => (
          <div class="sol-row" role="listitem" style={`--accent: ${sol.accent};`}>
            <button
              class:list={['sol-trigger', { 'is-open': i === 0 }]}
              type="button"
              aria-expanded={i === 0 ? 'true' : 'false'}
              data-sol-trigger
            >
              <span class="sol-trigger-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="sol-trigger-label">{sol.label}</span>
              <span class="sol-trigger-line" aria-hidden="true"></span>
              <span class="sol-trigger-chevron" aria-hidden="true"></span>
            </button>
            <div class:list={['sol-panel', { 'is-open': i === 0 }]} data-sol-panel>
              <div class="sol-panel-inner">
                <div class="sol-panel-layout">
                  <div class="sol-panel-img-wrap">
                    <Image
                      src={sol.image}
                      alt={sol.label}
                      widths={[800, 1400]}
                      sizes="(max-width: 767px) 100vw, 60vw"
                      class="sol-panel-img"
                      loading={i === 0 ? 'eager' : 'lazy'}
                    />
                    <div class="sol-panel-img-overlay" aria-hidden="true"></div>
                  </div>
                  <div class="sol-panel-content">
                    <h3 class="sol-panel-promise">{sol.promise}</h3>
                    {sol.description && <p class="sol-panel-desc">{sol.description}</p>}
                    <ul class="sol-panel-services">
                      {sol.services.map((s) => (
                        <li>
                          <a href={s.href} class="sol-panel-service">
                            <span>{s.label}</span>
                            <span aria-hidden="true">→</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- 5. TRABAJO -->
  <div class="work-pin-stage">
  <section
    id="trabajo"
    data-header-theme="light"
    style="background: var(--surface); background-image: radial-gradient(oklch(10% 0.01 25 / 0.045) 1px, transparent 1px); background-size: 22px 22px;"
    class="work-overlap"
    aria-label="Nuestro trabajo"
  >
    <div class="container-libera w-full work-inner">
      <div class="work-header mb-5 flex-shrink-0" data-reveal>
        <div>
          <h2 class="display-md" style="color: var(--text-primary);">
            Construimos para clientes.<br/>
            <em style="color: var(--orange); font-style: italic;">También construimos para aprender.</em>
          </h2>
          <p class="text-sm leading-relaxed mt-3 max-w-xl" style="color: var(--text-secondary);">
            Cada proyecto, propio o de cliente, es un sistema en producción.
          </p>
        </div>
        <a
          href="/trabajo"
          class="work-ver-todo inline-flex items-center gap-2 text-sm font-bold transition-opacity duration-150 hover:opacity-70"
          style="color: var(--orange);"
        >
          Ver todo el trabajo <span aria-hidden="true">→</span>
        </a>
      </div>
      <div
        class="work-card-grid"
        style="background: var(--border); border: 1px solid var(--border); gap: 1px;"
      >
        {[
          {
            name: 'Cenote Scout',
            category: 'Producto digital',
            description: 'Plataforma para descubrir cenotes, rutas y experiencias en Yucatán. Sistema de datos, mapas y contenido editorial.',
            stack: ['Astro', 'TypeScript', 'Supabase'],
            status: 'En desarrollo',
            href: '/trabajo/cenote-scout',
            accent: '#f77f00',
            image: logoCenotesImg,
          },
          {
            name: 'Second Brain/PAOS',
            category: 'Sistema interno',
            description: 'Sistema operativo del estudio: 15 agentes de IA, automatizaciones, vault Obsidian y flujos n8n para operar sin fricción.',
            stack: ['Obsidian', 'Agents', 'Skills'],
            status: 'En producción',
            href: '/trabajo/radar',
            accent: '#fcbf49',
            image: logoPaosImg,
          },
          {
            name: 'Sole Facile',
            category: 'Cliente',
            description: 'Ecosistema digital para empresa de instalación solar en Italia. Web, contenido, automatizaciones y agente IA.',
            stack: ['WordPress', 'n8n', 'Claude API'],
            status: 'En producción',
            href: '/trabajo/sole-facile',
            accent: '#d62828',
            image: logoSoleFacileImg,
          },
          {
            name: 'Morozzo Padel',
            category: 'Cliente',
            description: 'Presencia digital y sistema de reservas para club de pádel. Rediseño, SEO local y automatización de comunicación.',
            stack: ['HTML/CSS', 'JS', 'WhatsApp API'],
            status: 'Completado',
            href: '/trabajo/morozzo-padel',
            accent: '#eae2b7',
            image: logoMorozzoImg,
          },
        ].map((project, i) => (
          <a
            href={project.href}
            class="group relative overflow-hidden flex flex-col justify-between work-card"
            data-reveal
          >
            <Image
              src={project.image}
              alt=""
              aria-hidden="true"
              widths={[400, 700]}
              sizes="(max-width: 1023px) 100vw, 50vw"
              class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out group-hover:scale-105"
              loading="lazy"
            />
            <div
              class="absolute inset-0 transition-opacity duration-500 opacity-0"
              style="background: linear-gradient(to top, rgba(0,20,40,0.92) 0%, rgba(0,20,40,0.65) 50%, rgba(0,20,40,0.3) 100%);"
              aria-hidden="true"
              data-card-overlay
            ></div>
            <div class="relative z-10 flex flex-col justify-end h-full transition-opacity duration-500 opacity-0 group-hover:opacity-100 p-8">
              <h3
                class="font-display font-semibold text-2xl mb-4"
                style="font-family: var(--font-display); color: #ffffff; line-height: 1.2;"
              >
                {project.name}
              </h3>
              <div class="flex items-center justify-between gap-4">
                <div class="flex flex-wrap gap-2">
                  {project.stack.map((tech) => (
                    <span
                      class="text-xs font-mono px-2.5 py-1 rounded-md"
                      style="background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); font-family: var(--font-mono); border: 1px solid rgba(255,255,255,0.1);"
                    >
                      {tech}
                    </span>
                  ))}
                </div>
                <span
                  class="flex-shrink-0 text-2xl font-medium"
                  style="color: #fcbf49;"
                  aria-hidden="true"
                >→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  </div>


  <!-- 6. RADAR -->
  <div class="conocimiento-pin-stage">
  <section
    id="conocimiento"
    data-header-theme="dark"
    aria-label="Radar"
  >
    <div class="conocimiento-half radar-feature" style="background: var(--ink); position: relative; overflow: hidden;">
      <Image
        src={radarBgImg}
        alt=""
        aria-hidden="true"
        widths={[800, 1440, 1920]}
        sizes="100vw"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="lazy"
        style="opacity: 0.35;"
      />
      <div class="absolute inset-0" style="background: rgba(0,20,40,0.72);" aria-hidden="true"></div>

      <div class="container-libera w-full relative z-10">
        <div class="conocimiento-half-grid">

          <!-- Heading -->
          <div data-reveal class="flex flex-col justify-center pr-4" style="padding-block: 2.5rem;">
            <p class="eyebrow mb-3" style="color: #fcbf49; font-family: var(--font-mono);">Radar</p>
            <h2 class="display-lg mb-4" style="color: #ffffff;">
              Blog del equipo
            </h2>
            <p class="text-sm mb-6 leading-relaxed" style="color: oklch(72% 0.025 235);">
              Artículos del equipo. Sí, también escribimos.
            </p>
            <a
              href="/radar"
              class="inline-flex items-center gap-2 text-sm font-medium transition-opacity duration-150 hover:opacity-60 group"
              style="color: #fcbf49;"
            >
              Ver todos los artículos
              <span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
            </a>
          </div>

          <!-- Radar carousel -->
          <div class="radar-gallery" data-radar-gallery>
            <div
              class="radar-scroll-rail"
              data-radar-rail
              role="region"
              aria-label="Artículos destacados del Radar"
              tabindex="0"
            >
            {[
            {
              categoria: 'Dev',
              accent: '#fcbf49',
              pos: 'first',
              title: 'Microsoft lanza 7 modelos MAI: GitHub Copilot ya no depende de OpenAI',
              date: 'Jun 2026',
              read: '4 min',
              href: '/radar/microsoft-mai-modelos-build-2026',
              image: radarGeminiMigrationImg,
            },
            {
              categoria: 'IA',
              accent: '#fcbf49',
              pos: 'mid',
              title: 'Claude Opus 4.8: qué cambió y por qué importa si automatizas procesos',
              date: 'Jun 2026',
              read: '4 min',
              href: '/radar/claude-opus-4-8',
              image: radarOpenaiIpoImg,
            },
            {
              categoria: 'IA',
              accent: '#fcbf49',
              pos: 'last',
              title: 'Claude Fable 5: Anthropic libera su primer modelo de clase Mythos',
              date: 'Jun 2026',
              read: '5 min',
              href: '/radar/claude-fable-5',
              image: radar3Img,
            },
            {
              categoria: 'IA',
              accent: '#fcbf49',
              pos: 'mid',
