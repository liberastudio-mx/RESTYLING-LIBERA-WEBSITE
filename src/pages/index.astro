  /* Radar: one draggable carousel at every viewport size. */
  .radar-gallery {
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .radar-scroll-rail {
    display: flex;
    width: 100%;
    min-width: 0;
    gap: clamp(0.75rem, 1.2vw, 1rem);
    padding: 0 clamp(1.5rem, 4vw, 4rem) 0.75rem 0;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 0;
    scroll-behavior: smooth;
    scrollbar-width: none;
    cursor: grab;
    touch-action: pan-x pan-y pinch-zoom;
    -webkit-overflow-scrolling: touch;
  }

  .radar-scroll-rail::-webkit-scrollbar {
    display: none;
  }

  .radar-scroll-rail.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
    user-select: none;
  }

  .radar-scroll-rail img {
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }

  .radar-scroll-rail .conocimiento-card--dark {
    flex: 0 0 clamp(17rem, 28vw, 23rem);
    min-width: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .radar-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 1.1rem;
    margin-inline: auto;
    width: fit-content;
  }

  .radar-dot {
    width: 0.7rem;
    height: 0.7rem;
    border: 0;
    border-radius: 999px;
    background: color-mix(in srgb, white 72%, var(--text-secondary) 28%);
    cursor: pointer;
    transition:
      transform 0.2s var(--ease-premium),
      background-color 0.2s var(--ease-premium);
  }

  .radar-dot.is-active {
    background: var(--orange);
    transform: scale(1.15);
  }

  .radar-dot:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--orange) 60%, white 40%);
    outline-offset: 2px;
  }

  @media (min-width: 1024px) {
