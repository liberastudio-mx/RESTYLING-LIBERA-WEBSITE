  /* Hero hint: show mouse or touch label depending on pointer */
  .hero-hint-touch { display: none; }
  .hero-hint-mouse { display: block; }

  .hero-hint-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  @media (hover: none) and (pointer: coarse) {
    .hero-hint-mouse { display: none; }
    .hero-hint-touch { display: block; }
    .hero-hint-label {
      font-size: 1rem;
      color: rgba(255,255,255,0.82);
    }
  }

  /* Hero hint ring */
  .hero-hint-ring {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    border: 1.5px solid rgba(255,255,255,0.35);
    animation: hintPulse 2s ease-in-out infinite;
  }

  @media (hover: none) and (pointer: coarse) {
    .hero-hint-ring {
      width: 3.8rem;
      height: 3.8rem;
      border-width: 2px;
      border-color: rgba(255,255,255,0.6);
    }
  }

  @keyframes hintPulse {
    0%, 100% { transform: scale(1);   opacity: 0.6; }
    50%       { transform: scale(1.4); opacity: 0.15; }
  }

  /* Hero A: slow drift + apex node pulse */
  .hero-a {
    transform: translateY(-50%);
    animation: heroDrift 14s var(--ease-smooth) infinite alternate;
    will-change: transform;
  }

  @keyframes heroDrift {
    from { transform: translateY(calc(-50% - 8px)); }
    to   { transform: translateY(calc(-50% + 8px)); }
  }

  .hero-a-node {
    animation: nodePulse 3.2s var(--ease-smooth) infinite;
    transform-origin: center;
    transform-box: fill-box;
  }

  @keyframes nodePulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(1.35); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-a,
    .hero-a-node {
      animation: none;
    }
  }

