          </div>

          <a
            href="/radar"
            class="inline-flex items-center gap-3 px-6 py-3 rounded-full font-medium text-sm transition-all duration-200 hover:scale-[1.02]"
            style="background: oklch(16% 0.01 25); color: var(--orange); border: 1px solid oklch(26% 0.01 25);"
          >
            Explorar Radar <span aria-hidden="true">→</span>
