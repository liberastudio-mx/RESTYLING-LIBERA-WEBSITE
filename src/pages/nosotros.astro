---
import Layout from '@/layouts/Layout.astro';

const principles = [
  {
    number: '01',
    title: 'Código 100% original',
    copy: 'Nada de templates con nueva camisa. Cada sistema que construimos es nuestro desde la primera línea.',
    icon: `<svg viewBox="0 0 48 48" aria-hidden="true"><path d="m18 15-9 9 9 9M30 15l9 9-9 9M27 10l-6 28"/></svg>`,
  },
  {
    number: '02',
    title: 'Sistemas que puedes mantener sin nosotros',
    copy: 'Crecimiento sin dependencia. Construimos para que puedas operar solo si así lo decides.',
    icon: `<svg viewBox="0 0 48 48" aria-hidden="true"><circle cx="24" cy="17" r="7"/><path d="M11 39c1-8 6-12 13-12s12 4 13 12"/></svg>`,
  },
  {
    number: '03',
    title: 'Respuesta antes de 48h',
    copy: 'Una promesa operativa concreta. No somos una agencia con cola infinita de tickets.',
    icon: `<svg viewBox="0 0 48 48" aria-hidden="true"><circle cx="24" cy="24" r="18"/><path d="M24 4v5M24 39v5M4 24h5M39 24h5"/><text x="24" y="28" text-anchor="middle">48h</text></svg>`,
  },
  {
    number: '04',
    title: 'Construimos antes de prometer',
    copy: 'Probamos las soluciones en nuestro propio Laboratorio antes de venderlas. Si una herramienta no resiste, no la vendemos.',
    icon: `<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M19 6h10M21 6v13L10 39h28L27 19V6"/><path class="fill" d="M15 34h18l-4-9H19z"/><circle class="fill" cx="25" cy="28" r="1.5"/></svg>`,
  },
  {
    number: '05',
    title: 'IA en producción, no en diapositivas',
    copy: 'Automatizamos donde hay fricción real, no donde hay moda. Sin demos vacías: sistemas que trabajan hoy.',
    icon: `<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M19 8c-6 0-9 5-7 10-5 2-6 10-1 13-1 6 6 10 11 6V11c0-2-1-3-3-3ZM29 8c6 0 9 5 7 10 5 2 6 10 1 13 1 6-6 10-11 6V11c0-2 1-3 3-3Z"/><path d="M15 18h7M14 30h8M26 18h7M26 30h8M18 13v4M30 13v4M18 31v5M30 31v5"/></svg>`,
  },
];
---

<Layout
  title="Nosotros"
  description="Somos Alma y Cesare. LIBERA Studio es un laboratorio de sistemas digitales en Mérida, México: construimos antes de prometer."
>
  <!-- Design: Brand | Vibe: Soft Structuralism | Layout: Editorial Split | Color: Full Palette -->
  <div class="about-page">
    <section class="hero-about">
      <div class="container-libera hero-grid">
        <div class="hero-copy" data-reveal>
          <p class="about-kicker"><span></span>Nosotros</p>
          <h1>Un <em>laboratorio,</em><br />no una agencia.</h1>
          <p class="hero-intro">
            LIBERA es un laboratorio de tecnología, estrategia y automatización creado
            para construir sistemas que los negocios puedan usar, entender y mantener.
          </p>
          <p class="hero-intro hero-intro-sub">
            No nacimos para vender herramientas. Nacimos porque vimos demasiadas empresas
            atrapadas en tecnología que prometía liberar tiempo, pero terminaba creando
            más dependencia, más pasos y más confusión.
          </p>
        </div>

        <div class="hero-lab" data-reveal aria-hidden="true">
          <svg viewBox="0 0 650 420">
            <g class="lab-lines">
              <path d="M61 92h156v104h63v69h87" />
              <path d="M221 92h45v42h45" />
              <path d="M420 110h112v87h-37" />
              <path d="M398 289h134v66" />
              <path d="M170 330h114v-60" />
            </g>
            <g class="lab-box">
              <rect x="30" y="34" width="190" height="135" rx="10" />
              <path d="M30 59h190" />
              <circle cx="48" cy="47" r="3" /><circle cx="60" cy="47" r="3" /><circle cx="72" cy="47" r="3" />
              <rect x="106" y="79" width="38" height="20" rx="3" />
              <rect x="53" y="125" width="35" height="22" rx="3" />
              <rect x="108" y="125" width="35" height="22" rx="3" />
              <rect x="164" y="125" width="35" height="22" rx="3" class="dark-fill" />
              <path d="M125 99v26M70 125v-14h111v14M125 147v15" />
              <rect x="108" y="162" width="35" height="19" rx="3" />
            </g>
            <g class="flask">
              <path d="M335 61h58M345 61v98l-70 126c-10 19 3 42 25 42h138c22 0 35-23 25-42l-70-126V61" />
              <path class="liquid" d="M310 264h119l23 42c4 7-2 15-10 15H295c-8 0-14-8-10-15z" />
              <circle class="bubble" cx="354" cy="268" r="7" /><circle class="bubble" cx="383" cy="246" r="10" />
              <circle class="bubble" cx="367" cy="296" r="4" />
            </g>
            <g class="lab-box small-panel">
              <rect x="468" y="77" width="137" height="112" rx="10" />
              <rect x="486" y="101" width="13" height="13" rx="2" /><path d="m489 107 3 3 5-6M510 107h64" />
              <rect x="486" y="132" width="13" height="13" rx="2" /><path d="m489 138 3 3 5-6M510 138h76" />
            </g>
            <g class="code-box">
              <rect x="42" y="264" width="91" height="76" rx="10" />
              <path d="m78 285-12 13 12 13M97 285l12 13-12 13M92 278l-10 40" />
            </g>
            <g class="chat">
              <path d="M520 230h91a12 12 0 0 1 12 12v45a12 12 0 0 1-12 12h-51l-21 18v-18h-19a12 12 0 0 1-12-12v-45a12 12 0 0 1 12-12Z" />
              <circle cx="540" cy="264" r="5" /><circle cx="564" cy="264" r="5" /><circle cx="588" cy="264" r="5" />
            </g>
            <g class="database">
              <ellipse cx="574" cy="358" rx="29" ry="11" /><path d="M545 358v34c0 6 13 11 29 11s29-5 29-11v-34M545 375c0 6 13 11 29 11s29-5 29-11" />
            </g>
          </svg>
        </div>
      </div>
    </section>

    <section class="why-section">
      <div class="container-libera why-grid">
        <div class="why-copy" data-reveal>
          <h2>Por qué existimos</h2>
          <p>Los negocios no fracasan por falta de tecnología. Fracasan porque la tecnología que adoptan no está conectada.</p>
          <ul>
            <li>Una web aquí.</li>
            <li>Un WhatsApp allá.</li>
            <li>Un Excel en el otro extremo.</li>
            <li>Piezas sueltas que nadie unió.</li>
          </ul>
          <p>LIBERA nació para eso: escuchar el problema, diseñar el sistema, construirlo y quedarse hasta que funciona.</p>
          <p>Trabajamos desde Mérida con proyectos en México y Europa. Y aprendimos algo en el camino: los mejores sistemas no son los más complejos. Son los que el equipo puede entender, usar y mantener sin depender de nadie.</p>
        </div>

        <blockquote class=”manifesto” data-reveal>
          <span class=”quote-open” aria-hidden=”true”>”</span>
          <p>Construimos antes de prometer. Intentamos romper las soluciones antes de venderlas. Lo que se rompe, lo documentamos. Lo que resiste, lo entregamos.</p>
          <span class=”quote-close” aria-hidden=”true”>”</span>
        </blockquote>
      </div>
    </section>

    <section class="principles-section">
      <div class="container-libera">
        <h2>Cómo trabajamos</h2>
        <div class="principles-grid">
          {principles.map((principle) => (
            <article class="principle-card">
              <span class="principle-number">{principle.number}</span>
              <div class="principle-icon" set:html={principle.icon}></div>
              <h3>{principle.title}</h3>
              <p>{principle.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="team-section">
      <div class="container-libera">
        <h2>El equipo detrás de LIBERA</h2>
        <div class="team-grid">
          <article class="team-card">
            <div class="team-copy team-copy-full">
              <p class="role">Sistemas &amp; automatización</p>
              <span class="role-rule"></span>
              <p>Arquitectura de sistemas, automatización con n8n, agentes de IA y desarrollo web. Esta parte se encarga de construir, conectar y probar lo que sostiene cada proyecto.</p>
            </div>
          </article>

          <article class="team-card">
            <div class="team-copy team-copy-full">
              <p class="role">Estrategia &amp; operación</p>
              <span class="role-rule"></span>
              <p>Estrategia digital, diseño de procesos y gestión de clientes. Esta parte traduce el caos del negocio en una estructura clara, usable y fácil de mantener.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="about-cta">
      <div class="container-libera">
        <div class="cta-panel">
          <svg class="cta-diagram" viewBox="0 0 260 130" aria-hidden="true">
            <path d="M23 34h55v37h49v35h58M78 34V15h55M127 71h58V35h47" />
            <rect x="8" y="21" width="42" height="33" rx="4" class="solid-navy" />
            <rect x="62" y="55" width="35" height="33" rx="4" />
            <path d="m70 71 7 7 13-15" />
            <rect x="111" y="14" width="42" height="33" rx="4" />
            <rect x="111" y="89" width="42" height="33" rx="4" class="solid-navy" />
            <rect x="174" y="18" width="42" height="33" rx="4" class="solid-orange" />
            <circle cx="78" cy="34" r="3" /><circle cx="127" cy="71" r="3" /><circle cx="185" cy="71" r="3" />
          </svg>
          <div class="cta-copy">
            <h2>No vendemos <em>hype.</em></h2>
            <p>Construimos sistemas que se ven, se usan y se pueden mejorar.</p>
            <div class="cta-actions">
              <a href="/trabajo" class="about-btn about-btn-dark">Ver nuestro trabajo <span aria-hidden="true">→</span></a>
              <a href="/diagnostico" class="about-btn about-btn-orange">Solicitar diagnóstico <span aria-hidden="true">→</span></a>
            </div>
          </div>
          <svg class="cta-flask" viewBox="0 0 130 150" aria-hidden="true">
            <path d="M45 10h40M52 10v48L20 122c-5 10 2 20 13 20h64c11 0 18-10 13-20L78 58V10" />
            <circle cx="67" cy="108" r="6" class="solid-orange" /><circle cx="83" cy="125" r="4" class="solid-orange" />
          </svg>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .about-page {
    --about-paper: oklch(98.7% 0.004 75);
    --about-line: oklch(88% 0.018 235);
    background: var(--about-paper);
    color: var(--brand-navy);
  }

  .hero-about {
    padding: calc(var(--nav-height) + 3.5rem) 0 4.75rem;
    border-bottom: 1px solid var(--about-line);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, .93fr) minmax(440px, 1.07fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 7rem);
  }

  .about-kicker {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-bottom: 2.25rem;
    font-size: .875rem;
    font-weight: 600;
  }

  .about-kicker span {
    width: .45rem;
    height: .45rem;
    border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 .25rem oklch(70% .19 55 / .1);
  }

  .hero-copy h1 {
    max-width: 720px;
    margin: 0;
    font-size: clamp(3.2rem, 6.1vw, 6.5rem);
    font-weight: 750;
    line-height: .93;
    letter-spacing: -.045em;
  }

  .hero-copy h1 em,
  .cta-copy h2 em {
    color: var(--orange);
    font-style: normal;
  }

  .hero-intro {
    max-width: 640px;
    margin-top: 1.75rem;
    font-size: clamp(1.05rem, 1.45vw, 1.35rem);
    line-height: 1.65;
  }

  .hero-intro-sub {
    margin-top: 1rem;
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    opacity: 0.75;
  }

  .hero-lab svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .hero-lab::after,
  .manifesto::after,
  .about-cta::after {
    content: '';
    position: absolute;
    width: 150px;
    height: 150px;
    background-image: radial-gradient(var(--orange) 1.35px, transparent 1.35px);
    background-size: 14px 14px;
    opacity: .45;
    pointer-events: none;
  }

  .hero-lab {
    position: relative;
  }

  .hero-lab::after {
    right: -2rem;
    top: 1rem;
    z-index: 0;
  }

  .hero-lab svg {
    position: relative;
    z-index: 1;
  }

  .lab-lines, .lab-box, .flask, .code-box, .small-panel, .database {
    fill: none;
    stroke: var(--brand-navy);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .dark-fill, .chat { fill: var(--brand-navy); stroke: var(--brand-navy); }
  .chat circle { fill: var(--about-paper); stroke: none; }
  .liquid { fill: var(--orange); stroke: var(--orange); }
  .bubble { fill: var(--about-paper); stroke: none; }

  .why-section {
    padding: 5.5rem 0 5.75rem;
    border-bottom: 1px solid var(--about-line);
  }

  .why-grid {
    display: grid;
    grid-template-columns: minmax(0, .95fr) minmax(420px, 1.05fr);
    gap: clamp(3rem, 7vw, 8rem);
    align-items: center;
  }

  .why-copy { max-width: 650px; }
  .why-copy h2, .principles-section h2, .team-section h2 {
    margin: 0 0 1rem;
    font-size: clamp(2.15rem, 3.3vw, 3.35rem);
    letter-spacing: -.035em;
  }

  .why-copy p {
    margin: 0 0 1.4rem;
    line-height: 1.65;
  }

  .why-copy ul {
    display: grid;
    gap: .3rem;
    margin: 0 0 1.6rem;
    padding: 0;
    list-style: none;
    font-size: 1.08rem;
    font-weight: 680;
  }

  .why-copy li::before {
    content: '•';
    margin-right: .85rem;
    color: var(--orange);
  }

  .manifesto {
    position: relative;
    min-height: 350px;
    display: flex;
    align-items: center;
    margin: 0;
    padding: 4.5rem clamp(2.5rem, 5vw, 5.2rem);
    border: 1px solid var(--about-line);
    border-radius: 1.35rem;
    background: oklch(99.4% .002 75);
    box-shadow: 0 18px 50px oklch(22% .06 235 / .035);
    overflow: hidden;
  }

  .manifesto::after { right: -2rem; top: 1rem; }
  .manifesto p {
    position: relative;
    z-index: 1;
    max-width: 650px;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.35;
  }

  .quote-open, .quote-close {
    position: absolute;
    z-index: 1;
    color: var(--orange);
    font-family: Georgia, serif;
    font-size: 6rem;
    font-weight: 700;
    line-height: 1;
  }
  .quote-open { left: 2.2rem; top: 2rem; }
  .quote-close { right: 2.2rem; bottom: .5rem; }

  .principles-section {
    position: relative;
    padding: 5.5rem 0 6.5rem;
    border-bottom: 1px solid var(--about-line);
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .principle-card {
    min-height: 390px;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--about-line);
    border-radius: 1rem;
    background: oklch(99.3% .002 75);
    transition: transform .28s var(--ease-premium), border-color .28s var(--ease-premium), box-shadow .28s var(--ease-premium);
  }

  .principle-card:hover {
    transform: translateY(-5px);
    border-color: oklch(78% .045 55);
    box-shadow: 0 18px 38px oklch(22% .06 235 / .07);
  }

  .principle-number {
    color: var(--orange);
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 750;
  }

  .principle-icon {
    width: 58px;
    height: 58px;
    display: grid;
    place-items: center;
    margin: 1rem 0 1.35rem;
    border: 1px solid var(--about-line);
    border-radius: 50%;
  }

  .principle-icon :global(svg) {
    width: 39px;
    height: 39px;
    fill: none;
    stroke: var(--brand-navy);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .principle-icon :global(text) {
    fill: var(--brand-navy);
    stroke: none;
    font: 700 10px var(--font-body);
  }
  .principle-icon :global(.fill) { fill: var(--brand-navy); }

  .principle-card h3 {
    min-height: 3.2em;
    margin: 0 0 1rem;
    font-size: 1.15rem;
    line-height: 1.18;
  }

  .principle-card p {
    margin: 0;
    font-size: .92rem;
    line-height: 1.62;
  }

  .team-section {
    padding: 5rem 0 3.5rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }

  .team-card {
    min-height: 220px;
    display: grid;
    overflow: hidden;
    border: 1px solid var(--about-line);
    border-radius: 1.1rem;
    background: oklch(99.3% .002 75);
  }

  .team-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
  }

  .team-copy-full {
    padding: 2.5rem;
  }

  .team-copy .role {
    margin: 0;
    color: var(--orange);
    font-size: .77rem;
    font-weight: 750;
    letter-spacing: .045em;
    text-transform: uppercase;
  }

  .role-rule {
    width: 2.5rem;
    height: 2px;
    margin: 1rem 0 1.25rem;
    background: var(--orange);
  }

  .team-copy > p:last-child {
    margin: 0;
    font-size: .93rem;
    line-height: 1.55;
  }

  .about-cta {
    position: relative;
    padding: 0 0 6rem;
    overflow: hidden;
  }

  .about-cta::after { right: 1rem; top: 2rem; }

  .cta-panel {
    position: relative;
    z-index: 1;
    min-height: 270px;
    display: grid;
    grid-template-columns: 270px minmax(0, 1fr) 170px;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(2rem, 4vw, 4rem);
    border: 1px solid var(--about-line);
    border-radius: 1.25rem;
    background: linear-gradient(105deg, oklch(99% .006 75), oklch(97% .02 72));
    overflow: hidden;
  }

  .cta-panel svg {
    width: 100%;
    fill: none;
    stroke: var(--brand-navy);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .cta-panel .solid-navy { fill: var(--brand-navy); }
  .cta-panel .solid-orange { fill: var(--orange); stroke: var(--orange); }

  .cta-copy h2 {
    margin: 0 0 .4rem;
    font-size: clamp(2.3rem, 4vw, 4rem);
    letter-spacing: -.04em;
  }

  .cta-copy > p {
    margin: 0 0 1.4rem;
    font-size: 1.15rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }

  .about-btn {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    padding: .85rem 1.25rem;
    border-radius: .65rem;
    font-size: .93rem;
    font-weight: 700;
    transition: transform .24s var(--ease-premium), background-color .24s var(--ease-premium);
  }
  .about-btn:hover { transform: translateY(-2px); }
  .about-btn:active { transform: scale(.98); }
  .about-btn-dark { background: var(--brand-navy); color: oklch(99% .002 75); }
  .about-btn-orange { background: var(--orange); color: oklch(99% .002 75); }
  .about-btn-dark:hover { background: oklch(25% .075 235); }
  .about-btn-orange:hover { background: oklch(61% .2 55); }

  .cta-flask { max-height: 180px; }

  @media (max-width: 1180px) {
    .principles-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .principle-card { min-height: 340px; }
    .team-card { grid-template-columns: 48% 52%; }
    .cta-panel { grid-template-columns: 210px minmax(0, 1fr) 120px; }
  }

  @media (max-width: 900px) {
    .hero-about { padding-top: calc(var(--nav-height) + 2.5rem); }
    .hero-grid, .why-grid { grid-template-columns: 1fr; }
    .hero-grid { gap: 2.5rem; }
    .hero-lab { max-width: 680px; margin-inline: auto; }
    .why-grid { gap: 2.5rem; }
    .manifesto { min-height: 300px; }
    .principles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .team-grid { grid-template-columns: 1fr; }
    .cta-panel { grid-template-columns: 1fr; text-align: center; }
    .cta-diagram, .cta-flask { display: none; }
    .cta-actions { justify-content: center; }
  }

  @media (max-width: 600px) {
    .hero-about { padding-bottom: 3.5rem; }
    .hero-copy h1 { font-size: clamp(2.8rem, 14vw, 4.4rem); }
    .about-kicker { margin-bottom: 1.5rem; }
    .why-section, .principles-section { padding-block: 4rem; }
    .principles-grid { grid-template-columns: 1fr; }
    .principle-card { min-height: auto; }
    .principle-card h3 { min-height: 0; }
    .team-section { padding-top: 4rem; }
    .team-card { grid-template-columns: 1fr; }
    .team-image { min-height: 250px; aspect-ratio: 16 / 10; }
    .team-copy { padding: 1.75rem; }
    .manifesto { padding: 4.5rem 1.6rem 3.5rem; }
    .quote-open { left: 1.3rem; }
    .quote-close { right: 1.3rem; }
    .cta-panel { padding: 2.5rem 1.25rem; }
