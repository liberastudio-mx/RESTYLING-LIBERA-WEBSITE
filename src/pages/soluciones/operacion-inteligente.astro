---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Operación Inteligente" description="PAOS, CRM, dashboards internos y automatización de procesos para operar con orden, no con memoria.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--operacion); font-family: var(--font-mono);">Soluciones</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Operación Inteligente</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">PAOS, CRM simple, dashboards internos y automatización de procesos. Para que tu negocio funcione con orden, no con memoria.</p>
      <a href="/soluciones" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Soluciones</a>
    </div>
  </section>
</Layout>
