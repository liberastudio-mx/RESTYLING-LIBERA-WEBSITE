---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Flujos con n8n | IA y automatización" description="n8n conecta tus herramientas y ejecuta pasos automáticamente. Sin código, sin cambiar de sistema. Esos pasos dejan de hacerse a mano.">

  <main class="n8n-page">

    <!-- BREADCRUMB -->
    <nav class="n8n-breadcrumb container-libera" aria-label="breadcrumb">
      <a href="/soluciones">Soluciones</a>
      <span>›</span>
      <a href="/soluciones/ai-automation">IA y automatización</a>
      <span>›</span>
      <span aria-current="page">Flujos con n8n</span>
    </nav>

    <!-- HERO -->
    <section class="n8n-hero">
      <div class="container-libera n8n-hero-grid">

        <div class="n8n-hero-copy" data-reveal>
          <h1 class="n8n-title">
            Conecta tus herramientas.<br/>
            <em>Elimina los pasos manuales en el medio.</em>
          </h1>
          <p class="n8n-lead">
            Cada vez que alguien copia datos de una app a otra, recuerda mandar un correo, actualiza una hoja de cálculo a mano o avisa a otro equipo sobre algo que ya pasó, hay fricción. n8n conecta esas herramientas y ejecuta esos pasos automáticamente. No necesitas código. No necesitas cambiar de sistema. Esos pasos dejan de hacerse a mano.
          </p>
          <ul class="n8n-checks">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Sin código, lógica visual
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Se conecta con tus herramientas actuales
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Datos bajo tu control
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Menos errores, más tiempo para lo importante
            </li>
          </ul>
        </div>

        <!-- Mock: hub de integraciones n8n -->
        <aside class="n8n-mock" aria-hidden="true" data-reveal>
          <div class="n8n-hub-grid">
            <!-- fila 1 -->
            <div class="n8n-tool n8n-tool--gmail">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" fill="#fff" stroke="rgba(0,0,0,0.08)"/><path d="M2 7l10 7 10-7" stroke="#d62828" stroke-width="1.5"/></svg>
              <span>Gmail</span>
            </div>
            <div class="n8n-tool n8n-tool--sheets">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="4" y="2" width="16" height="20" rx="2" fill="#0f9d58" opacity=".9"/><path d="M8 10h8M8 14h8M8 18h5" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/></svg>
              <span>Sheets</span>
            </div>
            <div class="n8n-tool n8n-tool--slack">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="4" fill="#4a154b"/><path d="M8 13a2 2 0 0 1 0-4h1V8a2 2 0 0 1 4 0v1h1a2 2 0 0 1 0 4h-1v1a2 2 0 0 1-4 0v-1H8z" fill="#e01e5a" opacity=".8"/></svg>
              <span>Slack</span>
            </div>
            <!-- fila 2 -->
            <div class="n8n-tool n8n-tool--notion">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="3" fill="#fff" stroke="rgba(0,0,0,0.15)"/><path d="M7 7h6l4 4v6H7V7z" fill="#000" opacity=".8"/></svg>
              <span>Notion</span>
            </div>
            <!-- n8n center -->
            <div class="n8n-center">
              <div class="n8n-center-ring">
                <div class="n8n-center-icon">
                  <svg width="28" height="20" viewBox="0 0 40 28" fill="none">
                    <circle cx="8" cy="14" r="6" stroke="var(--orange)" stroke-width="2"/>
                    <circle cx="32" cy="14" r="6" stroke="var(--orange)" stroke-width="2"/>
                    <path d="M14 14h12" stroke="var(--orange)" stroke-width="2"/>
                    <circle cx="20" cy="7" r="4" stroke="var(--orange)" stroke-width="2"/>
                    <path d="M20 11v3" stroke="var(--orange)" stroke-width="2"/>
                  </svg>
                  <span>n8n</span>
                </div>
              </div>
            </div>
            <div class="n8n-tool n8n-tool--postgres">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="6" rx="8" ry="3" fill="#336791"/><path d="M4 6v6c0 1.66 3.58 3 8 3s8-1.34 8-3V6" fill="#336791" opacity=".7"/><path d="M4 12v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6" fill="#336791" opacity=".5"/></svg>
              <span>Postgres</span>
            </div>
            <!-- fila 3 -->
            <div class="n8n-tool n8n-tool--salesforce">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="4" fill="#00a1e0"/><path d="M12 6c2.2 0 4 1.8 4 4s-1.8 4-4 4-4-1.8-4-4 1.8-4 4-4z" fill="#fff" opacity=".9"/></svg>
              <span>Salesforce</span>
            </div>
            <div class="n8n-tool n8n-tool--whatsapp">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" fill="#25d366"/><path d="M12 7a5 5 0 0 1 4.33 7.5l.67 2.5-2.5-.67A5 5 0 1 1 12 7z" fill="#fff" opacity=".9"/></svg>
              <span>WhatsApp</span>
            </div>
            <div class="n8n-tool n8n-tool--hubspot">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="4" fill="#ff7a59"/><circle cx="12" cy="12" r="4" fill="#fff" opacity=".9"/><circle cx="12" cy="6" r="1.5" fill="#fff" opacity=".9"/></svg>
              <span>HubSpot</span>
            </div>
          </div>

          <!-- Strip inferior -->
          <div class="n8n-strip">
            <div class="n8n-strip-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            <p><strong>n8n se conecta con cientos de herramientas.</strong> Si usas una herramienta en tu operación, probablemente ya existe una integración.</p>
          </div>
        </aside>

      </div>
    </section>

    <!-- CONTENT: Lo que automatizamos + Por qué n8n -->
    <section class="n8n-content">
      <div class="container-libera n8n-content-grid">

        <div class="n8n-flows" data-reveal>
          <h2 class="n8n-flows-title">Lo que automatizamos con <em>n8n</em></h2>
          <ul class="n8n-flow-list">
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos de notificación</p>
                <p class="n8n-flow-ds">Cuando algo pasa en una app, se avisa en otra.</p>
              </div>
            </li>
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos de sincronización</p>
                <p class="n8n-flow-ds">Los datos viajan solos entre sistemas.</p>
              </div>
            </li>
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos de aprobación</p>
                <p class="n8n-flow-ds">Una solicitud se recibe, se enruta a quien decide y se actualiza cuando hay respuesta.</p>
              </div>
            </li>
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos con IA en el medio</p>
                <p class="n8n-flow-ds">Un mensaje llega, se clasifica, se redacta una respuesta y se envía, todo sin intervención humana.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="n8n-why" data-reveal>
          <h2 class="n8n-why-title">¿Por qué <em>n8n</em> frente a Zapier o Make?</h2>
          <p class="n8n-why-body">n8n puede correr en un entorno controlado por ti o gestionado por nosotros. Eso reduce dependencia de plataformas externas innecesarias, ayuda a controlar mejor los datos y evita que el costo escale por cada ejecución.</p>
          <p class="n8n-why-body">Para flujos de alto volumen o datos sensibles, la diferencia es relevante.</p>
          <div class="n8n-why-icon" aria-hidden="true">
            <svg width="52" height="52" viewBox="0 0 64 64" fill="none">
              <path d="M32 8L12 20v24l20 12 20-12V20L32 8z" stroke="var(--orange)" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M32 8v36M12 20l20 12 20-12" stroke="var(--orange)" stroke-width="1.5"/>
              <path d="M24 44l-5 8M40 44l5 8" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
        </div>

      </div>
    </section>

    <!-- PUNTOS CLAVE -->
    <section class="n8n-puntos">
      <div class="container-libera" data-reveal>
        <h2 class="n8n-puntos-title">Puntos clave</h2>
        <div class="n8n-puntos-grid">
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <p class="n8n-punto-ttl">Puede correr en un entorno controlado por ti</p>
            <p class="n8n-punto-ds">En tu infraestructura o gestionado por nosotros.</p>
          </div>
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/><path d="M8 2.5C9.5 2 11 1.8 12 2"/></svg>
            </div>
            <p class="n8n-punto-ttl">Mejor costo para flujos de alto volumen</p>
            <p class="n8n-punto-ds">Sin cobros por cada ejecución o tarea.</p>
          </div>
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <p class="n8n-punto-ttl">Flujos documentados y transferibles</p>
            <p class="n8n-punto-ds">No flujos que solo nosotros entendemos.</p>
          </div>
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.59a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <p class="n8n-punto-ttl">Mantenimiento incluido el primer mes</p>
            <p class="n8n-punto-ds">Después lo operas tú si quieres.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="n8n-cta">
      <div class="container-libera n8n-cta-inner" data-reveal>
        <div class="n8n-cta-left">
          <div class="n8n-cta-icon" aria-hidden="true">
            <svg width="52" height="52" viewBox="0 0 64 64" fill="none">
              <rect x="8" y="8" width="20" height="14" rx="3" stroke="var(--orange)" stroke-width="1.5"/>
              <rect x="8" y="30" width="20" height="14" rx="3" stroke="var(--orange)" stroke-width="1.5"/>
              <circle cx="44" cy="22" r="8" stroke="var(--orange)" stroke-width="1.5"/>
              <circle cx="44" cy="22" r="3" fill="var(--orange)"/>
              <path d="M28 15h8M28 37h8" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M36 15l8 7M36 37l8-7" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M36 22h4" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="n8n-cta-text">
            <p>¿Qué parte de tu operación se repite todos los días y <em>nadie debería hacer a mano?</em></p>
            <p class="n8n-orange">Cuéntanos tu caso y te mostramos qué flujos podemos automatizar con n8n.</p>
          </div>
        </div>
        <a href="/diagnostico" class="btn-primary n8n-cta-btn">Solicitar diagnóstico <span aria-hidden="true">→</span></a>
      </div>
    </section>

  </main>

  <style>
    .n8n-page { background: #fff; color: var(--text-primary); }

    /* BREADCRUMB */
    .n8n-breadcrumb {
      display: flex; align-items: center; gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 1.25rem);
      font-size: 0.8rem; color: var(--text-secondary); flex-wrap: wrap;
    }
    .n8n-breadcrumb a { color: var(--text-secondary); transition: color .2s; }
    .n8n-breadcrumb a:hover { color: var(--orange); }
    .n8n-breadcrumb [aria-current="page"] { color: var(--orange); font-weight: 600; }

    /* HERO */
    .n8n-hero { padding-top: clamp(4rem, calc(3vw + 2.5rem), 5rem); padding-bottom: clamp(3rem, 6vw, 5rem); }
    .n8n-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: start;
    }

    .n8n-title { font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.1; margin-bottom: 1.5rem; }
    .n8n-title em { font-style: normal; color: var(--orange); }

    .n8n-lead { color: var(--text-secondary); font-size: clamp(0.9rem, 1.15vw, 1rem); line-height: 1.75; max-width: 46ch; margin-bottom: 1.5rem; }

    .n8n-checks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.55rem; }
    .n8n-checks li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; color: var(--text-secondary); }
    .n8n-checks svg { flex-shrink: 0; }

    /* MOCK HUB */
    .n8n-mock {
      border-radius: 0.5rem; overflow: hidden;
      border: 1px solid rgba(0,48,73,0.08);
      box-shadow: 0 8px 40px oklch(0% 0 0 / 0.12);
      background: #fff; padding: 1.25rem;
      display: flex; flex-direction: column; gap: 1rem;
    }

    .n8n-hub-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem; align-items: center;
    }

    .n8n-tool {
      display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
      padding: 0.65rem 0.5rem; border-radius: 0.4rem;
      border: 1px solid rgba(0,48,73,0.08); background: #fafafa;
      font-size: 0.55rem; color: var(--text-secondary); font-family: var(--font-mono);
      letter-spacing: 0.04em;
    }

    .n8n-center {
      display: flex; align-items: center; justify-content: center;
    }
    .n8n-center-ring {
      width: 72px; height: 72px; border-radius: 50%;
      border: 2px solid var(--orange); background: oklch(98.5% 0.012 55);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 0 6px oklch(97% 0.01 55);
    }
    .n8n-center-icon {
      display: flex; flex-direction: column; align-items: center; gap: 0.15rem;
    }
    .n8n-center-icon span {
      font-family: var(--font-display); font-size: 0.65rem; font-weight: 800;
      color: var(--orange); letter-spacing: 0.05em;
    }

    .n8n-strip {
      display: flex; align-items: flex-start; gap: 0.75rem;
      padding: 0.75rem 0.9rem; background: oklch(98.5% 0.008 55);
      border-radius: 0.35rem; border: 1px solid rgba(247,127,0,0.15);
    }
    .n8n-strip-icon { flex-shrink: 0; margin-top: 0.1rem; }
    .n8n-strip p { font-size: 0.72rem; color: var(--text-secondary); line-height: 1.5; margin: 0; }
    .n8n-strip strong { color: var(--text-primary); }

    /* CONTENT */
    .n8n-content { padding-block: clamp(2.5rem, 5vw, 4rem); background: #fff; }
    .n8n-content-grid {
      display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2rem, 5vw, 4rem); align-items: start;
    }

    .n8n-flows-title {
      font-family: var(--font-display); font-size: clamp(1rem, 1.6vw, 1.2rem);
      font-weight: 700; color: var(--text-primary); margin-bottom: 1.25rem;
    }
    .n8n-flows-title em { font-style: normal; color: var(--orange); }

    .n8n-flow-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
    .n8n-flow-list li { display: flex; align-items: flex-start; gap: 0.75rem; }
    .n8n-flow-icon {
      display: flex; align-items: center; justify-content: center;
      width: 2.25rem; height: 2.25rem; border-radius: 50%; flex-shrink: 0;
      border: 1.5px solid var(--orange); background: oklch(98.5% 0.008 55);
      margin-top: 0.05rem;
    }
    .n8n-flow-ttl { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.2rem; }
    .n8n-flow-ds { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; margin: 0; }

    /* Por qué n8n */
    .n8n-why {
      background: #003049; border-radius: 0.5rem; padding: clamp(1.5rem, 3vw, 2.25rem);
      position: relative; overflow: hidden;
    }
    .n8n-why-title {
      font-family: var(--font-display); font-size: clamp(1.1rem, 2vw, 1.4rem);
      font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: 1.1rem;
    }
    .n8n-why-title em { font-style: normal; color: var(--orange); }
    .n8n-why-body { font-size: 0.9rem; color: rgba(255,255,255,0.7); line-height: 1.7; margin: 0 0 0.75rem; }
    .n8n-why-icon {
      position: absolute; bottom: 1rem; right: 1.25rem; opacity: 0.25;
    }

    /* PUNTOS CLAVE */
    .n8n-puntos { padding-block: clamp(2rem, 4vw, 3.5rem); background: var(--surface-alt); }
    .n8n-puntos-title {
      font-family: var(--font-display); font-size: clamp(1.1rem, 1.8vw, 1.35rem);
      font-weight: 700; color: var(--text-primary); margin-bottom: 1.75rem;
    }
    .n8n-puntos-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
    .n8n-punto {
      background: #fff; border-radius: 0.5rem; padding: 1.25rem 1rem 1rem;
      border: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.5rem;
      border-bottom: 3px solid var(--orange);
    }
    .n8n-punto-icon { margin-bottom: 0.25rem; }
    .n8n-punto-ttl { font-size: 0.92rem; font-weight: 700; color: var(--text-primary); line-height: 1.35; margin: 0; }
