  </div>

  <style>
    .n8n-page { background: #fff; color: var(--text-primary); }

    /* BREADCRUMB */
    .n8n-breadcrumb {
      display: flex; align-items: center; gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 1.25rem);
      font-size: 0.8rem; color: var(--text-secondary); flex-wrap: wrap;
    }
    .n8n-breadcrumb a { color: var(--text-secondary); transition: color .2s; }
    .n8n-breadcrumb a:hover { color: var(--orange); }
    .n8n-breadcrumb [aria-current="page"] { color: var(--orange); font-weight: 600; }

    /* HERO */
    .n8n-hero { padding-top: clamp(4rem, calc(3vw + 2.5rem), 5rem); padding-bottom: clamp(3rem, 6vw, 5rem); }
    .n8n-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: start;
    }

    .n8n-title { font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.1; margin-bottom: 1.5rem; }
    .n8n-title em { font-style: normal; color: var(--orange); }

    .n8n-lead { color: var(--text-secondary); font-size: clamp(0.9rem, 1.15vw, 1rem); line-height: 1.75; max-width: 46ch; margin-bottom: 1.5rem; }

    .n8n-checks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.55rem; }
    .n8n-checks li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; color: var(--text-secondary); }
    .n8n-checks svg { flex-shrink: 0; }

    /* ORBITAL MOCK */
    .n8n-mock {
      display: flex; flex-direction: column; align-items: center; gap: 1rem;
      padding: 1.5rem 1.5rem 1.25rem;
    }

    .int-orbit-scene {
      position: relative; width: min(380px, 100%); aspect-ratio: 1;
    }

    .int-ring-track {
      position: absolute; top: 50%; left: 50%;
      border: 1px dashed var(--border); border-radius: 50%;
      transform: translate(-50%, -50%); pointer-events: none;
    }
    .int-ring-track--1 { width: 140px; height: 140px; }
    .int-ring-track--2 { width: 240px; height: 240px; }
    .int-ring-track--3 { width: 340px; height: 340px; }

    .int-orbit-hub {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 64px; height: 64px; border-radius: 50%;
      background: #fff; border: 2px solid var(--orange);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 2px; z-index: 10;
    }

    .int-orbit-hub-glow {
      position: absolute; inset: -8px; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,109,90,0.12) 0%, transparent 70%);
      pointer-events: none; animation: int-glow 3s ease-in-out infinite;
    }

    @keyframes int-glow {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50%       { opacity: 1;   transform: scale(1.12); }
    }

    .int-orbit-hub span {
      font-family: var(--font-mono, monospace); font-size: 0.55rem; font-weight: 700;
      color: var(--orange); letter-spacing: 0.02em; position: relative; z-index: 1;
    }

    @keyframes int-orbit-cw {
      from { transform: rotate(var(--s)) translateX(var(--r)) rotate(calc(-1 * var(--s))); }
      to   { transform: rotate(calc(var(--s) + 360deg)) translateX(var(--r)) rotate(calc(-1 * var(--s) - 360deg)); }
    }
    @keyframes int-orbit-ccw {
      from { transform: rotate(var(--s)) translateX(var(--r)) rotate(calc(-1 * var(--s))); }
      to   { transform: rotate(calc(var(--s) - 360deg)) translateX(var(--r)) rotate(calc(-1 * var(--s) + 360deg)); }
    }

    .int-oi {
      position: absolute; top: 50%; left: 50%;
      width: 42px; height: 42px; margin: -21px;
      animation: int-orbit-cw var(--d) linear infinite; z-index: 5;
    }
    .int-oi--ccw { animation-name: int-orbit-ccw; }

    .int-oi-chip {
      width: 42px; height: 42px; border-radius: 50%;
      background: var(--bg, #333); border: 1.5px solid rgba(255,255,255,0.15);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 12px rgba(0,0,0,0.4);
    }

    .int-orbit-caption {
      font-size: 0.6rem; color: var(--text-secondary); text-align: center;
      letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500; margin: 0;
    }

    /* CONTENT */
    .n8n-content { padding-block: clamp(2.5rem, 5vw, 4rem); background: #fff; }
    .n8n-content-grid {
      display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2rem, 5vw, 4rem); align-items: start;
    }

    .n8n-flows-title {
      font-family: var(--font-display); font-size: clamp(1rem, 1.6vw, 1.2rem);
      font-weight: 700; color: var(--text-primary); margin-bottom: 1.25rem;
    }
    .n8n-flows-title em { font-style: normal; color: var(--orange); }

    .n8n-flow-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
    .n8n-flow-list li { display: flex; align-items: flex-start; gap: 0.75rem; }
    .n8n-flow-icon {
      display: flex; align-items: center; justify-content: center;
      width: 2.25rem; height: 2.25rem; border-radius: 50%; flex-shrink: 0;
      border: 1.5px solid var(--orange); background: oklch(98.5% 0.008 55);
      margin-top: 0.05rem;
    }
    .n8n-flow-ttl { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.2rem; }
    .n8n-flow-ds { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; margin: 0; }

    /* Por qué n8n */
    .n8n-why {
      background: #003049; border-radius: 0.5rem; padding: clamp(1.5rem, 3vw, 2.25rem);
      position: relative; overflow: hidden;
    }
    .n8n-why-title {
      font-family: var(--font-display); font-size: clamp(1.1rem, 2vw, 1.4rem);
      font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: 1.1rem;
    }
    .n8n-why-title em { font-style: normal; color: var(--orange); }
    .n8n-why-body { font-size: 0.9rem; color: rgba(255,255,255,0.7); line-height: 1.7; margin: 0 0 0.75rem; }
    .n8n-why-icon {
      position: absolute; bottom: 1rem; right: 1.25rem; opacity: 0.25;
    }

    /* PUNTOS CLAVE */
    .n8n-puntos { padding-block: clamp(2rem, 4vw, 3.5rem); background: var(--surface-alt); }
    .n8n-puntos-title {
      font-family: var(--font-display); font-size: clamp(1.1rem, 1.8vw, 1.35rem);
      font-weight: 700; color: var(--text-primary); margin-bottom: 1.75rem;
    }
    .n8n-puntos-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
    .n8n-punto {
      background: #fff; border-radius: 0.5rem; padding: 1.25rem 1rem 1rem;
      border: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.5rem;
      border-bottom: 3px solid var(--orange);
    }
    .n8n-punto-icon { margin-bottom: 0.25rem; }
    .n8n-punto-ttl { font-size: 0.92rem; font-weight: 700; color: var(--text-primary); line-height: 1.35; margin: 0; }
    .n8n-punto-ds { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.5; margin: 0; }

    /* CTA */
    .n8n-cta { padding-block: clamp(2rem, 4vw, 3.5rem); background: #fff; }
    .n8n-cta-inner {
      display: flex; align-items: center; justify-content: space-between;
      gap: 2rem; padding: clamp(1.25rem, 2.5vw, 2rem);
      border: 1px solid var(--border); border-radius: 0.5rem;
    }
    .n8n-cta-left { display: flex; align-items: center; gap: 1.5rem; }
    .n8n-cta-icon { flex-shrink: 0; }
    .n8n-cta-text { display: flex; flex-direction: column; gap: 0.3rem; }
    .n8n-cta-text p {
      font-family: var(--font-display); font-size: clamp(0.9rem, 1.3vw, 1.05rem);
      font-weight: 700; color: var(--text-primary); line-height: 1.35; margin: 0;
    }
    .n8n-cta-text em { font-style: normal; color: var(--orange); }
    .n8n-orange { color: var(--orange) !important; font-weight: 600 !important; }
    .n8n-cta-btn {
      white-space: nowrap; flex-shrink: 0;
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.5rem; font-size: 0.92rem;
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .n8n-puntos-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 900px) {
      .n8n-hero-grid, .n8n-content-grid { grid-template-columns: 1fr; }
      .n8n-cta-inner { flex-direction: column; align-items: flex-start; }
      .n8n-cta-btn { width: 100%; justify-content: center; }
    }
    @media (max-width: 640px) {
      .n8n-puntos-grid { grid-template-columns: 1fr; }
    }
  </style>

</Layout>
