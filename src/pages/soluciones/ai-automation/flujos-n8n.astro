---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Flujos con n8n | IA y automatización" description="n8n conecta tus herramientas y ejecuta pasos automáticamente. Sin código, sin cambiar de sistema. Esos pasos dejan de hacerse a mano.">

  <div class="n8n-page">

    <!-- BREADCRUMB -->
    <nav class="n8n-breadcrumb container-libera" aria-label="breadcrumb">
      <a href="/soluciones">Soluciones</a>
      <span>›</span>
      <a href="/soluciones/ai-automation">IA y automatización</a>
      <span>›</span>
      <span aria-current="page">Flujos con n8n</span>
    </nav>

    <!-- HERO -->
    <section class="n8n-hero">
      <div class="container-libera n8n-hero-grid">

        <div class="n8n-hero-copy">
          <h1 class="n8n-title">
            Conecta tus herramientas.<br/>
            <em>Elimina los pasos manuales en el medio.</em>
          </h1>
          <p class="n8n-lead">
            Cada vez que alguien copia datos de una app a otra, recuerda mandar un correo, actualiza una hoja de cálculo a mano o avisa a otro equipo sobre algo que ya pasó, hay fricción. n8n conecta esas herramientas y ejecuta esos pasos automáticamente. No necesitas código. No necesitas cambiar de sistema. Esos pasos dejan de hacerse a mano.
          </p>
          <ul class="n8n-checks">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Sin código, lógica visual
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Se conecta con tus herramientas actuales
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Datos bajo tu control
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="var(--orange)" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Menos errores, más tiempo para lo importante
            </li>
          </ul>
        </div>

        <!-- Orbital integration mock -->
        <aside class="n8n-mock" aria-hidden="true">
          <div class="int-orbit-scene">
            <div class="int-ring-track int-ring-track--1"></div>
            <div class="int-ring-track int-ring-track--2"></div>
            <div class="int-ring-track int-ring-track--3"></div>

            <div class="int-orbit-hub">
              <div class="int-orbit-hub-glow"></div>
              <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
                <circle cx="6"  cy="16" r="4" fill="#FF6D5A"/>
                <circle cx="26" cy="8"  r="4" fill="#FF6D5A" opacity="0.8"/>
                <circle cx="26" cy="24" r="4" fill="#FF6D5A" opacity="0.6"/>
                <line x1="10" y1="16" x2="22" y2="9"  stroke="#FF6D5A" stroke-width="1.5" opacity="0.5"/>
                <line x1="10" y1="16" x2="22" y2="23" stroke="#FF6D5A" stroke-width="1.5" opacity="0.5"/>
              </svg>
              <span>n8n</span>
            </div>

            <!-- Inner CW 18s r=70px -->
            <div class="int-oi" style="--s:0deg;   --r:70px; --d:18s"><div class="int-oi-chip" style="--bg:#25D366"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.985-1.398A9.961 9.961 0 0 0 12 22c5.523 0 10-4.477 10-10S17.522 2 12 2z"/></svg></div></div>
            <div class="int-oi" style="--s:90deg;  --r:70px; --d:18s"><div class="int-oi-chip" style="--bg:#EA4335"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="white" stroke-width="1.3"/><path d="M2 6l10 7 10-7" stroke="white" stroke-width="1.4" fill="none"/></svg></div></div>
            <div class="int-oi" style="--s:180deg; --r:70px; --d:18s"><div class="int-oi-chip" style="--bg:#FCB400"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="8" rx="1.5" fill="white" opacity="0.95"/><rect x="2" y="13" width="9" height="8" rx="1.5" fill="white" opacity="0.8"/><rect x="13" y="13" width="9" height="8" rx="1.5" fill="white" opacity="0.55"/></svg></div></div>
            <div class="int-oi" style="--s:270deg; --r:70px; --d:18s"><div class="int-oi-chip" style="--bg:#010101"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.93a8.18 8.18 0 0 0 4.78 1.52V7a4.85 4.85 0 0 1-1.01-.31z"/></svg></div></div>

            <!-- Middle CCW 32s r=120px -->
            <div class="int-oi int-oi--ccw" style="--s:0deg;   --r:120px; --d:32s"><div class="int-oi-chip" style="--bg:#0084FF"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.961 1.44 5.601 3.702 7.35V22l3.375-1.855A11.12 11.12 0 0 0 12 20.486c5.523 0 10-4.144 10-9.243C22 6.145 17.523 2 12 2zm1.008 12.453L10.57 12l-4.773 2.453 5.237-5.566 2.437 2.453 4.773-2.453-5.236 5.566z"/></svg></div></div>
            <div class="int-oi int-oi--ccw" style="--s:72deg;  --r:120px; --d:32s"><div class="int-oi-chip" style="--bg:#EA4335"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg></div></div>
            <div class="int-oi int-oi--ccw" style="--s:144deg; --r:120px; --d:32s"><div class="int-oi-chip" style="--bg:#C13584"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="white" stroke="none"/></svg></div></div>
            <div class="int-oi int-oi--ccw" style="--s:216deg; --r:120px; --d:32s"><div class="int-oi-chip" style="--bg:#1877F2"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></div></div>
            <div class="int-oi int-oi--ccw" style="--s:288deg; --r:120px; --d:32s"><div class="int-oi-chip" style="--bg:#0F9D58"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="1.5"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg></div></div>

            <!-- Outer CW 52s r=170px -->
            <div class="int-oi" style="--s:0deg;   --r:170px; --d:52s"><div class="int-oi-chip" style="--bg:#635BFF"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M13.479 9.883c-1.626-.604-2.512-1.067-2.512-1.803 0-.609.567-1.065 1.818-1.065 1.667 0 3.197.574 3.197.574l.467-2.887S14.941 4 12.713 4C10.898 4 9.386 4.54 8.369 5.484 7.359 6.421 6.886 7.65 6.886 9.05c0 2.32 1.543 3.527 4.068 4.401 1.617.567 2.3 1.101 2.3 1.831 0 .745-.645 1.149-1.87 1.149-1.641 0-3.55-.703-3.55-.703l-.5 2.88s1.77.879 4.26.879c1.879 0 3.372-.527 4.39-1.536.983-.983 1.455-2.287 1.455-3.714-.008-2.442-1.597-3.649-3.96-4.354z"/></svg></div></div>
            <div class="int-oi" style="--s:60deg;  --r:170px; --d:52s"><div class="int-oi-chip" style="--bg:#000000"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M4.459 4.208c.746.606 1.026.56 2.428.466l13.215-.793c.28 0 .047-.28-.046-.326L17.86 1.968c-.42-.326-.981-.7-2.055-.607L3.01 2.295c-.466.046-.56.28-.374.466l1.823 1.447zm.793 3.08v13.904c0 .747.373 1.027 1.214.98l14.523-.84c.841-.046.935-.56.935-1.167V6.354c0-.606-.233-.933-.748-.887l-15.177.887c-.56.047-.747.327-.747.933zm14.337.745c.093.42 0 .84-.42.888l-.7.14v10.264c-.608.327-1.168.514-1.635.514-.748 0-.935-.234-1.495-.933l-4.577-7.186v6.952L12.21 19s0 .84-1.168.84l-3.222.186c-.093-.186 0-.653.327-.746l.84-.233V9.854L7.822 9.76c-.094-.42.14-1.026.793-1.073l3.456-.233 4.764 7.279v-6.44l-1.215-.14c-.093-.514.28-.887.747-.933l3.222-.187z"/></svg></div></div>
            <div class="int-oi" style="--s:120deg; --r:170px; --d:52s"><div class="int-oi-chip" style="--bg:#4A154B"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zm10.122 2.521a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.268 0a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zm-2.523 10.122a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.268a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg></div></div>
            <div class="int-oi" style="--s:180deg; --r:170px; --d:52s"><div class="int-oi-chip" style="--bg:#4353FF"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.7 3H24l-6.3 13.95L24 21h-6.3L12 10.5l-1.2 3H14l-2.4 5.25L9 21 2.1 3H8.7l3.3 8.1L14.4 3z"/></svg></div></div>
            <div class="int-oi" style="--s:240deg; --r:170px; --d:52s"><div class="int-oi-chip" style="--bg:#FF4A00"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M14.24 10.56l-2.4 7.2-2.4-7.2-7.2-2.4 7.2-2.4 2.4-7.2 2.4 7.2 7.2 2.4-7.2 2.4z"/></svg></div></div>
            <div class="int-oi" style="--s:300deg; --r:170px; --d:52s"><div class="int-oi-chip" style="--bg:#010101; border: 1.5px solid #EE1D52 !important"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.93a8.18 8.18 0 0 0 4.78 1.52V7a4.85 4.85 0 0 1-1.01-.31z"/></svg></div></div>
          </div>

          <p class="int-orbit-caption">Motor de flujos · APIs · Webhooks</p>
        </aside>

      </div>
    </section>

    <!-- CONTENT: Lo que automatizamos + Por qué n8n -->
    <section class="n8n-content">
      <div class="container-libera n8n-content-grid">

        <div class="n8n-flows">
          <h2 class="n8n-flows-title">Lo que automatizamos con <em>n8n</em></h2>
          <ul class="n8n-flow-list">
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos de notificación</p>
                <p class="n8n-flow-ds">Cuando algo pasa en una app, se avisa en otra.</p>
              </div>
            </li>
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos de sincronización</p>
                <p class="n8n-flow-ds">Los datos viajan solos entre sistemas.</p>
              </div>
            </li>
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos de aprobación</p>
                <p class="n8n-flow-ds">Una solicitud se recibe, se enruta a quien decide y se actualiza cuando hay respuesta.</p>
              </div>
            </li>
            <li>
              <span class="n8n-flow-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>
              </span>
              <div>
                <p class="n8n-flow-ttl">Flujos con IA en el medio</p>
                <p class="n8n-flow-ds">Un mensaje llega, se clasifica, se redacta una respuesta y se envía, todo sin intervención humana.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="n8n-why">
          <h2 class="n8n-why-title">¿Por qué <em>n8n</em> frente a Zapier o Make?</h2>
          <p class="n8n-why-body">n8n puede correr en un entorno controlado por ti o gestionado por nosotros. Eso reduce dependencia de plataformas externas innecesarias, ayuda a controlar mejor los datos y evita que el costo escale por cada ejecución.</p>
          <p class="n8n-why-body">Para flujos de alto volumen o datos sensibles, la diferencia es relevante.</p>
          <div class="n8n-why-icon" aria-hidden="true">
            <svg width="52" height="52" viewBox="0 0 64 64" fill="none">
              <path d="M32 8L12 20v24l20 12 20-12V20L32 8z" stroke="var(--orange)" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M32 8v36M12 20l20 12 20-12" stroke="var(--orange)" stroke-width="1.5"/>
              <path d="M24 44l-5 8M40 44l5 8" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
        </div>

      </div>
    </section>

    <!-- PUNTOS CLAVE -->
    <section class="n8n-puntos">
      <div class="container-libera">
        <h2 class="n8n-puntos-title">Puntos clave</h2>
        <div class="n8n-puntos-grid">
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <p class="n8n-punto-ttl">Puede correr en un entorno controlado por ti</p>
            <p class="n8n-punto-ds">En tu infraestructura o gestionado por nosotros.</p>
          </div>
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/><path d="M8 2.5C9.5 2 11 1.8 12 2"/></svg>
            </div>
            <p class="n8n-punto-ttl">Mejor costo para flujos de alto volumen</p>
            <p class="n8n-punto-ds">Sin cobros por cada ejecución o tarea.</p>
          </div>
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <p class="n8n-punto-ttl">Flujos documentados y transferibles</p>
            <p class="n8n-punto-ds">No flujos que solo nosotros entendemos.</p>
          </div>
          <div class="n8n-punto">
            <div class="n8n-punto-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.59a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <p class="n8n-punto-ttl">Mantenimiento incluido el primer mes</p>
            <p class="n8n-punto-ds">Después lo operas tú si quieres.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="n8n-cta">
      <div class="container-libera n8n-cta-inner">
        <div class="n8n-cta-left">
          <div class="n8n-cta-icon" aria-hidden="true">
            <svg width="52" height="52" viewBox="0 0 64 64" fill="none">
              <rect x="8" y="8" width="20" height="14" rx="3" stroke="var(--orange)" stroke-width="1.5"/>
              <rect x="8" y="30" width="20" height="14" rx="3" stroke="var(--orange)" stroke-width="1.5"/>
              <circle cx="44" cy="22" r="8" stroke="var(--orange)" stroke-width="1.5"/>
              <circle cx="44" cy="22" r="3" fill="var(--orange)"/>
              <path d="M28 15h8M28 37h8" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M36 15l8 7M36 37l8-7" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M36 22h4" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
