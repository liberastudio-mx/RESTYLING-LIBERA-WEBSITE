---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="WhatsApp Business | Presencia Digital"
  description="Configuramos WhatsApp Business para atender, organizar y dar seguimiento a contactos con mayor orden y velocidad."
>
  <div class="wa-page">

    <!-- BREADCRUMB -->
    <nav class="wa-breadcrumb container-libera" aria-label="breadcrumb">
      <a href="/soluciones">Soluciones</a>
      <span>›</span>
      <a href="/soluciones/presencia-digital">Presencia Digital</a>
      <span>›</span>
      <span aria-current="page">WhatsApp Business</span>
    </nav>

    <!-- HERO -->
    <section class="wa-hero">
      <div class="container-libera wa-hero-grid">

        <div class="wa-hero-copy" data-reveal>
          <h1 class="wa-title">
            WhatsApp Business: <em>tu canal de atención más rápido,</em> funcionando con estructura.
          </h1>
          <p class="wa-lead">
            Configuramos y optimizamos WhatsApp Business para que tu negocio atienda, filtre y dé seguimiento a contactos con orden, velocidad y sin depender de que una sola persona esté disponible todo el día.
          </p>
          <div class="wa-benefits">
            <div class="wa-benefit">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span>Atención más rápida</span>
            </div>
            <div class="wa-benefit">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.5" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              <span>Conversaciones organizadas</span>
            </div>
            <div class="wa-benefit">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Seguimiento sin perder nada</span>
            </div>
            <div class="wa-benefit">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.5" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
              <span>Más oportunidades convertidas</span>
            </div>
          </div>
        </div>

        <aside class="wa-mock" aria-hidden="true" data-reveal>

          <div class="wa-phone">
            <div class="wa-phone-frame">
              <div class="wa-phone-notch"></div>
              <div class="wa-phone-screen">

                <div class="wa-status-bar">
                  <span>11:23</span>
                  <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="16" height="10" rx="2"/><path d="M22 11v2"/></svg>
                </div>

                <div class="wa-chat-header">
                  <div class="wa-chat-avatar">M</div>
                  <div class="wa-chat-info">
                    <p class="wa-chat-name">Mi Negocio</p>
                    <p class="wa-chat-sub">Cuenta de empresa</p>
                  </div>
                </div>

                <div class="wa-chat-body">
                  <div class="wa-bubble-in">
                    <p>¡Hola! Gracias por escribirnos. ¿En qué podemos ayudarte hoy?</p>
                    <span>11:23</span>
                  </div>
                  <div class="wa-quick-replies">
                    <div class="wa-qr">Quiero más información</div>
                    <div class="wa-qr">Precios y servicios</div>
                    <div class="wa-qr">Hablar con un asesor</div>
                  </div>
                  <div class="wa-bubble-out">
                    <p>Quiero más información</p>
                    <span>11:24 ✓✓</span>
                  </div>
                  <div class="wa-bubble-in">
                    <p>Perfecto. ¿Cuál es tu consulta principal?</p>
                    <span>11:34</span>
                  </div>
                </div>

                <div class="wa-input-bar">
                  <div class="wa-input-field"></div>
                  <div class="wa-mic-btn">
                    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <div class="wa-feat-cards">
            <div class="wa-feat-card">
              <div class="wa-feat-icon wa-fi-green">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <div>
                <p class="wa-ft">Mensajes automáticos</p>
                <p class="wa-fd">Responde al instante, 24/7</p>
              </div>
            </div>
            <div class="wa-feat-card">
              <div class="wa-feat-icon wa-fi-red">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d62828" stroke-width="1.5" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              </div>
              <div>
                <p class="wa-ft">Etiquetas y filtros</p>
                <p class="wa-fd">Organiza cada conversación</p>
              </div>
            </div>
            <div class="wa-feat-card">
              <div class="wa-feat-icon wa-fi-orange">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
              </div>
              <div>
                <p class="wa-ft">Integraciones</p>
                <p class="wa-fd">Conecta con tu CRM y más</p>
              </div>
            </div>
            <div class="wa-feat-card">
              <div class="wa-feat-icon wa-fi-navy">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#003049" stroke-width="1.5" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              </div>
              <div>
                <p class="wa-ft">Métricas reales</p>
                <p class="wa-fd">Mide y mejora cada día</p>
              </div>
            </div>
          </div>

        </aside>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="wa-content">
      <div class="container-libera wa-content-grid">

        <div class="wa-body" data-reveal>

          <div class="wa-row">
            <div class="wa-row-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <p>WhatsApp ya es el canal donde muchos clientes quieren contactarte. El problema no es el canal: es lo que pasa después de que llega el mensaje.</p>
          </div>

          <div class="wa-row">
            <div class="wa-row-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <p>Sin estructura, cada conversación depende de que alguien recuerde responder, sepa qué decir, tenga la información correcta y pueda atender en el momento adecuado. Así se pierden oportunidades, se repiten respuestas, se olvidan seguimientos y el cliente termina esperando más de lo necesario.</p>
          </div>

          <div class="wa-row">
            <div class="wa-row-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </div>
            <p><strong>Convertimos WhatsApp en parte de tu sistema de atención y ventas, no en una bandeja caótica manejada como si fuera el WhatsApp personal de alguien del equipo.</strong></p>
          </div>

          <div class="wa-row">
            <div class="wa-row-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
            </div>
            <p>Configuramos mensajes de bienvenida, respuestas fuera de horario, etiquetas, flujos de calificación, plantillas de seguimiento, registro de contactos e integración con CRM o base de datos.</p>
          </div>

          <div class="wa-row">
            <div class="wa-row-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p>Cuando el volumen o la operación lo requiere, también implementamos WhatsApp Business API para automatizar procesos más avanzados y centralizar la atención del equipo. Bien configurado, WhatsApp deja de ser solo un canal de mensajes y se convierte en un punto de entrada claro, medible y conectado con tu operación comercial.</p>
          </div>

        </div>

        <div class="wa-checklist" data-reveal>
          <h2 class="wa-cl-title">Lo que construimos</h2>
          <ul class="wa-cl-list">
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>Configuración y optimización de WhatsApp Business.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8l5 3-5 3V8z"/></svg>
              <span>Implementación de WhatsApp Business API cuando el negocio lo requiere.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span>Mensajes automáticos de bienvenida, fuera de horario y confirmación.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
              <span>Flujos de calificación para filtrar leads antes de la atención humana.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              <span>Etiquetas, respuestas rápidas y estructura de atención para el equipo.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
              <span>Integración con CRM, base de datos o sistema de seguimiento.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg>
              <span>Plantillas para seguimiento, recordatorios y notificaciones.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
              <span>Panel de gestión para atender conversaciones desde un solo lugar.</span>
            </li>
            <li class="wa-cl-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f77f00" stroke-width="1.5" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              <span>Métricas de respuesta, volumen de conversaciones y oportunidades generadas.</span>
            </li>
          </ul>
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="wa-cta">
      <div class="container-libera wa-cta-inner" data-reveal>
        <div class="wa-cta-left">
          <div class="wa-cta-icon" aria-hidden="true">
            <svg width="52" height="52" viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="26" stroke="#25d366" stroke-width="1.5" fill="none"/>
              <path d="M32 14c-9.9 0-18 8.1-18 18 0 3.2 0.84 6.2 2.3 8.8L14 50l9.4-2.4A17.9 17.9 0 0 0 32 50c9.9 0 18-8.1 18-18s-8.1-18-18-18z" stroke="#25d366" stroke-width="1.2" fill="none"/>
              <line x1="26" y1="28" x2="38" y2="28" stroke="#f77f00" stroke-width="1.2" stroke-linecap="round"/>
              <line x1="26" y1="33" x2="34" y2="33" stroke="#f77f00" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="wa-cta-text">
            <p>Un WhatsApp bien configurado responde más rápido, ordena mejor las conversaciones y ayuda a convertir más oportunidades</p>
            <p class="wa-green">con el mismo equipo que ya tienes.</p>
          </div>
        </div>
        <a href="/diagnostico" class="btn-primary wa-cta-btn">Ordenar mi WhatsApp Business <span aria-hidden="true">→</span></a>
      </div>
    </section>

  </div>

  <style>
    .wa-page { background: #ffffff; color: var(--text-primary); }

    .wa-breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 1.25rem);
      font-size: 0.8rem;
      color: var(--text-secondary);
    }
    .wa-breadcrumb a { color: var(--text-secondary); transition: color 0.2s; }
    .wa-breadcrumb a:hover { color: #f77f00; }
    .wa-breadcrumb [aria-current="page"] { color: #f77f00; font-weight: 600; }

    .wa-hero {
      padding-top: clamp(4rem, calc(3vw + 2.5rem), 5rem);
      padding-bottom: clamp(2.5rem, 5vw, 4rem);
    }
    .wa-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: clamp(2rem, 4vw, 4rem);
      align-items: start;
    }


    .wa-title {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(1.75rem, 3.2vw, 2.75rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1.25rem;
      color: var(--text-primary);
    }
    .wa-title em { font-style: normal; color: #f77f00; }

    .wa-lead {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.75;
      max-width: 46ch;
      margin-bottom: 1.75rem;
    }

    .wa-benefits {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }
    .wa-benefit {
      display: flex;
      align-items: center;
      gap: 0.65rem;
    }
    .wa-benefit span {
      font-size: 0.88rem;
      color: var(--text-secondary);
      line-height: 1.3;
    }

    .wa-mock {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      align-items: start;
    }

    .wa-phone {
      display: flex;
      justify-content: center;
    }

    .wa-phone-frame {
      width: 100%;
      max-width: 13rem;
      background: #1a1a1a;
      border-radius: 1rem;
      padding: 0.5rem 0.35rem 0.7rem;
      box-shadow: 0 8px 32px rgba(0,0,0,0.28);
      position: relative;
    }

    .wa-phone-notch {
      width: 3rem;
      height: 0.4rem;
      background: #333333;
      border-radius: 999px;
      margin: 0 auto 0.5rem;
    }

    .wa-phone-screen {
      background: #ece5dd;
      border-radius: 0.6rem;
      overflow: hidden;
    }

    .wa-status-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.28rem 0.65rem;
      background: #075e54;
      font-size: 0.56rem;
      color: #ffffff;
    }

    .wa-chat-header {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.4rem 0.65rem;
      background: #075e54;
      color: #ffffff;
    }

    .wa-chat-avatar {
      width: 1.8rem;
      height: 1.8rem;
      border-radius: 50%;
      background: #25d366;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .wa-chat-info { display: flex; flex-direction: column; gap: 0.05rem; }
    .wa-chat-name { font-size: 0.7rem; font-weight: 700; margin: 0; }
    .wa-chat-sub { font-size: 0.54rem; opacity: 0.8; margin: 0; }

    .wa-chat-body {
      padding: 0.65rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      min-height: 9rem;
    }

    .wa-bubble-in {
      background: #ffffff;
      border-radius: 0 0.5rem 0.5rem 0.5rem;
      padding: 0.4rem 0.5rem 0.22rem;
      max-width: 85%;
      align-self: flex-start;
    }
    .wa-bubble-in p { font-size: 0.6rem; line-height: 1.4; color: #1a1a1a; margin: 0; }
    .wa-bubble-in span { font-size: 0.46rem; color: #999999; display: block; text-align: right; margin-top: 0.1rem; }

    .wa-bubble-out {
      background: #dcf8c6;
      border-radius: 0.5rem 0.5rem 0 0.5rem;
      padding: 0.4rem 0.5rem 0.22rem;
      max-width: 85%;
      align-self: flex-end;
    }
    .wa-bubble-out p { font-size: 0.6rem; line-height: 1.4; color: #1a1a1a; margin: 0; }
    .wa-bubble-out span { font-size: 0.46rem; color: #999999; display: block; text-align: right; margin-top: 0.1rem; }

    .wa-quick-replies {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      align-self: flex-start;
      width: 80%;
    }
    .wa-qr {
      background: #ffffff;
      border: 1px solid #25d366;
      border-radius: 999px;
      padding: 0.2rem 0.5rem;
      font-size: 0.54rem;
      color: #075e54;
      font-weight: 600;
      text-align: center;
    }

    .wa-input-bar {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.32rem 0.5rem;
      background: #f0f0f0;
    }
    .wa-input-field {
      flex: 1;
      height: 1.3rem;
      background: #ffffff;
      border-radius: 999px;
    }
    .wa-mic-btn {
      width: 1.3rem;
      height: 1.3rem;
      background: #25d366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .wa-feat-cards {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .wa-feat-card {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      padding: 0.65rem 0.75rem;
      background: #ffffff;
      border: 1px solid #e8e8e8;
      border-radius: 0.4rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .wa-feat-icon {
      width: 2.1rem;
      height: 2.1rem;
      border-radius: 0.3rem;
      background: rgba(37,211,102,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .wa-fi-red { background: rgba(214,40,40,0.08); }
    .wa-fi-orange { background: rgba(247,127,0,0.1); }
    .wa-fi-navy { background: rgba(0,48,73,0.08); }

    .wa-ft { font-size: 0.72rem; font-weight: 700; color: #1a1a1a; margin: 0 0 0.15rem; }
    .wa-fd { font-size: 0.62rem; color: #5f6368; margin: 0; line-height: 1.35; }

    .wa-content {
      padding-top: clamp(2.5rem, 5vw, 4rem);
      padding-bottom: clamp(2.5rem, 5vw, 4rem);
      background: #ffffff;
    }
    .wa-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: start;
    }

    .wa-body { display: flex; flex-direction: column; gap: 1rem; }

    .wa-row {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .wa-row-icon { flex-shrink: 0; margin-top: 0.1rem; }
