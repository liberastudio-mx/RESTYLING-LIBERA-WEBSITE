---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Productos Digitales" description="Web apps, MVPs, paneles administrativos y prototipos funcionales para construir herramientas que realmente se usan.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--productos); font-family: var(--font-mono);">Soluciones</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Productos Digitales</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Web apps, MVPs, paneles administrativos y prototipos funcionales. Construimos herramientas digitales que realmente se usan.</p>
      <a href="/soluciones" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Soluciones</a>
    </div>
  </section>
</Layout>
