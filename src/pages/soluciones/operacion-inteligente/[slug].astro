---
import Layout from '@/layouts/Layout.astro';

export const operationSections = [
  {
    slug: 'paos',
    label: 'PAOS',
    title: 'PAOS',
    description: 'La estructura interna para operar con orden: procesos, responsables, tareas recurrentes y decisiones documentadas en un sistema claro.',
    intro: 'Un PAOS ordena la manera en que trabaja tu negocio. Convierte conocimiento disperso, mensajes, archivos y decisiones en una base operativa consultable, mantenible y preparada para automatizar.',
    points: [
      'Procesos documentados sin depender de memoria individual.',
      'Roles, responsables y próximos pasos claros.',
      'Base sólida para CRM, automatizaciones y dashboards.',
    ],
  },
  {
    slug: 'automatizacion',
    label: 'Automatización',
    title: 'Automatización',
    description: 'Flujos que reducen tareas repetitivas y conectan formularios, mensajes, avisos, registros y seguimiento.',
    intro: 'Automatizamos donde hay fricción real: capturas manuales, recordatorios, traspaso de datos, respuestas repetitivas y tareas que consumen tiempo sin aportar criterio.',
    points: [
      'Menos trabajo manual en tareas repetitivas.',
      'Avisos y seguimientos ejecutados a tiempo.',
      'Flujos conectados con las herramientas que ya usas.',
    ],
  },
  {
    slug: 'crm-seguimiento',
    label: 'CRM y seguimiento',
    title: 'CRM y seguimiento',
    description: 'Un sistema simple para saber qué lead llegó, en qué estado está y cuál es el siguiente paso.',
    intro: 'Ordenamos contactos, oportunidades y clientes para que vender no dependa de buscar conversaciones viejas. Cada lead debe tener contexto, estado y seguimiento visible.',
    points: [
      'Registro claro de leads y clientes.',
      'Estados comerciales y próximos pasos definidos.',
      'Seguimiento menos improvisado y más medible.',
    ],
  },
  {
    slug: 'dashboards',
    label: 'Dashboards',
    title: 'Dashboards',
    description: 'Indicadores internos para entender qué está pasando sin pedir reportes ni revisar diez herramientas.',
    intro: 'Creamos vistas útiles para leer la operación: contactos recibidos, tareas pendientes, oportunidades abiertas, fuentes de leads y métricas que ayudan a decidir.',
    points: [
      'Indicadores clave en un solo lugar.',
      'Lectura rápida del estado operativo.',
      'Datos accionables para tomar decisiones.',
    ],
  },
  {
    slug: 'integraciones',
    label: 'Integraciones',
    title: 'Integraciones',
    description: 'Conexiones entre web, WhatsApp, formularios, CRM, hojas de cálculo, dashboards y automatizaciones.',
    intro: 'Hacemos que tus herramientas trabajen como partes del mismo sistema. La información debe moverse sin copiar y pegar, sin duplicados y sin perder contexto.',
    points: [
      'Herramientas conectadas entre sí.',
      'Menos captura manual y menos errores.',
      'Flujo de información más limpio y confiable.',
    ],
  },
];

export function getStaticPaths() {
  return operationSections.map((section) => ({
    params: { slug: section.slug },
    props: { section },
  }));
}

const { section } = Astro.props;
---

<Layout title={`${section.title} | Operación Interna`} description={section.description}>
  <main class="operation-detail-page">
    <section class="operation-detail-hero">
      <div class="container-libera operation-detail-grid">
        <div class="operation-detail-copy" data-reveal>
          <a href="/soluciones/operacion-inteligente" class="operation-back">← Operación Interna</a>
          <p class="operation-kicker">Operación Inteligente</p>
          <h1 class="display-hero operation-detail-title">{section.title}</h1>
          <p class="operation-detail-lead">{section.intro}</p>
        </div>

        <aside class="operation-detail-panel" aria-label={`Puntos clave de ${section.title}`} data-reveal>
          <p>Puntos clave</p>
          <ul>
            {section.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
          <a href="/diagnostico" class="operation-detail-cta">
            Solicitar diagnóstico
            <span aria-hidden="true">→</span>
          </a>
        </aside>
      </div>
    </section>
  </main>

  <style>
    .operation-detail-page {
      background: #ffffff;
      color: var(--text-primary);
    }

    .operation-detail-hero {
      min-height: auto;
      padding-block: calc(var(--nav-height) + clamp(3.75rem, 6vw, 5.5rem)) clamp(4rem, 7vw, 6rem);
      background: #ffffff;
    }

    .operation-detail-grid {
      display: grid;
      grid-template-columns: minmax(0, 680px) minmax(300px, 420px);
      justify-content: space-between;
      gap: clamp(2.5rem, 6vw, 6.5rem);
      align-items: start;
    }

    .operation-detail-copy {
      max-width: 680px;
    }

    .operation-back {
      display: inline-flex;
      margin-bottom: 2.25rem;
      color: var(--text-secondary);
      font-size: 0.9rem;
      transition: color 0.2s var(--ease-premium);
    }

    .operation-back:hover {
      color: var(--orange);
    }

    .operation-kicker {
      margin-bottom: 1rem;
      color: var(--orange);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .operation-detail-title {
      max-width: 11ch;
      color: var(--text-primary);
    }

    .operation-detail-lead {
      margin-top: 1.75rem;
      color: var(--text-secondary);
      font-size: 1.125rem;
      line-height: 1.7;
      max-width: 700px;
    }

    .operation-detail-panel {
      display: grid;
      gap: 1.5rem;
      padding: clamp(1.25rem, 2vw, 1.75rem);
      border: 1px solid var(--border);
      background: var(--surface);
    }

    .operation-detail-panel > p {
      color: var(--text-primary);
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 700;
    }

    .operation-detail-panel ul {
      display: grid;
      gap: 0.875rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .operation-detail-panel li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.75rem;
      color: var(--text-secondary);
      line-height: 1.55;
    }

    .operation-detail-panel li::before {
      content: '';
      width: 0.42rem;
      height: 0.42rem;
      margin-top: 0.58rem;
      border-radius: 999px;
      background: var(--orange);
    }

    .operation-detail-cta {
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 0.5rem;
      padding: 0.95rem 1rem;
      background: var(--orange);
      color: #ffffff;
      font-weight: 700;
      transition:
        transform 0.25s var(--ease-premium),
        background-color 0.25s var(--ease-premium);
    }

    .operation-detail-cta:hover {
      transform: translateY(-2px);
      background: var(--orange-dark);
    }

    @media (max-width: 820px) {
      .operation-detail-grid {
        grid-template-columns: 1fr;
      }

      .operation-detail-title {
        max-width: 100%;
      }
    }

    @media (max-width: 640px) {
      .operation-detail-hero {
        padding-block: calc(var(--nav-height) + 1.75rem) 2.5rem;
      }
    }
  </style>
</Layout>
