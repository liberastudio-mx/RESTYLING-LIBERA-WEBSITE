---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Automatización | Operación Interna"
  description="Diseñamos flujos de automatización con n8n que conectan las herramientas que ya usas. Menos tiempo en tareas repetitivas, más en lo que importa."
>
  <main class="auto-page">

    <!-- BREADCRUMB -->
    <nav class="auto-breadcrumb container-libera" aria-label="Navegación de migas de pan">
      <a href="/soluciones">Soluciones</a>
      <span aria-hidden="true">›</span>
      <a href="/soluciones/operacion-inteligente">Operación Interna</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Automatización</span>
    </nav>

    <!-- HERO -->
    <section class="auto-hero">
      <div class="container-libera auto-hero-grid">

        <div class="auto-hero-copy" data-reveal>
          <span class="auto-kicker">02 · Automatización</span>
          <h1 class="auto-title display-hero">
            <em>Automatización:</em> menos tiempo en tareas repetitivas, más en lo que importa.
          </h1>
          <div class="auto-hero-dots" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
          <p class="auto-lead">
            Automatizamos los procesos que hoy dependen de que alguien se acuerde de hacerlos: seguimientos, notificaciones, registros, reportes, respuestas, actualizaciones internas. Todo lo que pasa igual una y otra vez puede empezar a funcionar solo.
          </p>
        </div>

        <!-- Mock n8n flow -->
        <aside class="auto-mock" aria-hidden="true" data-reveal>
          <div class="flow-wrap">
            <!-- Sources -->
            <div class="flow-col flow-col--sources">
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--web">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <span>Sitio web</span>
              </div>
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--wa">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.999 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.985-1.398A9.961 9.961 0 0 0 12 22c5.523 0 10-4.477 10-10S17.522 2 12 2z"/></svg>
                </div>
                <span>WhatsApp</span>
              </div>
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--mail">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <span>Correo</span>
              </div>
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--form">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                </div>
                <span>Formularios</span>
              </div>
            </div>

            <!-- Arrows left -->
            <div class="flow-col flow-col--arrows-left">
              <span class="flow-arrow"></span>
              <span class="flow-arrow"></span>
              <span class="flow-arrow"></span>
              <span class="flow-arrow"></span>
            </div>

            <!-- Hub -->
            <div class="flow-col flow-col--hub">
              <div class="flow-hub">
                <div class="flow-hub-dots">
                  <span></span><span></span><span></span>
                  <span></span><span></span><span></span>
                  <span></span><span></span><span></span>
                </div>
                <span class="flow-hub-label">n8n</span>
              </div>
              <p class="flow-caption">La automatización trabaja<br/>en segundo plano.</p>
            </div>

            <!-- Arrows right -->
            <div class="flow-col flow-col--arrows-right">
              <span class="flow-arrow"></span>
              <span class="flow-arrow"></span>
              <span class="flow-arrow"></span>
              <span class="flow-arrow"></span>
            </div>

            <!-- Targets -->
            <div class="flow-col flow-col--targets">
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--sheets">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                </div>
                <span>Hojas de cálculo</span>
              </div>
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--crm">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <span>CRM</span>
              </div>
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--notif">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <span>Notificaciones</span>
              </div>
              <div class="flow-node">
                <div class="flow-node-icon flow-icon--db">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                </div>
                <span>Base de datos</span>
              </div>
            </div>
          </div>
        </aside>

      </div>
    </section>

    <!-- CONTENT -->
    <section class="auto-content">
      <div class="container-libera auto-content-grid">

        <div class="auto-body" data-reveal>
          <p>
            Cada negocio tiene tareas que se repiten todos los días: enviar el mensaje de bienvenida a un cliente nuevo, recordar un pago, preparar un reporte semanal, registrar un lead en una hoja de cálculo, avisar al equipo cuando entra un formulario o dar seguimiento a una solicitud que quedó pendiente.
          </p>
          <p>Alguien las hace. Una por una. Todos los días.</p>
          <p>
            Ese tiempo tiene un costo. Y los errores por olvido, copia manual o falta de seguimiento también.
          </p>
          <p>
            <strong>Diseñamos flujos de automatización con n8n que conectan las herramientas que ya usas: tu sitio web, WhatsApp, CRM, correo, formularios, hojas de cálculo o bases de datos.</strong> La automatización trabaja en segundo plano, reduce intervención manual y deja una operación más clara, rápida y fácil de sostener.
          </p>
          <p>
            No automatizamos porque esté de moda. Automatizamos donde hay fricción real: tareas repetidas, pasos manuales, información duplicada, avisos que llegan tarde o procesos que dependen demasiado de una sola persona.
          </p>
          <p>Y cuando un proceso requiere criterio humano, lo dejamos en manos humanas.</p>
        </div>

        <div class="auto-benefits" data-reveal>
          <h2 class="auto-benefits-title">Con automatización puedes:</h2>
          <ul class="auto-benefits-list">
            <li>
              <svg class="auto-ben-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Eliminar tareas repetitivas que consumen horas cada semana.
            </li>
            <li>
              <svg class="auto-ben-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              Reducir errores por olvido o captura manual de datos.
            </li>
            <li>
              <svg class="auto-ben-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Responder más rápido a leads, clientes y solicitudes.
            </li>
            <li>
              <svg class="auto-ben-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
              Conectar herramientas que hoy no se hablan entre sí.
            </li>
            <li>
              <svg class="auto-ben-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="23" y1="11" x2="23" y2="17"/><line x1="20" y1="14" x2="26" y2="14"/></svg>
              Dar seguimiento sin depender de la memoria del equipo.
            </li>
            <li>
              <svg class="auto-ben-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Liberar tiempo para trabajo que requiere criterio real.
            </li>
            <li>
              <svg class="auto-ben-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              Escalar tu operación sin contratar para cada tarea nueva.
            </li>
          </ul>
        </div>

      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="auto-cta">
      <div class="container-libera auto-cta-inner" data-reveal>
        <div class="auto-cta-copy">
          <div class="auto-cta-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="22" stroke="var(--orange)" stroke-width="1.5" fill="none"/>
              <circle cx="32" cy="32" r="14" stroke="var(--orange)" stroke-width="1.5" fill="none" opacity="0.5"/>
              <circle cx="32" cy="32" r="4" fill="var(--orange)"/>
              <line x1="32" y1="10" x2="32" y2="20" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"/>
              <line x1="32" y1="44" x2="32" y2="54" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
              <line x1="10" y1="32" x2="20" y2="32" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
              <line x1="44" y1="32" x2="54" y2="32" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
              <line x1="32" y1="32" x2="38" y2="26" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"/>
              <!-- gear teeth -->
              <path d="M54 38a4 4 0 0 1 0-8" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
              <path d="M56 30v-3l-3-1-1-3 2-2-3-3-2 2-3-1-1-3h-3l-1 3-3 1-2-2-3 3 2 2-1 3-3 1v3l3 1 1 3-2 2 3 3 2-2 3 1 1 3h3l1-3 3-1 2 2 3-3-2-2 1-3z" stroke="var(--orange)" stroke-width="1" fill="none" opacity="0.25"/>
            </svg>
          </div>
          <p class="auto-cta-text">
            Si una tarea se repite cada semana, no debería seguir consumiendo tiempo, atención y energía todos los días.
          </p>
        </div>
        <a href="/diagnostico" class="btn-primary auto-cta-btn">
          Automatizar mi operación
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

  </main>

  <style>
    .auto-page {
      background: #ffffff;
      color: var(--text-primary);
    }

    /* ── BREADCRUMB ── */
    .auto-breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 1.25rem);
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .auto-breadcrumb a {
      color: var(--text-secondary);
      transition: color 0.2s;
    }

    .auto-breadcrumb a:hover {
      color: var(--orange);
    }

    .auto-breadcrumb [aria-current="page"] {
      color: var(--orange);
      font-weight: 600;
    }

    /* ── HERO ── */
    .auto-hero {
      padding-top: clamp(4rem, calc(3vw + 2.5rem), 5rem);
      padding-bottom: clamp(3rem, 6vw, 5rem);
    }

    .auto-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: start;
    }

    .auto-kicker {
      display: inline-block;
      margin-bottom: 1.5rem;
      padding: 0.3rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      color: var(--text-secondary);
    }

    .auto-title {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      color: var(--text-primary);
      margin-bottom: 1.25rem;
    }

    .auto-title em {
      font-style: normal;
      color: var(--orange);
    }

    .auto-hero-dots {
      display: flex;
      gap: 0.35rem;
      margin-bottom: 1.25rem;
    }

    .auto-hero-dots span {
      display: block;
      width: 0.35rem;
      height: 0.35rem;
      border-radius: 50%;
      background: var(--orange);
      opacity: 0.5;
    }

    .auto-hero-dots span:first-child {
      opacity: 1;
    }

    .auto-lead {
      color: var(--text-secondary);
      font-size: clamp(0.95rem, 1.2vw, 1.05rem);
      line-height: 1.75;
      max-width: 52ch;
    }

    /* ── N8N FLOW MOCK ── */
    .auto-mock {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      padding: clamp(1.25rem, 2.5vw, 2rem);
      box-shadow: 0 4px 24px oklch(0% 0 0 / 0.07);
    }

    .flow-wrap {
      display: grid;
      grid-template-columns: auto auto 1fr auto auto;
      align-items: center;
      gap: 0.5rem;
    }

    .flow-col {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }

    .flow-col--hub {
      align-items: center;
      gap: 0.75rem;
    }

    .flow-node {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
    }

    .flow-node span {
      font-size: 0.6rem;
      color: var(--text-secondary);
      text-align: center;
      line-height: 1.2;
      max-width: 4.5rem;
    }

    .flow-node-icon {
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 0.4rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .flow-node-icon svg {
      width: 1.1rem;
      height: 1.1rem;
    }

    .flow-icon--web   { background: oklch(95% 0.02 220); color: oklch(40% 0.08 220); }
    .flow-icon--wa    { background: oklch(95% 0.04 145); color: #25d366; }
    .flow-icon--mail  { background: oklch(97% 0.03 55);  color: var(--orange); }
    .flow-icon--form  { background: oklch(95% 0.02 250); color: oklch(45% 0.1 250); }
    .flow-icon--sheets { background: oklch(95% 0.05 145); color: oklch(40% 0.12 145); }
    .flow-icon--crm   { background: oklch(95% 0.03 200); color: oklch(40% 0.1 200); }
    .flow-icon--notif { background: oklch(97% 0.03 55);  color: var(--orange); }
    .flow-icon--db    { background: oklch(95% 0.02 240); color: oklch(35% 0.05 240); }

    .flow-col--arrows-left,
    .flow-col--arrows-right {
      gap: 1rem;
    }

    .flow-arrow {
      display: block;
      width: clamp(1rem, 2vw, 1.75rem);
      height: 0.1rem;
      background: var(--orange);
      position: relative;
      opacity: 0.5;
      border-top: 2px dashed var(--orange);
      background: transparent;
    }

    .flow-arrow::after {
      content: '›';
      position: absolute;
      right: -0.4rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--orange);
      font-size: 0.8rem;
      line-height: 1;
    }

    .flow-hub {
      width: 3.5rem;
      height: 3.5rem;
      background: #003049;
      border-radius: 0.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      position: relative;
    }

    .flow-hub-dots {
      display: grid;
      grid-template-columns: repeat(3, 0.22rem);
      gap: 0.2rem;
    }

    .flow-hub-dots span {
      display: block;
      width: 0.22rem;
      height: 0.22rem;
      border-radius: 50%;
      background: var(--orange);
    }

    .flow-hub-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.05em;
    }

    .flow-caption {
      font-size: 0.6rem;
      color: var(--text-secondary);
      text-align: center;
      line-height: 1.4;
      max-width: 6rem;
      margin: 0;
    }

    /* ── CONTENT ── */
    .auto-content {
      padding-block: clamp(3rem, 6vw, 5rem);
      background: #fff;
    }

    .auto-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2.5rem, 6vw, 6rem);
      align-items: start;
    }

    .auto-body {
      display: flex;
      flex-direction: column;
      gap: 1.1rem;
    }

    .auto-body p {
      color: var(--text-secondary);
      font-size: clamp(0.9rem, 1.1vw, 1rem);
      line-height: 1.75;
    }

    .auto-body strong {
      color: var(--text-primary);
    }

    .auto-benefits-title {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2vw, 1.5rem);
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
    }

    .auto-benefits-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 1rem;
    }

    .auto-benefits-list li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.75rem;
      align-items: start;
      font-size: 0.975rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .auto-ben-icon {
      width: 1.1rem;
      height: 1.1rem;
      color: var(--orange);
      flex-shrink: 0;
      margin-top: 0.2rem;
    }

    /* ── CTA BANNER ── */
    .auto-cta {
      padding-block: clamp(2.5rem, 5vw, 4rem);
      background: #fff;
    }

    .auto-cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      padding: clamp(1.5rem, 3vw, 2.5rem);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
    }

    .auto-cta-copy {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .auto-cta-icon {
      width: 3.5rem;
      height: 3.5rem;
      flex-shrink: 0;
    }

    .auto-cta-icon svg {
      width: 100%;
      height: 100%;
    }

    .auto-cta-text {
      font-family: var(--font-display);
      font-size: clamp(1rem, 1.6vw, 1.25rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.3;
      max-width: 40ch;
    }

    .auto-cta-btn {
      white-space: nowrap;
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 1.5rem;
      font-size: 0.95rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 960px) {
      .auto-hero-grid,
      .auto-content-grid {
        grid-template-columns: 1fr;
      }

      .auto-cta-inner {
        flex-direction: column;
        align-items: flex-start;
