    .dash-alert-icon--red { color: #e74c3c; }
    .dash-alert-icon--orange { color: #e67e22; }
    .dash-alert-title { display: block; font-size: 0.58rem; font-weight: 600; color: var(--text-primary); }
    .dash-alert-sub { display: block; font-size: 0.52rem; color: var(--text-secondary); }

    .dash-pending-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: start;
