    .dash-line-chart {
      display: flex;
      gap: 0.25rem;
      height: 5rem;
    }

    .dash-y-axis {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding-bottom: 1rem;
    }

    .dash-y-axis span { font-size: 0.5rem; color: var(--text-secondary); }

    .dash-chart-area { flex: 1; display: flex; flex-direction: column; }

    .dash-chart-area svg { flex: 1; width: 100%; }

    .dash-x-axis {
      display: flex;
      justify-content: space-between;
      padding: 0.15rem 0;
    }

    .dash-x-axis span { font-size: 0.48rem; color: var(--text-secondary); }

    .dash-funnel { display: flex; flex-direction: column; gap: 0.35rem; }

    .dash-funnel-row {
