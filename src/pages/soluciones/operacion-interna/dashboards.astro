    .dash-kpi-icon--warn { color: #e67e22; }
    .dash-kpi-icon--green { color: #2ecc71; }
    .dash-kpi-value { font-family: var(--font-display); font-weight: 700; font-size: 1rem; color: var(--text-primary); line-height: 1; }
