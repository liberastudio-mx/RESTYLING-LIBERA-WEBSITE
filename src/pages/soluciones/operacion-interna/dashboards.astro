    .dash-cta-text {
      font-family: var(--font-display);
      font-size: clamp(1rem, 1.6vw, 1.25rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.3;
      max-width: 44ch;
    }

    .dash-cta-btn {
      white-space: nowrap;
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 1.5rem;
      font-size: 0.95rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .dash-hero-grid { grid-template-columns: 1fr; }
      .dash-kpi-row { grid-template-columns: repeat(2, 1fr); }
      .dash-charts-row { grid-template-columns: 1fr; }
    }

    @media (max-width: 960px) {
      .dash-content-grid { grid-template-columns: 1fr; }
      .dash-cta-inner { flex-direction: column; align-items: flex-start; }
    }

    @media (max-width: 640px) {
      .dash-kpi-row { grid-template-columns: repeat(2, 1fr); }
      .dash-lower-row { grid-template-columns: 1fr; }
      .dash-quote-inner { flex-direction: column; align-items: flex-start; }
      .dash-cta-copy { flex-direction: column; align-items: flex-start; }
      .dash-cta-btn { width: 100%; justify-content: center; }
    }
