    .dash-due--today { color: #e74c3c; }
    .dash-due--tomorrow { color: #e67e22; }
    .dash-due--2d { color: var(--text-secondary); }

    .dash-mock-link { font-size: 0.55rem; color: var(--orange); margin-top: auto; cursor: pointer; }

    /* ── CONTENT ── */
    .dash-content {
      padding-block: clamp(3rem, 6vw, 5rem);
      background: #fff;
    }

    .dash-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2.5rem, 6vw, 6rem);
