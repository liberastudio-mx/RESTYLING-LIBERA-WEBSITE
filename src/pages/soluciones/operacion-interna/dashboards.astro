    .dash-funnel-num { font-size: 0.55rem; font-weight: 700; color: var(--text-primary); text-align: right; }

    /* Lower */
    .dash-lower-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.4rem;
    }

    .dash-alerts-card,
    .dash-pending-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 0.3rem;
      padding: 0.6rem;
