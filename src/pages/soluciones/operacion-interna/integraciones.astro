---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Integraciones | Operación Interna"
  description="Conectamos las herramientas que ya usas para mover información sin duplicar datos ni copiarla manualmente entre sistemas."
>
  <div class="int-page">

    <!-- HERO -->
    <section class="int-hero">
      <div class="container-libera int-hero-grid">

        <div class="int-hero-copy">
          <h1 class="int-title display-hero">
            <em>Integraciones:</em> tus herramientas conectadas, tu operación sin fricciones
          </h1>
          <div class="int-hero-dots" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
          <p class="int-lead">
            Conectamos las herramientas que ya usas para que trabajen juntas. Sin duplicar datos, sin copiar información de un sistema a otro y sin perder detalles importantes en el camino.
          </p>
        </div>

        <!-- Mock: integration network -->
        <aside class="int-mock" aria-hidden="true">

          <div class="int-orbit-scene">

            <!-- Ring tracks -->
            <div class="int-ring-track int-ring-track--1"></div>
            <div class="int-ring-track int-ring-track--2"></div>
            <div class="int-ring-track int-ring-track--3"></div>

            <!-- Center hub: n8n -->
            <div class="int-orbit-hub">
              <div class="int-orbit-hub-glow"></div>
              <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
                <circle cx="6"  cy="16" r="4" fill="#FF6D5A"/>
                <circle cx="26" cy="8"  r="4" fill="#FF6D5A" opacity="0.8"/>
                <circle cx="26" cy="24" r="4" fill="#FF6D5A" opacity="0.6"/>
                <line x1="10" y1="16" x2="22" y2="9"  stroke="#FF6D5A" stroke-width="1.5" opacity="0.5"/>
                <line x1="10" y1="16" x2="22" y2="23" stroke="#FF6D5A" stroke-width="1.5" opacity="0.5"/>
              </svg>
              <span>n8n</span>
            </div>

            <!-- Inner orbit CW 18s r=70px: WhatsApp, Gmail, Airtable, Shopify -->
            <div class="int-oi" style="--s:0deg;   --r:70px; --d:18s">
              <div class="int-oi-chip" style="--bg:#25D366">
                <!-- WhatsApp -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.985-1.398A9.961 9.961 0 0 0 12 22c5.523 0 10-4.477 10-10S17.522 2 12 2z"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:90deg;  --r:70px; --d:18s">
              <div class="int-oi-chip" style="--bg:#EA4335">
                <!-- Gmail -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="white" stroke-width="1.3"/><path d="M2 6l10 7 10-7" stroke="white" stroke-width="1.4" fill="none"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:180deg; --r:70px; --d:18s">
              <div class="int-oi-chip" style="--bg:#FCB400">
                <!-- Airtable -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="8" rx="1.5" fill="white" opacity="0.95"/><rect x="2" y="13" width="9" height="8" rx="1.5" fill="white" opacity="0.8"/><rect x="13" y="13" width="9" height="8" rx="1.5" fill="white" opacity="0.55"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:270deg; --r:70px; --d:18s">
              <div class="int-oi-chip" style="--bg:#96BF48">
                <!-- Shopify -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M15.34 5.12c-.01-.08-.08-.13-.15-.14l-1.28-.1a3 3 0 0 0-2.91-2.38 3 3 0 0 0-2.91 2.38l-1.28.1c-.07.01-.14.06-.15.14L5.5 19.5a.5.5 0 0 0 .5.5h12a.5.5 0 0 0 .5-.5L15.34 5.12zM12 3.5a2 2 0 0 1 1.85 1.5H10.15A2 2 0 0 1 12 3.5zm2.5 9.5H9.5v-1h5v1z"/></svg>
              </div>
            </div>

            <!-- Middle orbit CCW 32s r=120px: GitHub, Maps, ClickUp, TiendaNube, Sheets -->
            <div class="int-oi int-oi--ccw" style="--s:0deg;   --r:120px; --d:32s">
              <div class="int-oi-chip" style="--bg:#24292E">
                <!-- GitHub -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.269 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.295 2.747-1.026 2.747-1.026.546 1.378.203 2.394.1 2.651.64.699 1.028 1.592 1.028 2.686 0 3.848-2.339 4.695-4.566 4.942.359.31.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
              </div>
            </div>
            <div class="int-oi int-oi--ccw" style="--s:72deg;  --r:120px; --d:32s">
              <div class="int-oi-chip" style="--bg:#EA4335">
                <!-- Google Maps -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
              </div>
            </div>
            <div class="int-oi int-oi--ccw" style="--s:144deg; --r:120px; --d:32s">
              <div class="int-oi-chip" style="--bg:#7B68EE">
                <!-- ClickUp -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M3.5 14.5L8 9.5l4 3 4-3 4.5 5-8.5 5-8.5-5z"/><path d="M3.5 9.5L8 4.5l4 3 4-3 4.5 5L12 14 3.5 9.5z" opacity=".65"/></svg>
              </div>
            </div>
            <div class="int-oi int-oi--ccw" style="--s:216deg; --r:120px; --d:32s">
              <div class="int-oi-chip" style="--bg:#3483FA">
                <!-- TiendaNube -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M18.5 11A5.5 5.5 0 0 0 8.22 8.1 4 4 0 1 0 5 15.9V16h13.5a3.5 3.5 0 0 0 0-7V11z"/><path d="M9 19h6M11 19v2M13 19v2" stroke="white" stroke-width="1.3" stroke-linecap="round"/></svg>
              </div>
            </div>
            <div class="int-oi int-oi--ccw" style="--s:288deg; --r:120px; --d:32s">
              <div class="int-oi-chip" style="--bg:#0F9D58">
                <!-- Google Sheets -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="1.5"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
              </div>
            </div>

            <!-- Outer orbit CW 52s r=170px: Stripe, Notion, Slack, Webflow, Zapier, HubSpot -->
            <div class="int-oi" style="--s:0deg;   --r:170px; --d:52s">
              <div class="int-oi-chip" style="--bg:#635BFF">
                <!-- Stripe -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M13.479 9.883c-1.626-.604-2.512-1.067-2.512-1.803 0-.609.567-1.065 1.818-1.065 1.667 0 3.197.574 3.197.574l.467-2.887S14.941 4 12.713 4C10.898 4 9.386 4.54 8.369 5.484 7.359 6.421 6.886 7.65 6.886 9.05c0 2.32 1.543 3.527 4.068 4.401 1.617.567 2.3 1.101 2.3 1.831 0 .745-.645 1.149-1.87 1.149-1.641 0-3.55-.703-3.55-.703l-.5 2.88s1.77.879 4.26.879c1.879 0 3.372-.527 4.39-1.536.983-.983 1.455-2.287 1.455-3.714-.008-2.442-1.597-3.649-3.96-4.354z"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:60deg;  --r:170px; --d:52s">
              <div class="int-oi-chip" style="--bg:#000000">
                <!-- Notion -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M4.459 4.208c.746.606 1.026.56 2.428.466l13.215-.793c.28 0 .047-.28-.046-.326L17.86 1.968c-.42-.326-.981-.7-2.055-.607L3.01 2.295c-.466.046-.56.28-.374.466l1.823 1.447zm.793 3.08v13.904c0 .747.373 1.027 1.214.98l14.523-.84c.841-.046.935-.56.935-1.167V6.354c0-.606-.233-.933-.748-.887l-15.177.887c-.56.047-.747.327-.747.933zm14.337.745c.093.42 0 .84-.42.888l-.7.14v10.264c-.608.327-1.168.514-1.635.514-.748 0-.935-.234-1.495-.933l-4.577-7.186v6.952L12.21 19s0 .84-1.168.84l-3.222.186c-.093-.186 0-.653.327-.746l.84-.233V9.854L7.822 9.76c-.094-.42.14-1.026.793-1.073l3.456-.233 4.764 7.279v-6.44l-1.215-.14c-.093-.514.28-.887.747-.933l3.222-.187z"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:120deg; --r:170px; --d:52s">
              <div class="int-oi-chip" style="--bg:#4A154B">
                <!-- Slack -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zm10.122 2.521a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.268 0a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zm-2.523 10.122a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.268a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:180deg; --r:170px; --d:52s">
              <div class="int-oi-chip" style="--bg:#4353FF">
                <!-- Webflow -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.7 3H24l-6.3 13.95L24 21h-6.3L12 10.5l-1.2 3H14l-2.4 5.25L9 21 2.1 3H8.7l3.3 8.1L14.4 3z"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:240deg; --r:170px; --d:52s">
              <div class="int-oi-chip" style="--bg:#FF4A00">
                <!-- Zapier -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M14.24 10.56l-2.4 7.2-2.4-7.2-7.2-2.4 7.2-2.4 2.4-7.2 2.4 7.2 7.2 2.4-7.2 2.4zM6 17.5l1.5-4.5L3 11.5l4.5-1.5L9 5.5l1.5 4.5 4.5 1.5-4.5 1.5L9 17.5l-1.5-4.5z"/></svg>
              </div>
            </div>
            <div class="int-oi" style="--s:300deg; --r:170px; --d:52s">
              <div class="int-oi-chip" style="--bg:#FF7A59">
                <!-- HubSpot -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M16 8.5V6.25a1.75 1.75 0 1 0-1.5 0V8.5a4.5 4.5 0 0 0-2.12 1.23l-5.4-4.2a2 2 0 1 0-.9 1.16l5.12 3.98A4.5 4.5 0 0 0 10.5 13a4.5 4.5 0 0 0 .7 2.4l-1.6 1.6a1.75 1.75 0 1 0 1.06 1.06l1.6-1.6A4.5 4.5 0 1 0 16 8.5zm-1.5 7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
              </div>
            </div>

          </div>

          <p class="int-orbit-caption">Motor de flujos · APIs · Webhooks</p>

        </aside>

      </div>
    </section>

    <!-- CONTENT -->
    <section class="int-content">
      <div class="container-libera int-content-grid">

        <div class="int-body">
          <p>La mayoría de los negocios no tiene un problema de herramientas. Tiene un problema de conexión.</p>
          <p>
            El formulario del sitio no habla con el CRM. El CRM no avisa al equipo por WhatsApp. La factura se genera en una plataforma y se registra a mano en otra. El pago entra por un sistema, pero alguien tiene que actualizar el estado en una hoja de cálculo.
          </p>
          <p>Cada vez que un dato pasa de una app a otra, alguien lo tiene que mover.</p>
          <p>
            Ese trabajo invisible acumula horas cada semana, genera errores cada mes y hace que la operación dependa demasiado de pasos manuales que podrían resolverse mejor.
          </p>
          <p>
            Diseñamos integraciones a medida entre las plataformas que ya forman parte de tu negocio: sitio web, WhatsApp Business, Google Sheets, Airtable, Notion, sistemas de facturación, pasarelas de pago, plataformas de email, CRM y cualquier herramienta que pueda conectarse mediante API o webhooks.
          </p>
          <p>
            Cuando las piezas se conectan, la información fluye mejor, el equipo trabaja con menos fricción y cada sistema deja de funcionar como una isla separada.
          </p>
        </div>

        <div class="int-features">
          <h2 class="int-features-title">Lo que construimos</h2>
          <ul class="int-features-list">
            <li>
              <svg class="int-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              Integración entre formularios del sitio y tu CRM o base de datos.
            </li>
            <li>
              <svg class="int-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Notificaciones automáticas por WhatsApp, correo o canales internos.
            </li>
            <li>
              <svg class="int-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
              Sincronización de datos entre plataformas sin intervención manual.
            </li>
            <li>
              <svg class="int-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              Conexión entre pagos, facturación y registros internos.
            </li>
            <li>
              <svg class="int-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              Flujos con APIs y webhooks para herramientas sin integración nativa.
            </li>
            <li>
              <svg class="int-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              Documentación clara para que tu equipo entienda cómo funciona cada conexión.
            </li>
            <li>
              <svg class="int-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              Estructura preparada para futuras automatizaciones y reportes.
            </li>
          </ul>
        </div>

      </div>
    </section>

    <!-- QUOTE -->
    <section class="int-quote">
      <div class="container-libera int-quote-inner">
        <div class="int-quote-icon" aria-hidden="true">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="32" cy="32" r="10" stroke="var(--orange)" stroke-width="1.5"/>
            <circle cx="32" cy="32" r="4" fill="var(--orange)"/>
            <circle cx="10" cy="20" r="5" stroke="var(--orange)" stroke-width="1.5" opacity="0.6"/>
            <circle cx="54" cy="20" r="5" stroke="var(--orange)" stroke-width="1.5" opacity="0.6"/>
            <circle cx="10" cy="44" r="5" stroke="var(--orange)" stroke-width="1.5" opacity="0.6"/>
            <circle cx="54" cy="44" r="5" stroke="var(--orange)" stroke-width="1.5" opacity="0.6"/>
            <line x1="15" y1="22" x2="23" y2="27" stroke="var(--orange)" stroke-width="1.2" stroke-dasharray="3 2" opacity="0.5"/>
            <line x1="41" y1="27" x2="49" y2="22" stroke="var(--orange)" stroke-width="1.2" stroke-dasharray="3 2" opacity="0.5"/>
            <line x1="15" y1="42" x2="23" y2="37" stroke="var(--orange)" stroke-width="1.2" stroke-dasharray="3 2" opacity="0.5"/>
            <line x1="41" y1="37" x2="49" y2="42" stroke="var(--orange)" stroke-width="1.2" stroke-dasharray="3 2" opacity="0.5"/>
          </svg>
        </div>
        <div class="int-quote-lines">
          <p>La información fluye <em>mejor.</em></p>
          <p>El equipo trabaja con <em>menos fricción.</em></p>
          <p>Cada sistema <em>deja de funcionar como una isla.</em></p>
        </div>
      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="int-cta">
      <div class="container-libera int-cta-inner">
        <div class="int-cta-copy">
          <div class="int-cta-icon" aria-hidden="true">
            <svg viewBox="0 0 72 56" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- plug -->
              <rect x="28" y="22" width="16" height="12" rx="2" stroke="var(--orange)" stroke-width="1.5"/>
              <line x1="36" y1="34" x2="36" y2="42" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"/>
              <path d="M30 22v-4M42 22v-4" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"/>
              <!-- WA bubble -->
              <circle cx="8" cy="12" r="7" stroke="var(--orange)" stroke-width="1.2" opacity="0.6"/>
              <path d="M11 8.5c0 1.5-1.5 3-3 3a3 3 0 0 1-1.4-.35L4 12l.85-2.6A3 3 0 1 1 11 8.5z" stroke="var(--orange)" stroke-width="1" fill="none" opacity="0.6"/>
              <!-- DB -->
              <ellipse cx="8" cy="44" rx="7" ry="3" stroke="var(--orange)" stroke-width="1.2" opacity="0.6"/>
              <path d="M1 44v5c0 1.66 3.13 3 7 3s7-1.34 7-3v-5" stroke="var(--orange)" stroke-width="1.2" opacity="0.6"/>
              <!-- Sheets -->
              <rect x="57" y="6" width="14" height="14" rx="1" stroke="var(--orange)" stroke-width="1.2" opacity="0.6"/>
              <line x1="57" y1="10" x2="71" y2="10" stroke="var(--orange)" stroke-width="1" opacity="0.5"/>
              <line x1="64" y1="6" x2="64" y2="20" stroke="var(--orange)" stroke-width="1" opacity="0.5"/>
              <!-- Mail -->
              <rect x="57" y="36" width="14" height="10" rx="1" stroke="var(--orange)" stroke-width="1.2" opacity="0.6"/>
              <polyline points="57,37 64,42 71,37" stroke="var(--orange)" stroke-width="1" opacity="0.5"/>
              <!-- Lines -->
              <line x1="15" y1="12" x2="28" y2="28" stroke="var(--orange)" stroke-width="1" stroke-dasharray="3 2" opacity="0.4"/>
              <line x1="15" y1="44" x2="28" y2="36" stroke="var(--orange)" stroke-width="1" stroke-dasharray="3 2" opacity="0.4"/>
              <line x1="57" y1="13" x2="44" y2="28" stroke="var(--orange)" stroke-width="1" stroke-dasharray="3 2" opacity="0.4"/>
              <line x1="57" y1="41" x2="44" y2="36" stroke="var(--orange)" stroke-width="1" stroke-dasharray="3 2" opacity="0.4"/>
