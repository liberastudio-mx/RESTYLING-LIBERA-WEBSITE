  </div>

  <style>
    .int-page {
      background: #ffffff;
      color: var(--text-primary);
    }

    /* ── BREADCRUMB ── */
    .int-breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 2.5rem);
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .int-breadcrumb a { color: var(--text-secondary); transition: color 0.2s; }
    .int-breadcrumb a:hover { color: var(--orange); }
    .int-breadcrumb [aria-current="page"] { color: var(--orange); font-weight: 600; }

    /* ── HERO ── */
    .int-hero {
      padding-top: calc(var(--nav-height) + clamp(4rem, 5vw, 5rem));
      padding-bottom: clamp(3rem, 6vw, 5rem);
    }

    .int-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: start;
    }


    .int-title {
      font-size: clamp(1.75rem, 3.5vw, 2.75rem);
      line-height: 1.1;
      color: var(--text-primary);
      margin-bottom: 1.25rem;
    }

    .int-title em { font-style: normal; color: var(--orange); }

    .int-hero-dots {
      display: flex;
      gap: 0.35rem;
      margin-bottom: 1.25rem;
    }

    .int-hero-dots span {
      display: block;
      width: 0.35rem;
      height: 0.35rem;
      border-radius: 50%;
      background: var(--orange);
      opacity: 0.5;
    }

    .int-hero-dots span:first-child { opacity: 1; }

    .int-lead {
      color: var(--text-secondary);
      font-size: clamp(0.9rem, 1.15vw, 1rem);
      line-height: 1.75;
      max-width: 44ch;
    }

    /* ── ORBITAL INTEGRATION MOCK ── */
    .int-mock {
      border: none;
      border-radius: 0.75rem;
      padding: 1.5rem 1.5rem 1.25rem;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .int-orbit-scene {
      position: relative;
      width: min(380px, 100%);
      aspect-ratio: 1;
    }

    /* static dashed ring tracks */
    .int-ring-track {
      position: absolute;
      top: 50%;
      left: 50%;
      border: 1px dashed var(--border);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }

    .int-ring-track--1 {
      width: 140px;
      height: 140px;
    }

    .int-ring-track--2 {
      width: 240px;
      height: 240px;
    }

    .int-ring-track--3 {
      width: 340px;
      height: 340px;
    }

    /* center hub */
    .int-orbit-hub {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: #fff;
      border: 2px solid var(--orange);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      z-index: 10;
    }

    .int-orbit-hub-glow {
      position: absolute;
      inset: -8px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,109,90,0.12) 0%, transparent 70%);
      pointer-events: none;
      animation: int-glow 3s ease-in-out infinite;
    }

    @keyframes int-glow {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50%       { opacity: 1;   transform: scale(1.12); }
    }

    .int-orbit-hub span {
      font-family: var(--font-mono, monospace);
      font-size: 0.55rem;
      font-weight: 700;
      color: var(--orange);
      letter-spacing: 0.02em;
      position: relative;
      z-index: 1;
    }

    /* orbiting icon elements */
    @keyframes int-orbit-cw {
      from { transform: rotate(var(--s)) translateX(var(--r)) rotate(calc(-1 * var(--s))); }
      to   { transform: rotate(calc(var(--s) + 360deg)) translateX(var(--r)) rotate(calc(-1 * var(--s) - 360deg)); }
    }

    @keyframes int-orbit-ccw {
      from { transform: rotate(var(--s)) translateX(var(--r)) rotate(calc(-1 * var(--s))); }
      to   { transform: rotate(calc(var(--s) - 360deg)) translateX(var(--r)) rotate(calc(-1 * var(--s) + 360deg)); }
    }

    .int-oi {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 42px;
      height: 42px;
      margin: -21px;
      animation: int-orbit-cw var(--d) linear infinite;
      z-index: 5;
    }

    .int-oi--ccw {
      animation-name: int-orbit-ccw;
    }

    .int-oi-chip {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--bg, #333);
      border: 1.5px solid rgba(255,255,255,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 12px rgba(0,0,0,0.4);
    }

    .int-orbit-caption {
      font-size: 0.6rem;
      color: var(--text-secondary);
      text-align: center;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
      margin: 0;
    }

    /* ── CONTENT ── */
    .int-content {
      padding-block: clamp(3rem, 6vw, 5rem);
      background: #fff;
    }

    .int-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2.5rem, 6vw, 6rem);
      align-items: start;
    }

    .int-body { display: flex; flex-direction: column; gap: 1.1rem; }

    .int-body p {
      color: var(--text-secondary);
      font-size: clamp(0.9rem, 1.1vw, 1rem);
      line-height: 1.75;
    }

    .int-features-title {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2vw, 1.5rem);
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
    }

    .int-features-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 1rem;
    }

    .int-features-list li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.75rem;
      align-items: start;
      font-size: 0.975rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .int-feat-icon {
      width: 1.1rem;
      height: 1.1rem;
      color: var(--orange);
      flex-shrink: 0;
      margin-top: 0.2rem;
    }

    /* ── QUOTE ── */
    .int-quote {
      padding-block: clamp(2.5rem, 5vw, 4rem);
      background: var(--surface-alt);
    }

    .int-quote-inner {
      display: flex;
      align-items: center;
      gap: 2rem;
      max-width: 680px;
      margin-inline: auto;
      padding: clamp(1.5rem, 3vw, 2.5rem);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      background: #fff;
    }

    .int-quote-icon { width: 4rem; height: 4rem; flex-shrink: 0; }
    .int-quote-icon svg { width: 100%; height: 100%; }

    .int-quote-lines { display: flex; flex-direction: column; gap: 0.1rem; }

    .int-quote-lines p {
      font-family: var(--font-display);
      font-size: clamp(0.95rem, 1.5vw, 1.15rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.4;
      margin: 0;
    }

    .int-quote-lines em {
      font-style: normal;
      color: var(--orange);
    }

    /* ── CTA ── */
    .int-cta {
      padding-block: clamp(2.5rem, 5vw, 4rem);
      background: #fff;
    }

    .int-cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      padding: clamp(1.5rem, 3vw, 2.5rem);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
    }

    .int-cta-copy {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .int-cta-icon { width: 4.5rem; height: 3.5rem; flex-shrink: 0; }
    .int-cta-icon svg { width: 100%; height: 100%; }

    .int-cta-text-wrap { display: flex; flex-direction: column; gap: 0.4rem; }

    .int-cta-title {
      font-family: var(--font-display);
      font-size: clamp(1rem, 1.5vw, 1.2rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.3;
      max-width: 44ch;
    }

    .int-cta-sub {
      font-size: clamp(0.85rem, 1vw, 0.95rem);
      color: var(--text-secondary);
      line-height: 1.55;
      max-width: 50ch;
    }

    .int-cta-btn {
      white-space: nowrap;
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 1.5rem;
      font-size: 0.95rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 960px) {
      .int-hero-grid,
      .int-content-grid {
        grid-template-columns: 1fr;
      }

      .int-cta-inner {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 640px) {
      .int-quote-inner {
        flex-direction: column;
        align-items: flex-start;
      }

      .int-cta-copy {
        flex-direction: column;
        align-items: flex-start;
      }

      .int-cta-btn {
        width: 100%;
        justify-content: center;
      }

      .int-diagram-top,
      .int-diagram-bottom {
        gap: 0.5rem;
      }

      .int-tool-icon {
        width: 2.25rem;
        height: 2.25rem;
      }

      .int-tool-icon svg { width: 1rem; height: 1rem; }
    }
  </style>
</Layout>
