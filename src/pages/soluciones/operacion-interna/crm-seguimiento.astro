    .crm-cta-icon { width: 3.5rem; height: 3.5rem; flex-shrink: 0; }
    .crm-cta-icon svg { width: 100%; height: 100%; }

    .crm-cta-text {
      font-family: var(--font-display);
      font-size: clamp(1rem, 1.6vw, 1.25rem);
