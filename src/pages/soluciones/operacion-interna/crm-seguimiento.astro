      .crm-cta-inner {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 640px) {
      .crm-mock-stats {
        grid-template-columns: repeat(2, 1fr);
      }

      .crm-mock-kanban {
        grid-template-columns: repeat(2, 1fr);
      }

      .crm-mock-lower {
        grid-template-columns: 1fr;
      }

      .crm-quote-inner {
        flex-direction: column;
        align-items: flex-start;
      }

      .crm-cta-copy {
        flex-direction: column;
        align-items: flex-start;
      }

      .crm-cta-btn {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</Layout>
