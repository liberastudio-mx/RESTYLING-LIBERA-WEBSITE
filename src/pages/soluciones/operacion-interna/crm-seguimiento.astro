    .crm-feat-icon {
      width: 1.1rem;
      height: 1.1rem;
      color: var(--orange);
      flex-shrink: 0;
      margin-top: 0.2rem;
    }

    /* ── QUOTE ── */
    .crm-quote {
      padding-block: clamp(2.5rem, 5vw, 4rem);
      background: var(--surface-alt);
    }

    .crm-quote-inner {
      display: flex;
      align-items: center;
      gap: 2rem;
      max-width: 680px;
      margin-inline: auto;
      padding: clamp(1.5rem, 3vw, 2.5rem);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      background: #fff;
    }

    .crm-quote-icon {
      width: 4rem;
      height: 4rem;
      flex-shrink: 0;
    }

    .crm-quote-icon svg { width: 100%; height: 100%; }

    .crm-quote-text {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    .crm-quote-text p {
      font-family: var(--font-display);
      font-size: clamp(1rem, 1.5vw, 1.2rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.35;
      margin: 0;
    }

    .crm-quote-orange { color: var(--orange) !important; }

    /* ── CTA ── */
    .crm-cta {
      padding-block: clamp(2.5rem, 5vw, 4rem);
      background: #fff;
    }

    .crm-cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      padding: clamp(1.5rem, 3vw, 2.5rem);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
    }

    .crm-cta-copy {
      display: flex;
      align-items: center;
      gap: 1.5rem;
