---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="CRM y seguimiento | Operación Interna"
  description="Diseñamos sistemas de seguimiento adaptados a tu operación real. Ningún lead se pierde, ningún cliente queda sin respuesta."
>
  <div class="crm-page">

    <!-- BREADCRUMB -->
    <nav class="crm-breadcrumb container-libera" aria-label="Navegación de migas de pan">
      <a href="/soluciones">Soluciones</a>
      <span aria-hidden="true">›</span>
      <a href="/soluciones/operacion-interna">Operación Interna</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">CRM y seguimiento</span>
    </nav>

    <!-- HERO -->
    <section class="crm-hero">
      <div class="container-libera crm-hero-grid">

        <div class="crm-hero-copy">
          <h1 class="crm-title display-hero">
            <em>CRM y seguimiento:</em> ningún lead se pierde, ningún cliente queda sin respuesta
          </h1>
          <div class="crm-hero-dots" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
          <p class="crm-lead">
            Diseñamos sistemas de seguimiento adaptados a tu operación real, no plantillas genéricas. Cada contacto entra, se registra y avanza con claridad, para que el equipo sepa qué hacer, cuándo hacerlo y en qué estado está cada oportunidad.
          </p>
        </div>

        <!-- Mock CRM dashboard -->
        <aside class="crm-mock" aria-hidden="true">
          <div class="crm-mock-header">
            <div class="crm-mock-sidebar">
              <div class="crm-mock-logo">A</div>
              <div class="crm-mock-nav">
                <span class="crm-nav-dot crm-nav-dot--active"></span>
                <span class="crm-nav-dot"></span>
                <span class="crm-nav-dot"></span>
                <span class="crm-nav-dot"></span>
                <span class="crm-nav-dot"></span>
                <span class="crm-nav-dot"></span>
                <span class="crm-nav-dot"></span>
              </div>
            </div>
            <div class="crm-mock-content">
              <div class="crm-mock-topbar">
                <span class="crm-mock-title-bar">CRM · Pipeline de ventas</span>
                <div class="crm-mock-topbar-icons">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                  <div class="crm-mock-avatar"></div>
                </div>
              </div>

              <!-- Stats row -->
              <div class="crm-mock-stats">
                <div class="crm-mock-stat">
                  <span class="crm-stat-label">Nuevos leads</span>
                  <span class="crm-stat-value">128</span>
                  <span class="crm-stat-delta up">+ 18%</span>
                  <span class="crm-stat-sub">vs. semana anterior</span>
                </div>
                <div class="crm-mock-stat">
                  <span class="crm-stat-label">En conversación</span>
                  <span class="crm-stat-value">45</span>
                  <span class="crm-stat-delta up">+ 12%</span>
                  <span class="crm-stat-sub">vs. semana anterior</span>
                </div>
                <div class="crm-mock-stat">
                  <span class="crm-stat-label">Conversión</span>
                  <span class="crm-stat-value">23%</span>
                  <span class="crm-stat-delta up">+ 6%</span>
                  <span class="crm-stat-sub">vs. semana anterior</span>
                </div>
                <div class="crm-mock-stat">
                  <span class="crm-stat-label">Ingresos estimados</span>
                  <span class="crm-stat-value">$48.5k</span>
                  <span class="crm-stat-delta up">+ 22%</span>
                  <span class="crm-stat-sub">vs. semana anterior</span>
                </div>
              </div>

              <!-- Kanban -->
              <div class="crm-mock-kanban">
                <div class="crm-kanban-col">
                  <span class="crm-kanban-head">Nuevo <em>128 leads</em></span>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">María López</span>
                    <span class="crm-card-co">Mkt Digital</span>
                    <span class="crm-card-time"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="8 5 8 8 10 9"/></svg> Hace 1 h</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Carlos Ruiz</span>
                    <span class="crm-card-co">Tienda Online</span>
                    <span class="crm-card-time"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="12" height="11" rx="1"/><line x1="2" y1="7" x2="14" y2="7"/></svg> Hace 2 h</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Ana Torres</span>
                    <span class="crm-card-co">Consultoría</span>
                    <span class="crm-card-time"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="8 5 8 8 10 9"/></svg> Hace 3 h</span>
                  </div>
                  <span class="crm-kanban-more">+ 25 más</span>
                </div>
                <div class="crm-kanban-col">
                  <span class="crm-kanban-head">En conversación <em>17 leads</em></span>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Javier Morales</span>
                    <span class="crm-card-co">Software</span>
                    <span class="crm-card-time crm-card-time--now"><svg viewBox="0 0 16 16" fill="none" stroke="#25d366" stroke-width="1.5"><path d="M13.5 8.5c0 3-2.7 5-5.5 5a5.5 5.5 0 0 1-2.6-.65L2 14l1.15-3.4A5.5 5.5 0 1 1 13.5 8.5z"/></svg> Hoy</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Lucía Gómez</span>
                    <span class="crm-card-co">Distribuidora</span>
                    <span class="crm-card-time crm-card-time--now"><svg viewBox="0 0 16 16" fill="none" stroke="#25d366" stroke-width="1.5"><path d="M13.5 8.5c0 3-2.7 5-5.5 5a5.5 5.5 0 0 1-2.6-.65L2 14l1.15-3.4A5.5 5.5 0 1 1 13.5 8.5z"/></svg> Hoy</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Diego Paredes</span>
                    <span class="crm-card-co">Agencia</span>
                    <span class="crm-card-time"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="12" height="11" rx="1"/><line x1="2" y1="7" x2="14" y2="7"/></svg> Ayer</span>
                  </div>
                  <span class="crm-kanban-more">+ 12 más</span>
                </div>
                <div class="crm-kanban-col">
                  <span class="crm-kanban-head">Cotizado <em>12 leads</em></span>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Claudia Vega</span>
                    <span class="crm-card-co">Manufactura</span>
                    <span class="crm-card-time crm-card-time--now">Hoy</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Roberto Díaz</span>
                    <span class="crm-card-co">Servicios</span>
                    <span class="crm-card-time">Ayer</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Paola Herrera</span>
                    <span class="crm-card-co">E-commerce</span>
                    <span class="crm-card-time">Ayer</span>
                  </div>
                  <span class="crm-kanban-more">+ 7 más</span>
                </div>
                <div class="crm-kanban-col">
                  <span class="crm-kanban-head">Pendiente <em>15 leads</em></span>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Fernando Gil</span>
                    <span class="crm-card-co">Importaciones</span>
                    <span class="crm-card-time crm-card-time--warn"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="8 5 8 8 10 9"/></svg> Vence mañana</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Andrea Soto</span>
                    <span class="crm-card-co">Educación</span>
                    <span class="crm-card-time crm-card-time--warn">Vence en 2 días</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Luis Martínez</span>
                    <span class="crm-card-co">Logística</span>
                    <span class="crm-card-time crm-card-time--warn">Vence en 3 días</span>
                  </div>
                  <span class="crm-kanban-more">+ 4 más</span>
                </div>
                <div class="crm-kanban-col">
                  <span class="crm-kanban-head">Cerrado <em>15 leads</em></span>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Grupo Andino</span>
                    <span class="crm-card-co">Proyecto CRM</span>
                    <span class="crm-card-badge crm-badge--won">Ganado</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Vita Home</span>
                    <span class="crm-card-co">Tienda Online</span>
                    <span class="crm-card-badge crm-badge--won">Ganado</span>
                  </div>
                  <div class="crm-kanban-card">
                    <span class="crm-card-name">Nova Tech</span>
                    <span class="crm-card-co">Web App</span>
                    <span class="crm-card-badge crm-badge--won">Ganado</span>
                  </div>
                  <span class="crm-kanban-more">+ 12 más</span>
                </div>
              </div>

              <!-- Lower panels -->
              <div class="crm-mock-lower">
                <div class="crm-mock-activity">
                  <p class="crm-mock-panel-title">Actividad reciente</p>
                  <div class="crm-activity-item">
                    <span class="crm-activity-dot crm-dot--wa"></span>
                    <div>
                      <span class="crm-act-title">Nueva respuesta de WhatsApp</span>
                      <span class="crm-act-sub">María López · Mkt Digital · Hace 10 min</span>
                    </div>
                  </div>
                  <div class="crm-activity-item">
                    <span class="crm-activity-dot crm-dot--mail"></span>
                    <div>
                      <span class="crm-act-title">Cotización enviada</span>
                      <span class="crm-act-sub">Claudia Vega · Manufactura · Hace 1 h</span>
                    </div>
                  </div>
                  <div class="crm-activity-item">
                    <span class="crm-activity-dot crm-dot--call"></span>
                    <div>
                      <span class="crm-act-title">Llamada registrada</span>
                      <span class="crm-act-sub">Javier Morales · Software · Hace 2 h</span>
                    </div>
                  </div>
                  <span class="crm-mock-link">Ver toda la actividad →</span>
                </div>
                <div class="crm-mock-tasks">
                  <p class="crm-mock-panel-title">Tareas y recordatorios</p>
                  <div class="crm-task-item">
                    <span class="crm-task-icon"></span>
                    <span class="crm-task-label">Responder a Fernando Gil</span>
                    <span class="crm-task-due crm-due--tomorrow">Vence mañana</span>
                  </div>
                  <div class="crm-task-item">
                    <span class="crm-task-icon"></span>
                    <span class="crm-task-label">Enviar propuesta a Andrea Soto</span>
                    <span class="crm-task-due crm-due--2d">Vence en 2 días</span>
                  </div>
                  <div class="crm-task-item">
                    <span class="crm-task-icon"></span>
                    <span class="crm-task-label">Llamar a Luis Martínez</span>
                    <span class="crm-task-due crm-due--3d">Vence en 3 días</span>
                  </div>
                  <span class="crm-mock-link">Ver todas mis tareas →</span>
                </div>
              </div>
            </div>
          </div>
        </aside>

      </div>
    </section>

    <!-- CONTENT -->
    <section class="crm-content">
      <div class="container-libera crm-content-grid">

        <div class="crm-body">
          <p>
            La mayoría de los negocios no pierden clientes potenciales por falta de producto ni necesariamente por precio. Los pierden porque nadie dio seguimiento a tiempo, porque el lead quedó en el WhatsApp de una sola persona, porque la cotización se envió y nadie volvió a escribir, o porque <strong>no había una forma clara de saber quién debía continuar la conversación.</strong>
          </p>
          <p><strong>Un CRM bien diseñado resuelve eso.</strong></p>
          <p>
            No hablamos del software más caro ni del sistema más complejo. Hablamos de una estructura simple, clara y útil, construida para que tu equipo la use de verdad todos los días.
          </p>
          <p>
            Creamos tu flujo de seguimiento desde el primer contacto hasta el cierre: entrada de leads, estados visibles, recordatorios automáticos, registro de interacciones y reportes simples para entender qué está pasando con tus oportunidades comerciales.
          </p>
          <p>Todo el equipo ve la misma información. Nadie trabaja de memoria. Y cada lead tiene un siguiente paso claro.</p>
        </div>

        <div class="crm-features">
          <h2 class="crm-features-title">Lo que construimos</h2>
          <ul class="crm-features-list">
            <li>
              <svg class="crm-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Flujo de seguimiento adaptado a tu proceso real de ventas.
            </li>
            <li>
              <svg class="crm-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              Estados de contacto claros: nuevo, en conversación, cotizado, pendiente, cerrado.
            </li>
            <li>
              <svg class="crm-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              Recordatorios automáticos para no perder el momento correcto de respuesta.
            </li>
            <li>
              <svg class="crm-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Registro de interacciones por canal: WhatsApp, correo, llamada o formulario.
            </li>
            <li>
              <svg class="crm-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              Reportes simples de conversión que puedes leer en pocos minutos.
            </li>
            <li>
              <svg class="crm-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 17.5h7M17.5 14v7"/></svg>
              Integración con las herramientas que tu equipo ya usa.
            </li>
            <li>
              <svg class="crm-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/></svg>
              Vista clara de oportunidades abiertas, pendientes y cerradas.
            </li>
          </ul>
        </div>

      </div>
    </section>

    <!-- QUOTE -->
    <section class="crm-quote">
      <div class="container-libera crm-quote-inner">
        <div class="crm-quote-icon" aria-hidden="true">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="28" r="10" stroke="var(--orange)" stroke-width="1.5"/>
            <circle cx="40" cy="28" r="10" stroke="var(--orange)" stroke-width="1.5" opacity="0.5"/>
            <path d="M14 48c0-5.5 4.5-10 10-10h16c5.5 0 10 4.5 10 10" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M34 42l4 4-4 4" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>
          </svg>
        </div>
        <div class="crm-quote-text">
          <p>Todo el equipo ve la misma información.</p>
          <p class="crm-quote-orange">Nadie trabaja de memoria.</p>
          <p>Y cada lead tiene un siguiente paso claro.</p>
        </div>
      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="crm-cta">
      <div class="container-libera crm-cta-inner">
        <div class="crm-cta-copy">
          <div class="crm-cta-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="8" y="10" width="36" height="44" rx="2" stroke="var(--orange)" stroke-width="1.5"/>
              <line x1="16" y1="22" x2="36" y2="22" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="16" y1="30" x2="36" y2="30" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              <line x1="16" y1="38" x2="28" y2="38" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              <circle cx="48" cy="46" r="10" stroke="var(--orange)" stroke-width="1.5" fill="none"/>
              <line x1="48" y1="42" x2="48" y2="46" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="48" y1="46" x2="51" y2="49" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="20" cy="54" r="5" stroke="var(--orange)" stroke-width="1.5" fill="none" opacity="0.4"/>
              <path d="M18 54l1.5 1.5L23 51" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
            </svg>
          </div>
          <p class="crm-cta-text">
            Si tus oportunidades dependen de quién recuerda dar seguimiento, es momento de ordenar el proceso comercial antes de perder más leads.
          </p>
        </div>
        <a href="/diagnostico" class="btn-primary crm-cta-btn">
          Ordenar mi seguimiento
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

  </div>

  <style>
    .crm-page {
      background: #ffffff;
      color: var(--text-primary);
    }

    /* ── BREADCRUMB ── */
    .crm-breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 1.25rem);
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .crm-breadcrumb a { color: var(--text-secondary); transition: color 0.2s; }
    .crm-breadcrumb a:hover { color: var(--orange); }
    .crm-breadcrumb [aria-current="page"] { color: var(--orange); font-weight: 600; }

    /* ── HERO ── */
    .crm-hero {
      padding-top: clamp(4rem, calc(3vw + 2.5rem), 5rem);
      padding-bottom: clamp(3rem, 6vw, 5rem);
    }

    .crm-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: start;
    }


    .crm-title {
      font-size: clamp(1.75rem, 3.5vw, 2.75rem);
      line-height: 1.1;
      color: var(--text-primary);
      margin-bottom: 1.25rem;
    }

    .crm-title em {
      font-style: normal;
      color: var(--orange);
    }

    .crm-hero-dots {
      display: flex;
      gap: 0.35rem;
      margin-bottom: 1.25rem;
    }

    .crm-hero-dots span {
      display: block;
      width: 0.35rem;
      height: 0.35rem;
      border-radius: 50%;
      background: var(--orange);
      opacity: 0.5;
    }

    .crm-hero-dots span:first-child { opacity: 1; }

    .crm-lead {
      color: var(--text-secondary);
      font-size: clamp(0.9rem, 1.15vw, 1rem);
      line-height: 1.75;
      max-width: 48ch;
    }

    /* ── MOCK CRM ── */
    .crm-mock {
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      overflow: hidden;
      box-shadow: 0 4px 28px oklch(0% 0 0 / 0.09);
      font-size: 0.62rem;
    }

    .crm-mock-header {
      display: flex;
      height: 100%;
    }

    .crm-mock-sidebar {
      width: 2.5rem;
      background: #003049;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0.75rem 0;
      gap: 1rem;
      flex-shrink: 0;
    }

    .crm-mock-logo {
      width: 1.4rem;
      height: 1.4rem;
      background: var(--orange);
      border-radius: 0.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.7rem;
      color: #fff;
    }

    .crm-mock-nav {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      align-items: center;
    }

    .crm-nav-dot {
      display: block;
      width: 0.9rem;
      height: 0.9rem;
      border-radius: 0.2rem;
      background: oklch(100% 0 0 / 0.15);
    }

    .crm-nav-dot--active { background: var(--orange); }

    .crm-mock-content {
      flex: 1;
      background: #fafafa;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      padding: 0.75rem;
      min-width: 0;
    }

    .crm-mock-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .crm-mock-title-bar {
      font-weight: 700;
      font-size: 0.7rem;
      color: var(--text-primary);
