    .crm-cta-btn {
      white-space: nowrap;
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 1.5rem;
      font-size: 0.95rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .crm-hero-grid {
        grid-template-columns: 1fr;
      }

      .crm-mock-kanban {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 960px) {
      .crm-content-grid {
        grid-template-columns: 1fr;
