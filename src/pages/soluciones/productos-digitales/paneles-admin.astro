---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Paneles admin | Productos Digitales"
  description="Paneles de administración conectados a tus datos reales, con vistas por rol, alertas y métricas orientadas a decisiones."
>
  <!-- Design: Hybrid | Vibe: Soft Structuralism | Layout: Editorial Split | Color: Restrained -->
  <div class="admin-page">
    <nav class="admin-breadcrumb container-libera" aria-label="Navegación de migas de pan">
      <a href="/soluciones">Soluciones</a>
      <span aria-hidden="true">›</span>
      <a href="/soluciones/productos-digitales">Productos digitales</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Paneles admin</span>
    </nav>

    <section class="admin-hero">
      <div class="container-libera admin-hero-grid">
        <div class="admin-hero-copy">
          <p class="admin-eyebrow">04 · Paneles admin</p>
          <h1 class="admin-title">
            Los números que importan,
            <em>visibles cuando los necesitas</em>
          </h1>
          <p class="admin-lead">
            Un panel de administración no es un tablero bonito. Es el lugar donde alguien toma decisiones todos los días: qué está pasando, qué está mal, qué necesita atención. Si hay que exportar a Excel para entenderlo, si los datos llegan con un día de retraso o si nadie sabe qué significa la mitad de los indicadores, el panel no está haciendo su trabajo.
          </p>

          <ul class="admin-hero-points" aria-label="Ventajas principales">
            <li><span aria-hidden="true">◇</span> Conectado a tus fuentes reales</li>
            <li><span aria-hidden="true">○</span> Vistas por rol</li>
            <li><span aria-hidden="true">◎</span> Diseño orientado a decisiones</li>
            <li><span aria-hidden="true">△</span> Alertas configurables</li>
          </ul>
        </div>

        <div class="admin-visual">
          <aside class="admin-mock" aria-hidden="true">
            <div class="admin-browser-bar">
              <div class="admin-dots"><i></i><i></i><i></i></div>
              <strong>Panel de administración</strong>
              <span>Hoy　⌄　●</span>
            </div>

            <div class="admin-app">
              <div class="admin-sidebar">
                <b>◆</b><span>⌁</span><span>♙</span><span>▱</span><span>$</span><span>⚙</span>
              </div>

              <div class="admin-workspace">
                <div class="admin-tabs"><b>Dueño</b><span>Ventas</span><span>Soporte</span></div>

                <div class="admin-kpis">
                  <div><span>Ventas del día</span><strong>$124,560</strong><small>↑ 18%</small></div>
                  <div><span>Leads nuevos</span><strong>86</strong><small>↑ 12%</small></div>
                  <div><span>Tickets abiertos</span><strong>32</strong><small class="down">↑ 8%</small></div>
                  <div><span>Conversión</span><strong>4.8%</strong><small>↑ 0.6 pp</small></div>
                  <div><span>Cobros pendientes</span><strong>$78,230</strong><small class="down">↑ 9%</small></div>
                </div>

                <div class="admin-panels">
                  <div class="admin-panel admin-trend">
                    <strong>Ventas últimos 7 días</strong>
                    <div class="admin-line-chart">
                      <span>$150k</span><span>$100k</span><span>$50k</span>
                      <svg viewBox="0 0 220 82" preserveAspectRatio="none">
                        <polyline points="0,67 35,42 70,55 105,22 140,48 176,39 220,10"></polyline>
                        <circle cx="176" cy="39" r="3"></circle>
                      </svg>
                    </div>
                  </div>

                  <div class="admin-panel">
                    <strong>Ventas por canal</strong>
                    <div class="admin-donut">
                      <i></i>
                      <ul>
                        <li><span></span>Web <b>46%</b></li>
                        <li><span></span>Referidos <b>26%</b></li>
                        <li><span></span>WhatsApp <b>18%</b></li>
                        <li><span></span>Tiendas <b>10%</b></li>
                      </ul>
                    </div>
                  </div>

                  <div class="admin-panel admin-alerts">
                    <strong>Alertas activas</strong>
                    <p><i>!</i><span>Cobros vencidos mayores a 30 días<small>$18,430 en 12 cuentas</small></span></p>
                    <p><i>!</i><span>Tickets sin respuesta &gt; 24 h<small>15 tickets</small></span></p>
                    <p><i>!</i><span>Conversión debajo del objetivo<small>4.8% (meta: 6%)</small></span></p>
                  </div>
                </div>

                <div class="admin-table">
                  <strong>Actividad reciente</strong>
                  <div><span>● Nueva venta</span><span>Orden #A-10492 por $3,450</span><span>Luis Herrera</span><span>09:24</span></div>
                  <div><span>● Ticket creado</span><span>#T-8841 · Error de acceso</span><span>María López</span><span>09:11</span></div>
                  <div><span>● Cobro recibido</span><span>Pago parcial de $2,000</span><span>Ana Torres</span><span>08:45</span></div>
                </div>
              </div>
            </div>
          </aside>

          <p class="admin-visual-caption">
            <span aria-hidden="true">▥</span>
            Indicadores definidos para <em>decidir</em>, no para decorar.
          </p>
        </div>
      </div>
    </section>

    <section class="admin-process">
      <div class="container-libera admin-process-grid">
        <article class="admin-process-column">
          <h2>Lo que construimos</h2>
          <div class="admin-sources" aria-hidden="true">
            <ul>
              <li><span>☁</span> CRM</li>
              <li><span>▾</span> Sistema de ventas</li>
              <li><span>◇</span> Tienda en línea</li>
              <li><span>▱</span> Base de datos interna</li>
            </ul>
            <div class="admin-connectors"><i></i><i></i><i></i><i></i></div>
            <div class="admin-mini-panel"><b></b><span></span><i></i></div>
          </div>
          <p>
            Paneles conectados a las fuentes de datos reales de tu negocio: tu CRM, tu sistema de ventas, tu tienda en línea, tu base de datos interna.
          </p>
          <p>
            Los indicadores los definimos contigo, basados en las preguntas que tu equipo se hace todos los días, no en los indicadores genéricos que se ven en cualquier plantilla.
          </p>
        </article>

        <article class="admin-process-column">
          <h2>Para quién es cada vista</h2>
          <ul class="admin-roles">
            <li><span aria-hidden="true">♙</span><div><strong>Resumen ejecutivo / Dueño</strong><p>Visión general del negocio: ventas, conversiones, cobros, alertas críticas.</p></div></li>
            <li><span aria-hidden="true">↗</span><div><strong>Coordinación de ventas</strong><p>Detalle por vendedor, metas vs. real, pipeline y conversión.</p></div></li>
            <li><span aria-hidden="true">Ω</span><div><strong>Soporte</strong><p>Tickets abiertos por antigüedad, tiempos de respuesta y satisfacción.</p></div></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="admin-avoid">
      <div class="container-libera">
        <h2>Lo que evitamos</h2>
        <div class="admin-avoid-grid">
          <article><span aria-hidden="true">⌁</span><strong>Gráficas que nadie consulta</strong></article>
          <article><span aria-hidden="true">↝</span><strong>Indicadores que no guían decisiones</strong></article>
          <article><span aria-hidden="true">◷</span><strong>Datos que llegan tarde</strong></article>
          <article><span aria-hidden="true">▤</span><strong>Herramientas que requieren capacitación para leer un número</strong></article>
        </div>
        <p><span aria-hidden="true">◇</span> Si no ayuda a <em>decidir</em>, no está.</p>
      </div>
    </section>

    <section class="admin-features">
      <div class="container-libera">
        <h2>Puntos clave</h2>
        <div class="admin-features-grid">
          <article class="admin-feature"><span aria-hidden="true">▱</span><div><strong>Conectado a tus fuentes de datos reales</strong><p>Actualización automática, sin exportaciones manuales.</p></div></article>
          <article class="admin-feature"><span aria-hidden="true">○</span><div><strong>Vistas por rol</strong><p>Cada usuario ve lo que le corresponde.</p></div></article>
          <article class="admin-feature"><span aria-hidden="true">◎</span><div><strong>Diseño orientado a decisiones</strong><p>No a presentaciones ni gráficas decorativas.</p></div></article>
          <article class="admin-feature"><span aria-hidden="true">△</span><div><strong>Alertas configurables</strong><p>Cuando un indicador sale del rango esperado.</p></div></article>
        </div>
      </div>
    </section>

    <section class="admin-manifesto">
      <div class="container-libera">
        <p>
          <span aria-hidden="true">◇</span>
          Si un número requiere explicación para interpretarse, hay algo que <em>rediseñar.</em>
        </p>
      </div>
    </section>

    <section class="admin-cta">
      <div class="container-libera admin-cta-card">
        <div class="admin-cta-visual" aria-hidden="true">
          <div class="admin-cta-window">
            <i></i><i></i><i></i>
            <svg viewBox="0 0 220 72" preserveAspectRatio="none">
              <polyline points="0,58 34,40 67,49 101,27 135,38 172,17 220,8"></polyline>
            </svg>
            <b></b>
            <span></span><span></span><span></span>
          </div>
          <div class="admin-cta-bell">△</div>
        </div>

        <div class="admin-cta-copy">
          <h2>
            Si tienes datos pero no claridad, un panel bien construido
            <em>cambia la forma en que opera tu equipo.</em>
          </h2>
          <p>Exploramos tu operación, entendemos qué preguntas necesitas responder y construimos un panel que te da claridad, a tiempo y sin fricción.</p>
          <div class="admin-cta-actions">
            <a href="/diagnostico" class="btn btn-primary">Solicitar diagnóstico <span aria-hidden="true">→</span></a>
            <small><span aria-hidden="true">✓</span> Sin compromiso. Respuesta en 24–48 h.</small>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .admin-page{overflow:clip;background:#fff;color:var(--text-primary)}
    .admin-breadcrumb{display:flex;align-items:center;flex-wrap:wrap;gap:.45rem;padding-top:calc(var(--nav-height) + 1.25rem);color:var(--text-secondary);font-size:.78rem}
    .admin-breadcrumb a{color:inherit}.admin-breadcrumb a:hover,.admin-breadcrumb [aria-current="page"]{color:var(--orange)}
    .admin-hero{padding:clamp(3.25rem,6vw,5.25rem) 0 clamp(3rem,5vw,4.5rem)}
    .admin-hero-grid{display:grid;grid-template-columns:minmax(18rem,.82fr) minmax(30rem,1.35fr);gap:clamp(2.5rem,5vw,5rem);align-items:center}
    .admin-eyebrow{width:fit-content;margin-bottom:1.35rem;padding:.32rem .65rem;border:1px solid var(--orange);border-radius:999px;color:var(--orange);font-family:var(--font-mono);font-size:.68rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
    .admin-title{max-width:13ch;margin:0 0 1.25rem;font-family:var(--font-display);font-size:clamp(2rem,4vw,3.15rem);font-weight:700;line-height:1.02;letter-spacing:-.035em;text-wrap:balance}
    .admin-title em{display:block;color:var(--orange);font-style:normal}
    .admin-lead{max-width:48ch;color:var(--text-secondary);font-size:clamp(.88rem,1vw,.98rem);line-height:1.68;text-wrap:pretty}
    .admin-hero-points{display:grid;gap:.6rem;margin:1.65rem 0 0;padding:0;list-style:none;font-size:.82rem}
    .admin-hero-points li{display:flex;align-items:center;gap:.65rem}
    .admin-hero-points span,.admin-feature>span{display:grid;width:1.75rem;height:1.75rem;flex:0 0 auto;place-items:center;border:1px solid oklch(84% .11 50);border-radius:50%;color:var(--orange);font-family:var(--font-mono)}
    .admin-visual{min-width:0}
    .admin-mock{overflow:hidden;border:1px solid var(--border);border-radius:.55rem;background:#f7f8fa;box-shadow:0 14px 36px oklch(20% .03 240/.11)}
    .admin-browser-bar{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;min-height:2.45rem;padding:0 .85rem;border-bottom:1px solid var(--border);background:#fff;font-size:.58rem}
    .admin-browser-bar>span{justify-self:end}.admin-dots{display:flex;gap:.32rem}.admin-dots i{width:.48rem;height:.48rem;border-radius:50%;background:#ff4d4d}.admin-dots i:nth-child(2){background:#ffad16}.admin-dots i:nth-child(3){background:#1dbb66}
    .admin-app{display:grid;grid-template-columns:3.8rem 1fr;min-height:22.5rem}.admin-sidebar{display:flex;flex-direction:column;align-items:center;gap:.62rem;padding:.8rem .4rem;background:#003b59;color:#fff;font-size:.7rem}.admin-sidebar>*{display:grid;width:2rem;height:2rem;place-items:center;border-radius:.28rem}.admin-sidebar b{background:#07599a}
    .admin-workspace{min-width:0;padding:.75rem}.admin-tabs{display:flex;gap:1.4rem;margin-bottom:.55rem;border-bottom:1px solid var(--border);font-size:.5rem}.admin-tabs>*{padding:.15rem .15rem .45rem}.admin-tabs b{border-bottom:2px solid #0b75d1}
    .admin-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:.45rem;margin-bottom:.5rem}.admin-kpis>div,.admin-panel,.admin-table{min-width:0;border:1px solid var(--border);border-radius:.3rem;background:#fff}.admin-kpis>div{display:flex;min-height:4.1rem;flex-direction:column;padding:.48rem}.admin-kpis span{color:var(--text-secondary);font-size:.43rem}.admin-kpis strong{margin-top:.32rem;font-size:.78rem;font-variant-numeric:tabular-nums}.admin-kpis small{margin-top:auto;color:#15945a;font-size:.37rem}.admin-kpis small.down{color:#e94736}
    .admin-panels{display:grid;grid-template-columns:1.1fr .9fr 1fr;gap:.5rem}.admin-panel{min-height:8.7rem;padding:.55rem}.admin-panel>strong,.admin-table>strong{display:block;margin-bottom:.4rem;font-size:.5rem}
    .admin-line-chart{position:relative;height:6.5rem;padding-left:1.7rem;background:repeating-linear-gradient(to bottom,transparent 0,transparent 1.75rem,var(--border) 1.8rem)}.admin-line-chart>span{position:absolute;left:0;color:var(--text-secondary);font-size:.34rem}.admin-line-chart>span:nth-child(2){top:2rem}.admin-line-chart>span:nth-child(3){top:4rem}.admin-line-chart svg{position:absolute;inset:.75rem .2rem .3rem 1.7rem;width:calc(100% - 1.9rem);height:calc(100% - 1.05rem);overflow:visible}.admin-line-chart polyline{fill:none;stroke:#1670e8;stroke-width:2}.admin-line-chart circle{fill:#1670e8}
    .admin-donut{display:flex;align-items:center;gap:.65rem;padding-top:.6rem}.admin-donut>i{width:4rem;height:4rem;flex:0 0 auto;border-radius:50%;background:conic-gradient(#0b75d1 0 46%,var(--orange) 46% 72%,#7a42d1 72% 90%,#16a873 90%);box-shadow:inset 0 0 0 .9rem #fff}.admin-donut ul{display:grid;width:100%;gap:.3rem;margin:0;padding:0;list-style:none;font-size:.38rem}.admin-donut li{display:flex;align-items:center;gap:.25rem}.admin-donut li>span{width:.35rem;height:.35rem;border-radius:50%;background:#0b75d1}.admin-donut li:nth-child(2)>span{background:var(--orange)}.admin-donut li:nth-child(3)>span{background:#7a42d1}.admin-donut li:nth-child(4)>span{background:#16a873}.admin-donut b{margin-left:auto}
    .admin-alerts p{display:flex;gap:.35rem;padding:.35rem 0;border-bottom:1px solid var(--border);font-size:.37rem;line-height:1.3}.admin-alerts p:last-child{border:0}.admin-alerts i{display:grid;width:.9rem;height:.9rem;flex:0 0 auto;place-items:center;border-radius:50%;background:oklch(95% .04 40);color:var(--orange);font-style:normal}.admin-alerts span{font-weight:600}.admin-alerts small{display:block;margin-top:.08rem;color:var(--text-secondary);font-weight:400}
    .admin-table{margin-top:.5rem;padding:.5rem}.admin-table>div{display:grid;grid-template-columns:1fr 1.8fr 1fr .4fr;gap:.4rem;padding:.25rem 0;border-top:1px solid var(--border);font-size:.36rem}.admin-table div span:first-child{color:#0a7551}.admin-table div span:not(:first-child){color:var(--text-secondary)}
    .admin-visual-caption{display:flex;align-items:center;justify-content:center;gap:.7rem;margin:.75rem 0 0;padding:.7rem 1rem;border:1px solid oklch(90% .06 50);border-radius:.4rem;background:oklch(98% .018 50);font-size:.8rem;font-weight:600}.admin-visual-caption span,.admin-visual-caption em{color:var(--orange);font-style:normal}
    .admin-process{padding:clamp(3.5rem,6vw,5.5rem) 0;background:var(--surface-alt)}.admin-process-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(3rem,7vw,7rem)}.admin-process-column h2,.admin-avoid h2,.admin-features h2{margin:0 0 1.5rem;font-family:var(--font-display);font-size:clamp(1.2rem,2vw,1.55rem);line-height:1.2}.admin-process-column>p{margin-top:1rem;color:var(--text-secondary);font-size:.88rem;line-height:1.62}
    .admin-sources{display:grid;grid-template-columns:1fr 2.5rem .8fr;align-items:center;margin-bottom:1.2rem}.admin-sources ul{display:grid;gap:.45rem;margin:0;padding:0;list-style:none}.admin-sources li{display:flex;align-items:center;gap:.45rem;padding:.45rem .6rem;border:1px solid var(--border);border-radius:.28rem;background:#fff;font-size:.66rem}.admin-sources li span{color:var(--orange)}.admin-connectors{display:grid;gap:1rem}.admin-connectors i{height:1px;background:#0b4f8a}.admin-mini-panel{height:5.2rem;padding:.45rem;border:1px solid #0b4f8a;border-radius:.35rem;background:#fff}.admin-mini-panel b{display:block;height:.55rem;background:#dce3e8}.admin-mini-panel span{display:inline-block;width:2.4rem;height:2.4rem;margin:.6rem .3rem 0 0;border-radius:50%;background:conic-gradient(#0b75d1 0 70%,#dfe4e8 70%)}.admin-mini-panel i{display:inline-block;width:2.4rem;height:2rem;background:linear-gradient(90deg,#dce3e8 20%,transparent 20% 32%,#0b75d1 32% 52%,transparent 52% 64%,var(--orange) 64% 84%,transparent 84%)}
    .admin-roles{display:grid;gap:.15rem;margin:0;padding:0;list-style:none}.admin-roles li{display:grid;grid-template-columns:3.3rem 1fr;gap:1rem;align-items:center;padding:.7rem 0;border-bottom:1px solid var(--border)}.admin-roles li:last-child{border:0}.admin-roles>li>span{display:grid;width:3.3rem;height:3.3rem;place-items:center;border:1px solid oklch(84% .08 240);border-radius:50%;background:oklch(95% .025 240);color:#0b75d1;font-size:1.25rem}.admin-roles li:nth-child(2)>span{border-color:oklch(84% .08 155);background:oklch(95% .025 155);color:#16a873}.admin-roles li:nth-child(3)>span{border-color:oklch(84% .08 300);background:oklch(95% .025 300);color:#7240be}.admin-roles strong{display:block;margin-bottom:.2rem;font-size:.9rem}.admin-roles p{color:var(--text-secondary);font-size:.8rem;line-height:1.5}
    .admin-avoid{padding:clamp(3rem,5vw,4.25rem) 0 1rem}.admin-avoid-grid{display:grid;grid-template-columns:repeat(4,1fr);margin-bottom:1.2rem}.admin-avoid-grid article{display:flex;align-items:center;gap:.85rem;padding:0 1.2rem;border-right:1px solid var(--border)}.admin-avoid-grid article:first-child{padding-left:0}.admin-avoid-grid article:last-child{border:0}.admin-avoid-grid span{display:grid;width:2.7rem;height:2.7rem;flex:0 0 auto;place-items:center;border:1px solid oklch(84% .11 50);border-radius:50%;color:var(--orange);font-size:1rem}.admin-avoid-grid strong{font-size:.78rem;line-height:1.4}.admin-avoid>div>p{display:flex;justify-content:center;gap:.5rem;font-weight:600}.admin-avoid>div>p span,.admin-avoid>div>p em{color:var(--orange);font-style:normal}
    .admin-features{padding:clamp(2.5rem,5vw,4rem) 0}.admin-features-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.admin-feature{display:flex;min-width:0;gap:.85rem;padding:1rem;border:1px solid var(--border);border-radius:.35rem;background:#fff}.admin-feature>span{width:2.1rem;height:2.1rem;font-size:.85rem}.admin-feature strong{display:block;margin-bottom:.28rem;font-size:.82rem;line-height:1.35}.admin-feature p{color:var(--text-secondary);font-size:.73rem;line-height:1.5}
    .admin-manifesto{padding-bottom:clamp(2.5rem,5vw,4rem)}.admin-manifesto p{display:flex;align-items:center;justify-content:center;gap:1rem;margin:0;padding:1.15rem 1.5rem;border:1px solid oklch(89% .065 50);background:oklch(98% .018 50);font-family:var(--font-display);font-size:clamp(1rem,1.8vw,1.35rem);font-weight:700;text-align:center}.admin-manifesto span,.admin-manifesto em{color:var(--orange);font-style:normal}
    .admin-cta{padding:0 0 clamp(4rem,7vw,6rem)}.admin-cta-card{display:grid;grid-template-columns:minmax(18rem,.85fr) minmax(24rem,1.15fr);gap:clamp(2rem,5vw,5rem);align-items:center;padding:clamp(1.5rem,3vw,2.5rem);border:1px solid var(--border);border-radius:.45rem;background:#fff}
    .admin-cta-visual{position:relative;display:grid;place-items:center;min-height:10rem}.admin-cta-window{position:relative;width:min(100%,21rem);height:9rem;padding:.7rem;border:1px solid #0b4f8a;border-radius:.3rem;background:#fff}.admin-cta-window>i{display:inline-block;width:.35rem;height:.35rem;margin-right:.15rem;border-radius:50%;background:#0b4f8a}.admin-cta-window svg{display:block;width:68%;height:3.6rem;margin:.65rem 0 .5rem}.admin-cta-window polyline{fill:none;stroke:#1670e8;stroke-width:2}.admin-cta-window b{position:absolute;right:1rem;top:2rem;width:3.7rem;height:3.7rem;border-radius:50%;background:conic-gradient(#0b4f8a 0 65%,#dfe4e8 65%);box-shadow:inset 0 0 0 .8rem #fff}.admin-cta-window>span{display:inline-block;width:27%;height:1.8rem;margin-right:4%;background:#edf0f2}.admin-cta-bell{position:absolute;left:7%;bottom:-.4rem;display:grid;width:3.7rem;height:3.7rem;place-items:center;border:2px solid var(--orange);border-radius:50%;background:#fff;color:var(--orange);font-size:1.3rem}
    .admin-cta-copy h2{max-width:27ch;margin:0 0 .8rem;font-family:var(--font-display);font-size:clamp(1.25rem,2.3vw,1.8rem);line-height:1.16;text-wrap:balance}.admin-cta-copy h2 em{color:var(--orange);font-style:normal}.admin-cta-copy>p{max-width:55ch;color:var(--text-secondary);font-size:.88rem;line-height:1.6}.admin-cta-actions{display:flex;align-items:center;gap:1rem;margin-top:1.25rem}.admin-cta-actions .btn{padding:.75rem 1.15rem;font-size:.84rem;white-space:nowrap}.admin-cta-actions small{color:var(--text-secondary);font-size:.7rem}.admin-cta-actions small span{color:var(--orange)}
