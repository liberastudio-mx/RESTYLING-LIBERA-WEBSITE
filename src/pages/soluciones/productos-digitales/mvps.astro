---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="MVPs | Productos Digitales"
  description="Un MVP no es una app incompleta. Es la versión mínima que prueba la hipótesis central de tu idea antes de invertir en el desarrollo completo."
>
  <!-- Design: Brand | Vibe: Soft Structuralism | Layout: Editorial Split | Color: Full Palette -->
  <div class="mvp-page">

    <!-- HERO -->
    <section class="mvp-hero">
      <div class="container-libera mvp-hero-grid">

        <div class="mvp-hero-copy">
          <h1 class="mvp-title display-hero">
            La versión más pequeña que
            <em>prueba si la idea funciona</em>
          </h1>
          <p class="mvp-lead">
            Antes de invertir seis meses en construir el producto completo, conviene saber si alguien lo va a usar. Un MVP no es una app incompleta: es la versión mínima que prueba la hipótesis central. Si la idea tiene tracción, la base ya está. Si no la tiene, descubrirlo rápido es la mejor inversión posible.
          </p>
        </div>

        <!-- Validation flow mock -->
        <aside class="mvp-mock" aria-hidden="true">
          <div class="mvp-browser">
            <div class="mvp-browser-bar">
              <span class="mvp-dot mvp-dot--red"></span>
              <span class="mvp-dot mvp-dot--yellow"></span>
              <span class="mvp-dot mvp-dot--green"></span>
              <span class="mvp-url-bar">app.mvp.co/validar</span>
            </div>
            <div class="mvp-browser-content">

              <!-- Progress header -->
              <div class="mvp-progress-header">
                <span class="mvp-progress-label">Registro rápido</span>
                <div class="mvp-steps-bar">
                  <span class="mvp-step-dot mvp-step-done"></span>
                  <span class="mvp-step-line mvp-step-line--done"></span>
                  <span class="mvp-step-dot mvp-step-done"></span>
                  <span class="mvp-step-line mvp-step-line--done"></span>
                  <span class="mvp-step-dot mvp-step-active"></span>
                  <span class="mvp-step-line"></span>
                  <span class="mvp-step-dot"></span>
                </div>
                <span class="mvp-progress-pct">Paso 3 de 4</span>
              </div>

              <!-- Form card -->
              <div class="mvp-form-card">
                <p class="mvp-form-title">¿Qué necesitas resolver?</p>
                <div class="mvp-form-field">
                  <label class="mvp-field-label">Nombre de tu negocio</label>
                  <div class="mvp-input mvp-input--filled">Studio Natura</div>
                </div>
                <div class="mvp-form-field">
                  <label class="mvp-field-label">Sector</label>
                  <div class="mvp-input mvp-input--filled">Servicios profesionales</div>
                </div>
                <div class="mvp-form-field">
                  <label class="mvp-field-label">Cuál es tu principal problema</label>
                  <div class="mvp-textarea">No tengo visibilidad sobre qué hace cada miembro...</div>
                </div>
                <span class="mvp-form-btn">Continuar →</span>
              </div>

              <!-- Metric strip -->
              <div class="mvp-metric-strip">
                <div class="mvp-metric">
                  <span class="mvp-metric-val">3 sem.</span>
                  <span class="mvp-metric-label">Entrega</span>
                </div>
                <div class="mvp-metric-sep"></div>
                <div class="mvp-metric">
                  <span class="mvp-metric-val">1 hipótesis</span>
                  <span class="mvp-metric-label">Objetivo</span>
                </div>
                <div class="mvp-metric-sep"></div>
                <div class="mvp-metric">
                  <span class="mvp-metric-val">Datos reales</span>
                  <span class="mvp-metric-label">Resultado</span>
                </div>
              </div>

            </div>
          </div>
        </aside>

      </div>
    </section>

    <!-- CONTENT: 2 columns -->
    <section class="mvp-content">
      <div class="container-libera mvp-content-grid">

        <!-- Columna izquierda -->
        <div class="mvp-col">
          <h2 class="mvp-col-title">Lo que construimos y lo que no</h2>
          <p class="mvp-col-body">
            Antes de empezar, definimos juntos cuál es la pregunta que el MVP tiene que responder y cuál es la función mínima que la responde. Todo lo demás espera.
          </p>
          <ul class="mvp-checklist">
            <li>
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="9" cy="9" r="7.5"/><path d="M6 9l2 2 4-4"/></svg>
              Validar si la idea tiene tracción real
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="9" cy="9" r="7.5"/><path d="M6 9l2 2 4-4"/></svg>
              Construir solo lo mínimo que responde la hipótesis
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="9" cy="9" r="7.5"/><path d="M6 9l2 2 4-4"/></svg>
              Entregar algo funcional en semanas, no en meses
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="9" cy="9" r="7.5"/><path d="M6 9l2 2 4-4"/></svg>
              Dejar todo lo demás para después de validar
            </li>
          </ul>
          <p class="mvp-note">
            No construimos todo lo que se nos ocurre en la primera reunión.
          </p>
        </div>

        <!-- Columna derecha -->
        <div class="mvp-col">
          <h2 class="mvp-col-title">Construimos antes de prometer</h2>
          <p class="mvp-col-body">
            Antes de vender un MVP, lo probamos nosotros mismos. Lo usamos, lo rompemos, lo ajustamos. Si hay un fallo de lógica o un flujo que no funciona, mejor descubrirlo en el estudio que frente al primer usuario.
          </p>
          <div class="mvp-quote-inline">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
              <circle cx="14" cy="14" r="13" stroke="var(--orange)" stroke-width="1.2" stroke-dasharray="3 3" opacity="0.4"/>
              <path d="M10 10v5a3 3 0 0 0 3 3h1v2l3-2h1a3 3 0 0 0 3-3v-5a3 3 0 0 0-3-3h-4a3 3 0 0 0-3 3z" stroke="var(--orange)" stroke-width="1.2" fill="none"/>
            </svg>
            <p>
              Un MVP no es una app incompleta.<br>
              <em>Es la forma más rápida de aprender.</em>
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ¿QUÉ PASA DESPUÉS? -->
    <section class="mvp-after">
      <div class="container-libera">
        <h2 class="mvp-after-title">¿Qué pasa después del MVP?</h2>
        <div class="mvp-scenarios">
          <div class="mvp-scenario mvp-scenario--a">
            <div class="mvp-scenario-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <circle cx="14" cy="14" r="12" stroke="var(--orange)" stroke-width="1.5"/>
                <path d="M9 14l3.5 3.5L19 10" stroke="var(--orange)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="mvp-scenario-title">La hipótesis se valida</h3>
            <p class="mvp-scenario-body">El MVP se convierte en la base del producto real. Construimos sobre algo que ya sabe que funciona, con usuarios reales y datos concretos.</p>
          </div>
          <div class="mvp-scenario-divider" aria-hidden="true">o</div>
          <div class="mvp-scenario mvp-scenario--b">
            <div class="mvp-scenario-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <circle cx="14" cy="14" r="12" stroke="var(--text-secondary)" stroke-width="1.5"/>
                <path d="M9 14h10M14 9l5 5-5 5" stroke="var(--text-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="mvp-scenario-title">No se valida</h3>
            <p class="mvp-scenario-body">Tienes información concreta para pivotar. El código es tuyo, documentado y limpio. No quedas atado a nosotros para el siguiente paso.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PUNTOS CLAVE -->
    <section class="mvp-features-section">
      <div class="container-libera">
        <h2 class="mvp-features-title">Puntos clave</h2>
        <div class="mvp-features-grid">
          <div class="mvp-feat">
            <svg width="24" height="24" class="mvp-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <div>
              <p class="mvp-feat-name">Enfoque en la hipótesis central</p>
              <p class="mvp-feat-desc">No en la lista de funciones. Solo construimos lo que necesitamos para validar.</p>
            </div>
          </div>
          <div class="mvp-feat">
            <svg width="24" height="24" class="mvp-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <div>
              <p class="mvp-feat-name">Entrega en semanas</p>
              <p class="mvp-feat-desc">Con usuarios reales desde el inicio, no meses de espera antes de saber si funciona.</p>
            </div>
          </div>
          <div class="mvp-feat">
            <svg width="24" height="24" class="mvp-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            <div>
              <p class="mvp-feat-name">Código transferible</p>
              <p class="mvp-feat-desc">Si quieres que otro equipo haga la segunda versión, puede tomar el proyecto sin fricción.</p>
            </div>
          </div>
          <div class="mvp-feat">
            <svg width="24" height="24" class="mvp-feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              <p class="mvp-feat-name">Sin dependencia</p>
              <p class="mvp-feat-desc">La decisión de continuar es tuya, con datos reales, sin estar atado a nosotros.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="mvp-cta">
      <div class="container-libera mvp-cta-inner">
        <div class="mvp-cta-copy">
          <div class="mvp-cta-icon" aria-hidden="true">
            <svg width="80" height="60" viewBox="0 0 80 60" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Rocket body -->
              <path d="M40 10 C40 10 50 18 52 32 L40 40 L28 32 C30 18 40 10 40 10z" stroke="var(--orange)" stroke-width="1.5" fill="none"/>
              <!-- Rocket window -->
              <circle cx="40" cy="26" r="4" stroke="var(--orange)" stroke-width="1.2" fill="none"/>
              <!-- Fins -->
              <path d="M28 32 L22 42 L32 38" stroke="var(--orange)" stroke-width="1.2" fill="none"/>
              <path d="M52 32 L58 42 L48 38" stroke="var(--orange)" stroke-width="1.2" fill="none"/>
              <!-- Flame -->
              <path d="M36 40 Q38 48 40 44 Q42 48 44 40" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6"/>
              <!-- Stars -->
              <circle cx="16" cy="14" r="1" fill="var(--orange)" opacity="0.5"/>
              <circle cx="64" cy="10" r="1.5" fill="var(--orange)" opacity="0.4"/>
              <circle cx="68" cy="28" r="1" fill="var(--orange)" opacity="0.5"/>
              <circle cx="12" cy="32" r="1" fill="var(--orange)" opacity="0.3"/>
            </svg>
          </div>
          <p class="mvp-cta-text">
            ¿Tienes una idea que quieres probar sin apostar todo a ella?<br>
            <em>Es exactamente para lo que sirve un MVP.</em>
          </p>
        </div>
        <a href="/diagnostico" class="btn btn-primary mvp-cta-btn">
          Hablar del proyecto
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

  </div>

  <style>
    .mvp-page {
      background: #fff;
      color: var(--text-primary);
    }

    /* ── BREADCRUMB ── */
    .mvp-breadcrumb {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 2.5rem);
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .mvp-breadcrumb a { color: var(--text-secondary); transition: color 0.2s; }
    .mvp-breadcrumb a:hover { color: var(--orange); }
    .mvp-breadcrumb [aria-current="page"] { color: var(--orange); font-weight: 600; }

    /* ── HERO ── */
    .mvp-hero {
      padding-top: calc(var(--nav-height) + clamp(4rem, 5vw, 5rem));
      padding-bottom: clamp(3rem, 6vw, 5rem);
    }

    .mvp-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: start;
    }

    .mvp-title {
      font-size: clamp(1.75rem, 3.5vw, 2.75rem);
      line-height: 1.1;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
    }

    .mvp-title em { font-style: normal; color: var(--orange); }

    .mvp-lead {
      color: var(--text-secondary);
      font-size: clamp(0.9rem, 1.15vw, 1rem);
      line-height: 1.75;
      max-width: 46ch;
    }

    /* ── BROWSER MOCK ── */
    .mvp-mock {
      min-width: 0;
      border-radius: 0.5rem;
      overflow: hidden;
      box-shadow: 0 8px 40px oklch(0% 0 0 / 0.12);
      border: 1px solid var(--border);
    }

    .mvp-browser-bar {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 0.75rem;
      background: #f0f0f0;
      border-bottom: 1px solid var(--border);
    }

    .mvp-dot {
      display: block;
      width: 0.55rem;
      height: 0.55rem;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .mvp-dot--red    { background: #ff5f57; }
    .mvp-dot--yellow { background: #febc2e; }
    .mvp-dot--green  { background: #28c840; }

    .mvp-url-bar {
      margin-left: 0.5rem;
      font-size: 0.5rem;
      color: #888;
      background: #e8e8e8;
      padding: 0.15rem 0.5rem;
      border-radius: 2rem;
      font-family: var(--font-mono, monospace);
    }

    .mvp-browser-content {
      background: #f7f8fa;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    /* Progress header */
    .mvp-progress-header {
      background: #fff;
      border-bottom: 1px solid var(--border);
      padding: 0.6rem 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .mvp-progress-label {
      font-size: 0.55rem;
      font-weight: 700;
      color: var(--text-primary);
      white-space: nowrap;
    }

    .mvp-steps-bar {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 0.2rem;
    }

    .mvp-step-dot {
      display: block;
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
    }

    .mvp-step-dot.mvp-step-done   { background: var(--orange); }
    .mvp-step-dot.mvp-step-active { background: var(--orange); box-shadow: 0 0 0 2px oklch(90% 0.08 55); }

    .mvp-step-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .mvp-step-line--done { background: var(--orange); }

    .mvp-progress-pct {
      font-size: 0.48rem;
      color: var(--text-secondary);
      white-space: nowrap;
    }

    /* Form card */
    .mvp-form-card {
      background: #fff;
      margin: 0.75rem;
      border: 1px solid var(--border);
      border-radius: 0.35rem;
      padding: 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .mvp-form-title {
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0 0 0.2rem;
    }

    .mvp-form-field {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .mvp-field-label {
      font-size: 0.45rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .mvp-input {
      font-size: 0.52rem;
      padding: 0.3rem 0.4rem;
      border: 1px solid var(--border);
      border-radius: 0.2rem;
      color: var(--text-primary);
      background: #fff;
    }

    .mvp-input--filled { background: #fafafa; }

    .mvp-textarea {
      font-size: 0.48rem;
      padding: 0.3rem 0.4rem;
      border: 1px solid var(--border);
      border-radius: 0.2rem;
      color: var(--text-secondary);
      background: #fff;
      min-height: 1.5rem;
      line-height: 1.4;
    }

    .mvp-form-btn {
      align-self: flex-end;
      padding: 0.3rem 0.75rem;
      background: var(--orange);
      color: #fff;
      border-radius: 0.2rem;
      font-size: 0.52rem;
      font-weight: 600;
      border: none;
      cursor: default;
    }

    /* Metric strip */
    .mvp-metric-strip {
      display: flex;
      align-items: center;
      background: #003049;
      padding: 0.5rem 0.75rem;
      gap: 0.75rem;
    }

    .mvp-metric {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
      flex: 1;
      align-items: center;
    }

    .mvp-metric-val   { font-size: 0.62rem; font-weight: 700; color: #fff; }
    .mvp-metric-label { font-size: 0.45rem; color: rgba(255,255,255,0.55); }

    .mvp-metric-sep {
      width: 1px;
      height: 1.5rem;
      background: rgba(255,255,255,0.15);
      flex-shrink: 0;
    }

    /* ── CONTENT ── */
    .mvp-content {
      padding-block: clamp(3rem, 6vw, 5rem);
      background: var(--surface-alt);
    }

    .mvp-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2.5rem, 6vw, 6rem);
      align-items: start;
    }

    .mvp-col-title {
      font-family: var(--font-display);
      font-size: clamp(1.15rem, 2vw, 1.4rem);
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.875rem;
    }

    .mvp-col-body {
      color: var(--text-secondary);
      font-size: 0.975rem;
      line-height: 1.7;
      margin-bottom: 1.25rem;
    }

    .mvp-checklist {
      list-style: none;
      margin: 0 0 1.25rem;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .mvp-checklist li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.65rem;
      align-items: start;
      font-size: 0.975rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .mvp-checklist svg { color: var(--orange); flex-shrink: 0; margin-top: 0.1rem; }

    .mvp-note {
      font-size: 0.875rem;
      color: var(--text-secondary);
      line-height: 1.7;
      padding: 0.875rem 1rem;
      border: 1px solid oklch(88% 0.07 50);
      border-radius: 0.5rem;
      background: oklch(98% 0.015 50);
      margin: 0;
    }

    /* Quote inline */
    .mvp-quote-inline {
      display: flex;
      gap: 0.875rem;
      align-items: flex-start;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      padding: 1rem 1.25rem;
      margin-top: 1.25rem;
    }

    .mvp-quote-inline svg { flex-shrink: 0; margin-top: 0.1rem; }

    .mvp-quote-inline p {
      font-family: var(--font-display);
      font-size: clamp(0.95rem, 1.4vw, 1.1rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.4;
      margin: 0;
    }

    .mvp-quote-inline em { font-style: normal; color: var(--orange); }

    /* ── DESPUÉS DEL MVP ── */
    .mvp-after {
      padding-block: clamp(3rem, 6vw, 5rem);
      background: #fff;
    }

    .mvp-after-title {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2vw, 1.5rem);
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 2rem;
    }

    .mvp-scenarios {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 1.5rem;
      align-items: center;
    }

    .mvp-scenario {
      padding: 1.5rem;
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .mvp-scenario--a { border-color: oklch(88% 0.07 50); background: oklch(98% 0.015 50); }
    .mvp-scenario--b { background: #fff; }

    .mvp-scenario-icon { display: flex; }

    .mvp-scenario-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
    }

    .mvp-scenario-body {
      font-size: 0.9rem;
      color: var(--text-secondary);
      line-height: 1.65;
      margin: 0;
    }

    .mvp-scenario-divider {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-secondary);
      text-align: center;
      opacity: 0.4;
      flex-shrink: 0;
    }

    /* ── FEATURES ── */
    .mvp-features-section {
      padding-block: clamp(3rem, 6vw, 5rem);
      background: var(--surface-alt);
    }

