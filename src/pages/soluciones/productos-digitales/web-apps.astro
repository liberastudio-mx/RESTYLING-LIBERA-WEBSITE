---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Web Apps | Productos Digitales"
  description="Una web app construida para ti hace exactamente lo que necesitas. Sin límites, sin funciones que estorban, funciona en el navegador y escala con tu operación."
>
  <div class="webapp-page">

    <!-- HERO -->
    <section class="webapp-hero">
      <div class="container-libera webapp-hero-grid">

        <div class="webapp-hero-copy">
          <h1 class="webapp-title display-hero">
            Una herramienta hecha para cómo
            <em>trabaja tu negocio</em>
          </h1>
          <p class="webapp-lead">
            Las apps genéricas hacen de todo para todos. Una web app construida para ti hace exactamente lo que necesitas, sin funciones que estorban y sin límites que te obligan a adaptarte a la herramienta en lugar de al revés. Funciona en el navegador, no requiere instalación y escala con tu operación.
          </p>
        </div>

        <!-- Dashboard mock -->
        <aside class="webapp-mock" aria-hidden="true">
          <div class="webapp-browser">
            <div class="webapp-browser-bar">
              <span class="webapp-dot webapp-dot--red"></span>
              <span class="webapp-dot webapp-dot--yellow"></span>
              <span class="webapp-dot webapp-dot--green"></span>
              <span class="webapp-url-bar">app.tuempresa.com/dashboard</span>
            </div>
            <div class="webapp-browser-content">

              <div class="webapp-app-layout">
                <!-- Sidebar -->
                <nav class="webapp-app-sidebar">
                  <div class="webapp-app-logo">OPERACIÓN</div>
                  <ul class="webapp-nav-list">
                    <li class="webapp-nav-item webapp-nav-active">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" style="flex-shrink:0"><rect x="1" y="1" width="4" height="4" rx="0.4"/><rect x="7" y="1" width="4" height="4" rx="0.4"/><rect x="1" y="7" width="4" height="4" rx="0.4"/><rect x="7" y="7" width="4" height="4" rx="0.4"/></svg>
                      Dashboard
                    </li>
                    <li class="webapp-nav-item">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" style="flex-shrink:0"><path d="M6 1a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/><path d="M10 11a4 4 0 0 0-8 0"/></svg>
                      Clientes
                    </li>
                    <li class="webapp-nav-item">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" style="flex-shrink:0"><polyline points="1 10 4 6 6 8 9 4 11 6"/></svg>
                      Reportes
                    </li>
                    <li class="webapp-nav-item">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" style="flex-shrink:0"><circle cx="6" cy="6" r="4"/><path d="M6 4v2l1.5 1"/></svg>
                      Historial
                    </li>
                  </ul>
                </nav>

                <!-- Main content -->
                <div class="webapp-app-main">
                  <div class="webapp-app-header">
                    <span class="webapp-app-title">Dashboard</span>
                    <span class="webapp-app-date">Jun 2025</span>
                  </div>

                  <!-- KPIs -->
                  <div class="webapp-kpi-row">
                    <div class="webapp-kpi">
                      <span class="webapp-kpi-label">Solicitudes</span>
                      <span class="webapp-kpi-val">128</span>
                      <span class="webapp-kpi-delta webapp-up">+12%</span>
                    </div>
                    <div class="webapp-kpi">
                      <span class="webapp-kpi-label">En proceso</span>
                      <span class="webapp-kpi-val">64</span>
                      <span class="webapp-kpi-delta webapp-neu">—</span>
                    </div>
                    <div class="webapp-kpi">
                      <span class="webapp-kpi-label">Ingresos</span>
                      <span class="webapp-kpi-val">$1.24K</span>
                      <span class="webapp-kpi-delta webapp-up">+8%</span>
                    </div>
                  </div>

                  <!-- Mini chart -->
                  <div class="webapp-chart-wrap">
                    <div class="webapp-chart-label">Actividad semanal</div>
                    <div class="webapp-bars">
                      <div class="webapp-bar" style="height:35%"></div>
                      <div class="webapp-bar" style="height:55%"></div>
                      <div class="webapp-bar" style="height:42%"></div>
                      <div class="webapp-bar" style="height:70%"></div>
                      <div class="webapp-bar" style="height:60%"></div>
                      <div class="webapp-bar webapp-bar--hi" style="height:90%"></div>
                      <div class="webapp-bar" style="height:75%"></div>
                    </div>
                  </div>

                  <!-- Recent list -->
                  <div class="webapp-list-wrap">
                    <div class="webapp-list-row webapp-list-head">
                      <span>Solicitud</span><span>Estado</span><span>Resp.</span>
                    </div>
                    <div class="webapp-list-row">
                      <span>#0044 — Contrato B</span>
                      <span class="webapp-tag webapp-tag--green">Activo</span>
                      <span>M. López</span>
                    </div>
                    <div class="webapp-list-row">
                      <span>#0043 — Revisión</span>
                      <span class="webapp-tag webapp-tag--orange">Pendiente</span>
                      <span>A. Torres</span>
                    </div>
                    <div class="webapp-list-row">
                      <span>#0042 — Alta cliente</span>
                      <span class="webapp-tag webapp-tag--green">Activo</span>
                      <span>M. López</span>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </aside>

      </div>
    </section>

    <!-- CONTENT -->
    <section class="webapp-content">
      <div class="container-libera webapp-content-grid">

        <div class="webapp-col">
          <h2 class="webapp-col-title">Cuándo tiene sentido construir una</h2>
          <ul class="webapp-reasons-list">
            <li>
              <svg class="webapp-icon-bullet" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4"/></svg>
              Cuando ninguna herramienta existente hace exactamente lo que necesitas.
            </li>
            <li>
              <svg class="webapp-icon-bullet" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4"/></svg>
              Cuando usas tres apps distintas para algo que debería vivir en una sola.
            </li>
            <li>
              <svg class="webapp-icon-bullet" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4"/></svg>
              Cuando tu equipo trabaja con hojas de cálculo que ya se volvieron insostenibles.
            </li>
            <li>
              <svg class="webapp-icon-bullet" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4"/></svg>
              Cuando tienes un proceso tan específico de tu negocio que ningún SaaS lo modela bien.
            </li>
          </ul>
          <p class="webapp-note">
            No construimos apps por construir. Si hay una herramienta existente que resuelve el problema, te lo decimos antes de escribir una línea de código.
          </p>
        </div>

        <div class="webapp-col">
          <h2 class="webapp-col-title">Cómo las construimos</h2>
          <div class="webapp-steps">
            <div class="webapp-step-item">
              <span class="webapp-step-num">01</span>
              <div>
                <p class="webapp-step-name">Entendemos el proceso</p>
                <p class="webapp-step-desc">Empezamos por entender el proceso, no por elegir la tecnología. Definimos juntos qué hace la app, quién la usa y qué datos maneja.</p>
              </div>
            </div>
            <div class="webapp-step-item">
              <span class="webapp-step-num">02</span>
              <div>
                <p class="webapp-step-name">Construimos lo que importa</p>
                <p class="webapp-step-desc">Primero lo prioritario, lo probamos con usuarios reales y ajustamos antes de agregar más funcionalidad.</p>
              </div>
            </div>
            <div class="webapp-step-item">
              <span class="webapp-step-num">03</span>
              <div>
                <p class="webapp-step-name">Entregamos código limpio</p>
                <p class="webapp-step-desc">Documentado y transferible: si en algún momento quieres que otro equipo lo tome, puede.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- FEATURES -->
    <section class="webapp-features-section">
      <div class="container-libera">
        <h2 class="webapp-features-title">Puntos clave</h2>
        <div class="webapp-features-grid">
          <div class="webapp-feat">
            <svg class="webapp-feat-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            <div>
              <p class="webapp-feat-name">Tecnología moderna, código 100% original</p>
              <p class="webapp-feat-desc">Sin plantillas disfrazadas.</p>
            </div>
          </div>
          <div class="webapp-feat">
            <svg class="webapp-feat-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.74"/></svg>
            <div>
              <p class="webapp-feat-name">Acceso por roles</p>
              <p class="webapp-feat-desc">Cada usuario ve exactamente lo que necesita ver.</p>
            </div>
          </div>
          <div class="webapp-feat">
            <svg class="webapp-feat-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="14" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
            <div>
              <p class="webapp-feat-name">Diseño funcional desde el primer día</p>
              <p class="webapp-feat-desc">No maquetas que nunca se usan.</p>
            </div>
          </div>
          <div class="webapp-feat">
            <svg class="webapp-feat-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
            <div>
              <p class="webapp-feat-name">Documentación técnica incluida</p>
              <p class="webapp-feat-desc">En cada entrega, sin coste adicional.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="webapp-cta">
      <div class="container-libera webapp-cta-inner">
        <div class="webapp-cta-copy">
          <div class="webapp-cta-icon" aria-hidden="true">
            <svg width="80" height="60" viewBox="0 0 80 60" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="6" width="52" height="36" rx="2" stroke="var(--orange)" stroke-width="1.5"/>
              <line x1="4" y1="14" x2="56" y2="14" stroke="var(--orange)" stroke-width="1.2"/>
              <line x1="30" y1="42" x2="30" y2="48" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="18" y1="48" x2="42" y2="48" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="4" y1="14" x2="4" y2="42" stroke="var(--orange)" stroke-width="1" opacity="0.3"/>
              <line x1="16" y1="14" x2="16" y2="42" stroke="var(--orange)" stroke-width="1" opacity="0.2"/>
              <rect x="20" y="18" width="10" height="4" rx="0.5" stroke="var(--orange)" stroke-width="1" opacity="0.5"/>
              <rect x="32" y="18" width="10" height="4" rx="0.5" stroke="var(--orange)" stroke-width="1" opacity="0.5"/>
              <line x1="20" y1="26" x2="50" y2="26" stroke="var(--orange)" stroke-width="1" opacity="0.3"/>
              <line x1="20" y1="29" x2="44" y2="29" stroke="var(--orange)" stroke-width="1" opacity="0.25"/>
              <line x1="20" y1="32" x2="48" y2="32" stroke="var(--orange)" stroke-width="1" opacity="0.25"/>
              <circle cx="65" cy="42" r="9" fill="var(--orange)"/>
              <path d="M61 42l2.5 2.5 4.5-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="webapp-cta-text">
            Si tienes un proceso que ya no cabe en una hoja de cálculo, <em>hay algo que podemos construir.</em>
          </p>
        </div>
        <a href="/diagnostico" class="btn-primary webapp-cta-btn">
          Hablar del proyecto
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

  </div>

  <style>
    .webapp-page { background: #fff; color: var(--text-primary); }

    .webapp-breadcrumb {
      display: flex; align-items: center; gap: 0.5rem;
      padding-top: calc(var(--nav-height) + 2.5rem);
      font-size: 0.8rem; color: var(--text-secondary);
    }
    .webapp-breadcrumb a { color: var(--text-secondary); transition: color 0.2s; }
    .webapp-breadcrumb a:hover { color: var(--orange); }
    .webapp-breadcrumb [aria-current="page"] { color: var(--orange); font-weight: 600; }

    /* ── HERO ── */
    .webapp-hero {
      padding-top: calc(var(--nav-height) + clamp(4rem, 5vw, 5rem));
      padding-bottom: clamp(3rem, 6vw, 5rem);
    }
    .webapp-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: start;
    }
    .webapp-title {
      font-size: clamp(1.75rem, 3.5vw, 2.75rem);
      line-height: 1.1; color: var(--text-primary); margin-bottom: 1.5rem;
    }
    .webapp-title em { font-style: normal; color: var(--orange); }
    .webapp-lead {
      color: var(--text-secondary);
      font-size: clamp(0.9rem, 1.15vw, 1rem);
      line-height: 1.75; max-width: 46ch;
    }

    /* ── BROWSER MOCK ── */
    .webapp-mock {
      border-radius: 0.5rem; overflow: hidden;
      box-shadow: 0 8px 40px oklch(0% 0 0 / 0.12);
      border: 1px solid var(--border);
    }
    .webapp-browser-bar {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.5rem 0.75rem; background: #f0f0f0;
      border-bottom: 1px solid var(--border);
    }
    .webapp-dot { display: block; width: 0.55rem; height: 0.55rem; border-radius: 50%; flex-shrink: 0; }
    .webapp-dot--red    { background: #ff5f57; }
    .webapp-dot--yellow { background: #febc2e; }
    .webapp-dot--green  { background: #28c840; }
    .webapp-url-bar {
      margin-left: 0.5rem; font-size: 0.5rem; color: #888;
      background: #e8e8e8; padding: 0.15rem 0.5rem;
      border-radius: 2rem; font-family: var(--font-mono, monospace);
    }
    .webapp-browser-content { background: #f7f8fa; overflow: hidden; }

    /* App layout */
    .webapp-app-layout { display: grid; grid-template-columns: 5rem 1fr; min-height: 16rem; }
    .webapp-app-sidebar {
      background: #003049; padding: 0.75rem 0;
      display: flex; flex-direction: column; gap: 0.1rem;
    }
    .webapp-app-logo {
      font-size: 0.42rem; font-weight: 800; color: #fff; letter-spacing: 0.06em;
      padding: 0.3rem 0.6rem 0.6rem;
      border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 0.4rem;
    }
    .webapp-nav-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.1rem; }
    .webapp-nav-item {
      display: flex; align-items: center; gap: 0.35rem;
      padding: 0.35rem 0.6rem; font-size: 0.52rem; color: rgba(255,255,255,0.6);
    }
    .webapp-nav-active { background: rgba(255,255,255,0.12); color: #fff; border-radius: 0.2rem; }
    .webapp-app-main { padding: 0.7rem; display: flex; flex-direction: column; gap: 0.6rem; background: #fff; }
    .webapp-app-header { display: flex; justify-content: space-between; align-items: baseline; }
    .webapp-app-title { font-size: 0.7rem; font-weight: 700; color: var(--text-primary); }
    .webapp-app-date  { font-size: 0.5rem; color: var(--text-secondary); }
    .webapp-kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.4rem; }
    .webapp-kpi {
      background: #f7f8fa; border: 1px solid var(--border); border-radius: 0.25rem;
      padding: 0.45rem; display: flex; flex-direction: column; gap: 0.1rem;
    }
    .webapp-kpi-label { font-size: 0.48rem; color: var(--text-secondary); }
    .webapp-kpi-val   { font-size: 0.85rem; font-weight: 800; color: var(--text-primary); line-height: 1; }
    .webapp-kpi-delta { font-size: 0.45rem; font-weight: 600; }
    .webapp-up  { color: #22c55e; }
    .webapp-neu { color: var(--text-secondary); }
    .webapp-chart-wrap { background: #f7f8fa; border: 1px solid var(--border); border-radius: 0.25rem; padding: 0.45rem; }
    .webapp-chart-label { font-size: 0.5rem; color: var(--text-secondary); margin-bottom: 0.35rem; }
    .webapp-bars { display: flex; gap: 0.25rem; align-items: flex-end; height: 2.5rem; }
    .webapp-bar { flex: 1; background: oklch(25% 0.06 240 / 0.15); border-radius: 0.1rem 0.1rem 0 0; }
    .webapp-bar--hi { background: var(--orange); }
    .webapp-list-wrap { background: #f7f8fa; border: 1px solid var(--border); border-radius: 0.25rem; overflow: hidden; }
    .webapp-list-row {
      display: grid; grid-template-columns: 1fr auto auto;
      gap: 0.5rem; align-items: center;
      padding: 0.35rem 0.5rem; font-size: 0.48rem; color: var(--text-primary);
      border-bottom: 1px solid var(--border);
    }
    .webapp-list-row:last-child { border-bottom: none; }
    .webapp-list-head { background: #f0f1f3; color: var(--text-secondary); font-weight: 600; }
    .webapp-tag { padding: 0.1rem 0.35rem; border-radius: 0.2rem; font-size: 0.42rem; font-weight: 600; white-space: nowrap; }
    .webapp-tag--green  { background: oklch(90% 0.08 145); color: oklch(35% 0.1 145); }
    .webapp-tag--orange { background: oklch(92% 0.08 55);  color: oklch(40% 0.12 55); }

    /* ── CONTENT ── */
    .webapp-content { padding-block: clamp(3rem, 6vw, 5rem); background: var(--surface-alt); }
    .webapp-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(2.5rem, 6vw, 6rem); align-items: start;
    }
    .webapp-col-title {
      font-family: var(--font-display); font-size: clamp(1.15rem, 2vw, 1.4rem);
      font-weight: 700; color: var(--text-primary); margin-bottom: 1.25rem;
    }
    .webapp-reasons-list {
      list-style: none; margin: 0 0 1.25rem; padding: 0;
      display: flex; flex-direction: column; gap: 0.875rem;
    }
    .webapp-reasons-list li {
      display: grid; grid-template-columns: auto 1fr; gap: 0.65rem;
      align-items: start; font-size: 0.975rem; color: var(--text-secondary); line-height: 1.6;
    }
    .webapp-icon-bullet { width: 1.1rem; height: 1.1rem; color: var(--orange); flex-shrink: 0; margin-top: 0.2rem; }
    .webapp-note { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.7; padding-left: 1rem; border-left: 2px solid var(--orange); }
    .webapp-steps { display: flex; flex-direction: column; gap: 1.25rem; }
    .webapp-step-item { display: grid; grid-template-columns: auto 1fr; gap: 1rem; align-items: start; }
    .webapp-step-num {
      font-family: var(--font-mono, monospace); font-size: 0.7rem; font-weight: 700;
      color: var(--orange); background: oklch(95% 0.05 50); border: 1px solid oklch(88% 0.07 50);
      border-radius: 0.25rem; padding: 0.25rem 0.4rem; line-height: 1; white-space: nowrap; margin-top: 0.15rem;
    }
    .webapp-step-name { font-weight: 700; font-size: 0.975rem; color: var(--text-primary); margin: 0 0 0.3rem; }
    .webapp-step-desc { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.65; margin: 0; }

    /* ── FEATURES ── */
    .webapp-features-section { padding-block: clamp(3rem, 6vw, 5rem); background: #fff; }
    .webapp-features-title {
      font-family: var(--font-display); font-size: clamp(1.2rem, 2vw, 1.5rem);
      font-weight: 700; color: var(--text-primary); margin-bottom: 2rem;
    }
    .webapp-features-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .webapp-feat {
      display: flex; align-items: flex-start; gap: 1rem;
      padding: 1.25rem; border: 1px solid var(--border); border-radius: 0.5rem;
    }
    .webapp-feat-icon { width: 1.25rem; height: 1.25rem; color: var(--orange); flex-shrink: 0; margin-top: 0.1rem; }
    .webapp-feat-name { font-weight: 700; font-size: 0.975rem; color: var(--text-primary); margin: 0 0 0.25rem; }
    .webapp-feat-desc { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }

    /* ── CTA ── */
    .webapp-cta { padding-block: clamp(2.5rem, 5vw, 4rem); background: var(--surface-alt); }
    .webapp-cta-inner {
      display: flex; align-items: center; justify-content: space-between; gap: 2rem;
      padding: clamp(1.5rem, 3vw, 2.5rem); border: 1px solid var(--border);
      border-radius: 0.5rem; background: #fff;
    }
    .webapp-cta-copy { display: flex; align-items: center; gap: 1.5rem; }
    .webapp-cta-icon { width: 5rem; height: 3.75rem; flex-shrink: 0; }
