---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Soluciones" description="Soluciones de LIBERA Studio: presencia digital, operación inteligente, AI y automatización, y productos digitales.">
  <section style="background: var(--surface);" class="pt-40 pb-20">
    <div class="container-libera">
      <div class="max-w-2xl mb-16" data-reveal>
        <span class="eyebrow block mb-4" style="color: var(--text-secondary); font-family: var(--font-mono);">Soluciones</span>
        <h1 class="font-display mb-6" style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; letter-spacing: -0.04em; color: var(--text-primary); line-height: 1.0;">
          Infraestructura digital para empresas que quieren operar mejor.
        </h1>
      </div>
      <div class="grid md:grid-cols-2 gap-px" style="background: var(--border); border: 1px solid var(--border);">
        {[
          { label: 'Presencia Digital', href: '/soluciones/presencia-digital', accent: 'var(--presencia)' },
          { label: 'Operación Inteligente', href: '/soluciones/operacion-inteligente', accent: 'var(--operacion)' },
          { label: 'AI & Automation', href: '/soluciones/ai-automation', accent: 'var(--ai)' },
          { label: 'Productos Digitales', href: '/soluciones/productos-digitales', accent: 'var(--productos)' },
        ].map((s) => (
          <a href={s.href} class="group p-8 md:p-10 transition-all duration-300 hover:-translate-y-0.5" style="background: var(--surface);" data-reveal>
            <span class="w-10 h-px block mb-8 transition-all duration-300 group-hover:w-16" style={`background: ${s.accent};`} aria-hidden="true"></span>
            <h2 class="font-display font-semibold text-2xl mb-5" style={`font-family: var(--font-display); color: var(--text-primary);`}>{s.label}</h2>
            <span class="text-sm font-medium inline-flex items-center gap-2 transition-all duration-200 group-hover:gap-3" style={`color: ${s.accent};`}>Ver solución <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
