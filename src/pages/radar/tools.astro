---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Radar Tools" description="Herramientas digitales que analizamos, comparamos y usamos en el trabajo diario del estudio.">
  <section style="background: var(--ink); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--orange); font-family: var(--font-mono);">Radar</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-light); margin-bottom: 1.5rem;">Tools</h1>
      <p style="color: var(--text-light); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Las herramientas que analizamos, comparamos y usamos. Opinión directa sobre qué vale la pena adoptar y qué no.</p>
      <a href="/radar" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Radar</a>
    </div>
  </section>
</Layout>
