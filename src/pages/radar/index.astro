---
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import radar1 from '@/assets/images/LS - radar 1.png';
import radar2 from '@/assets/images/LS - radar 2.png';
import radar3 from '@/assets/images/LS - radar 3.png';
import radarVetoFable5 from '@/assets/images/LS - radar veto claude fable 5.png';
import radarCopilotCredits from '@/assets/images/LS - radar github copilot credits.png';
import radarCopilotTokens from '@/assets/images/LS - radar github copilot tokens.png';
import radarMicrosoftMai from '@/assets/images/LS - radar microsoft mai.png';
import radarClaudeOpus48 from '@/assets/images/LS - radar claude opus 4.8.png';
import radarClaudeFable5 from '@/assets/images/LS - radar claude fable 5 mythos.png';

const articles = [
  {
    category: 'Automatización',
    date: 'Jun 2026',
    read: '4 min',
    title: 'Zapier cobra hasta 5x más por pasos de IA desde junio 15',
    excerpt: 'El cambio ya aplica. Qué pasó con AI by Zapier y qué revisar si tus flujos usan IA.',
    href: '/radar/zapier-ia-precios-5x-junio-2026',
    image: radar1,
  },
  {
    category: 'IA',
    date: 'Jun 2026',
    read: '4 min',
    title: 'OpenAI sale a bolsa: $850B de valuación y posibles recortes en sus APIs',
    excerpt: 'La solicitud confidencial de IPO y la presión competitiva pueden mover precios en la API.',
    href: '/radar/openai-ipo-2026-precios-api',
    image: radar2,
  },
  {
    category: 'IA',
    date: 'Jun 2026',
    read: '4 min',
    title: 'Gemini 2.0 Flash está muerto: qué pasó, qué lo reemplaza y cuánto cuesta ahora',
    excerpt: 'Google apagó Gemini 2.0 Flash y la migración ya no se puede postergar.',
    href: '/radar/gemini-35-flash-depreciacion-migracion-2026',
    image: radar3,
  },
  {
    category: 'IA',
    date: 'Jun 2026',
    read: '5 min',
    title: 'Claude Fable 5 vetado: el modelo más potente de Anthropic llegó y se fue en 4 días para México',
    excerpt: 'Qué cambió con el veto, qué modelos siguen activos y qué alternativas quedan para LATAM.',
    href: '/radar/veto-claude-fable-5-eeuu',
    image: radarVetoFable5,
  },
  {
    category: 'Dev',
    date: 'Jun 2026',
    read: '5 min',
    title: 'GitHub Copilot cobra por créditos desde junio: qué cambió y cómo calcular tu costo',
    excerpt: 'El “todo incluido” terminó. Así funciona AI Credits y dónde se dispara el gasto.',
    href: '/radar/github-copilot-creditos-billing-junio-2026',
    image: radarCopilotCredits,
  },
  {
    category: 'Dev',
    date: 'Jun 2026',
    read: '4 min',
    title: 'GitHub Copilot abandona la tarifa fija: lo que cuesta ahora y qué hacer',
    excerpt: 'Desde junio Copilot cobra por consumo. Qué implica para equipos que ya usan funciones agénticas.',
    href: '/radar/github-copilot-billing-por-tokens-2026',
    image: radarCopilotTokens,
  },
  {
    category: 'Dev',
    date: 'Jun 2026',
    read: '4 min',
    title: 'Microsoft lanza 7 modelos MAI: GitHub Copilot ya no depende de OpenAI',
    excerpt: 'Qué cambia para Copilot, Azure AI Foundry y equipos que desarrollan con IA en producción.',
    href: '/radar/microsoft-mai-modelos-build-2026',
    image: radarMicrosoftMai,
  },
  {
    category: 'IA',
    date: 'Jun 2026',
    read: '4 min',
    title: 'Claude Opus 4.8: qué cambió y por qué importa si automatizas procesos',
    excerpt: 'Menos errores silenciosos, más capacidad en tareas largas y mejor control para flujos de IA.',
    href: '/radar/claude-opus-4-8',
    image: radarClaudeOpus48,
  },
  {
    category: 'IA',
    date: 'Jun 2026',
    read: '5 min',
    title: 'Claude Fable 5: Anthropic libera su primer modelo de clase Mythos',
    excerpt: 'El primer modelo público de la familia Mythos llega con safeguards activos y más capacidad en código agentico.',
    href: '/radar/claude-fable-5',
    image: radarClaudeFable5,
  },
];
---

<Layout title="Radar" description="El observatorio de LIBERA Studio. Analizamos herramientas, modelos y tendencias antes de convertirlos en decisiones reales.">
  <section style="background: var(--ink-mid);" class="pt-40 pb-24">
    <div class="container-libera">
      <div class="max-w-3xl mb-16" data-reveal>
        <span class="eyebrow block mb-4" style="color: var(--orange); font-family: var(--font-mono);">Radar</span>
        <h1 class="font-display mb-6" style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4.8rem); font-weight: 800; letter-spacing: 0.01em; color: var(--text-light); line-height: 0.95;">
          No seguimos tendencias.<br/>Las probamos.
        </h1>
        <p class="text-lg" style="color: oklch(74% 0.018 235);">
          Inteligencia práctica sobre IA, herramientas y automatización. Sin ruido.
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        {articles.map((article) => (
          <a
            href={article.href}
            class="group flex flex-col overflow-hidden"
            style="background: oklch(10% 0.015 235); border: 1px solid oklch(28% 0.02 235 / 0.55);"
            data-reveal
          >
            <Image
              src={article.image}
              alt=""
              widths={[400, 800, 1254]}
              sizes="(max-width: 768px) 100vw, 33vw"
              loading="lazy"
              class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.035]"
              style="aspect-ratio: 1 / 1;"
            />
            <div class="p-6 flex flex-col flex-1">
              <div class="mb-5 flex items-center justify-between gap-3">
                <span class="text-xs font-mono uppercase tracking-wider" style="color: var(--orange); font-family: var(--font-mono);">{article.category}</span>
                <span class="text-xs font-mono" style="color: oklch(64% 0.014 235); font-family: var(--font-mono);">{article.date} · {article.read}</span>
              </div>
              <h2 class="font-display text-2xl leading-tight" style="font-family: var(--font-display); color: var(--text-light);">
                {article.title}
              </h2>
              <p class="mt-4 text-sm leading-relaxed" style="color: oklch(72% 0.014 235);">
                {article.excerpt}
              </p>
              <span class="mt-auto pt-8 inline-block text-sm font-medium transition-transform duration-200 group-hover:translate-x-1" style="color: var(--orange);">
                Leer en Radar →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
