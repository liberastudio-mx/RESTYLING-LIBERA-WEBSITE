---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Radar" description="El observatorio de LIBERA Studio. Analizamos herramientas, modelos y tendencias antes de convertirlos en decisiones reales.">
  <section style="background: var(--ink-mid);" class="pt-40 pb-20">
    <div class="container-libera">
      <div class="max-w-2xl mb-16" data-reveal>
        <span class="eyebrow block mb-4" style="color: var(--orange); font-family: var(--font-mono);">Radar</span>
        <h1 class="font-display mb-6" style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; letter-spacing: -0.04em; color: var(--text-light); line-height: 1.0;">
          No seguimos tendencias.<br/>Las probamos.
        </h1>
        <p class="text-lg" style="color: oklch(52% 0.008 25);">
          Analizamos herramientas, modelos, automatizaciones y cambios tecnológicos antes de convertirlos en decisiones reales.
        </p>
      </div>
      <p class="text-base" style="color: oklch(48% 0.008 25);">Contenido del Radar próximamente. <a href="/diagnostico" style="color: var(--orange);">Solicitar diagnóstico →</a></p>
    </div>
  </section>
</Layout>
