---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Radar Web" description="Tendencias, tecnologías y decisiones de arquitectura web que seguimos de cerca en el estudio.">
  <section style="background: var(--ink); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--orange); font-family: var(--font-mono);">Radar</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-light); margin-bottom: 1.5rem;">Web</h1>
      <p style="color: var(--text-light); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Tecnologías, patrones de arquitectura y decisiones de desarrollo web que seguimos de cerca y usamos en producción.</p>
      <a href="/radar" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Radar</a>
    </div>
  </section>
</Layout>
