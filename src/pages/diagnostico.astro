---
import Layout from '@/layouts/Layout.astro';
import DiagnosticForm from '@/components/DiagnosticForm.astro';
---

<Layout
  title="Diagnóstico de sistema digital"
  description="Revisamos cómo te encuentran, cómo respondes y dónde se pierde valor en tu operación digital. Informe claro con prioridades, sin costo y sin compromiso."
>
  <section class="diagnostic-page">
    <div class="container-libera">
      <div class="diagnostic-page__content">
        <span class="eyebrow diagnostic-page__eyebrow">Diagnóstico</span>
        <h1>Diagnóstico de sistema digital.</h1>
        <p class="diagnostic-page__intro">
          Revisamos cómo te encuentran, cómo respondes, cómo captas oportunidades y dónde se pierde
          valor en tu operación digital. Recibes un informe claro con prioridades, útil con o sin nosotros.
        </p>

        <DiagnosticForm idPrefix="pagina-diagnostico" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .diagnostic-page {
    min-height: 100dvh;
    padding-block: 10rem 5rem;
    background: var(--ink);
  }

  .diagnostic-page__content {
    max-width: 42rem;
  }

  .diagnostic-page__eyebrow {
    display: block;
    margin-bottom: 1.5rem;
    color: var(--orange);
    font-family: var(--font-mono);
  }

  .diagnostic-page h1 {
    margin-bottom: 1.5rem;
    color: var(--text-light);
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .diagnostic-page__intro {
    margin-bottom: 3rem;
    color: oklch(65% 0.008 25);
    font-size: 1.125rem;
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .diagnostic-page {
      padding-block: 7rem 4rem;
    }
  }
</style>
