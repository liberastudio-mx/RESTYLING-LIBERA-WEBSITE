---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="PAOS" description="El sistema operativo digital de tu empresa. Conocimiento estructurado, procesos repetibles y agentes conectados en un solo lugar.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--operacion); font-family: var(--font-mono);">Servicios</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">PAOS</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">El sistema operativo digital de tu empresa. Construimos tu PAOS con base de conocimiento estructurada, plantillas de proceso, seguimiento de clientes y agentes de IA integrados.</p>
      <a href="/servicios" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Servicios</a>
    </div>
  </section>
</Layout>
