---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Landing Pages" description="Landing pages de alta conversión para campañas, lanzamientos y captación de leads.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--presencia); font-family: var(--font-mono);">Servicios</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Landing Pages</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Páginas de aterrizaje diseñadas para convertir. Para campañas publicitarias, lanzamientos de producto y captación de leads calificados.</p>
      <a href="/servicios" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Servicios</a>
    </div>
  </section>
</Layout>
