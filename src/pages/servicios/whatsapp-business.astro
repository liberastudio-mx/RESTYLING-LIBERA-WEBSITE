---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="WhatsApp Business" description="Configuración y automatización de WhatsApp Business para atender, calificar y dar seguimiento a clientes sin esfuerzo manual.">
  <section style="background: var(--surface); min-height: calc(100dvh - var(--nav-height));" class="flex items-center">
    <div class="container-libera py-40">
      <p class="eyebrow mb-6" style="color: var(--presencia); font-family: var(--font-mono);">Servicios</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">WhatsApp Business</h1>
      <p style="color: var(--text-secondary); font-size: 1.125rem; max-width: 560px; line-height: 1.7; margin-bottom: 2.5rem;">Configuración y automatización de WhatsApp Business para atender, calificar y dar seguimiento a clientes sin depender de respuestas manuales.</p>
      <a href="/servicios" style="color: var(--orange); font-size: 0.875rem; font-weight: 500;">← Volver a Servicios</a>
    </div>
  </section>
</Layout>
