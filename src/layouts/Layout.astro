---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
  jsonLdExtra?: string;
}

const {
  title,
  description,
  ogImage = '/images/og-default.png',
  canonical,
  noIndex = false,
  jsonLdExtra,
} = Astro.props;

const siteUrl = 'https://www.liberastudio.tech';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const fullTitle = title === 'LIBERA Studio'
  ? 'LIBERA Studio, Sistemas digitales, automatización e IA para empresas'
  : `${title}, LIBERA Studio`;

const jsonLdOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  "name": "LIBERA Studio",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "@id": `${siteUrl}/#logo`,
    "url": `${siteUrl}/images/LIBERA-Logo-dark.png`,
    "width": 1530,
    "height": 286
  },
  "description": "Estudio de sistemas digitales, automatización e inteligencia artificial para empresas que quieren operar mejor.",
  "address": { "@type": "PostalAddress", "addressLocality": "Mérida", "addressCountry": "MX" },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "hola@liberastudio.tech",
    "url": `${siteUrl}/diagnostico`,
    "availableLanguage": ["es", "it", "en"]
  },
  "areaServed": ["MX", "IT"],
  "sameAs": ["https://www.linkedin.com/company/libera-studio"]
});

const jsonLdWebsite = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "url": `${siteUrl}/`,
  "name": "LIBERA Studio",
  "inLanguage": "es-MX",
  "publisher": { "@id": `${siteUrl}/#organization` }
});

const jsonLdWebPage = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  "url": canonicalUrl,
  "name": fullTitle,
  "description": description,
  "inLanguage": "es-MX",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#organization` },
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": `${siteUrl}${ogImage}`
  }
});

// Auto BreadcrumbList from URL path
const segments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const slugToLabel: Record<string, string> = {
  soluciones: 'Soluciones',
  'presencia-digital': 'Presencia Digital',
  'operacion-interna': 'Operación Interna',
  'ai-automation': 'AI & Automation',
  'productos-digitales': 'Productos Digitales',
  'sitios-web-premium': 'Sitios web premium',
  'landing-pages': 'Landing pages',
  'google-business-profile': 'Google Business Profile',
  'whatsapp-business': 'WhatsApp Business',
  'redes-sociales': 'Redes sociales',
  paos: 'Second Brain/PAOS',
  automatizacion: 'Automatización',
  'crm-seguimiento': 'CRM y seguimiento',
  dashboards: 'Dashboards',
  integraciones: 'Integraciones',
  'agentes-ia': 'Agentes de IA',
  'asistentes-internos': 'Asistentes internos',
  'flujos-n8n': 'Flujos con n8n',
  'clasificacion-mensajes': 'Clasificación de mensajes',
  'automatizacion-documental': 'Automatización documental',
  'web-apps': 'Web apps',
  mvps: 'MVPs',
  'apps-internas': 'Apps internas',
  'paneles-admin': 'Paneles admin',
  prototipos: 'Prototipos',
  radar: 'Radar',
  trabajo: 'Trabajo',
  nosotros: 'Nosotros',
  diagnostico: 'Solicitar diagnóstico',
  'cenote-scout': 'Cenote Scout',
  'sole-facile': 'Sole Facile',
  'morozzo-padel': 'Morozzo Padel',
};

const breadcrumbLd = segments.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    ...segments.map((seg, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": slugToLabel[seg] ?? seg,
      "item": `${siteUrl}/${segments.slice(0, i + 1).join('/')}`
    }))
  ]
}) : null;
---

<!doctype html>
<html lang="es" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="LIBERA Studio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Fonts: self-hosted (preload critical path) -->
    <link rel="preload" href="/fonts/Pliant-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Google Consent Mode v2: defaults denied before GTM loads -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
      gtag('js', new Date());
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KD87L7NQ');</script>

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" set:html={jsonLdOrg} />
    <!-- JSON-LD WebSite and current WebPage -->
    <script type="application/ld+json" set:html={jsonLdWebsite} />
    <script type="application/ld+json" set:html={jsonLdWebPage} />
    <!-- JSON-LD BreadcrumbList -->
    {breadcrumbLd && <script type="application/ld+json" set:html={breadcrumbLd} />}
    <!-- JSON-LD page-specific -->
    {jsonLdExtra && <script type="application/ld+json" set:html={jsonLdExtra} />}
  </head>
  <body>
    <!-- Google Tag Manager (noscript fallback) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KD87L7NQ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <a href="#main" class="skip-link">Ir al contenido principal</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
      );

      document.querySelectorAll('[data-reveal]').forEach((el) => {
        observer.observe(el);
      });
    </script>

    <!-- Consent update + Meta Pixel -->
    <script>
      const PIXEL_ID = '1021679673642512';

      function readStoredConsent() {
        const c = document.cookie.split('; ').find(r => r.startsWith('libera_cookie_consent='));
        if (!c) return null;
        try {
          const v = JSON.parse(decodeURIComponent(c.split('=').slice(1).join('=')));
          return v?.version === 1 ? v : null;
        } catch { return null; }
      }

      function applyGtmConsent(analytics: boolean) {
        const state = analytics ? 'granted' : 'denied';
        window.gtag?.('consent', 'update', { analytics_storage: state });
      }

      function loadMetaPixel() {
        if ((window as any).fbq) {
          (window as any).fbq('track', 'PageView');
          return;
        }
        /* eslint-disable */
        (function(f: any,b: any,e: any,v: any,n?: any,t?: any,s?: any){
          if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};
          if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
          n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];
          s.parentNode.insertBefore(t,s)
        })(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
        /* eslint-enable */
        (window as any).fbq('init', PIXEL_ID);
        (window as any).fbq('track', 'PageView');
      }

      function applyConsent(prefs: { analytics: boolean; marketing: boolean }) {
        applyGtmConsent(prefs.analytics);
        if (prefs.marketing) loadMetaPixel();
      }

      // Apply stored consent on page load
      const stored = readStoredConsent();
      if (stored) applyConsent(stored);

      // Apply consent when user interacts with the banner
      window.addEventListener('libera:consent', (e: Event) => {
        const detail = (e as CustomEvent).detail;
        applyConsent({ analytics: detail.analytics, marketing: detail.marketing ?? false });
      });

      // Re-apply on Astro page transitions
      document.addEventListener('astro:page-load', () => {
        const s = readStoredConsent();
        if (s) applyConsent(s);
      });
    </script>
  </body>
</html>
