---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
  jsonLdExtra?: string;
}

const {
  title,
  description,
  ogImage = '/images/og-default.png',
  canonical,
  noIndex = false,
  jsonLdExtra,
} = Astro.props;

const siteUrl = 'https://www.liberastudio.tech';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const fullTitle = title === 'LIBERA Studio'
  ? 'LIBERA Studio, Sistemas digitales, automatización e IA para empresas'
  : `${title}, LIBERA Studio`;

const jsonLdOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  "name": "LIBERA Studio",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "@id": `${siteUrl}/#logo`,
    "url": `${siteUrl}/images/LIBERA-Logo-dark.png`,
    "width": 1530,
    "height": 286
  },
  "description": "Estudio de sistemas digitales, automatización e inteligencia artificial para empresas que quieren operar mejor.",
  "address": { "@type": "PostalAddress", "addressLocality": "Mérida", "addressCountry": "MX" },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "hola@liberastudio.tech",
    "url": `${siteUrl}/diagnostico`,
    "availableLanguage": ["es", "it", "en"]
  },
  "areaServed": ["MX", "IT"],
  "sameAs": ["https://www.linkedin.com/company/libera-studio"]
});

const jsonLdWebsite = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "url": `${siteUrl}/`,
  "name": "LIBERA Studio",
  "inLanguage": "es-MX",
  "publisher": { "@id": `${siteUrl}/#organization` }
});

const schemaType = (() => {
  if (Astro.url.pathname === '/contacto') return 'ContactPage';
  if (Astro.url.pathname === '/nosotros') return 'AboutPage';
  if (Astro.url.pathname === '/radar' || Astro.url.pathname === '/trabajo') return 'CollectionPage';
  if (Astro.url.pathname.startsWith('/soluciones/')) return 'Service';
  return 'WebPage';
})();

const jsonLdWebPage = JSON.stringify({
  "@context": "https://schema.org",
  "@type": schemaType,
  "@id": `${canonicalUrl}#webpage`,
  "url": canonicalUrl,
  "name": fullTitle,
  "description": description,
  "inLanguage": "es-MX",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#organization` },
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": `${siteUrl}${ogImage}`
  }
});

// Auto BreadcrumbList from URL path
const segments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const slugToLabel: Record<string, string> = {
  soluciones: 'Soluciones',
  'presencia-digital': 'Presencia Digital',
  'operacion-interna': 'Operación Interna',
  'ai-automation': 'AI & Automation',
  'productos-digitales': 'Productos Digitales',
  'sitios-web-premium': 'Sitios web premium',
  'landing-pages': 'Landing pages',
  'google-business-profile': 'Google Business Profile',
  'whatsapp-business': 'WhatsApp Business',
  'redes-sociales': 'Redes sociales',
  paos: 'Second Brain/PAOS',
  automatizacion: 'Automatización',
  'crm-seguimiento': 'CRM y seguimiento',
  dashboards: 'Dashboards',
  integraciones: 'Integraciones',
  'agentes-ia': 'Agentes de IA',
  'asistentes-internos': 'Asistentes internos',
  'flujos-n8n': 'Flujos con n8n',
  'clasificacion-mensajes': 'Clasificación de mensajes',
  'automatizacion-documental': 'Automatización documental',
  'web-apps': 'Web apps',
  mvps: 'MVPs',
  'apps-internas': 'Apps internas',
  'paneles-admin': 'Paneles admin',
  prototipos: 'Prototipos',
  radar: 'Radar',
  trabajo: 'Trabajo',
  nosotros: 'Nosotros',
  diagnostico: 'Solicitar diagnóstico',
  'cenote-scout': 'Cenote Scout',
  'sole-facile': 'Sole Facile',
  'morozzo-padel': 'Morozzo Padel',
};

const breadcrumbLd = segments.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    ...segments.map((seg, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": slugToLabel[seg] ?? seg,
      "item": `${siteUrl}/${segments.slice(0, i + 1).join('/')}`
    }))
  ]
}) : null;

const isSolucionesSubpage = segments[0] === 'soluciones' && segments.length >= 3;
---

<!doctype html>
<html lang="es" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="LIBERA Studio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Fonts: self-hosted (preload critical path) -->
    <link rel="preload" href="/fonts/Pliant-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Google Consent Mode v2: defaults denied before GTM loads -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
      gtag('js', new Date());
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KD87L7NQ');</script>

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" set:html={jsonLdOrg} />
    <!-- JSON-LD WebSite and current WebPage -->
    <script type="application/ld+json" set:html={jsonLdWebsite} />
    <script type="application/ld+json" set:html={jsonLdWebPage} />
    <!-- JSON-LD BreadcrumbList -->
    {breadcrumbLd && <script type="application/ld+json" set:html={breadcrumbLd} />}
    <!-- JSON-LD page-specific -->
    {jsonLdExtra && <script type="application/ld+json" set:html={jsonLdExtra} />}
  </head>
  <body data-soluciones-subpage={isSolucionesSubpage ? 'true' : undefined}>
    <!-- Google Tag Manager (noscript fallback) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KD87L7NQ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <a href="#main" class="skip-link">Ir al contenido principal</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/524152197945"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Escríbenos por WhatsApp"
      class="wa-fab"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="22" height="22" aria-hidden="true" focusable="false">
        <path d="M16 0C7.163 0 0 7.163 0 16c0 2.822.737 5.469 2.027 7.77L0 32l8.465-2.003A15.938 15.938 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.77-1.851l-.485-.289-5.024 1.188 1.215-4.897-.318-.504A13.263 13.263 0 0 1 2.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.273-9.92c-.398-.2-2.356-1.163-2.72-1.295-.365-.133-.63-.2-.895.2-.265.397-1.028 1.295-1.26 1.561-.232.265-.465.298-.863.1-.398-.2-1.68-.619-3.2-1.975-1.183-1.055-1.982-2.358-2.214-2.756-.232-.398-.025-.613.174-.812.179-.178.398-.465.597-.697.2-.233.265-.399.398-.665.133-.265.066-.498-.033-.697-.1-.2-.895-2.157-1.227-2.953-.323-.773-.651-.668-.895-.68-.232-.012-.498-.015-.763-.015-.265 0-.697.1-1.062.498-.365.398-1.393 1.361-1.393 3.318s1.426 3.847 1.625 4.112c.2.265 2.807 4.286 6.803 5.87.951.366 1.693.584 2.272.748.955.27 1.824.232 2.51.14.766-.1 2.356-.963 2.688-1.893.333-.93.333-1.727.232-1.893-.1-.165-.365-.265-.763-.465z"/>
      </svg>
    </a>

    <style>
      body[data-soluciones-subpage="true"] :global(main > div > section:first-child[class$="-hero"]) {
        padding-top: calc(var(--nav-height) + clamp(5.5rem, 7vw, 6.75rem)) !important;
      }

      @media (max-width: 640px) {
        body[data-soluciones-subpage="true"] :global(main > div > section:first-child[class$="-hero"]) {
          padding-top: calc(var(--nav-height) + 4.5rem) !important;
        }
      }

      .wa-fab {
        position: fixed;
        bottom: max(1.25rem, env(safe-area-inset-bottom));
        right: max(
          clamp(1.25rem, 4vw, 3.5rem),
          calc((100vw - var(--container-max)) / 2 + 3.5rem)
        );
        z-index: 9000;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 3rem;
        height: 3rem;
        border: 1px solid rgba(0, 120, 60, 0.35);
        border-radius: 50%;
        background: #25d366;
        color: #ffffff;
        text-decoration: none;
        box-shadow: 0 2px 12px rgba(37, 211, 102, 0.28);
        transition:
          background-color 0.2s var(--ease-smooth),
          box-shadow 0.2s var(--ease-smooth),
          transform 0.2s var(--ease-smooth);
      }
      .wa-fab:hover {
        background: #1ebe5d;
        box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
        transform: translateY(-2px);
      }
      .wa-fab:active {
        transform: translateY(0) scale(0.96);
      }
      .wa-fab:focus-visible {
        outline: 3px solid #ffffff;
        outline-offset: 3px;
      }
      .wa-fab svg {
        fill: #ffffff;
        flex-shrink: 0;
      }
    </style>

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
      );

      document.querySelectorAll('[data-reveal]').forEach((el) => {
        observer.observe(el);
      });
    </script>

    <!-- Consent update + Meta Pixel -->
    <script>
      const PIXEL_ID = '1021679673642512';

      function readStoredConsent() {
        const c = document.cookie.split('; ').find(r => r.startsWith('libera_cookie_consent='));
        if (!c) return null;
        try {
          const v = JSON.parse(decodeURIComponent(c.split('=').slice(1).join('=')));
          return v?.version === 1 ? v : null;
        } catch { return null; }
      }

      function applyGtmConsent(analytics: boolean) {
        const state = analytics ? 'granted' : 'denied';
        window.gtag?.('consent', 'update', { analytics_storage: state });
      }

      function loadMetaPixel() {
        if ((window as any).fbq) {
          (window as any).fbq('track', 'PageView');
          return;
        }
        /* eslint-disable */
        (function(f: any,b: any,e: any,v: any,n?: any,t?: any,s?: any){
          if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};
          if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
          n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];
          s.parentNode.insertBefore(t,s)
        })(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
        /* eslint-enable */
        (window as any).fbq('init', PIXEL_ID);
        (window as any).fbq('track', 'PageView');
      }

      function applyConsent(prefs: { analytics: boolean; marketing: boolean }) {
        applyGtmConsent(prefs.analytics);
        if (prefs.marketing) loadMetaPixel();
      }

      // Apply stored consent on page load
      const stored = readStoredConsent();
      if (stored) applyConsent(stored);

      // Apply consent when user interacts with the banner
      window.addEventListener('libera:consent', (e: Event) => {
        const detail = (e as CustomEvent).detail;
        applyConsent({ analytics: detail.analytics, marketing: detail.marketing ?? false });
      });

      // Re-apply on Astro page transitions
      document.addEventListener('astro:page-load', () => {
        const s = readStoredConsent();
        if (s) applyConsent(s);
      });
    </script>
  </body>
</html>
