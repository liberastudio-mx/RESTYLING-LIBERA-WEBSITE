---
import { Image } from 'astro:assets';
import logoDarkImg from '@/assets/images/LIBERA-Logo-dark.png';
import logoWhiteImg from '@/assets/images/LIBERA-Logo-white.png';

const currentPath = Astro.url.pathname;

const BRAND_COLORS = ['#003049', '#d62828', '#f77f00', '#fcbf49'];

const MOBILE_SOLUTION_GROUPS = [
  {
    heading: 'Operación Interna',
    accent: BRAND_COLORS[0],
    links: [
      ['Second Brain/PAOS', '/soluciones/operacion-interna/paos'],
      ['Automatización', '/soluciones/operacion-interna/automatizacion'],
      ['CRM y seguimiento', '/soluciones/operacion-interna/crm-seguimiento'],
      ['Dashboards', '/soluciones/operacion-interna/dashboards'],
      ['Integraciones', '/soluciones/operacion-interna/integraciones'],
    ],
  },
  {
    heading: 'Presencia Digital',
    accent: BRAND_COLORS[1],
    links: [
      ['Sitios web premium', '/soluciones/presencia-digital/sitios-web-premium'],
      ['Landing pages', '/soluciones/presencia-digital/landing-pages'],
      ['Google Business Profile', '/soluciones/presencia-digital/google-business-profile'],
      ['WhatsApp Business', '/soluciones/presencia-digital/whatsapp-business'],
      ['Redes sociales', '/soluciones/presencia-digital/redes-sociales'],
    ],
  },
  {
    heading: 'IA y automatización',
    accent: BRAND_COLORS[2],
    links: [
      ['Agentes de IA', '/soluciones/ai-automation/agentes-ia'],
      ['Asistentes internos', '/soluciones/ai-automation/asistentes-internos'],
      ['Flujos con n8n', '/soluciones/ai-automation/flujos-n8n'],
      ['Clasificación de mensajes', '/soluciones/ai-automation/clasificacion-mensajes'],
      ['Automatización documental', '/soluciones/ai-automation/automatizacion-documental'],
    ],
  },
  {
    heading: 'Productos Digitales',
    accent: BRAND_COLORS[3],
    links: [
      ['Web apps', '/soluciones/productos-digitales/web-apps'],
      ['MVPs', '/soluciones/productos-digitales/mvps'],
      ['Apps internas', '/soluciones/productos-digitales/apps-internas'],
      ['Paneles admin', '/soluciones/productos-digitales/paneles-admin'],
      ['Prototipos', '/soluciones/productos-digitales/prototipos'],
    ],
  },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0"
  data-header-theme="light"
  style="height: var(--nav-height); z-index: var(--z-header);"
>
  <!-- Design: Hybrid chrome | Product behavior | Minimal transparent surface | Adaptive contrast -->
  <!-- Backdrop -->
  <div
    id="header-bg"
    class="absolute inset-0"
    aria-hidden="true"
  ></div>

  <div class="container-libera relative h-full flex items-center justify-between gap-8">

    <!-- Logo: mobile only (on desktop the logo lives inside the nav pill) -->
    <a href="/" class="site-logo lg:hidden flex-shrink-0 flex items-center z-10" aria-label="LIBERA Studio, Inicio">
      <Image
        src={logoDarkImg}
        alt="LIBERA Studio"
        width={214}
        height={40}
        class="site-logo-image site-logo-image--dark block"
        style="width: auto; height: 24px;"
      />
      <Image
        src={logoWhiteImg}
        alt=""
        aria-hidden="true"
        width={214}
        height={40}
        class="site-logo-image site-logo-image--white block"
        style="width: auto; height: 24px;"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="central-nav hidden lg:flex items-center gap-0.5 justify-center" aria-label="Navegación principal">

      <!-- Logo inside pill: desktop only (pill is hidden on mobile) -->
      <a href="/" class="nav-logo flex items-center flex-shrink-0" aria-label="LIBERA Studio">
        <Image src={logoWhiteImg} alt="" aria-hidden="true" width={214} height={40} class="nav-logo-img nav-logo-img--white" style="width: auto; height: 20px;" />
        <Image src={logoDarkImg}  alt="" aria-hidden="true" width={214} height={40} class="nav-logo-img nav-logo-img--dark"  style="width: auto; height: 20px;" />
      </a>

      <!-- ── Soluciones, MEGA LARGE ───────────────────────────────── -->
      <div class="relative group">
        <button
          class="nav-btn flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Soluciones
          <svg class="chevron w-3 h-3 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5"/>
          </svg>
        </button>

        <div class="dropdown solutions-dropdown rounded-2xl opacity-0 invisible transition-all duration-200 pointer-events-none"
          style="background: #ffffff; border: 1px solid rgba(0,48,73,0.1); box-shadow: 0 24px 60px rgba(0,48,73,0.1);"
          role="region" aria-label="Soluciones"
        >
          <div class="grid grid-cols-4 p-5 gap-1">
            {[
              { heading: 'Operación Interna', accent: BRAND_COLORS[0],
                links: [['Second Brain/PAOS','/soluciones/operacion-interna/paos'],['Automatización','/soluciones/operacion-interna/automatizacion'],['CRM y seguimiento','/soluciones/operacion-interna/crm-seguimiento'],['Dashboards','/soluciones/operacion-interna/dashboards'],['Integraciones','/soluciones/operacion-interna/integraciones']] },
              { heading: 'Presencia Digital',     accent: BRAND_COLORS[1],
                links: [['Sitios web premium','/soluciones/presencia-digital/sitios-web-premium'],['Landing pages','/soluciones/presencia-digital/landing-pages'],['Google Business Profile','/soluciones/presencia-digital/google-business-profile'],['WhatsApp Business','/soluciones/presencia-digital/whatsapp-business'],['Redes sociales','/soluciones/presencia-digital/redes-sociales']] },
              { heading: 'IA y automatización',   accent: BRAND_COLORS[2],
                links: [['Agentes de IA','/soluciones/ai-automation/agentes-ia'],['Asistentes internos','/soluciones/ai-automation/asistentes-internos'],['Flujos con n8n','/soluciones/ai-automation/flujos-n8n'],['Clasificación de mensajes','/soluciones/ai-automation/clasificacion-mensajes'],['Automatización documental','/soluciones/ai-automation/automatizacion-documental']] },
              { heading: 'Productos Digitales',   accent: BRAND_COLORS[3],
                links: [['Web apps','/soluciones/productos-digitales/web-apps'],['MVPs','/soluciones/productos-digitales/mvps'],['Apps internas','/soluciones/productos-digitales/apps-internas'],['Paneles admin','/soluciones/productos-digitales/paneles-admin'],['Prototipos','/soluciones/productos-digitales/prototipos']] },
            ].map((col) => (
              <div class="px-4 py-3 rounded-xl hover:bg-[#003049]/[0.03] transition-colors duration-150">
                <div class="flex items-center gap-2 mb-3">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background:${col.accent};`}></span>
                  <span class="text-xs font-semibold tracking-wide uppercase" style={`color:${col.accent};`}>{col.heading}</span>
                </div>
                <ul class="space-y-1.5">
                  {col.links.map(([label, href]) => (
                    <li>
                      <a href={href} class="block text-sm py-0.5 transition-colors duration-150 hover:text-[#003049]" style="color: rgba(0,48,73,0.55);">{label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ── Trabajo, DROPDOWN VISUAL ─────────────────────────────── -->
      <div class="relative group">
        <button class="nav-btn flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium" aria-haspopup="true" aria-expanded="false">
          Trabajo
          <svg class="chevron w-3 h-3 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5"/>
          </svg>
        </button>

        <div class="dropdown absolute top-full left-0 mt-3 w-72 rounded-2xl opacity-0 invisible translate-y-2 transition-all duration-200 pointer-events-none"
          style="background: #ffffff; border: 1px solid rgba(0,48,73,0.1); box-shadow: 0 20px 48px rgba(0,48,73,0.1);"
        >
          <div class="p-3">
            {[
              { name: 'Cenote Scout',         cat: 'Producto', accent: BRAND_COLORS[0], href: '/trabajo/cenote-scout' },
              { name: 'LIBERA AI Automation', cat: 'Sistema',  accent: BRAND_COLORS[1], href: '/trabajo/radar' },
              { name: 'Sole Facile',          cat: 'Cliente',  accent: BRAND_COLORS[2], href: '/trabajo/sole-facile' },
            ].map((p) => (
              <a href={p.href} class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-150 hover:bg-[#003049]/[0.04] group/p">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background:${p.accent};`} aria-hidden="true"></span>
                <div>
                  <span class="block text-xs" style="color: rgba(0,48,73,0.45);">{p.cat}</span>
                  <span class="block text-sm font-medium transition-opacity duration-150 group-hover/p:opacity-70" style="color: #003049;">{p.name}</span>
                </div>
              </a>
            ))}
          </div>
          <div class="mx-3 mb-3 px-4 py-2.5 rounded-xl" style="border-top: 1px solid rgba(0,48,73,0.1);">
            <a href="/trabajo" class="flex items-center justify-between text-sm font-medium transition-opacity duration-150 hover:opacity-70" style="color: rgba(0,48,73,0.55);">
              Ver todo el trabajo <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>

      <!-- ── Guías, LINK DIRECTO ──────────────────────────────────── -->
      <a
        href="/guias"
        class="nav-btn px-4 py-2 rounded-md text-sm font-medium transition-colors duration-200"
        aria-current={currentPath === '/guias' ? 'page' : undefined}
      >
        Guías
      </a>

      <!-- ── Radar, LINK DIRECTO ──────────────────────────────────── -->
      <a
        href="/radar"
        class="nav-btn px-4 py-2 rounded-md text-sm font-medium transition-colors duration-200"
        aria-current={currentPath === '/radar' ? 'page' : undefined}
      >
        Radar
      </a>

      <!-- ── Nosotros, LINK DIRECTO ─────────────────────────────── -->
      <a
        href="/nosotros"
        class="nav-btn px-4 py-2 rounded-md text-sm font-medium transition-colors duration-200"
        aria-current={currentPath === '/nosotros' ? 'page' : undefined}
      >
        Nosotros
      </a>

    </nav>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <!-- Hamburger, mobile only -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-md"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
      >
        <span id="bar1" class="w-5 h-0.5 rounded-full transition-all duration-300 origin-center" style="background: currentColor;"></span>
        <span id="bar2" class="w-5 h-0.5 rounded-full transition-all duration-300" style="background: currentColor;"></span>
        <span id="bar3" class="w-5 h-0.5 rounded-full transition-all duration-300 origin-center" style="background: currentColor;"></span>
      </button>
    </div>
  </div>

</header>

<!-- Mobile menu: SIBLING of header (not child) — fixed-inside-fixed breaks background on iOS Safari -->
<div id="mobile-menu" aria-hidden="true">
  <div class="container-libera mobile-menu-inner">
    <details class="mobile-menu-section">
      <summary class="mobile-menu-summary">
        <span>Soluciones</span>
        <span class="mobile-menu-summary-icon" aria-hidden="true"></span>
      </summary>

      <div class="mobile-solutions-list">
        {MOBILE_SOLUTION_GROUPS.map((group, groupIndex) => (
          <details class="mobile-solution-group">
            <summary class="mobile-solution-summary">
              <span class="mobile-solution-dot" style={`background:${group.accent};`} aria-hidden="true"></span>
              <span>{group.heading}</span>
              <span class="mobile-menu-summary-icon" aria-hidden="true"></span>
            </summary>
            <div class="mobile-solution-panel">
              {group.links.map(([label, href]) => (
                <a href={href} class="mobile-solution-link">{label}</a>
              ))}
            </div>
          </details>
        ))}
      </div>
    </details>

    {[
      { label: 'Trabajo', href: '/trabajo' },
      { label: 'Guías', href: '/guias' },
      { label: 'Radar', href: '/radar' },
      { label: 'Nosotros', href: '/nosotros' },
    ].map((link) => (
      <a href={link.href} class="mobile-menu-link">
        {link.label}
      </a>
    ))}
  </div>
</div>

<style>
  /* ── Logo inside the nav pill ── */
  .nav-logo {
    flex: 0 0 auto;
    align-items: center;
    padding-inline: var(--nav-item-px, 1rem);
    white-space: nowrap;
    transition: opacity 0.2s var(--ease-premium);
  }
  .nav-logo:hover { opacity: 0.78; }

  /* Default: pill is dark (brand-navy) → show white logo */
  .nav-logo-img--dark  { display: none; }
  .nav-logo-img--white { display: block; }

  /* Dark header theme: pill becomes light → show dark logo */
  #site-header[data-header-theme="dark"] .nav-logo-img--dark  { display: block; }
  #site-header[data-header-theme="dark"] .nav-logo-img--white { display: none; }

  nav .group::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 0.75rem;
    pointer-events: none;
  }
  nav .group:has(.dropdown.kb-open) .chevron,
  nav .group:has(.dropdown.hover-open) .chevron {
    transform: rotate(180deg);
  }
  .site-logo {
    position: relative;
    min-height: 44px;
    transition: opacity 0.2s var(--ease-premium), transform 0.2s var(--ease-premium);
  }
  .site-logo-image {
    transition: opacity 0.24s var(--ease-premium);
  }
  .site-logo-image--white {
    position: absolute;
    inset: 50% auto auto 0;
    opacity: 0;
    transform: translateY(-50%);
  }
  .site-logo:hover {
    opacity: 0.78;
  }
  .site-logo:active {
    transform: scale(0.98);
  }
  .nav-btn {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    min-height: 2.5rem;
    padding-block: 0.3rem;
    padding-inline: var(--nav-item-px, 1rem);
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: oklch(99% 0.002 70) !important;
    white-space: nowrap;
    transition:
      color 0.24s var(--ease-premium),
      background-color 0.2s var(--ease-premium),
      border-color 0.2s var(--ease-premium);
  }
  .nav-btn:hover {
    background: oklch(100% 0 0 / 0.12);
    color: oklch(99% 0.002 70) !important;
  }
  .nav-btn:active {
    background: oklch(100% 0 0 / 0.18);
  }
  .nav-btn[aria-current="page"] {
    background: oklch(100% 0 0 / 0.14);
  }
  .central-nav {
    --nav-item-px: 1rem;
    --nav-pill-px: 1.5rem;
    --nav-gap: 0.125rem;
    position: absolute;
    left: 50%;
    flex: 0 0 auto;
    width: max-content;
    max-width: calc(100vw - 3rem);
    gap: var(--nav-gap);
    padding: 0.15rem var(--nav-pill-px);
    border: 1px solid var(--brand-navy);
    border-radius: 999px;
    background: var(--brand-navy);
    overflow: visible;
    transform: translateX(-50%);
    transition:
      background-color 0.24s var(--ease-premium),
      border-color 0.24s var(--ease-premium);
  }
  @media (min-width: 1024px) and (max-width: 1180px) {
    .central-nav {
      --nav-item-px: 0.72rem;
      --nav-pill-px: 0.95rem;
      --nav-gap: 0.05rem;
    }
    .nav-btn {
      font-size: 0.92rem;
    }
    .nav-logo-img {
      height: 18px !important;
    }
  }
  #site-header {
    --header-foreground: #003049;
    --header-hover: rgba(0,48,73,0.05);
    color: var(--header-foreground);
    transition: color 0.24s var(--ease-premium);
  }
  #header-bg {
    background: transparent;
    border: 0;
    box-shadow: none;
    pointer-events: none;
  }
  #menu-toggle {
    color: var(--header-foreground);
    transition:
      color 0.24s var(--ease-premium),
      background-color 0.2s var(--ease-premium);
  }
  #menu-toggle:hover {
    background: var(--header-hover);
  }
  #site-header[data-header-theme="dark"] {
    --header-foreground: oklch(98% 0.004 70);
    --header-hover: oklch(100% 0 0 / 0.12);
  }
  #site-header[data-header-theme="dark"] .central-nav {
    border-color: oklch(98% 0.004 70);
    background: oklch(98% 0.004 70);
  }
  #site-header[data-header-theme="dark"] .nav-btn {
    color: var(--brand-navy) !important;
  }
  #site-header[data-header-theme="dark"] .nav-btn:hover {
    background: oklch(22% 0.06 235 / 0.1);
    color: var(--brand-navy) !important;
  }
  #site-header[data-header-theme="dark"] .nav-btn:active,
  #site-header[data-header-theme="dark"] .nav-btn[aria-current="page"] {
    background: oklch(22% 0.06 235 / 0.16);
  }
  #site-header[data-header-theme="dark"] .site-logo-image--dark {
    opacity: 0;
  }
  #site-header[data-header-theme="dark"] .site-logo-image--white {
    opacity: 1;
  }
  @media (max-width: 1023px) {
    #site-header {
      --header-foreground: oklch(98% 0.004 70);
      --header-hover: oklch(100% 0 0 / 0.12);
      background: var(--brand-navy);
      color: var(--header-foreground);
      box-shadow: 0 0.75rem 2rem oklch(15% 0.025 235 / 0.14);
    }
    #header-bg {
      background: var(--brand-navy);
    }
    #site-header .site-logo-image--dark {
      opacity: 0;
    }
    #site-header .site-logo-image--white {
      opacity: 1;
    }
    #menu-toggle {
      color: var(--header-foreground);
    }
  }
  .dropdown.kb-open,
  .dropdown.hover-open {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
    pointer-events: auto !important;
  }
  .solutions-dropdown {
    position: fixed;
    top: calc(var(--nav-height) + 0.75rem);
    left: 50%;
    width: min(840px, calc(100vw - 2rem));
    max-height: calc(100dvh - var(--nav-height) - 1.5rem);
    overflow-y: auto;
    transform: translate(-50%, 0.5rem);
  }
  .solutions-dropdown.kb-open,
  .solutions-dropdown.hover-open {
    transform: translate(-50%, 0) !important;
  }
</style>

<script>
  const siteHeader = document.getElementById('site-header');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let menuOpen = false;

  const themeCandidates = Array.from(
    document.querySelectorAll<HTMLElement>('main section, main [data-header-theme]')
  );

  const colorIsDark = (color: string) => {
    const match = color.match(/rgba?\(([\d.]+)[,\s]+([\d.]+)[,\s]+([\d.]+)/i);
    if (!match) return false;
    const red = Number(match[1]);
    const green = Number(match[2]);
    const blue = Number(match[3]);
    const luminance = (0.2126 * red + 0.7152 * green + 0.0722 * blue) / 255;
    return luminance < 0.48;
  };

  const themeBelowHeader = (): 'light' | 'dark' => {
    const sampleY = Math.max(1, Math.min(window.innerHeight - 1, (siteHeader?.offsetHeight ?? 72) / 2));
    const sampleXs = [24, window.innerWidth / 2, window.innerWidth - 24];
    let darkVotes = 0;

    sampleXs.forEach((sampleX) => {
      const stack = document.elementsFromPoint(sampleX, sampleY);
      const underlying = stack.find((element) => !siteHeader?.contains(element));
      if (!underlying) return;

      const declaredSection = underlying.closest<HTMLElement>('[data-header-theme]');
      if (declaredSection?.dataset.headerTheme === 'dark') {
        darkVotes += 1;
        return;
      }
      if (declaredSection?.dataset.headerTheme === 'light') return;

      let node: HTMLElement | null = underlying as HTMLElement;
      while (node && node !== document.body) {
        const background = getComputedStyle(node).backgroundColor;
        if (background && background !== 'transparent' && !background.endsWith(', 0)')) {
          if (colorIsDark(background)) darkVotes += 1;
          return;
        }
        node = node.parentElement;
      }
    });

    return darkVotes >= 2 ? 'dark' : 'light';
  };

  const updateHeaderTheme = () => {
    if (!siteHeader || menuOpen) return;
    siteHeader.dataset.headerTheme = themeBelowHeader();
  };

  let contrastObserver: IntersectionObserver | null = null;
  const observeHeaderLine = () => {
    contrastObserver?.disconnect();
    const sampleY = Math.round((siteHeader?.offsetHeight ?? 72) / 2);
    const bottomMargin = Math.max(0, window.innerHeight - sampleY - 1);
    contrastObserver = new IntersectionObserver(updateHeaderTheme, {
      rootMargin: `-${sampleY}px 0px -${bottomMargin}px 0px`,
      threshold: 0,
    });
    themeCandidates.forEach((candidate) => contrastObserver?.observe(candidate));
    updateHeaderTheme();
  };

  const setMenu = (open: boolean) => {
    menuOpen = open;
    menuToggle!.setAttribute('aria-expanded', String(open));
    mobileMenu!.setAttribute('aria-hidden', String(!open));
    mobileMenu!.classList.toggle('open', open);
    bar1!.style.transform = open ? 'translateY(8px) rotate(45deg)' : '';
    bar2!.style.opacity   = open ? '0' : '1';
    bar3!.style.transform = open ? 'translateY(-8px) rotate(-45deg)' : '';
    document.body.style.overflow = open ? 'hidden' : '';
    if (siteHeader) siteHeader.dataset.headerTheme = open ? 'dark' : themeBelowHeader();
  };

  menuToggle?.addEventListener('click', () => setMenu(!menuOpen));
  document.addEventListener('pointerdown', (event: PointerEvent) => {
    if (!menuOpen || window.innerWidth >= 1024) return;
    const target = event.target as Node | null;
    if (!target || mobileMenu?.contains(target) || menuToggle?.contains(target)) return;
    setMenu(false);
  });
  document.querySelectorAll('#mobile-menu a').forEach(l => l.addEventListener('click', () => setMenu(false)));
  window.addEventListener('resize', observeHeaderLine, { passive: true });
  observeHeaderLine();

  const CLOSE_DELAY = 250;
  const navGroups = document.querySelectorAll('nav .group');

  navGroups.forEach((group) => {
    const trigger = group.querySelector('button.nav-btn') as HTMLButtonElement | null;
    const dropdown = group.querySelector('.dropdown') as HTMLElement | null;
    if (!dropdown) return;
    let closeTimer: ReturnType<typeof setTimeout> | null = null;

    group.addEventListener('mouseenter', () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      navGroups.forEach((g) => {
        if (g !== group) (g.querySelector('.dropdown') as HTMLElement | null)?.classList.remove('hover-open');
      });
      dropdown.classList.add('hover-open');
    });
    group.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(() => { dropdown.classList.remove('hover-open'); closeTimer = null; }, CLOSE_DELAY);
    });

    if (!trigger) return;
    const kbOpen = () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      dropdown.classList.add('kb-open');
      trigger.setAttribute('aria-expanded', 'true');
    };
    const kbClose = () => {
      dropdown.classList.remove('kb-open');
      trigger.setAttribute('aria-expanded', 'false');
    };
    trigger.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
        e.preventDefault();
        kbOpen();
        (dropdown.querySelector('a') as HTMLElement | null)?.focus();
      }
    });
    group.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') { kbClose(); trigger.focus(); }
    });
    group.addEventListener('focusout', (e: FocusEvent) => {
      if (!group.contains(e.relatedTarget as Node)) kbClose();
    });
  });
</script>
