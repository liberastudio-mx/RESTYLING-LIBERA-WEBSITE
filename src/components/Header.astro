---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Soluciones', href: '/soluciones', type: 'mega-large' },
  { label: 'Trabajo',    href: '/trabajo',    type: 'dropdown-visual' },
  { label: 'Guías',      href: '/guias',      type: 'mega-editorial' },
  { label: 'Radar',      href: '/radar',      type: 'dropdown-simple' },
  { label: 'Nosotros', href: '/nosotros', type: 'link' },
];

const BRAND_COLORS = ['#003049', '#d62828', '#f77f00', '#fcbf49'];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0"
  style="height: var(--nav-height); z-index: var(--z-header);"
>
  <!-- Backdrop -->
  <div
    id="header-bg"
    class="absolute inset-0 transition-all duration-300"
    style="background: #ffffff; border-bottom: none;"
  ></div>

  <div class="container-libera relative h-full flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href="/" class="flex-shrink-0 flex items-center gap-2 z-10" aria-label="LIBERA Studio, Inicio">
      <span class="nav-dot" aria-hidden="true"></span>
      <img src="/images/logo-blu.png" alt="LIBERA Studio" height="32" class="block" style="width: auto; height: 32px;" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-0.5 flex-1 justify-center" aria-label="Navegación principal">

      <!-- ── Soluciones, MEGA LARGE ───────────────────────────────── -->
      <div class="relative group">
        <button
          class="nav-btn flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Soluciones
          <svg class="chevron w-3 h-3 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5"/>
          </svg>
        </button>

        <div class="dropdown absolute top-full left-1/2 -translate-x-1/2 mt-3 w-[840px] rounded-2xl opacity-0 invisible translate-y-2 transition-all duration-200 pointer-events-none"
          style="background: #ffffff; border: 1px solid rgba(0,48,73,0.1); box-shadow: 0 24px 60px rgba(0,48,73,0.1);"
          role="region" aria-label="Soluciones"
        >
          <div class="grid grid-cols-4 p-5 gap-1">
            {[
              { heading: 'Operación Inteligente', accent: BRAND_COLORS[0], href: '/soluciones/operacion-inteligente',
                links: [['PAOS','/servicios/paos'],['Automatización','/servicios/automatizacion'],['CRM y seguimiento','/servicios/automatizacion'],['Dashboards','/servicios/automatizacion'],['Integraciones','/servicios/automatizacion']] },
              { heading: 'Presencia Digital',     accent: BRAND_COLORS[1], href: '/soluciones/presencia-digital',
                links: [['Sitios web premium','/servicios/diseno-web'],['Landing pages','/servicios/landing-pages'],['Google Business Profile','/servicios/google-business-profile'],['WhatsApp Business','/servicios/whatsapp-business'],['SEO local','/servicios/seo-local']] },
              { heading: 'AI & Automation',       accent: BRAND_COLORS[2], href: '/soluciones/ai-automation',
                links: [['Agentes de IA','/servicios/agentes-ia'],['Asistentes internos','/servicios/agentes-ia'],['Flujos con n8n','/servicios/automatizacion'],['Clasificación de mensajes','/servicios/agentes-ia'],['Automatización documental','/servicios/automatizacion']] },
              { heading: 'Productos Digitales',   accent: BRAND_COLORS[3], href: '/soluciones/productos-digitales',
                links: [['Web apps','/servicios/diseno-web'],['MVPs','/servicios/diseno-web'],['Apps internas','/servicios/diseno-web'],['Paneles admin','/servicios/diseno-web'],['Prototipos','/servicios/diseno-web']] },
            ].map((col) => (
              <div class="px-4 py-3 rounded-xl hover:bg-[#003049]/[0.03] transition-colors duration-150">
                <a href={col.href} class="flex items-center gap-2 mb-3 group/col">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background:${col.accent};`}></span>
                  <span class="text-xs font-semibold tracking-wide uppercase transition-opacity duration-150 group-hover/col:opacity-70" style={`color:${col.accent};`}>{col.heading}</span>
                </a>
                <ul class="space-y-1.5">
                  {col.links.map(([label, href]) => (
                    <li>
                      <a href={href} class="block text-sm py-0.5 transition-colors duration-150 hover:text-[#003049]" style="color: rgba(0,48,73,0.55);">{label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <div class="mx-5 mb-5 px-4 py-3 rounded-xl flex items-center justify-between" style="background: rgba(0,48,73,0.04); border: 1px solid rgba(0,48,73,0.1);">
            <p class="text-xs" style="color: rgba(0,48,73,0.5);">¿No sabes por dónde empezar?</p>
            <a href="/diagnostico" class="text-xs font-semibold px-4 py-1.5 rounded-full transition-all duration-200 hover:bg-orange-500/10" style="color: var(--orange); border: 1px solid rgba(247,127,0,0.4);">
              Solicitar diagnóstico →
            </a>
          </div>
        </div>
      </div>

      <!-- ── Trabajo, DROPDOWN VISUAL ─────────────────────────────── -->
      <div class="relative group">
        <button class="nav-btn flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium" aria-haspopup="true" aria-expanded="false">
          Trabajo
          <svg class="chevron w-3 h-3 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5"/>
          </svg>
        </button>

        <div class="dropdown absolute top-full left-0 mt-3 w-72 rounded-2xl opacity-0 invisible translate-y-2 transition-all duration-200 pointer-events-none"
          style="background: #ffffff; border: 1px solid rgba(0,48,73,0.1); box-shadow: 0 20px 48px rgba(0,48,73,0.1);"
        >
          <div class="p-3">
            {[
              { name: 'Cenote Scout',         cat: 'Producto', accent: BRAND_COLORS[0], href: '/trabajo/cenote-scout' },
              { name: 'LIBERA AI Automation', cat: 'Sistema',  accent: BRAND_COLORS[1], href: '/trabajo/radar' },
              { name: 'Sole Facile',          cat: 'Cliente',  accent: BRAND_COLORS[2], href: '/trabajo/sole-facile' },
            ].map((p) => (
              <a href={p.href} class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-150 hover:bg-[#003049]/[0.04] group/p">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background:${p.accent};`} aria-hidden="true"></span>
                <div>
                  <span class="block text-xs" style="color: rgba(0,48,73,0.45);">{p.cat}</span>
                  <span class="block text-sm font-medium transition-opacity duration-150 group-hover/p:opacity-70" style="color: #003049;">{p.name}</span>
                </div>
              </a>
            ))}
          </div>
          <div class="mx-3 mb-3 px-4 py-2.5 rounded-xl" style="border-top: 1px solid rgba(0,48,73,0.1);">
            <a href="/trabajo" class="flex items-center justify-between text-sm font-medium transition-opacity duration-150 hover:opacity-70" style="color: rgba(0,48,73,0.55);">
              Ver todo el trabajo <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>

      <!-- ── Guías, MEGA EDITORIAL ─────────────────────────────────── -->
      <div class="relative group">
        <button class="nav-btn flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium" aria-haspopup="true" aria-expanded="false">
          Guías
          <svg class="chevron w-3 h-3 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5"/>
          </svg>
        </button>

        <div class="dropdown absolute top-full left-1/2 -translate-x-1/2 mt-3 w-[680px] rounded-2xl opacity-0 invisible translate-y-2 transition-all duration-200 pointer-events-none"
          style="background: #ffffff; border: 1px solid rgba(0,48,73,0.1); box-shadow: 0 24px 60px rgba(0,48,73,0.1);"
        >
          <div class="grid grid-cols-2 gap-1 p-5">
            {[
              { heading: 'PAOS',                 accent: BRAND_COLORS[0],
                links: [['Qué es un PAOS','/guias/paos/que-es-un-paos'],['Cómo ordenar tu operación','/guias/paos'],['PAOS vs CRM','/guias/paos'],['PAOS para pequeños negocios','/guias/paos']] },
              { heading: 'Automatización',       accent: BRAND_COLORS[1],
                links: [['Qué automatizar primero','/guias/automatizacion'],['n8n vs Make vs Zapier','/guias/automatizacion'],['Cuándo no automatizar','/guias/automatizacion'],['Automatización con WhatsApp','/guias/automatizacion']] },
              { heading: 'Inteligencia Artificial', accent: BRAND_COLORS[2],
                links: [['Qué es un agente de IA','/guias/inteligencia-artificial/agentes-ia-empresa'],['Agente IA vs chatbot','/guias/inteligencia-artificial'],['IA para atención al cliente','/guias/inteligencia-artificial'],['Errores comunes con IA','/guias/inteligencia-artificial']] },
              { heading: 'Presencia Digital',    accent: BRAND_COLORS[3],
                links: [['Qué debe tener una web','/guias/presencia-digital'],['Web vs landing page','/guias/presencia-digital'],['Google Maps para negocios','/guias/presencia-digital'],['Por qué tu web no convierte','/guias/presencia-digital/como-saber-si-tu-web-convierte']] },
            ].map((col) => (
              <div class="px-4 py-3 rounded-xl hover:bg-[#003049]/[0.03] transition-colors duration-150">
                <p class="text-xs font-mono font-semibold tracking-widest uppercase mb-3" style={`color:${col.accent}; font-family: var(--font-mono);`}>{col.heading}</p>
                <ul class="space-y-1.5">
                  {col.links.map(([label, href]) => (
                    <li><a href={href} class="block text-sm py-0.5 leading-snug transition-colors duration-150 hover:text-[#003049]" style="color: rgba(0,48,73,0.55);">{label}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <div class="mx-5 mb-5 px-5 py-4 rounded-xl" style="background: rgba(0,48,73,0.04); border: 1px solid rgba(0,48,73,0.1);">
            <p class="text-xs mb-2" style="color: rgba(0,48,73,0.45);">Empieza por aquí:</p>
            <a href="/guias/paos/que-es-un-paos" class="text-sm font-medium hover:opacity-70 transition-opacity duration-150" style="color: #003049;">
              "¿Necesita tu negocio una web, una automatización o un sistema completo?" →
            </a>
          </div>
        </div>
      </div>

      <!-- ── Radar, DROPDOWN SIMPLE ────────────────────────────────── -->
      <div class="relative group">
        <button class="nav-btn flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium" aria-haspopup="true" aria-expanded="false">
          Radar
          <svg class="chevron w-3 h-3 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 1.5l5 5 5-5"/>
          </svg>
        </button>

        <div class="dropdown absolute top-full left-0 mt-3 w-52 rounded-2xl opacity-0 invisible translate-y-2 transition-all duration-200 pointer-events-none"
          style="background: #ffffff; border: 1px solid rgba(0,48,73,0.1); box-shadow: 0 16px 40px rgba(0,48,73,0.1);"
        >
          <ul class="p-2">
            {[
              ['AI',            '/radar/ai',          '#d62828'],
              ['Automatización','/radar/automation',   '#f77f00'],
              ['Tools',         '/radar/tools',        '#fcbf49'],
              ['Web',           '/radar/web',          '#003049'],
              ['SEO',           '/radar/seo',          '#d62828'],
              ['Experimentos',  '/radar/experiments',  '#f77f00'],
              ['Opinión',       '/radar/opinion',      '#fcbf49'],
            ].map(([label, href, dot]) => (
              <li>
                <a href={href} class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-sm transition-all duration-150 hover:bg-[#003049]/[0.04] hover:text-[#003049]" style="color: rgba(0,48,73,0.65);">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${dot};`} aria-hidden="true"></span>
                  {label}
                </a>
              </li>
            ))}
          </ul>
          <div class="mx-2 mb-2 px-4 py-2.5 rounded-xl" style="border-top: 1px solid rgba(0,48,73,0.1);">
            <a href="/radar" class="flex items-center justify-between text-xs font-medium transition-opacity duration-150 hover:opacity-70" style="color: rgba(0,48,73,0.5);">
              Ver todo Radar <span style="color: var(--orange);">→</span>
            </a>
          </div>
        </div>
      </div>

      <!-- ── Nosotros, LINK DIRECTO ─────────────────────────────── -->
      <a
        href="/nosotros"
        class="nav-btn px-4 py-2 rounded-md text-sm font-medium transition-colors duration-200"
        aria-current={currentPath === '/nosotros' ? 'page' : undefined}
      >
        Nosotros
      </a>

    </nav>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a
        href="/diagnostico"
        class="hidden md:flex items-center gap-2.5 px-5 py-2.5 text-sm font-semibold transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
        style="background: var(--orange); color: #ffffff; border-radius: 0.625rem;"
      >
        Solicitar diagnóstico
        <span class="w-5 h-5 flex items-center justify-center" style="background: var(--orange-dark); border-radius: 0.375rem;" aria-hidden="true">
          <svg width="7" height="7" viewBox="0 0 8 8" fill="currentColor"><path d="M1 7L7 1M7 1H2M7 1v5"/></svg>
        </span>
      </a>

      <!-- Hamburger, mobile only -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-md"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
        style="color: #003049;"
      >
        <span id="bar1" class="w-5 h-0.5 rounded-full transition-all duration-300 origin-center" style="background: currentColor;"></span>
        <span id="bar2" class="w-5 h-0.5 rounded-full transition-all duration-300" style="background: currentColor;"></span>
        <span id="bar3" class="w-5 h-0.5 rounded-full transition-all duration-300 origin-center" style="background: currentColor;"></span>
      </button>
    </div>
  </div>

  <!-- ── Mobile menu ────────────────────────────────────────────────── -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-x-0 bottom-0 opacity-0 invisible transition-all duration-300 overflow-y-auto"
    style="top: var(--nav-height); background: var(--ink);"
    aria-hidden="true"
  >
    <div class="container-libera py-8 flex flex-col gap-1">
      {[
        { label: 'Soluciones',  href: '/soluciones' },
        { label: 'Trabajo',     href: '/trabajo' },
        { label: 'Guías',       href: '/guias' },
        { label: 'Radar',       href: '/radar' },
        { label: 'Nosotros',    href: '/nosotros' },
      ].map((link, i) => (
        <a
          href={link.href}
          class="py-4 text-2xl font-semibold border-b transition-colors duration-200 hover:text-white"
          style={`font-family: var(--font-display); color: oklch(72% 0.008 60); border-color: var(--border-dark); transition-delay: ${i * 35}ms;`}
        >
          {link.label}
        </a>
      ))}
      <div class="mt-8">
        <a href="/diagnostico" class="inline-flex items-center gap-3 px-7 py-4 rounded-full font-semibold" style="background: var(--orange); color: var(--ink);">
          Solicitar diagnóstico
          <span class="w-6 h-6 rounded-full flex items-center justify-center text-sm" style="background: var(--orange-dark);" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  nav .group::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 0.75rem;
    pointer-events: none;
  }
  nav .group:has(.dropdown.kb-open) .chevron,
  nav .group:has(.dropdown.hover-open) .chevron {
    transform: rotate(180deg);
  }
  .nav-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #f77f00;
    box-shadow: 0 0 14px #f77f00;
    flex-shrink: 0;
    animation: nav-breathe 2.8s ease-in-out infinite;
  }
  @keyframes nav-breathe {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: .42; transform: scale(.76); }
  }
  .nav-btn {
    color: #003049 !important;
  }
  .nav-btn:hover {
    color: #003049 !important;
    background: rgba(0,48,73,0.05);
  }
  #mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }
  .dropdown.kb-open,
  .dropdown.hover-open {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
    pointer-events: auto !important;
  }
</style>

<script>
  const headerBg = document.getElementById('header-bg');
  const siteHeader = document.getElementById('site-header');
  const updateHeader = () => {
    const scrolled = window.scrollY > 40;
    if (!headerBg) return;
    headerBg.style.background    = '#ffffff';
    headerBg.style.backdropFilter = 'none';
    headerBg.style.borderBottom  = 'none';
    siteHeader?.classList.toggle('scrolled', scrolled);
  };
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let menuOpen = false;

  const setMenu = (open: boolean) => {
    menuOpen = open;
    menuToggle!.setAttribute('aria-expanded', String(open));
    mobileMenu!.setAttribute('aria-hidden', String(!open));
    mobileMenu!.classList.toggle('open', open);
    bar1!.style.transform = open ? 'translateY(8px) rotate(45deg)' : '';
    bar2!.style.opacity   = open ? '0' : '1';
    bar3!.style.transform = open ? 'translateY(-8px) rotate(-45deg)' : '';
    document.body.style.overflow = open ? 'hidden' : '';
  };

  menuToggle?.addEventListener('click', () => setMenu(!menuOpen));
  document.querySelectorAll('#mobile-menu a').forEach(l => l.addEventListener('click', () => setMenu(false)));

  const CLOSE_DELAY = 250;
  const navGroups = document.querySelectorAll('nav .group');

  navGroups.forEach((group) => {
    const trigger = group.querySelector('button.nav-btn') as HTMLButtonElement | null;
    const dropdown = group.querySelector('.dropdown') as HTMLElement | null;
    if (!dropdown) return;
    let closeTimer: ReturnType<typeof setTimeout> | null = null;

    group.addEventListener('mouseenter', () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      navGroups.forEach((g) => {
        if (g !== group) (g.querySelector('.dropdown') as HTMLElement | null)?.classList.remove('hover-open');
      });
      dropdown.classList.add('hover-open');
    });
    group.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(() => { dropdown.classList.remove('hover-open'); closeTimer = null; }, CLOSE_DELAY);
    });

    if (!trigger) return;
    const kbOpen = () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      dropdown.classList.add('kb-open');
      trigger.setAttribute('aria-expanded', 'true');
    };
    const kbClose = () => {
      dropdown.classList.remove('kb-open');
      trigger.setAttribute('aria-expanded', 'false');
    };
    trigger.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
        e.preventDefault();
        kbOpen();
        (dropdown.querySelector('a') as HTMLElement | null)?.focus();
      }
    });
    group.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') { kbClose(); trigger.focus(); }
    });
    group.addEventListener('focusout', (e: FocusEvent) => {
      if (!group.contains(e.relatedTarget as Node)) kbClose();
    });
  });
</script>
