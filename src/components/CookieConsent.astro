<!-- Design: Product behavior | Brand styling | Color: Restrained -->
<div
  id="cookie-consent"
  class="cookie-consent"
  data-state="closed"
  aria-live="polite"
>
  <section
    id="cookie-banner"
    class="cookie-banner"
    aria-labelledby="cookie-banner-title"
    aria-describedby="cookie-banner-description"
    hidden
  >
    <div class="cookie-copy">
      <p class="cookie-label">Privacidad</p>
      <h2 id="cookie-banner-title">Tú decides qué guardar.</h2>
      <p id="cookie-banner-description">
        Usamos almacenamiento necesario para que el sitio funcione. La analítica y el marketing son opcionales y solo
        se activarán con tu permiso.
        <a href="/privacidad#cookies">Ver política de cookies</a>.
      </p>
    </div>
    <div class="cookie-actions">
      <button type="button" class="cookie-button cookie-button-secondary" data-cookie-reject>
        Rechazar opcionales
      </button>
      <button type="button" class="cookie-button cookie-button-secondary" data-cookie-customize>
        Configurar
      </button>
      <button type="button" class="cookie-button cookie-button-primary" data-cookie-accept>
        Aceptar todo
      </button>
    </div>
  </section>

  <dialog id="cookie-dialog" class="cookie-dialog" aria-labelledby="cookie-dialog-title">
    <form method="dialog" class="cookie-dialog-inner">
      <div class="cookie-dialog-header">
        <div>
          <p class="cookie-label">Preferencias</p>
          <h2 id="cookie-dialog-title">Control de cookies</h2>
        </div>
        <button type="button" class="cookie-close" data-cookie-close aria-label="Cerrar preferencias">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>

      <p class="cookie-dialog-intro">
        Puedes cambiar tu decisión en cualquier momento. Las cookies necesarias no se pueden desactivar porque
        guardan esta elección y permiten el funcionamiento básico del sitio.
      </p>

      <div class="cookie-category">
        <div>
          <h3>Necesarias</h3>
          <p>Guardan tu preferencia de privacidad durante 180 días. No se usan para publicidad.</p>
        </div>
        <span class="cookie-required" aria-label="Siempre activas">Siempre activas</span>
      </div>

      <label class="cookie-category cookie-category-toggle" for="cookie-analytics">
        <div>
          <h3>Analítica</h3>
          <p>
            Google Analytics 4 mide visitas, páginas vistas y rendimiento del sitio. No se usa para publicidad.
          </p>
        </div>
        <span class="cookie-switch">
          <input id="cookie-analytics" type="checkbox" />
          <span aria-hidden="true"></span>
        </span>
      </label>

      <label class="cookie-category cookie-category-toggle" for="cookie-marketing">
        <div>
          <h3>Marketing</h3>
          <p>
            Meta Pixel mide el rendimiento de campañas publicitarias. Activo solo si aceptas esta categoría.
          </p>
        </div>
        <span class="cookie-switch">
          <input id="cookie-marketing" type="checkbox" />
          <span aria-hidden="true"></span>
        </span>
      </label>

      <div class="cookie-dialog-actions">
        <button type="button" class="cookie-button cookie-button-secondary" data-cookie-reject>
          Rechazar opcionales
        </button>
        <button type="button" class="cookie-button cookie-button-primary" data-cookie-save>
          Guardar preferencias
        </button>
      </div>
    </form>
  </dialog>
</div>

<style>
  .cookie-consent {
    --cookie-surface: oklch(98% 0.008 80);
    --cookie-text: #003049;
    --cookie-muted: oklch(45% 0.035 235);
    position: relative;
    z-index: var(--z-cookie, 1100);
  }

  .cookie-banner {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    left: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    max-width: 76rem;
    margin-inline: auto;
    padding: 1.5rem;
    border: 1px solid oklch(30% 0.04 235 / 0.18);
    border-radius: 1rem;
    background: var(--cookie-surface);
    box-shadow: 0 1.25rem 4rem oklch(20% 0.04 235 / 0.18);
  }

  .cookie-banner[hidden] {
    display: none;
  }

  .cookie-copy {
    max-width: 47rem;
  }

  .cookie-label {
    margin-bottom: 0.55rem;
    color: #c45f00;
    font: 600 0.68rem/1.2 var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cookie-copy h2,
  .cookie-dialog h2 {
    color: var(--cookie-text);
    font: 700 clamp(1.4rem, 2vw, 2rem)/1.05 var(--font-display);
    letter-spacing: -0.035em;
  }

  .cookie-copy p:last-child,
  .cookie-dialog-intro,
  .cookie-category p {
    margin-top: 0.7rem;
    color: var(--cookie-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .cookie-copy a {
    color: var(--cookie-text);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .cookie-actions,
  .cookie-dialog-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.65rem;
  }

  .cookie-button {
    min-height: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 1rem;
    border: 1px solid oklch(30% 0.04 235 / 0.22);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 650;
    cursor: pointer;
    transition:
      transform 0.2s cubic-bezier(0.32, 0.72, 0, 1),
      background-color 0.2s cubic-bezier(0.32, 0.72, 0, 1),
      border-color 0.2s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cookie-button:active {
    transform: scale(0.98);
  }

  .cookie-button-primary {
    position: relative;
    justify-content: space-between;
    gap: 0.9rem;
    padding: 0.25rem 3.75rem 0.25rem 1rem;
    color: var(--ink);
    background: oklch(98% 0.004 70);
    overflow: hidden;
  }

  .cookie-button-primary::after {
    content: "›";
    position: absolute;
    top: 0.25rem;
    right: 0.25rem;
    bottom: 0.25rem;
    display: inline-flex;
    width: 3.1rem;
    min-width: 2.6rem;
    height: auto;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: oklch(89% 0.008 235);
    font-size: 1.15rem;
    transition:
      width 0.5s cubic-bezier(0.32, 0.72, 0, 1),
      transform 0.15s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cookie-button-primary:hover {
    background: oklch(96% 0.008 70);
  }

  .cookie-button-primary:hover::after {
    width: calc(100% - 0.5rem);
  }

  .cookie-button-primary:active::after {
    transform: scale(0.95);
  }

  @media (hover: none) {
    .cookie-button-primary:hover::after {
      width: 3.1rem;
    }
  }

  .cookie-button-secondary {
    color: var(--cookie-text);
    border-color: oklch(30% 0.04 235 / 0.22);
    background: transparent;
  }

  .cookie-button-secondary:hover {
    background: oklch(30% 0.04 235 / 0.06);
  }

  .cookie-dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(42rem, calc(100vw - 2rem));
    max-height: calc(100dvh - 2rem);
    padding: 0;
    border: 1px solid oklch(30% 0.04 235 / 0.18);
    border-radius: 1rem;
    background: var(--cookie-surface);
    color: var(--cookie-text);
    box-shadow: 0 1.5rem 5rem oklch(15% 0.04 235 / 0.28);
  }

  .cookie-dialog::backdrop {
    background: oklch(12% 0.035 235 / 0.68);
  }

  .cookie-dialog-inner {
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .cookie-dialog-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .cookie-close {
    display: grid;
    flex: 0 0 auto;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid oklch(30% 0.04 235 / 0.18);
    border-radius: 50%;
    color: var(--cookie-text);
    background: transparent;
    font-size: 1.4rem;
    cursor: pointer;
  }

  .cookie-dialog-intro {
    max-width: 58ch;
    margin-bottom: 1.5rem;
  }

  .cookie-category {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.25rem 0;
    border-top: 1px solid oklch(30% 0.04 235 / 0.14);
  }

  .cookie-category h3 {
    color: var(--cookie-text);
    font: 650 1rem/1.3 var(--font-display);
  }

  .cookie-category p {
    max-width: 52ch;
    margin-top: 0.35rem;
  }

  .cookie-required {
    color: var(--cookie-muted);
    font: 600 0.7rem/1.2 var(--font-mono);
    text-align: right;
  }

  .cookie-category-toggle {
    cursor: pointer;
  }

  .cookie-switch {
    position: relative;
    display: block;
    width: 3.25rem;
    height: 1.85rem;
  }

  .cookie-switch input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .cookie-switch span {
    position: absolute;
    inset: 0;
    border: 1px solid oklch(30% 0.04 235 / 0.22);
    border-radius: 999px;
    background: oklch(88% 0.015 235);
    transition: background-color 0.2s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cookie-switch span::after {
    content: "";
    position: absolute;
    top: 0.2rem;
    left: 0.2rem;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0.15rem 0.45rem oklch(20% 0.04 235 / 0.2);
    transition: transform 0.2s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cookie-switch input:checked + span {
    background: var(--orange);
  }

  .cookie-switch input:checked + span::after {
    transform: translateX(1.4rem);
  }

  .cookie-switch input:focus-visible + span {
    outline: 3px solid var(--focus-ring);
    outline-offset: 3px;
  }

  .cookie-dialog-actions {
    margin-top: 1.5rem;
  }

  @media (max-width: 760px) {
    .cookie-banner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      max-height: calc(100dvh - 2rem);
      overflow-y: auto;
    }

    .cookie-actions,
    .cookie-dialog-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .cookie-button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-button,
    .cookie-switch span,
    .cookie-switch span::after {
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  type ConsentPreferences = {
    necessary: true;
    analytics: boolean;
    marketing: boolean;
    updatedAt: string;
    version: 1;
  };

  const COOKIE_NAME = 'libera_cookie_consent';
  const COOKIE_MAX_AGE = 60 * 60 * 24 * 180;

  const readConsent = (): ConsentPreferences | null => {
    const cookie = document.cookie
      .split('; ')
      .find((item) => item.startsWith(`${COOKIE_NAME}=`));

    if (!cookie) return null;

    try {
      const value = decodeURIComponent(cookie.split('=').slice(1).join('='));
      const parsed = JSON.parse(value) as ConsentPreferences;
      return parsed.version === 1 ? parsed : null;
    } catch {
      return null;
    }
  };

  const writeConsent = (analytics: boolean, marketing: boolean) => {
    const preferences: ConsentPreferences = {
      necessary: true,
      analytics,
      marketing,
      updatedAt: new Date().toISOString(),
      version: 1,
    };

    const secure = window.location.protocol === 'https:' ? '; Secure' : '';
    document.cookie = `${COOKIE_NAME}=${encodeURIComponent(JSON.stringify(preferences))}; Path=/; Max-Age=${COOKIE_MAX_AGE}; SameSite=Lax${secure}`;
    document.documentElement.dataset.analyticsConsent = String(analytics);
    document.documentElement.dataset.marketingConsent = String(marketing);
    window.dispatchEvent(new CustomEvent('libera:consent', { detail: preferences }));
    return preferences;
  };

  const initCookieConsent = () => {
    const banner = document.querySelector<HTMLElement>('#cookie-banner');
    const dialog = document.querySelector<HTMLDialogElement>('#cookie-dialog');
    const analyticsInput = document.querySelector<HTMLInputElement>('#cookie-analytics');
    const marketingInput = document.querySelector<HTMLInputElement>('#cookie-marketing');
    if (!banner || !dialog || !analyticsInput || !marketingInput) return;

    const current = readConsent();
    if (current) {
      analyticsInput.checked = current.analytics;
      marketingInput.checked = current.marketing ?? false;
      document.documentElement.dataset.analyticsConsent = String(current.analytics);
      document.documentElement.dataset.marketingConsent = String(current.marketing ?? false);
      banner.hidden = true;
    } else {
      banner.hidden = false;
    }

    const closeDialog = () => {
      if (dialog.open) dialog.close();
    };

    const save = (analytics: boolean, marketing: boolean) => {
      writeConsent(analytics, marketing);
      analyticsInput.checked = analytics;
      marketingInput.checked = marketing;
      banner.hidden = true;
      closeDialog();
    };

    document.querySelectorAll<HTMLElement>('[data-cookie-accept]').forEach((button) => {
      button.onclick = () => save(true, true);
    });

    document.querySelectorAll<HTMLElement>('[data-cookie-reject]').forEach((button) => {
      button.onclick = () => save(false, false);
    });

    document.querySelectorAll<HTMLElement>('[data-cookie-customize]').forEach((button) => {
      button.onclick = () => dialog.showModal();
    });

    document.querySelectorAll<HTMLElement>('[data-cookie-save]').forEach((button) => {
      button.onclick = () => save(analyticsInput.checked, marketingInput.checked);
    });

    document.querySelectorAll<HTMLElement>('[data-cookie-close]').forEach((button) => {
      button.onclick = closeDialog;
    });

    document.querySelectorAll<HTMLElement>('[data-cookie-settings]').forEach((btn) => {
      btn.onclick = () => {
        const saved = readConsent();
        analyticsInput.checked = saved?.analytics ?? false;
        marketingInput.checked = saved?.marketing ?? false;
        dialog.showModal();
      };
    });

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) closeDialog();
    });
  };

  initCookieConsent();
  document.addEventListener('astro:page-load', initCookieConsent);
</script>
