---
import { Image } from 'astro:assets';
import logoImg from '@/assets/images/LIBERA - Logo Bianco.png';

const year = new Date().getFullYear();

const footerLinks = {
  soluciones: [
    { label: 'Presencia Digital', href: '/soluciones/presencia-digital' },
    { label: 'Operación Interna', href: '/soluciones/operacion-interna' },
    { label: 'AI & Automation', href: '/soluciones/ai-automation' },
    { label: 'Productos Digitales', href: '/soluciones/productos-digitales' },
  ],
  estudio: [
    { label: 'Trabajo', href: '/trabajo' },
    { label: 'Radar', href: '/radar' },
    { label: 'Nosotros', href: '/nosotros' },
  ],
};
---

<footer style="background: var(--ink-mid); border-top: 1px solid var(--border-dark);">
  <div class="container-libera py-20">

    <!-- Top grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <a href="/" class="inline-block mb-6" aria-label="LIBERA Studio">
          <Image
            src={logoImg}
            width={190}
            height={33}
            alt="LIBERA Studio"
            class="block h-auto w-[168px] sm:w-[190px]"
          />
        </a>

        <p class="text-base leading-relaxed mb-8 max-w-xs" style="color: #ffffff;">
          Sistemas digitales, automatización e inteligencia artificial para empresas que quieren operar mejor.
        </p>

        <!-- CTA -->
        <a
          href="/diagnostico"
          class="inline-flex items-center gap-2.5 px-5 py-2.5 text-sm font-semibold"
          style="background: var(--orange); color: #ffffff; border-radius: 0.625rem;"
          data-magnetic
        >
          Solicitar diagnóstico
          <span class="w-5 h-5 flex items-center justify-center" style="background: var(--orange-dark, #c96200); border-radius: 0.375rem;" aria-hidden="true">
            <svg width="7" height="7" viewBox="0 0 8 8" fill="currentColor"><path d="M1 7L7 1M7 1H2M7 1v5"/></svg>
          </span>
        </a>

        <!-- Location badge -->
        <div class="flex items-center gap-2 mt-8">
          <span class="w-1.5 h-1.5 rounded-full" style="background: var(--operacion);"></span>
          <span class="text-xs tracking-wide" style="color: rgba(255,255,255,0.6);">Mérida, Yucatán · México</span>
        </div>
      </div>

      <!-- Link columns -->
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase mb-5" style="color: rgba(255,255,255,0.6);">
          Soluciones
        </p>
        <ul class="space-y-3">
          {footerLinks.soluciones.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-150 hover:text-white"
                style="color: #ffffff;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-xs font-semibold tracking-widest uppercase mb-5" style="color: rgba(255,255,255,0.6);">
          Estudio
        </p>
        <ul class="space-y-3">
          {footerLinks.estudio.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-150 hover:text-white"
                style="color: #ffffff;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-4 mt-16 pt-8"
      style="border-top: 1px solid oklch(18% 0.01 25);"
    >
      <p class="text-xs" style="color: rgba(255,255,255,0.5);">
        © {year} LIBERA Studio. Todos los derechos reservados.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        <a href="/privacidad" class="text-xs transition-colors duration-150 hover:text-white" style="color: rgba(255,255,255,0.5);">
          Privacidad
        </a>
        <a href="/terminos" class="text-xs transition-colors duration-150 hover:text-white" style="color: rgba(255,255,255,0.5);">
          Términos
        </a>
        <a href="/contacto" class="text-xs transition-colors duration-150 hover:text-white" style="color: rgba(255,255,255,0.5);">
          Contacto
        </a>
        <button
          type="button"
          data-cookie-settings
          class="text-xs transition-colors duration-150 hover:text-white"
          style="color: rgba(255,255,255,0.5);"
        >
          Preferencias de cookies
        </button>
      </div>
    </div>
  </div>
</footer>
